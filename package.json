{
  "name": "flycodecenter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev-server.mjs",
    "dev:astro": "astro dev",
    "sync:articles": "node ./scripts/fix-frontmatter-normalization.mjs",
    "fix:frontmatter": "node ./scripts/fix-frontmatter-normalization.mjs",
    "lint:frontmatter": "tsx ./scripts/lint-frontmatter-tags.mjs",
    "rebuild:frontmatter": "node ./scripts/rebuild-frontmatter.mjs",
    "guard:quality": "node ./scripts/quality-guard.mjs",
    "prebuild": "node ./scripts/clean-astro-cache.mjs",
    "build": "npm run sync:articles && npm run guard:quality && npm run build:minisearch && astro build",
    "preview": "astro preview",
    "postbuild": "node ./scripts/pagefind-index.mjs",
    "build:minisearch": "node ./scripts/build-minisearch.mjs",
    "build:pagefind": "node ./scripts/pagefind-index.mjs",
    "encrypt": "tsx ./scripts/encrypt.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/vercel": "^9.0.4",
    "@shikijs/transformers": "^3.13.0",
    "@shikijs/twoslash": "^3.13.0",
    "algoliasearch": "^5.41.0",
    "astro": "^5.17.1",
    "gray-matter": "^4.0.3",
    "marked": "^16.4.2",
    "mdast-util-from-markdown": "^2.0.2",
    "mdx": "^0.3.1",
    "micromatch": "^4.0.8",
    "minisearch": "^7.2.0",
    "reading-time": "^1.5.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.0.0",
    "astro-expressive-code": "^0.41.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "pagefind": "^1.4.0",
    "tsx": "^4.20.5"
  }
}
