---
interface Props {
  title: string;
  value: string | number;
  href?: string;
}

const { title, value, href } = Astro.props;
---

<article class="surface stats-card">
  <small>{title}</small>
  {
    href ? (
      <a href={href} class="value">{value}</a>
    ) : (
      <strong class="value">{value}</strong>
    )
  }
</article>

<style>
  .stats-card {
    padding: 0.76rem 0.82rem;
    border-radius: var(--radius-md);
    background: color-mix(in oklab, var(--surface-1) 90%, transparent 10%);
  }
  .stats-card small {
    color: var(--text-soft);
    display: block;
    margin-bottom: 0.25rem;
  }
  .value {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text);
  }
  a.value:hover {
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
  }
</style>
