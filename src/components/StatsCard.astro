---
interface Props {
  title: string;
  value: string | number;
  href?: string;
}

const { title, value, href } = Astro.props;
---

<article class="surface stats-card">
  <small>{title}</small>
  {
    href ? (
      <a href={href} class="value">{value}</a>
    ) : (
      <strong class="value">{value}</strong>
    )
  }
</article>

<style>
  .stats-card {
    padding: 0.66rem 0.72rem;
    background:
      linear-gradient(
        165deg,
        color-mix(in oklab, var(--bg-elev) 94%, transparent 6%),
        color-mix(in oklab, var(--brand-soft) 12%, var(--bg-elev) 88%)
      );
  }
  .stats-card small {
    color: var(--text-soft);
    display: block;
    margin-bottom: 0.25rem;
  }
  .value {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text);
  }
  a.value:hover {
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
  }
</style>
