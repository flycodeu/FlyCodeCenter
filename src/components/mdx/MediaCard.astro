---
export interface Props {
  title: string;
  desc?: string;
  url?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  cardWidth?: string;
  cardHeight?: string;
  imagePosition?: "left" | "right" | "top" | "background";
  align?: "start" | "center" | "end";
}

const {
  title,
  desc = "",
  url = "",
  image = "",
  imageWidth = 220,
  imageHeight = 140,
  cardWidth = "100%",
  cardHeight = "auto",
  imagePosition = "left",
  align = "start"
} = Astro.props;

const isExternal = Boolean(url && /^https?:\/\//.test(url));
const isBackground = imagePosition === "background";
---

<article
  class={`media-card media-${imagePosition} align-${align}`}
  style={`--card-width:${cardWidth};--card-height:${cardHeight};--img-width:${imageWidth}px;--img-height:${imageHeight}px;`}
>
  {
    image && !isBackground && (
      <div class="media-thumb">
        <img src={image} alt={title} loading="lazy" />
      </div>
    )
  }

  <div class="media-content">
    <h4>{title}</h4>
    {desc && <p>{desc}</p>}
    {
      url && (
        <a href={url} target={isExternal ? "_blank" : "_self"} rel={isExternal ? "noreferrer" : undefined}>
          打开链接
        </a>
      )
    }
  </div>

  {
    image && isBackground && (
      <div class="media-background" aria-hidden="true">
        <img src={image} alt="" loading="lazy" />
      </div>
    )
  }
</article>

<style>
  .media-card {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    width: var(--card-width);
    min-height: var(--card-height);
    margin: 1.2rem 0;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: color-mix(in oklab, var(--bg-elev) 88%, var(--brand-soft) 12%);
    overflow: hidden;
  }

  .media-card.media-right {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .media-card.media-right .media-thumb {
    order: 2;
  }

  .media-card.media-top {
    grid-template-columns: 1fr;
  }

  .media-card.media-background {
    grid-template-columns: 1fr;
    background: color-mix(in oklab, var(--bg-elev) 75%, #000 25%);
    color: #fff;
  }

  .media-card.align-center {
    align-items: center;
  }

  .media-card.align-end {
    align-items: end;
  }

  .media-thumb {
    width: var(--img-width);
    height: var(--img-height);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg);
  }

  .media-top .media-thumb {
    width: 100%;
    height: var(--img-height);
  }

  .media-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .media-content {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0.5rem;
    align-content: start;
  }

  .media-content h4 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .media-content p {
    margin: 0;
    font-size: 0.92rem;
    color: var(--text-soft);
    line-height: 1.55;
  }

  .media-card.media-background .media-content p {
    color: rgba(255, 255, 255, 0.86);
  }

  .media-content a {
    width: fit-content;
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--brand);
    border: 1px solid color-mix(in oklab, var(--brand) 45%, var(--line) 55%);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
  }

  .media-card.media-background .media-content a {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.45);
  }

  .media-background {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .media-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.45);
  }

  .media-background::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, rgba(0, 0, 0, 0.68), rgba(0, 0, 0, 0.45));
  }

  @media (max-width: 760px) {
    .media-card,
    .media-card.media-right {
      grid-template-columns: 1fr;
    }

    .media-card.media-right .media-thumb {
      order: initial;
    }

    .media-thumb {
      width: 100%;
      height: min(var(--img-height), 220px);
    }
  }
</style>
