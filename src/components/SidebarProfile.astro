---
import siteConfig from "@/site.config";

const profile = siteConfig.theme.profile;
const avatarClass = profile.shape === "circle" ? "avatar circle" : "avatar rect";
const themeSocial = siteConfig.theme.social as { email?: string };

const iconMap: Record<string, string> = {
  github: '<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  email: '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2" ry="2"/><path d="m3 7 9 6 9-6"/></svg>',
  wechat: '<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M8.5,13.25A1.25,1.25 0 1,1 9.75,12A1.25,1.25 0 0,1 8.5,13.25M15.5,13.25A1.25,1.25 0 1,1 16.75,12A1.25,1.25 0 0,1 15.5,13.25M12,2A10,10 0 0,0 2,12C2,13.9 2.54,15.68 3.46,17.2L2,22L6.96,20.69C8.47,21.53 10.18,22 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" /></svg>',
  discord: '<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.028zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>',
  default: '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>'
};

const getIcon = (name: string) => iconMap[name.toLowerCase()] || iconMap.default;
const isHttpLink = (url: string) => /^https?:\/\//i.test(url);
const extractEmail = (value: string) => {
  const raw = String(value || "").trim();
  if (!raw) return "";
  if (raw.toLowerCase().startsWith("mailto:")) {
    return raw.slice(7).split("?")[0] || "";
  }
  const hit = raw.match(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}/i);
  return hit ? hit[0] : "";
};

const profileEmailEntry = profile.socials.find((item) => String(item.icon || "").toLowerCase() === "email");
const contactEmail = extractEmail(themeSocial.email ?? "") || extractEmail(profileEmailEntry?.link ?? "");
const hasEmailSocial = profile.socials.some((item) => String(item.icon || "").toLowerCase() === "email");
const mergedSocials = [
  ...profile.socials,
  ...(!hasEmailSocial && contactEmail ? [{ name: "Email", icon: "email", link: `mailto:${contactEmail}` }] : [])
];
---

<section class="surface profile-card">
  <div class="avatar-wrap">
    <img src={profile.avatar} alt={profile.name} loading="lazy" class={avatarClass} />
  </div>
  <h3 class="site-name">{siteConfig.site.title}</h3>
  <h4 class="name">{profile.name}</h4>
  <p class="desc">{profile.desc}</p>
  {profile.quote && <blockquote class="quote">{profile.quote}</blockquote>}

  <hr class="divider" />

  <div class="social-links">
    {mergedSocials.map((social) =>
      String(social.icon || "").toLowerCase() === "email" && contactEmail ? (
        <button
          type="button"
          class="social-icon social-copy"
          title={`Email: ${contactEmail}（点击复制）`}
          aria-label={`复制邮箱 ${contactEmail}`}
          data-copy-text={contactEmail}
          data-copy-label="邮箱"
        >
          <Fragment set:html={getIcon(social.icon)} />
        </button>
      ) : (
        <a
          href={social.link}
          title={social.name}
          target={isHttpLink(social.link) ? "_blank" : undefined}
          rel={isHttpLink(social.link) ? "noreferrer" : undefined}
          class="social-icon"
        >
          <Fragment set:html={getIcon(social.icon)} />
        </a>
      )
    )}
  </div>
</section>

<script is:inline>
  const initProfileSocialCopy = () => {
    document.querySelectorAll(".social-copy[data-copy-text]").forEach((node) => {
      if (!(node instanceof HTMLButtonElement)) return;
      if (node.dataset.copyBound === "1") return;
      node.dataset.copyBound = "1";

      const baseTitle = node.title || "点击复制";
      node.addEventListener("click", async () => {
        const text = node.dataset.copyText || "";
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
          node.classList.add("is-copied");
          const label = node.dataset.copyLabel || "内容";
          if (typeof window.__flyNotifyCopySuccess === "function") {
            window.__flyNotifyCopySuccess(`${label}已复制`);
          } else {
            window.dispatchEvent(new CustomEvent("fly:copy-success", { detail: { message: `${label}已复制` } }));
          }
          node.title = `${label}已复制: ${text}`;
          window.setTimeout(() => {
            node.classList.remove("is-copied");
            node.title = baseTitle;
          }, 1600);
        } catch (error) {
          console.error("copy profile contact failed", error);
        }
      });
    });
  };

  document.addEventListener("astro:page-load", initProfileSocialCopy);
  initProfileSocialCopy();
</script>

<style>
  .profile-card {
    padding: 1.5rem 1.2rem;
    border-radius: var(--radius-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .avatar-wrap {
    margin-bottom: 1.25rem;
  }
  .avatar {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border: 2px solid var(--line);
    background: var(--bg-elev);
    padding: 0.25rem;
  }
  .avatar.circle {
    border-radius: 50%;
  }
  .avatar.rect {
    border-radius: 12px;
  }
  .site-name {
    margin: 0 0 0.25rem;
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
  }
  .name {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-soft);
  }
  .desc {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .quote {
    margin: 1rem 0 0;
    padding: 0.5rem 0.75rem;
    font-style: italic;
    color: var(--brand);
    font-size: 0.875rem;
    background: var(--brand-soft);
    border-radius: 8px;
    border-left: 2px solid var(--brand);
    text-align: left;
    width: 100%;
  }
  .divider {
    width: 100%;
    height: 1px;
    background: var(--line);
    border: none;
    margin: 1.5rem 0;
  }
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    width: 100%;
  }
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--text-soft);
    border-radius: 50%;
    border: 1px solid var(--line);
    transition: all 0.2s ease;
    text-decoration: none;
    background: var(--bg-elev);
  }
  .social-copy {
    font: inherit;
    cursor: copy;
  }
  .social-icon:hover {
    color: var(--brand);
    border-color: var(--brand);
    box-shadow: none;
  }
  .social-copy.is-copied {
    color: #10b981;
    border-color: #10b981;
  }
</style>
