---
import siteConfig from "@/site.config";
import Nav from "@/components/Nav.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
---

<header class="site-header">
  <div class="container header-inner">
    <a class="logo" href="/">
      <span class="logo-mark">{siteConfig.theme.logo.mark}</span>
      <span class="logo-text">{siteConfig.theme.logo.text}</span>
    </a>
    <Nav />
    <div class="actions">
      {
        siteConfig.search.provider !== "off" && (
          <button type="button" data-action="open-search" class="icon-btn" aria-label="打开搜索">
            <span class="search-hotkey">/</span>
            <span class="search-text">搜索</span>
          </button>
        )
      }
      <ThemeToggle />
      <a class="icon-btn" href={siteConfig.theme.social.github} target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 .5a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58l-.02-2.17c-3.34.73-4.04-1.42-4.04-1.42-.55-1.37-1.34-1.74-1.34-1.74-1.09-.74.08-.72.08-.72 1.2.09 1.83 1.22 1.83 1.22 1.07 1.8 2.8 1.28 3.49.98.1-.76.42-1.29.76-1.58-2.67-.3-5.48-1.31-5.48-5.84 0-1.29.47-2.34 1.22-3.16-.12-.3-.53-1.53.12-3.19 0 0 1.01-.32 3.31 1.21a11.6 11.6 0 0 1 6.03 0c2.3-1.53 3.3-1.2 3.3-1.2.66 1.65.25 2.88.13 3.18.76.82 1.22 1.87 1.22 3.16 0 4.54-2.81 5.54-5.49 5.83.43.36.81 1.08.81 2.18l-.01 3.23c0 .32.22.69.83.57A12 12 0 0 0 12 .5"
          />
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(var(--header-blur));
    background: linear-gradient(
      to right,
      color-mix(in oklab, var(--bg) 88%, transparent 12%),
      color-mix(in oklab, var(--bg-elev) 72%, transparent 28%)
    );
    border-bottom: 1px solid color-mix(in oklab, var(--line) 72%, transparent 28%);
  }
  .header-inner {
    min-height: 68px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.8rem;
    align-items: center;
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }
  .logo-mark {
    width: 34px;
    height: 34px;
    border-radius: 11px;
    background: linear-gradient(130deg, var(--brand), color-mix(in oklab, var(--accent) 65%, var(--brand) 35%));
    color: white;
    display: inline-grid;
    place-items: center;
    font-weight: 700;
    font-size: 0.72rem;
  }
  .logo-text {
    font-family: var(--font-serif);
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .icon-btn {
    min-width: 38px;
    height: 38px;
    border-radius: 11px;
    border: 1px solid var(--line);
    background: var(--bg-elev);
    color: var(--text-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.65rem;
    font-size: 0.78rem;
    cursor: pointer;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .icon-btn svg {
    display: block;
  }
  .search-text {
    display: none;
  }
  .icon-btn:hover {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 52%, var(--line) 48%);
  }
  @media (max-width: 900px) {
    .header-inner {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        "logo actions"
        "nav nav";
      padding: 0.55rem 0;
      gap: 0.5rem;
    }
    .logo {
      grid-area: logo;
    }
    :global(.nav) {
      grid-area: nav;
    }
    .actions {
      grid-area: actions;
      justify-content: flex-end;
    }
    .search-hotkey {
      display: none;
    }
    .search-text {
      display: inline;
      font-size: 0.82rem;
      font-weight: 600;
    }
  }
</style>
