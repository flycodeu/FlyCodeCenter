---
import siteConfig from "@/site.config";
import Nav from "@/components/Nav.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import CodeThemeToggle from "@/components/CodeThemeToggle.astro";
---

<header class="site-header">
  <div class="container header-inner">
    <a class="logo" href="/">
      <span class="logo-mark">{siteConfig.theme.logo.mark}</span>
      <span class="logo-text">{siteConfig.theme.logo.text}</span>
    </a>
    <Nav />
    <div class="actions">
      {
        siteConfig.search.provider !== "off" && (
          <button type="button" data-action="open-search" class="icon-btn" aria-label="打开搜索">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-4.343-4.343m0 0A8 8 0 1 0 5.343 5.343a8 8 0 0 0 11.314 11.314Z"/>
            </svg>
          </button>
        )
      }
      <ThemeToggle />
      <CodeThemeToggle />
      <a class="icon-btn github-link" href={siteConfig.theme.social.github} target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 .5a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58l-.02-2.17c-3.34.73-4.04-1.42-4.04-1.42-.55-1.37-1.34-1.74-1.34-1.74-1.09-.74.08-.72.08-.72 1.2.09 1.83 1.22 1.83 1.22 1.07 1.8 2.8 1.28 3.49.98.1-.76.42-1.29.76-1.58-2.67-.3-5.48-1.31-5.48-5.84 0-1.29.47-2.34 1.22-3.16-.12-.3-.53-1.53.12-3.19 0 0 1.01-.32 3.31 1.21a11.6 11.6 0 0 1 6.03 0c2.3-1.53 3.3-1.2 3.3-1.2.66 1.65.25 2.88.13 3.18.76.82 1.22 1.87 1.22 3.16 0 4.54-2.81 5.54-5.49 5.83.43.36.81 1.08.81 2.18l-.01 3.23c0 .32.22.69.83.57A12 12 0 0 0 12 .5"
          />
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    backdrop-filter: blur(calc(var(--header-blur) + 4px));
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--bg-elev) 84%, transparent 16%), color-mix(in oklab, var(--surface-1) 72%, transparent 28%));
    border-bottom: 1px solid color-mix(in oklab, var(--line) 56%, transparent 44%);
    box-shadow: 0 18px 46px -42px rgb(15 23 42 / 0.22);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .header-inner {
    min-height: 68px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
  }

  :global(.nav) {
    min-width: 0;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.82rem;
  }

  .logo-mark {
    width: 40px;
    height: 40px;
    border-radius: 14px;
    border: 1px solid color-mix(in oklab, var(--line) 72%, transparent 28%);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--surface-1) 96%, transparent 4%), color-mix(in oklab, var(--surface-2) 86%, transparent 14%));
    color: var(--text);
    display: inline-grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.92rem;
    letter-spacing: -0.04em;
    box-shadow: 0 12px 24px -22px rgb(15 23 42 / 0.5);
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--text);
    letter-spacing: 0.01em;
  }

  .actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 2;
    flex-wrap: nowrap;
    justify-self: end;
  }

  .icon-btn {
    min-width: 38px;
    height: 38px;
    border-radius: 14px;
    border: 1px solid color-mix(in oklab, var(--line) 72%, transparent 28%);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--surface-2) 88%, transparent 12%), color-mix(in oklab, var(--surface-1) 80%, transparent 20%));
    color: var(--text-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.58rem;
    font-size: 0.875rem;
    cursor: pointer;
    box-shadow: 0 16px 28px -26px rgb(15 23 42 / 0.38);
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
  }

  .icon-btn svg {
    display: block;
  }

  .github-link {
    display: inline-flex;
  }

  .icon-btn:hover {
    color: var(--text);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--surface-1) 94%, transparent 6%), color-mix(in oklab, var(--brand-soft) 20%, transparent 80%));
    border-color: color-mix(in oklab, var(--brand) 18%, var(--line) 82%);
    transform: translateY(-1px);
  }

  @media (max-width: 1180px) {
    .logo-text {
      display: none;
    }
  }

  @media (max-width: 1280px) {
    .github-link {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .site-header {
      backdrop-filter: blur(10px);
      background: color-mix(in oklab, var(--bg-elev) 88%, transparent 12%);
    }

    .header-inner {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        "logo actions"
        "nav nav";
      padding: 0.75rem 0;
      gap: 0.75rem;
    }

    .logo {
      grid-area: logo;
    }

    :global(.nav) {
      grid-area: nav;
    }

    .actions {
      grid-area: actions;
      justify-content: flex-end;
    }
  }
</style>
