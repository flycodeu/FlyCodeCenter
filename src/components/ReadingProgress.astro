---
import siteConfig from "@/site.config";

const progressConfig = siteConfig.article.ui.readingProgress;
---

{
  progressConfig.enable && (
    <button
      id="reading-progress-fab"
      class="reading-progress-fab"
      style={`--side-offset: ${progressConfig.sideOffset}px`}
      aria-label="返回顶部"
      title="返回顶部"
    >
      <svg class="progress-ring" width="52" height="52" aria-hidden="true">
        <circle class="progress-ring-bg" stroke-width="4" fill="transparent" r="22" cx="26" cy="26" />
        <circle class="progress-ring-circle" stroke-width="4" fill="transparent" r="22" cx="26" cy="26" />
      </svg>
      <span class="progress-core">
        <span class="progress-text" id="progress-text">0%</span>
      </span>
    </button>
  )
}

<script
  type="module"
  define:vars={{ minScrollableHeight: progressConfig.minScrollableHeight ?? 40 }}
>
  const minScrollableHeightValue = Number(minScrollableHeight ?? 40);
  const fab = document.getElementById("reading-progress-fab");
  const text = document.getElementById("progress-text");
  const circle = document.querySelector(".progress-ring-circle");
  const article = document.querySelector(".article-body");

  if (fab && text && circle instanceof SVGCircleElement && article instanceof HTMLElement) {
    const radius = circle.r.baseVal.value;
    const circumference = radius * 2 * Math.PI;
    circle.style.strokeDasharray = `${circumference} ${circumference}`;
    circle.style.strokeDashoffset = circumference;

    const getProgress = () => {
      const rect = article.getBoundingClientRect();
      const viewport = window.innerHeight || document.documentElement.clientHeight || 1;
      const articleTop = rect.top + window.scrollY;
      const articleHeight = Math.max(article.offsetHeight, 1);
      const start = articleTop - 40;
      const end = articleTop + articleHeight - viewport + 40;
      const total = Math.max(end - start, 1);
      const consumed = Math.min(Math.max(window.scrollY - start, 0), total);
      return Math.round((consumed / total) * 100);
    };

    const isScrollableEnough = () => {
      const total = Math.max(document.documentElement.scrollHeight, document.body.scrollHeight) - window.innerHeight;
      return total >= minScrollableHeightValue;
    };

    const render = () => {
      if (!isScrollableEnough()) {
        fab.classList.remove("visible");
        return;
      }
      const progress = getProgress();
      text.textContent = `${progress}%`;
      circle.style.strokeDashoffset = String(circumference - (progress / 100) * circumference);
      fab.setAttribute("aria-label", `返回顶部，当前阅读 ${progress}%`);
      fab.title = `返回顶部（${progress}%）`;
      fab.classList.add("visible");
    };

    let ticking = false;
    const requestRender = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        render();
        ticking = false;
      });
    };

    window.addEventListener("scroll", requestRender, { passive: true });
    window.addEventListener("resize", requestRender);
    window.addEventListener("site:decrypted", requestRender);
    requestRender();

    fab.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>

<style>
  .reading-progress-fab {
    position: fixed;
    right: var(--side-offset, 18px);
    bottom: calc(1rem + env(safe-area-inset-bottom));
    transform: translateY(12px) scale(0.96);
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg-elev) 92%, transparent 8%);
    border: 1px solid var(--line);
    box-shadow: 0 8px 24px color-mix(in oklab, var(--text) 10%, transparent 90%);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 80;
    opacity: 0;
    visibility: hidden;
    transition: opacity 220ms ease, transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }

  .reading-progress-fab.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .reading-progress-fab:hover {
    border-color: var(--brand);
    box-shadow: 0 10px 28px color-mix(in oklab, var(--brand) 18%, transparent 82%);
  }

  .progress-ring {
    position: absolute;
    inset: 0;
    transform: rotate(-90deg);
  }

  .progress-ring-bg {
    stroke: color-mix(in oklab, var(--line) 75%, transparent 25%);
  }

  .progress-ring-circle {
    stroke: var(--brand);
    transition: stroke-dashoffset 80ms linear;
  }

  .progress-core {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    line-height: 1;
    user-select: none;
  }

  .progress-text {
    font-size: 0.69rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .reading-progress-fab {
      right: 1rem;
      bottom: calc(0.8rem + env(safe-area-inset-bottom));
    }
  }
</style>
