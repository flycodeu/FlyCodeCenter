---
import siteConfig from "@/site.config";

const progressConfig = siteConfig.article.ui.readingProgress;
---

{
  progressConfig.enable && (
    <button
      id="reading-progress-fab"
      class="reading-progress-fab"
      style={`--side-offset: ${progressConfig.sideOffset}px`}
      aria-label="返回顶部"
      title="返回顶部"
    >
      <svg class="progress-ring" width="52" height="52" aria-hidden="true">
        <circle class="progress-ring-bg" stroke-width="4" fill="transparent" r="22" cx="26" cy="26" />
        <circle class="progress-ring-circle" stroke-width="4" fill="transparent" r="22" cx="26" cy="26" />
      </svg>
      <span class="progress-core">
        <span class="progress-text" id="progress-text">0%</span>
      </span>
    </button>
  )
}

<script
  type="module"
  define:vars={{ minScrollableHeight: progressConfig.minScrollableHeight ?? 40 }}
>
  const minScrollableHeightValue = Number(minScrollableHeight ?? 40);
  const state = window.__flyReadingProgressState ?? {
    fab: null,
    text: null,
    circle: null,
    article: null,
    circumference: 0,
    ticking: false,
    bound: false,
    disabled: false
  };
  window.__flyReadingProgressState = state;

  const shouldDisable = () =>
    document.documentElement.dataset.perf === "low" ||
    window.matchMedia("(max-width: 1024px)").matches;

  const bindTargets = () => {
    state.fab = document.getElementById("reading-progress-fab");
    state.text = document.getElementById("progress-text");
    state.circle = document.querySelector(".progress-ring-circle");
    state.article = document.querySelector(".article-body");

    if (!(state.circle instanceof SVGCircleElement)) return false;
    const radius = state.circle.r.baseVal.value;
    state.circumference = radius * 2 * Math.PI;
    state.circle.style.strokeDasharray = `${state.circumference} ${state.circumference}`;
    state.circle.style.strokeDashoffset = String(state.circumference);
    return true;
  };

  const isReady = () =>
    state.fab instanceof HTMLElement &&
    state.text instanceof HTMLElement &&
    state.circle instanceof SVGCircleElement &&
    state.article instanceof HTMLElement;

  const getProgress = () => {
    if (!(state.article instanceof HTMLElement)) return 0;
    const rect = state.article.getBoundingClientRect();
    const viewport = window.innerHeight || document.documentElement.clientHeight || 1;
    const articleTop = rect.top + window.scrollY;
    const articleHeight = Math.max(state.article.offsetHeight, 1);
    const start = articleTop - 40;
    const end = articleTop + articleHeight - viewport + 40;
    const total = Math.max(end - start, 1);
    const consumed = Math.min(Math.max(window.scrollY - start, 0), total);
    return Math.round((consumed / total) * 100);
  };

  const isScrollableEnough = () => {
    const pageScrollable = Math.max(document.documentElement.scrollHeight, document.body.scrollHeight) - window.innerHeight;
    const articleScrollable =
      state.article instanceof HTMLElement ? Math.max(state.article.scrollHeight - window.innerHeight, 0) : 0;
    return pageScrollable >= minScrollableHeightValue || articleScrollable >= minScrollableHeightValue;
  };

  const render = () => {
    if (!isReady()) return;
    if (shouldDisable()) {
      state.disabled = true;
      state.fab.classList.remove("visible");
      return;
    }
    state.disabled = false;
    if (!isScrollableEnough()) {
      state.fab.classList.remove("visible");
      return;
    }
    const progress = getProgress();
    state.text.textContent = `${progress}%`;
    state.circle.style.strokeDashoffset = String(state.circumference - (progress / 100) * state.circumference);
    state.fab.setAttribute("aria-label", `返回顶部，当前阅读 ${progress}%`);
    state.fab.title = `返回顶部（${progress}%）`;
    state.fab.classList.add("visible");
  };

  const requestRender = () => {
    if (state.ticking) return;
    state.ticking = true;
    requestAnimationFrame(() => {
      render();
      state.ticking = false;
    });
  };

  const init = () => {
    if (shouldDisable()) {
      state.disabled = true;
      const fab = document.getElementById("reading-progress-fab");
      if (fab instanceof HTMLElement) {
        fab.classList.remove("visible");
      }
      return;
    }
    const ok = bindTargets();
    if (!ok || !isReady()) return;
    requestRender();
    if (state.fab instanceof HTMLElement && !state.fab.dataset.bound) {
      state.fab.dataset.bound = "1";
      state.fab.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }
  };

  if (!state.bound) {
    state.bound = true;
    window.addEventListener("scroll", requestRender, { passive: true });
    window.addEventListener("resize", requestRender);
    window.addEventListener("site:decrypted", () => {
      init();
      requestRender();
    });
    document.addEventListener("astro:page-load", () => {
      init();
      requestRender();
    });
  }

  init();
</script>

<style>
  .reading-progress-fab {
    position: fixed;
    right: var(--side-offset, 18px);
    bottom: calc(1rem + env(safe-area-inset-bottom) + var(--floating-safe-bottom, 0px));
    transform: translateY(12px) scale(0.96);
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg-elev) 92%, transparent 8%);
    border: 1px solid var(--line);
    box-shadow: 0 8px 24px color-mix(in oklab, var(--text) 10%, transparent 90%);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 86;
    opacity: 0;
    visibility: hidden;
    transition: opacity 220ms ease, transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }

  .reading-progress-fab.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .reading-progress-fab:hover {
    border-color: var(--brand);
    box-shadow: 0 10px 28px color-mix(in oklab, var(--brand) 18%, transparent 82%);
  }

  .progress-ring {
    position: absolute;
    inset: 0;
    transform: rotate(-90deg);
  }

  .progress-ring-bg {
    stroke: color-mix(in oklab, var(--line) 75%, transparent 25%);
  }

  .progress-ring-circle {
    stroke: var(--brand);
    transition: stroke-dashoffset 80ms linear;
  }

  .progress-core {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    line-height: 1;
    user-select: none;
  }

  .progress-text {
    font-size: 0.69rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .reading-progress-fab {
      display: none;
    }
  }
</style>
