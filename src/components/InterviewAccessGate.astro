---
import siteConfig from "@/site.config";
import {
  createInterviewPasswordHash,
  createInterviewPasswordToken,
  createInterviewStorageSecret
} from "@/utils/interview-access";

const interviewConfig = siteConfig.pages.interviewCenter;
const passwordToken = createInterviewPasswordToken(interviewConfig.unlock.password);
const passwordHash = createInterviewPasswordHash(interviewConfig.unlock.password);
const storageSecret = createInterviewStorageSecret(passwordHash);
---

<section
  class="interview-access-gate"
  data-interview-access-gate
  data-password-token={passwordToken}
  data-password-hash={passwordHash}
  data-storage-secret={storageSecret}
  data-checking-text="正在验证..."
  data-error-text="密码错误，暂时无法进入面试中心。"
  data-storage-error-text="保存解锁状态失败，请重试。"
  data-verify-error-text="当前环境无法完成密码校验，请刷新后重试。"
>
  <div class="interview-access-card">
    <p class="access-eyebrow">Interview Center</p>
    <h2>{interviewConfig.unlock.title}</h2>
    <p class="access-copy">{interviewConfig.unlock.description} 通过校验后即可直接查看题目列表与正文。</p>
    <form data-interview-access-form>
      <input data-access-password type="password" autocomplete="off" placeholder="输入密码即可进入" required />
      <button type="submit">验证并进入</button>
    </form>
    <p class="access-message" data-access-message></p>
  </div>
</section>

<script>
  import "../scripts/interview-access-gate";
</script>

<style>
  .interview-access-gate {
    position: fixed;
    inset: 0;
    z-index: 105;
    display: grid;
    place-items: center;
    padding: 1.25rem;
    background:
      radial-gradient(circle at top left, color-mix(in oklab, var(--brand) 12%, transparent 88%), transparent 34%),
      radial-gradient(circle at top right, color-mix(in oklab, var(--accent) 10%, transparent 90%), transparent 36%),
      repeating-linear-gradient(
        90deg,
        color-mix(in oklab, var(--line) 10%, transparent 90%) 0,
        color-mix(in oklab, var(--line) 10%, transparent 90%) 1px,
        transparent 1px,
        transparent 32px
      ),
      rgb(16 18 23 / 0.38);
    backdrop-filter: blur(18px);
  }

  .interview-access-gate[hidden] {
    display: none !important;
  }

  .interview-access-card {
    width: min(460px, calc(100vw - 2rem));
    padding: 1.6rem;
    border-radius: 30px;
    border: 1px solid color-mix(in oklab, var(--line) 88%, transparent 12%);
    background:
      linear-gradient(135deg, color-mix(in oklab, var(--brand-soft) 18%, transparent 82%), transparent 42%),
      radial-gradient(circle at top right, color-mix(in oklab, var(--accent) 11%, transparent 89%), transparent 36%),
      linear-gradient(180deg, color-mix(in oklab, var(--surface-1) 97%, transparent 3%), color-mix(in oklab, var(--surface-2) 94%, transparent 6%));
    box-shadow:
      0 30px 72px -36px rgb(15 23 42 / 0.44),
      inset 0 1px 0 color-mix(in oklab, white 12%, transparent 88%);
  }

  .access-eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .interview-access-card h2 {
    margin: 0;
    font-size: clamp(1.56rem, 4vw, 1.92rem);
    line-height: 1.12;
  }

  .access-copy {
    margin: 0.72rem 0 0;
    color: var(--text-soft);
    line-height: 1.72;
  }

  .interview-access-card form {
    display: grid;
    gap: 0.8rem;
    margin-top: 1.1rem;
  }

  .interview-access-card input,
  .interview-access-card button {
    width: 100%;
    border-radius: 16px;
    padding: 0.92rem 1rem;
    border: 1px solid color-mix(in oklab, var(--line) 86%, transparent 14%);
    background: color-mix(in oklab, var(--surface-2) 92%, transparent 8%);
    color: var(--text);
    font: inherit;
  }

  .interview-access-card button {
    cursor: pointer;
    font-weight: 650;
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--brand) 22%, var(--surface-1) 78%), color-mix(in oklab, var(--brand) 14%, var(--surface-2) 86%));
    color: var(--text);
    border-color: color-mix(in oklab, var(--brand) 32%, var(--line) 68%);
  }

  .interview-access-gate[data-loading="1"] .interview-access-card button {
    opacity: 0.72;
    cursor: wait;
  }

  .access-message {
    min-height: 1.35rem;
    margin: 0.8rem 0 0;
    font-size: 0.84rem;
    color: var(--text-soft);
  }

  :global(html.interview-locked) [data-interview-protected] {
    filter: blur(22px) saturate(0.82);
    pointer-events: none;
    user-select: none;
  }
</style>
