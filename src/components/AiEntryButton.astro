---
import siteConfig from "@/site.config";

const enabled = siteConfig.ai.provider !== "off" && siteConfig.features.assistant.aiPanel;
---

{
  enabled && (
    <button class="ai-entry" data-action="open-ai" aria-label="打开 AI 助手">
      <span>AI</span>
      <small>聊天</small>
    </button>
  )
}

<style>
  .ai-entry {
    position: fixed;
    right: 18px;
    bottom: 86px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: linear-gradient(140deg, var(--brand), color-mix(in oklab, var(--accent) 72%, var(--brand) 28%));
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    z-index: 44;
    box-shadow: 0 14px 30px color-mix(in oklab, var(--brand) 20%, transparent 80%);
    display: grid;
    place-items: center;
    line-height: 1;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .ai-entry span {
    font-size: 0.86rem;
    letter-spacing: 0.04em;
  }
  .ai-entry small {
    font-size: 0.58rem;
    opacity: 0.9;
  }
  .ai-entry:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 34px color-mix(in oklab, var(--brand) 26%, transparent 74%);
  }
</style>
