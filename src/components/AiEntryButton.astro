---
import siteConfig from "@/site.config";

const enabled = siteConfig.ai.provider !== "off" && siteConfig.features.assistant.aiPanel;
---

{
  enabled && (
    <button class="ai-entry" data-action="open-ai" aria-label="打开 AI 助手">
      <span>AI</span>
      <small>聊天</small>
    </button>
  )
}

<style>
  .ai-entry {
    position: fixed;
    right: 18px;
    bottom: 86px;
    min-width: 92px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 94%, transparent 6%);
    color: color-mix(in oklab, var(--text) 70%, var(--brand) 30%);
    font-weight: 600;
    cursor: pointer;
    z-index: 44;
    box-shadow: 0 12px 24px color-mix(in oklab, var(--brand) 12%, transparent 88%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.22rem;
    padding: 0 0.74rem;
    line-height: 1;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .ai-entry span {
    font-size: 0.8rem;
    letter-spacing: 0.01em;
  }
  .ai-entry small {
    font-size: 0.66rem;
    opacity: 0.82;
  }
  .ai-entry:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 30px color-mix(in oklab, var(--brand) 18%, transparent 82%);
  }
</style>
