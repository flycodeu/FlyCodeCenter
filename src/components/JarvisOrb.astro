---
import siteConfig from "@/site.config";

const enabled = siteConfig.jarvis?.enable && siteConfig.jarvis?.floatingOrb?.enable;
const targetRoute = siteConfig.jarvis?.route ?? "/jarvis";
const orbConfig = siteConfig.jarvis?.floatingOrb;
const interaction = siteConfig.jarvis?.interaction;
const eventNamespace = interaction?.eventNamespace ?? "jarvis";

const label = orbConfig?.label ?? "JARVIS";
const position = orbConfig?.position ?? "left";
const offsetX = orbConfig?.offsetX ?? 16;
const offsetY = orbConfig?.offsetY ?? 16;
const defaultState = orbConfig?.defaultState ?? interaction?.defaultState ?? "idle";
const defaultText = orbConfig?.defaultText ?? "已待命";
const activeText = orbConfig?.activeText ?? "连接中";
---

{
  enabled && (
    <section
      id="jarvis-bot"
      class={`jarvis-bot ${position === "left" ? "is-left" : "is-right"}`}
      data-event-namespace={eventNamespace}
      data-default-state={defaultState}
      data-default-text={defaultText}
      data-active-text={activeText}
      data-target-route={targetRoute}
      data-expression="dot"
      style={`--bot-offset-x:${offsetX}px;--bot-offset-y:${offsetY}px;`}
      aria-label="Jarvis assistant"
    >
      <button id="jarvis-bot-trigger" class="jarvis-bot-trigger" type="button" aria-label="Jarvis actions">
        <span class="bot-core" aria-hidden="true">
          <span class="bot-pack"></span>
          <span class="bot-arm bot-arm-left bot-arm-primary"><i class="bot-arm-segment"></i><i class="bot-hand"></i></span>
          <span class="bot-arm bot-arm-right"><i class="bot-arm-segment"></i><i class="bot-hand"></i></span>
          <span class="bot-shell">
            <span class="bot-screen">
              <span class="screen-grid"></span>
              <span class="screen-scan"></span>
              <span class="bot-eyes"><span class="eye"><i></i></span><span class="eye"><i></i></span></span>
              <span class="screen-icon">AI</span>
            </span>
            <span class="bot-chest-strip"></span>
          </span>
        </span>
      </button>

      <p class="bot-label">{label}</p>
      <p id="jarvis-bot-status" class="bot-status">{defaultText}</p>

      <div id="jarvis-bot-menu" class="jarvis-bot-menu" role="menu" hidden>
        <button type="button" class="menu-item" data-action="start-chat" role="menuitem">开始对话</button>
        <button type="button" class="menu-item" data-action="toggle-music" role="menuitem">播放音乐（模拟）</button>
        <button type="button" class="menu-item" data-action="wallpaper-next" role="menuitem">切换壁纸（下一张）</button>
      </div>
    </section>
  )
}

<style>
  .jarvis-bot { position: fixed; bottom: calc(var(--bot-offset-y) + env(safe-area-inset-bottom) + var(--floating-safe-bottom, 0px)); z-index: 81; width: 114px; display: grid; justify-items: center; gap: 0.3rem; }
  .jarvis-bot.is-left { left: var(--bot-offset-x); }
  .jarvis-bot.is-right { right: var(--bot-offset-x); }
  .jarvis-bot-trigger { border: 0; background: transparent; cursor: pointer; padding: 0; width: 100%; display: grid; justify-items: center; }
  .bot-core { position: relative; width: 90px; height: 108px; filter: drop-shadow(0 14px 20px color-mix(in oklab, var(--brand) 35%, transparent 65%)); }
  .bot-shell { position: absolute; inset: 10px 10px 0; z-index: 2; border-radius: 24px; border: 2px solid color-mix(in oklab, var(--line) 64%, var(--brand) 36%); background: linear-gradient(165deg, color-mix(in oklab, var(--surface-1) 92%, transparent 8%), color-mix(in oklab, var(--surface-2) 82%, transparent 18%)); }
  .bot-pack { position: absolute; left: 50%; top: 22px; z-index: 0; width: 30px; height: 58px; border-radius: 14px; border: 2px solid color-mix(in oklab, var(--line) 74%, var(--brand) 26%); transform: translateX(-50%); }
  .bot-pack::before { content: ""; position: absolute; left: 50%; top: 7px; width: 8px; height: 8px; border-radius: 50%; background: color-mix(in oklab, #22d3ee 75%, #fff 25%); transform: translateX(-50%); box-shadow: 0 0 8px color-mix(in oklab, #22d3ee 52%, transparent 48%); }
  .bot-arm { position: absolute; top: 46px; z-index: 4; width: 32px; height: 12px; }
  .bot-arm-left { left: -18px; transform-origin: 32px 6px; transform: rotate(-32deg); }
  .bot-arm-right { right: -18px; transform-origin: 0 6px; transform: rotate(32deg); }
  .bot-arm-segment { position: absolute; top: 4px; width: 21px; height: 4px; border-radius: 999px; background: color-mix(in oklab, var(--line) 36%, var(--brand) 64%); }
  .bot-arm-left .bot-arm-segment { left: 4px; } .bot-arm-right .bot-arm-segment { right: 4px; }
  .bot-hand { position: absolute; top: 1px; width: 8px; height: 8px; border-radius: 50%; border: 1px solid color-mix(in oklab, var(--line) 62%, var(--brand) 38%); background: color-mix(in oklab, var(--surface-1) 88%, var(--brand-soft) 12%); }
  .bot-arm-left .bot-hand { left: -5px; } .bot-arm-right .bot-hand { right: -5px; }
  .bot-screen { position: absolute; left: 50%; top: 10px; width: 62px; height: 42px; transform: translateX(-50%); border-radius: 11px; overflow: hidden; border: 1px solid color-mix(in oklab, var(--brand) 46%, var(--line) 54%); background: linear-gradient(180deg, color-mix(in oklab, #02232a 92%, transparent 8%), color-mix(in oklab, #011116 94%, transparent 6%)); }
  .screen-grid { position: absolute; inset: 0; background: linear-gradient(to right, color-mix(in oklab, #22d3ee 12%, transparent 88%) 1px, transparent 1px), linear-gradient(to bottom, color-mix(in oklab, #22d3ee 12%, transparent 88%) 1px, transparent 1px); background-size: 8px 8px; opacity: 0.42; }
  .screen-scan { position: absolute; left: -60%; top: 0; width: 40%; height: 100%; background: linear-gradient(90deg, transparent, color-mix(in oklab, #67e8f9 35%, transparent 65%), transparent); opacity: 0; }
  .bot-eyes { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; gap: 10px; z-index: 1; }
  .eye i { display: block; width: 11px; height: 8px; border-radius: 9px; background: #67e8f9; box-shadow: 0 0 7px color-mix(in oklab, #22d3ee 64%, transparent 36%); transition: all 180ms ease; }
  .eye i::before, .eye i::after { content: none; }
  .screen-icon { position: absolute; right: 6px; bottom: 4px; font-size: 0.5rem; letter-spacing: 0.1em; color: color-mix(in oklab, #67e8f9 70%, #fff 30%); opacity: 0.74; font-family: var(--font-tech); }
  .bot-chest-strip { position: absolute; left: 50%; bottom: 13px; width: 36px; height: 6px; transform: translateX(-50%); border-radius: 999px; background: linear-gradient(90deg, color-mix(in oklab, #67e8f9 82%, #fff 18%), color-mix(in oklab, var(--brand) 72%, #fff 28%)); animation: bot-breathe 2.5s ease-in-out infinite; }
  .jarvis-bot[data-expression="dot"] .eye i { width: 10px; height: 10px; border-radius: 50%; }
  .jarvis-bot[data-expression="arc"] .eye i { width: 12px; height: 7px; background: transparent; border: 2px solid #67e8f9; border-top: 0; border-radius: 0 0 9px 9px; box-shadow: none; }
  .jarvis-bot[data-expression="cross"] .eye i, .jarvis-bot[data-expression="heart"] .eye i, .jarvis-bot[data-expression="surprised"] .eye i { width: 12px; height: 12px; border-radius: 50%; }
  .jarvis-bot[data-expression="cross"] .eye i { background: transparent; border: 2px solid #67e8f9; box-shadow: none; }
  .jarvis-bot[data-expression="heart"] .eye i { background: linear-gradient(180deg, #fb7185, #f43f5e); border-radius: 3px; transform: rotate(45deg); }
  .jarvis-bot[data-expression="wink"] .eye:first-child i, .jarvis-bot[data-expression="sleepy"] .eye i { width: 12px; height: 2px; border-radius: 999px; }
  .jarvis-bot[data-expression="focus"] .eye i, .jarvis-bot[data-expression="loading"] .eye i { width: 12px; height: 3px; border-radius: 999px; }
  .jarvis-bot[data-expression="loading"] .eye i { animation: bot-loading-eye 1s linear infinite; }
  .jarvis-bot[data-expression="angry"] .eye i { width: 12px; height: 3px; border-radius: 3px; }
  .jarvis-bot[data-expression="angry"] .eye:first-child i { transform: rotate(-18deg); }
  .jarvis-bot[data-expression="angry"] .eye:last-child i { transform: rotate(18deg); }
  .jarvis-bot.is-blink .eye i { transform: scaleY(0.22); }
  .jarvis-bot.is-waving .bot-arm-primary { animation: bot-wave 1s ease; }
  .jarvis-bot.is-nodding .bot-core { animation: bot-nod 760ms ease; }
  .jarvis-bot.is-shaking .bot-core { animation: bot-shake 700ms ease; }
  .jarvis-bot.is-pulsing .bot-core { animation: bot-pulse 800ms ease; }
  .jarvis-bot.is-scanning .screen-scan { opacity: 1; animation: bot-scan 980ms ease; }
  .jarvis-bot.is-music-on .bot-core { animation: bot-bob 1.2s ease-in-out infinite; }
  .bot-label, .bot-status { margin: 0; pointer-events: none; text-align: center; white-space: nowrap; }
  .bot-label { font-size: 0.62rem; letter-spacing: 0.16em; color: color-mix(in oklab, var(--text-soft) 72%, var(--brand) 28%); font-weight: 700; }
  .bot-status { font-size: 0.58rem; color: var(--text-muted); letter-spacing: 0.02em; max-width: 12rem; overflow: hidden; text-overflow: ellipsis; }
  .jarvis-bot.is-active .bot-status { color: color-mix(in oklab, var(--brand) 78%, var(--text) 22%); }
  .jarvis-bot-menu { position: fixed; width: min(290px, calc(100vw - 20px)); max-height: min(68vh, 460px); overflow: auto; border-radius: 14px; border: 1px solid color-mix(in oklab, var(--line) 56%, var(--brand) 44%); background: linear-gradient(180deg, color-mix(in oklab, var(--surface-1) 96%, transparent 4%), color-mix(in oklab, var(--bg-elev) 96%, transparent 4%)); backdrop-filter: blur(12px); padding: 0.5rem; z-index: 93; }
  .menu-title { margin: 0.38rem 0.22rem 0.18rem; font-size: 0.62rem; letter-spacing: 0.08em; color: var(--text-muted); text-transform: uppercase; }
  .menu-item { width: 100%; border: 1px solid color-mix(in oklab, var(--line) 84%, transparent 16%); background: color-mix(in oklab, var(--bg) 90%, transparent 10%); color: var(--text); border-radius: 10px; padding: 0.45rem 0.52rem; display: flex; align-items: center; gap: 0.55rem; cursor: pointer; font-size: 0.82rem; text-align: left; }
  .menu-item:hover { border-color: color-mix(in oklab, var(--brand) 56%, var(--line) 44%); background: color-mix(in oklab, var(--brand-soft) 68%, transparent 32%); }
  .menu-item.is-disabled { opacity: 0.5; cursor: not-allowed; }
  @keyframes bot-wave { 0% { transform: rotate(-32deg); } 20% { transform: rotate(-6deg); } 40% { transform: rotate(-50deg); } 60% { transform: rotate(14deg); } 80% { transform: rotate(-36deg); } 100% { transform: rotate(-32deg); } }
  @keyframes bot-nod { 0% { transform: translateY(0); } 40% { transform: translateY(2px); } 100% { transform: translateY(0); } }
  @keyframes bot-shake { 0% { transform: translateX(0); } 25% { transform: translateX(-2px); } 50% { transform: translateX(2px); } 75% { transform: translateX(-2px); } 100% { transform: translateX(0); } }
  @keyframes bot-pulse { 0% { transform: scale(1); } 45% { transform: scale(1.04); } 100% { transform: scale(1); } }
  @keyframes bot-scan { 0% { transform: translateX(0%); } 100% { transform: translateX(320%); } }
  @keyframes bot-loading-eye { 0% { opacity: 0.35; transform: scaleX(0.7); } 50% { opacity: 1; transform: scaleX(1); } 100% { opacity: 0.35; transform: scaleX(0.7); } }
  @keyframes bot-breathe { 0% { opacity: 0.42; } 50% { opacity: 0.92; } 100% { opacity: 0.42; } }
  @keyframes bot-bob { 0% { transform: translateY(0); } 50% { transform: translateY(-3px); } 100% { transform: translateY(0); } }
  :root[data-perf="low"] .jarvis-bot { display: none !important; }
  :root[data-perf="low"] .jarvis-bot .bot-chest-strip { animation-duration: 4s; }
  :root[data-perf="low"] .jarvis-bot.is-music-on .bot-core { animation-duration: 2.4s; }
  :root[data-perf="low"] .jarvis-bot .screen-scan { animation-duration: 1.4s; }
  @media (max-width: 960px) { .jarvis-bot { width: 102px; } .bot-core { width: 82px; height: 98px; } }
  @media (max-width: 900px) { .jarvis-bot { display: none !important; } }
</style>
