---
import siteConfig from "@/site.config";

const enabled = siteConfig.jarvis?.enable && siteConfig.jarvis?.floatingOrb?.enable;
const target = siteConfig.jarvis?.route ?? "/jarvis";
const label = siteConfig.jarvis?.floatingOrb?.label ?? "JARVIS";
---

{
  enabled && (
    <a id="jarvis-orb" class="jarvis-orb" href={target} aria-label="打开 Jarvis 控制台" title="进入 Jarvis 控制台">
      <span class="orb-shell" aria-hidden="true">
        <span class="orb-ring ring-1"></span>
        <span class="orb-ring ring-2"></span>
        <span class="orb-pulse"></span>
        <span class="orb-eyes">
          <span class="orb-eye"><i></i></span>
          <span class="orb-eye"><i></i></span>
        </span>
      </span>
      <span class="orb-label">{label}</span>
    </a>
  )
}

{
  enabled && (
    <script type="module">
      const node = document.getElementById("jarvis-orb");
      if (!(node instanceof HTMLElement)) {
        // no-op
      } else {
        const eyes = [...node.querySelectorAll(".orb-eye i")].filter((item) => item instanceof HTMLElement);

        const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

        const track = (clientX, clientY) => {
          const rect = node.getBoundingClientRect();
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const diffX = clamp((clientX - centerX) / 18, -5, 5);
          const diffY = clamp((clientY - centerY) / 18, -5, 5);
          const tiltX = clamp((clientY - centerY) / 64, -7, 7);
          const tiltY = clamp((centerX - clientX) / 64, -7, 7);

          node.style.setProperty("--eye-x", `${diffX}px`);
          node.style.setProperty("--eye-y", `${diffY}px`);
          node.style.setProperty("--tilt-x", `${tiltX}deg`);
          node.style.setProperty("--tilt-y", `${tiltY}deg`);

          eyes.forEach((eye) => {
            eye.style.transform = `translate(${diffX}px, ${diffY}px)`;
          });
        };

        const onMove = (event) => {
          track(event.clientX, event.clientY);
        };

        const spawnRipple = (x, y) => {
          const rect = node.getBoundingClientRect();
          const ripple = document.createElement("span");
          ripple.className = "orb-ripple";
          ripple.style.left = `${x - rect.left}px`;
          ripple.style.top = `${y - rect.top}px`;
          node.appendChild(ripple);
          window.setTimeout(() => ripple.remove(), 520);
        };

        node.addEventListener("pointermove", onMove, { passive: true });
        window.addEventListener("pointermove", onMove, { passive: true });

        node.addEventListener("pointerdown", (event) => {
          spawnRipple(event.clientX, event.clientY);
        });
      }
    </script>
  )
}

<style>
  .jarvis-orb {
    --eye-x: 0px;
    --eye-y: 0px;
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    position: fixed;
    right: 1rem;
    bottom: calc(1rem + env(safe-area-inset-bottom) + var(--floating-safe-bottom, 0px));
    width: 74px;
    height: 74px;
    z-index: 79;
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: var(--text);
    text-decoration: none;
    transform-style: preserve-3d;
    transform: perspective(220px) rotateX(var(--tilt-x)) rotateY(var(--tilt-y));
    transition: transform 120ms ease, filter 180ms ease;
    isolation: isolate;
  }

  .jarvis-orb:hover {
    filter: saturate(1.08);
  }

  .orb-shell {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    position: relative;
    border: 1px solid color-mix(in oklab, var(--brand) 48%, var(--line) 52%);
    background:
      radial-gradient(circle at 30% 24%, color-mix(in oklab, #fff 70%, transparent 30%), transparent 38%),
      radial-gradient(circle at 65% 74%, color-mix(in oklab, var(--accent) 30%, transparent 70%), transparent 54%),
      linear-gradient(160deg, color-mix(in oklab, var(--brand-soft) 72%, transparent 28%), color-mix(in oklab, var(--bg-elev) 84%, transparent 16%));
    backdrop-filter: blur(9px);
    box-shadow:
      0 14px 30px -16px color-mix(in oklab, var(--brand) 50%, transparent 50%),
      inset 0 1px 0 color-mix(in oklab, #fff 26%, transparent 74%);
    overflow: hidden;
  }

  .orb-ring {
    position: absolute;
    inset: 8px;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--brand) 42%, transparent 58%);
    animation: orb-spin 10s linear infinite;
    opacity: 0.84;
  }

  .orb-ring.ring-2 {
    inset: 16px;
    animation-duration: 6.8s;
    animation-direction: reverse;
    opacity: 0.62;
  }

  .orb-pulse {
    position: absolute;
    inset: 16px;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in oklab, var(--brand) 40%, transparent 60%), transparent 74%);
    animation: orb-pulse 2.2s ease-out infinite;
  }

  .orb-eyes {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
  }

  .orb-eye {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--brand) 56%, var(--line) 44%);
    background: color-mix(in oklab, var(--bg-elev) 88%, transparent 12%);
    display: grid;
    place-items: center;
  }

  .orb-eye i {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--brand);
    transition: transform 100ms linear;
  }

  .orb-label {
    position: absolute;
    bottom: -1.35rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: color-mix(in oklab, var(--text-soft) 74%, var(--brand) 26%);
    white-space: nowrap;
    pointer-events: none;
  }

  .orb-ripple {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--brand) 66%, transparent 34%);
    transform: translate(-50%, -50%);
    animation: orb-ripple 0.52s ease-out forwards;
    pointer-events: none;
  }

  @keyframes orb-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes orb-pulse {
    0% {
      transform: scale(0.84);
      opacity: 0.86;
    }
    100% {
      transform: scale(1.16);
      opacity: 0;
    }
  }

  @keyframes orb-ripple {
    0% {
      width: 8px;
      height: 8px;
      opacity: 0.84;
    }
    100% {
      width: 64px;
      height: 64px;
      opacity: 0;
    }
  }

  @media (max-width: 1024px) {
    .jarvis-orb {
      width: 64px;
      height: 64px;
      right: 0.85rem;
      bottom: calc(0.85rem + env(safe-area-inset-bottom) + var(--floating-safe-bottom, 0px));
    }

    .orb-label {
      font-size: 0.56rem;
      bottom: -1.1rem;
    }
  }
</style>

