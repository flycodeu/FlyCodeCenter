---
import siteConfig from "@/site.config";

const enabled = siteConfig.jarvis?.enable && siteConfig.jarvis?.floatingOrb?.enable;
const target = siteConfig.jarvis?.route ?? "/jarvis";
const orbConfig = siteConfig.jarvis?.floatingOrb;
const interaction = siteConfig.jarvis?.interaction;
const label = orbConfig?.label ?? "JARVIS";
const position = orbConfig?.position ?? "left";
const offsetX = orbConfig?.offsetX ?? 16;
const offsetY = orbConfig?.offsetY ?? 16;
const eventNamespace = interaction?.eventNamespace ?? "jarvis";
const defaultState = orbConfig?.defaultState ?? interaction?.defaultState ?? "idle";
const clickState = orbConfig?.clickState ?? interaction?.clickState ?? "active";
const hoverState = interaction?.hoverState ?? "active";
const defaultText = orbConfig?.defaultText ?? "已待命";
const activeText = orbConfig?.activeText ?? "连接中";
const modelPresetKey = orbConfig?.modelPresetKey ?? "";
const actionId = orbConfig?.actionId ?? "open-settings";
---

{
  enabled && (
    <a
      id="jarvis-orb"
      class={`jarvis-orb ${position === "left" ? "is-left" : "is-right"}`}
      href={target}
      aria-label="打开 Jarvis 控制台"
      title="进入 Jarvis 控制台"
      data-event-namespace={eventNamespace}
      data-default-state={defaultState}
      data-click-state={clickState}
      data-hover-state={hoverState}
      data-default-text={defaultText}
      data-active-text={activeText}
      data-model-preset={modelPresetKey}
      data-action-id={actionId}
      style={`--orb-offset-x:${offsetX}px;--orb-offset-y:${offsetY}px;`}
    >
      <span class="orb-shell" aria-hidden="true">
        <span class="orb-ring ring-1"></span>
        <span class="orb-ring ring-2"></span>
        <span class="orb-pulse"></span>
        <span class="orb-eyes">
          <span class="orb-eye"><i></i></span>
          <span class="orb-eye"><i></i></span>
        </span>
      </span>
      <span class="orb-label">{label}</span>
      <span class="orb-state" id="jarvis-orb-state">{defaultText}</span>
    </a>
  )
}

{
  enabled && (
    <script type="module">
      const node = document.getElementById("jarvis-orb");
      if (!(node instanceof HTMLElement)) {
        // no-op
      } else {
        const stateText = document.getElementById("jarvis-orb-state");
        const eyes = [...node.querySelectorAll(".orb-eye i")].filter((item) => item instanceof HTMLElement);
        const eventNamespace = node.dataset.eventNamespace || "jarvis";
        const defaultState = node.dataset.defaultState || "idle";
        const clickState = node.dataset.clickState || "active";
        const hoverState = node.dataset.hoverState || "active";
        let defaultText = node.dataset.defaultText || "已待命";
        let activeText = node.dataset.activeText || "连接中";
        const modelPreset = node.dataset.modelPreset || "";
        const actionId = node.dataset.actionId || "open-settings";
        const modelKey = "fly-jarvis-model-preset";

        const emit = (name, detail) => {
          window.dispatchEvent(new CustomEvent(`${eventNamespace}:${name}`, { detail }));
        };

        const setState = (state, notify = true, source = "orb") => {
          node.dataset.state = state;
          node.classList.toggle("is-active", state === "active");
          if (stateText instanceof HTMLElement) {
            stateText.textContent = state === "active" ? activeText : defaultText;
          }
          if (notify) {
            emit("state-change", { state, source });
          }
        };

        if (modelPreset && !localStorage.getItem(modelKey)) {
          localStorage.setItem(modelKey, modelPreset);
          emit("model-change", { modelId: modelPreset, source: "orb-init" });
        }

        setState(defaultState, true, "orb-init");

        const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

        const track = (clientX, clientY) => {
          const rect = node.getBoundingClientRect();
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const diffX = clamp((clientX - centerX) / 18, -5, 5);
          const diffY = clamp((clientY - centerY) / 18, -5, 5);
          const tiltX = clamp((clientY - centerY) / 64, -7, 7);
          const tiltY = clamp((centerX - clientX) / 64, -7, 7);

          node.style.setProperty("--eye-x", `${diffX}px`);
          node.style.setProperty("--eye-y", `${diffY}px`);
          node.style.setProperty("--tilt-x", `${tiltX}deg`);
          node.style.setProperty("--tilt-y", `${tiltY}deg`);

          eyes.forEach((eye) => {
            eye.style.transform = `translate(${diffX}px, ${diffY}px)`;
          });
        };

        const onMove = (event) => {
          track(event.clientX, event.clientY);
        };

        const spawnRipple = (x, y) => {
          const rect = node.getBoundingClientRect();
          const ripple = document.createElement("span");
          ripple.className = "orb-ripple";
          ripple.style.left = `${x - rect.left}px`;
          ripple.style.top = `${y - rect.top}px`;
          node.appendChild(ripple);
          window.setTimeout(() => ripple.remove(), 520);
        };

        window.addEventListener(`${eventNamespace}:state-change`, (event) => {
          if (!(event instanceof CustomEvent)) return;
          const state = String(event.detail?.state || "").trim();
          if (!state || state === node.dataset.state) return;
          setState(state, false, "external");
        });

        window.addEventListener(`${eventNamespace}:persona-change`, (event) => {
          if (!(event instanceof CustomEvent)) return;
          const nextDefault = String(event.detail?.defaultText || "").trim();
          const nextActive = String(event.detail?.activeText || "").trim();
          if (nextDefault) defaultText = nextDefault;
          if (nextActive) activeText = nextActive;
          const currentState = node.dataset.state || defaultState;
          setState(currentState, false, "external");
        });

        let speakTimer = 0;
        window.addEventListener(`${eventNamespace}:speak`, (event) => {
          if (!(event instanceof CustomEvent)) return;
          const text = String(event.detail?.text || "").trim();
          if (!(stateText instanceof HTMLElement) || !text) return;
          window.clearTimeout(speakTimer);
          stateText.textContent = text;
          node.classList.add("is-active");
          speakTimer = window.setTimeout(() => {
            node.classList.toggle("is-active", (node.dataset.state || defaultState) === "active");
            stateText.textContent = (node.dataset.state || defaultState) === "active" ? activeText : defaultText;
          }, 2200);
        });

        node.addEventListener("pointermove", onMove, { passive: true });
        window.addEventListener("pointermove", onMove, { passive: true });

        node.addEventListener("pointerenter", () => {
          setState(hoverState, true, "orb-hover");
        });

        node.addEventListener("pointerdown", (event) => {
          setState(clickState, true, "orb-click");
          emit("action", { actionId, source: "orb" });
          spawnRipple(event.clientX, event.clientY);
        });

        node.addEventListener("pointerleave", () => {
          setState(defaultState, true, "orb-leave");
        });
      }
    </script>
  )
}

<style>
  .jarvis-orb {
    --eye-x: 0px;
    --eye-y: 0px;
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    position: fixed;
    bottom: calc(var(--orb-offset-y) + env(safe-area-inset-bottom) + var(--floating-safe-bottom, 0px));
    width: 74px;
    height: 74px;
    z-index: 79;
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: var(--text);
    text-decoration: none;
    transform-style: preserve-3d;
    transform: perspective(220px) rotateX(var(--tilt-x)) rotateY(var(--tilt-y));
    transition: transform 120ms ease, filter 180ms ease;
    isolation: isolate;
  }

  .jarvis-orb.is-left {
    left: var(--orb-offset-x);
  }

  .jarvis-orb.is-right {
    right: var(--orb-offset-x);
  }

  .jarvis-orb:hover {
    filter: saturate(1.08);
  }

  .orb-shell {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    position: relative;
    border: 1px solid color-mix(in oklab, var(--brand) 48%, var(--line) 52%);
    background:
      radial-gradient(circle at 30% 24%, color-mix(in oklab, #fff 70%, transparent 30%), transparent 38%),
      radial-gradient(circle at 65% 74%, color-mix(in oklab, var(--accent) 30%, transparent 70%), transparent 54%),
      linear-gradient(160deg, color-mix(in oklab, var(--brand-soft) 72%, transparent 28%), color-mix(in oklab, var(--bg-elev) 84%, transparent 16%));
    backdrop-filter: blur(9px);
    box-shadow:
      0 14px 30px -16px color-mix(in oklab, var(--brand) 50%, transparent 50%),
      inset 0 1px 0 color-mix(in oklab, #fff 26%, transparent 74%);
    overflow: hidden;
  }

  .orb-ring {
    position: absolute;
    inset: 8px;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--brand) 42%, transparent 58%);
    animation: orb-spin 10s linear infinite;
    opacity: 0.84;
  }

  .orb-ring.ring-2 {
    inset: 16px;
    animation-duration: 6.8s;
    animation-direction: reverse;
    opacity: 0.62;
  }

  .orb-pulse {
    position: absolute;
    inset: 16px;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in oklab, var(--brand) 40%, transparent 60%), transparent 74%);
    animation: orb-pulse 2.2s ease-out infinite;
  }

  .orb-eyes {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
  }

  .orb-eye {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--brand) 56%, var(--line) 44%);
    background: color-mix(in oklab, var(--bg-elev) 88%, transparent 12%);
    display: grid;
    place-items: center;
  }

  .orb-eye i {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--brand);
    transition: transform 100ms linear;
  }

  .orb-label,
  .orb-state {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    pointer-events: none;
  }

  .orb-label {
    bottom: -1.35rem;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: color-mix(in oklab, var(--text-soft) 74%, var(--brand) 26%);
  }

  .orb-state {
    bottom: -2.2rem;
    font-size: 0.56rem;
    letter-spacing: 0.02em;
    color: var(--text-muted);
  }

  .jarvis-orb.is-active .orb-state {
    color: var(--brand);
  }

  .orb-ripple {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--brand) 66%, transparent 34%);
    transform: translate(-50%, -50%);
    animation: orb-ripple 0.52s ease-out forwards;
    pointer-events: none;
  }

  @keyframes orb-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes orb-pulse {
    0% {
      transform: scale(0.84);
      opacity: 0.86;
    }
    100% {
      transform: scale(1.16);
      opacity: 0;
    }
  }

  @keyframes orb-ripple {
    0% {
      width: 8px;
      height: 8px;
      opacity: 0.84;
    }
    100% {
      width: 64px;
      height: 64px;
      opacity: 0;
    }
  }

  @media (max-width: 1024px) {
    .jarvis-orb {
      width: 64px;
      height: 64px;
    }

    .orb-label {
      font-size: 0.56rem;
      bottom: -1.1rem;
    }

    .orb-state {
      bottom: -1.85rem;
    }
  }
</style>
