---
import siteConfig from "@/site.config";
import Giscus from "@/components/Giscus.astro";

interface Props {
  deferUntilEvent?: string;
}

const { deferUntilEvent } = Astro.props;
const provider = siteConfig.comment.provider;
const giscus = siteConfig.comment.giscus;
const walineServer = siteConfig.comment.waline.serverUrl;
const utterances = (siteConfig.comment as { utterances?: Record<string, string> }).utterances ?? {};
const giscusReady =
  Boolean(giscus.repo && giscus.repo !== "owner/repo") &&
  Boolean(giscus.repoId) &&
  Boolean(giscus.categoryId);
const utterancesReady = Boolean(utterances.repo && utterances.repo !== "owner/repo");
const activeProvider = provider;
const commentsEnabled = activeProvider !== "off";
---

{
  !commentsEnabled ? null : (
    <section class="surface comment-section">
      <h3>评论</h3>
      {activeProvider === "giscus" && giscusReady && <Giscus deferUntilEvent={deferUntilEvent} />}
      {
        activeProvider === "waline" && (
          <>
            <div id="waline-root" data-defer={deferUntilEvent ?? ""}></div>
            {!walineServer && <p class="comment-hint">Waline 尚未配置 `PUBLIC_WALINE_SERVER`，请先配置服务地址。</p>}
          </>
        )
      }
      {activeProvider === "twikoo" && <div id="twikoo-root" data-defer={deferUntilEvent ?? ""}></div>}
      {activeProvider === "utterances" && utterancesReady && (
        <div id="utterances-root" data-defer={deferUntilEvent ?? ""}></div>
      )}
      {
        activeProvider === "utterances" && (
          <>
            {!utterancesReady && <p class="comment-hint">Utterances 尚未配置 `PUBLIC_UTTERANCES_REPO`，请先填写 GitHub 仓库。</p>}
          </>
        )
      }
      {provider === "giscus" && !giscusReady && (
        <p class="comment-hint">当前已选 Giscus，但缺少仓库/分类 ID 配置，评论区未启用。</p>
      )}
    </section>
  )
}

{
  activeProvider === "waline" && (
    <script type="module" define:vars={{ deferUntilEvent, serverUrl: walineServer }}>
      const mount = async () => {
        const root = document.getElementById("waline-root");
        if (!root || !serverUrl) return;
        const { init } = await import("https://unpkg.com/@waline/client@v3/dist/waline.js");
        init({
          el: "#waline-root",
          serverURL: serverUrl,
          dark: document.documentElement.dataset.theme === "aurora-dark"
        });
      };
      if (deferUntilEvent) {
        window.addEventListener(deferUntilEvent, () => mount().catch(console.error), { once: true });
      } else {
        mount().catch(console.error);
      }
    </script>
  )
}

{
  activeProvider === "twikoo" && (
    <script type="module" define:vars={{ deferUntilEvent, envId: siteConfig.comment.twikoo.envId }}>
      const mount = async () => {
        const root = document.getElementById("twikoo-root");
        if (!root || !envId) return;
        await import("https://cdn.staticfile.org/twikoo/1.6.43/twikoo.all.min.js");
        window.twikoo?.init({
          envId,
          el: "#twikoo-root"
        });
      };
      if (deferUntilEvent) {
        window.addEventListener(deferUntilEvent, () => mount().catch(console.error), { once: true });
      } else {
        mount().catch(console.error);
      }
    </script>
  )
}

{
  activeProvider === "utterances" && (
    <script
      type="module"
      define:vars={{
        deferUntilEvent,
        repo: String(utterances.repo ?? ""),
        issueTerm: String(utterances.issueTerm ?? "pathname"),
        label: String(utterances.label ?? "comment"),
        themeLight: String(utterances.themeLight ?? "github-light"),
        themeDark: String(utterances.themeDark ?? "github-dark")
      }}
    >
      const themeOfSite = () => {
        const theme = document.documentElement.dataset.theme || "";
        return theme.includes("dark") ? themeDark : themeLight;
      };

      const syncUtterancesTheme = () => {
        const frame = document.querySelector("iframe.utterances-frame");
        if (frame instanceof HTMLIFrameElement && frame.contentWindow) {
          frame.contentWindow.postMessage({ type: "set-theme", theme: themeOfSite() }, "https://utteranc.es");
        }
      };

      const mount = async () => {
        const root = document.getElementById("utterances-root");
        if (!root || !repo) return;

        root.innerHTML = "";
        const script = document.createElement("script");
        script.src = "https://utteranc.es/client.js";
        script.async = true;
        script.crossOrigin = "anonymous";
        script.setAttribute("repo", repo);
        script.setAttribute("issue-term", issueTerm || "pathname");
        script.setAttribute("label", label || "comment");
        script.setAttribute("theme", themeOfSite());
        root.appendChild(script);

        window.setTimeout(syncUtterancesTheme, 220);
      };

      if (deferUntilEvent) {
        window.addEventListener(deferUntilEvent, () => mount().catch(console.error), { once: true });
      } else {
        mount().catch(console.error);
      }

      document.addEventListener("theme:change", syncUtterancesTheme);
    </script>
  )
}

<style>
  .comment-section {
    margin-top: 0;
    padding: 1.5rem;
    border-radius: var(--radius-md);
  }
  .comment-section h3 {
    margin: 0 0 0.8rem;
  }
  .comment-hint {
    margin: 0.65rem 0 0;
    color: var(--text-soft);
    font-size: 0.82rem;
  }
</style>
