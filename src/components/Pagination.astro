---
import siteConfig from "@/site.config";
import { getPageWindow } from "@/utils/pagination";

interface Props {
  currentPage?: number;
  lastPage?: number;
  basePath?: string;
  mode?: "page" | "loadMore";
  targetSelector?: string;
  batchSize?: number;
}

const {
  currentPage = 1,
  lastPage = 1,
  basePath = "/blog",
  mode = siteConfig.blog.pagination.mode,
  targetSelector = "",
  batchSize = siteConfig.blog.pagination.pageSize
} = Astro.props;

const pageWindow = getPageWindow(currentPage, lastPage, siteConfig.blog.pagination.maxPageNumbers);
const jumpInputId = `pager-jump-${basePath.replace(/[^a-z0-9]+/gi, "-")}-${currentPage}-${lastPage}`;

function pageUrl(page: number) {
  if (page <= 1) return basePath;
  return `${basePath}/${page}`;
}
---

{
  mode === "page" && lastPage > 1 && (
    <nav class="surface pager-shell pager-nav" aria-label="分页导航">
      <a
        class={`pager-btn ${currentPage <= 1 ? "is-disabled" : ""}`}
        href={currentPage <= 1 ? "#" : pageUrl(currentPage - 1)}
        aria-disabled={currentPage <= 1 ? "true" : "false"}
      >
        上一页
      </a>
      <div class="pager-meta" aria-hidden="true">
        <strong>{currentPage}</strong>
        <span>/ {lastPage}</span>
      </div>
      <div class="pager-pages">
        {
          pageWindow.map((item) =>
            typeof item === "number" ? (
              <a
                href={pageUrl(item)}
                class={`pager-btn pager-btn-num ${item === currentPage ? "is-active" : ""}`}
                aria-current={item === currentPage ? "page" : undefined}
              >
                {item}
              </a>
            ) : (
              <span class="pager-ellipsis" aria-hidden="true">…</span>
            )
          )
        }
      </div>
      <a
        class={`pager-btn ${currentPage >= lastPage ? "is-disabled" : ""}`}
        href={currentPage >= lastPage ? "#" : pageUrl(currentPage + 1)}
        aria-disabled={currentPage >= lastPage ? "true" : "false"}
      >
        下一页
      </a>
      <form class="pager-jump" data-base-path={basePath} data-last-page={String(lastPage)}>
        <label class="pager-jump-label" for={jumpInputId}>跳至</label>
        <input
          id={jumpInputId}
          class="pager-jump-input"
          type="number"
          min="1"
          max={lastPage}
          value={currentPage}
          inputmode="numeric"
        />
        <button class="pager-btn pager-go" type="submit">前往</button>
      </form>
    </nav>
  )
}

{
  mode === "loadMore" && (
    <div class="load-more-wrap">
      <button id="list-load-more" class="surface load-more" data-target={targetSelector} data-batch-size={String(batchSize)}>
        加载更多
      </button>
    </div>
  )
}

{
  mode === "page" && lastPage > 1 && (
    <script is:inline>
      const buildPageUrl = (basePath, page) => {
        const nextPage = Math.max(1, Number.parseInt(String(page || "1"), 10) || 1);
        return nextPage <= 1 ? basePath : `${basePath}/${nextPage}`;
      };

      document.querySelectorAll(".pager-jump").forEach((form) => {
        if (!(form instanceof HTMLFormElement)) return;
        if (form.dataset.bound === "1") return;
        form.dataset.bound = "1";

        form.addEventListener("submit", (event) => {
          event.preventDefault();
          const input = form.querySelector(".pager-jump-input");
          if (!(input instanceof HTMLInputElement)) return;
          const basePath = String(form.dataset.basePath || "/blog").trim() || "/blog";
          const lastPage = Math.max(1, Number.parseInt(form.dataset.lastPage || "1", 10) || 1);
          const nextPage = Math.max(1, Math.min(lastPage, Number.parseInt(input.value || "1", 10) || 1));
          window.location.href = buildPageUrl(basePath, nextPage);
        });
      });
    </script>
  )
}

{
  mode === "loadMore" && (
    <script type="module">
      const button = document.getElementById("list-load-more");
      if (!(button instanceof HTMLButtonElement)) {
        // no-op
      } else {
        const selector = button.dataset.target || "";
        const batchSize = Number(button.dataset.batchSize || 6);
        const host = selector ? document.querySelector(selector) : null;
        const items = host ? Array.from(host.querySelectorAll("[data-page-item]")) : [];

        const update = () => {
          const hidden = items.filter((item) => item.hasAttribute("hidden"));
          button.hidden = hidden.length === 0;
          button.disabled = hidden.length === 0;
        };

        button.addEventListener("click", () => {
          let count = 0;
          for (const item of items) {
            if (!item.hasAttribute("hidden")) continue;
            item.removeAttribute("hidden");
            count += 1;
            if (count >= batchSize) break;
          }
          update();
        });

        update();
      }
    </script>
  )
}

<style>
  .pager-nav {
    margin-top: 1rem;
  }

  .load-more-wrap {
    margin-top: 1rem;
    display: flex;
    justify-content: center;
  }

  .load-more {
    cursor: pointer;
    border: 1px solid color-mix(in oklab, var(--line) 88%, transparent 12%);
    border-radius: 12px;
    padding: 0.64rem 1.08rem;
    color: var(--text-soft);
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--surface-1) 96%, transparent 4%),
        color-mix(in oklab, var(--surface-2) 94%, transparent 6%)
      );
  }

  .load-more:hover {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 40%, var(--line) 60%);
  }
</style>
