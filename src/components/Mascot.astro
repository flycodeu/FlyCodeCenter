---
import siteConfig from "@/site.config";

const enabled = siteConfig.features.assistant.mascot && siteConfig.mascot.provider !== "off";
---

{
  enabled && (
    <div
      id="site-mascot"
      class="site-mascot"
      data-draggable={siteConfig.mascot.draggable ? "1" : "0"}
      data-speed={String(siteConfig.mascot.speed)}
      data-position={siteConfig.mascot.position}
      data-model={siteConfig.mascot.modelUrl}
    >
      <img src={siteConfig.mascot.sprite} alt="mascot" loading="lazy" />
    </div>
  )
}

{
  enabled && (
    <script type="module">
      const node = document.getElementById("site-mascot");
      if (!(node instanceof HTMLElement)) {
        // no-op
      } else {
        const draggable = node.dataset.draggable === "1";
        const speed = Math.max(8, Number(node.dataset.speed || 24));
        const edge = 14;

        let x = node.dataset.position === "left" ? edge : Math.max(edge, window.innerWidth - 96);
        let y = Math.max(edge, window.innerHeight - 220);
        let dx = node.dataset.position === "left" ? 1 : -1;
        let dy = -1;
        let dragging = false;
        let offsetX = 0;
        let offsetY = 0;

        const apply = () => {
          node.style.transform = `translate(${x}px, ${y}px)`;
        };

        const tick = () => {
          if (!dragging) {
            x += dx * 0.35 * (speed / 24);
            y += dy * 0.28 * (speed / 24);

            const maxX = window.innerWidth - node.offsetWidth - edge;
            const maxY = window.innerHeight - node.offsetHeight - edge;

            if (x <= edge) {
              x = edge;
              dx = 1;
            } else if (x >= maxX) {
              x = maxX;
              dx = -1;
            }

            if (y <= edge) {
              y = edge;
              dy = 1;
            } else if (y >= maxY) {
              y = maxY;
              dy = -1;
            }
          }

          apply();
          window.requestAnimationFrame(tick);
        };

        const onPointerMove = (event) => {
          if (!dragging) return;
          x = event.clientX - offsetX;
          y = event.clientY - offsetY;
          apply();
        };

        const onPointerUp = () => {
          dragging = false;
          window.removeEventListener("pointermove", onPointerMove);
          window.removeEventListener("pointerup", onPointerUp);
        };

        if (draggable) {
          node.addEventListener("pointerdown", (event) => {
            dragging = true;
            offsetX = event.clientX - x;
            offsetY = event.clientY - y;
            window.addEventListener("pointermove", onPointerMove);
            window.addEventListener("pointerup", onPointerUp);
          });
        }

        window.addEventListener("resize", () => {
          x = Math.min(x, window.innerWidth - node.offsetWidth - edge);
          y = Math.min(y, window.innerHeight - node.offsetHeight - edge);
          apply();
        });

        apply();
        window.requestAnimationFrame(tick);
      }
    </script>
  )
}

<style>
  .site-mascot {
    position: fixed;
    left: 0;
    top: 0;
    width: 76px;
    height: 76px;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 82%, transparent 18%);
    backdrop-filter: blur(6px);
    box-shadow: 0 12px 26px color-mix(in oklab, var(--brand) 14%, transparent 86%);
    z-index: 42;
    cursor: grab;
    user-select: none;
    overflow: hidden;
  }
  .site-mascot:active {
    cursor: grabbing;
  }
  .site-mascot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 860px) {
    .site-mascot {
      display: none;
    }
  }
</style>
