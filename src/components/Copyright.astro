---
import siteConfig from "@/site.config";

interface Props {
  title: string;
  url: string;
  editUrl?: string;
}

const { title, url, editUrl } = Astro.props;
---

{
  siteConfig.copyright.enable && (
    <section class="copy-box" aria-label="版权信息">
      <div class="copy-header">
        <span class="copy-title">版权信息</span>
        {editUrl && (
          <a href={editUrl} target="_blank" rel="noreferrer" class="edit-link">
            在 GitHub 编辑
          </a>
        )}
      </div>

      <div class="copy-content">
        <div class="copy-item">
          <span class="label">作者</span>
          <span class="value">{siteConfig.copyright.author}</span>
        </div>

        {siteConfig.copyright.showLink && (
          <div class="copy-item">
            <span class="label">本文链接</span>
            <a id="article-permalink" href={url} class="value url-link">{url}</a>
          </div>
        )}

        <div class="copy-item">
          <span class="label">许可证</span>
          <span class="value">
            <a
              href="https://creativecommons.org/licenses/by/4.0/"
              target="_blank"
              rel="noreferrer"
              class="url-link"
            >
              CC-BY-4.0
            </a>
          </span>
        </div>
      </div>
    </section>
  )
}

<script is:inline>
  (() => {
    const anchor = document.getElementById("article-permalink");
    if (!(anchor instanceof HTMLAnchorElement)) return;
    const full = `${location.origin}${location.pathname}`;
    anchor.href = full;
    anchor.textContent = full;
  })();
</script>

<style>
  .copy-box {
    margin-top: 2rem;
    padding: 1rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .copy-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .copy-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }
  .edit-link {
    font-size: 0.86rem;
    color: var(--text-soft);
    text-decoration: none;
  }
  .edit-link:hover {
    color: var(--brand);
  }
  .copy-content {
    display: grid;
    gap: 0.55rem;
  }
  .copy-item {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-size: 0.92rem;
  }
  .label {
    color: var(--text-soft);
    min-width: 4.4rem;
  }
  .value {
    color: var(--text);
    word-break: break-all;
  }
  .url-link {
    color: var(--brand);
    text-decoration: none;
  }
  .url-link:hover {
    text-decoration: underline;
  }
</style>
