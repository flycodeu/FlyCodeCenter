---
import siteConfig from "@/site.config";

interface Props {
  title: string;
  url: string;
  editUrl?: string;
}

const { title, url, editUrl } = Astro.props;
---

{
  siteConfig.copyright.enable && (
    <section class="surface copy-box">
      <div class="copy-header">
        <span class="copy-title">版权所有</span>
        {editUrl && (
          <a href={editUrl} target="_blank" rel="noreferrer" class="edit-link">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            在 GitHub 上编辑此页
          </a>
        )}
      </div>
      <div class="copy-content">
        <div class="copy-item">
          <span class="label">版权归属：</span>
          <span class="value">{siteConfig.copyright.author}</span>
        </div>
        {siteConfig.copyright.showLink && (
          <div class="copy-item">
            <span class="label">本文链接：</span>
            <a href={url} class="value url-link">{url}</a>
          </div>
        )}
        <div class="copy-item">
          <span class="label">许可证：</span>
          <span class="value">
            {siteConfig.copyright.license}，
            <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noreferrer" class="url-link">https://creativecommons.org/licenses/by/4.0/</a>
          </span>
        </div>
      </div>
    </section>
  )
}

<style>
  .copy-box {
    margin-top: 3rem;
    padding: 1.5rem;
    border-radius: 8px;
    background: color-mix(in oklab, var(--bg-elev) 60%, transparent 40%);
    border: 1px solid var(--line);
    border-left: 4px solid var(--brand);
    position: relative;
    overflow: hidden;
  }
  .copy-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px dashed var(--line);
  }
  .copy-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text);
  }
  .copy-content {
    display: grid;
    gap: 0.75rem;
  }
  .copy-item {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .label {
    color: var(--text-soft);
    font-weight: 500;
    min-width: 5rem;
  }
  .value {
    color: var(--text);
    flex: 1;
    word-break: break-all;
  }
  .url-link {
    color: var(--brand);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .url-link:hover {
    text-decoration: underline;
  }
  .edit-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-soft);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .edit-link:hover {
    color: var(--brand);
  }
</style>
