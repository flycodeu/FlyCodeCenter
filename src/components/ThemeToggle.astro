---
import siteConfig from "@/site.config";

const themes = siteConfig.theme.switchableThemes ?? siteConfig.theme.themes;
const storageKey = "flycode-theme";
const explicitKey = "flycode-theme-explicit";
const enableTransition = siteConfig.theme.transitions.theme;
---

<button class="theme-toggle" id="theme-toggle" aria-label="切换主题" data-themes={JSON.stringify(themes)}>
  <span class="theme-icon" id="theme-toggle-icon" aria-hidden="true">TH</span>
</button>

<script is:inline define:vars={{ storageKey, explicitKey, enableTransition }}>
  (() => {
    if (window.__flyThemeToggleBound) return;
    window.__flyThemeToggleBound = true;

    const root = document.documentElement;
    const icon = document.getElementById("theme-toggle-icon");

    const themeLight = "aurora-light";
    const themeDark = "aurora-dark";

    const readThemes = (button) => {
      try {
        const parsed = JSON.parse(button?.dataset.themes ?? "[]");
        if (Array.isArray(parsed)) {
          return parsed.filter((item) => typeof item === "string" && item.trim());
        }
      } catch {}
      return [];
    };

    const normalizeTheme = (themes, input) => {
      const fallback = root.dataset.defaultTheme || themes[0] || themeLight;
      const next = String(input ?? "").trim();
      if (themes.includes(next)) return next;
      if (themes.includes(fallback)) return fallback;
      return themes[0] || themeLight;
    };

    const syncToggleUi = (theme) => {
      const button = document.getElementById("theme-toggle");
      if (!(button instanceof HTMLElement)) return;
      if (icon instanceof HTMLElement) {
        icon.textContent = theme === themeDark ? "DK" : "LT";
      }
      const label = theme === themeDark ? "深色" : "浅色";
      button.setAttribute("aria-label", `切换主题，当前 ${label}`);
      button.title = `当前主题：${label}`;
    };

    const applyTheme = (theme) => {
      root.dataset.theme = theme;
      localStorage.setItem(storageKey, theme);
      localStorage.setItem(explicitKey, "1");
      syncToggleUi(theme);
      window.dispatchEvent(new CustomEvent("site:theme-change", { detail: theme }));
    };

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const button = target.closest("#theme-toggle");
      if (!(button instanceof HTMLElement)) return;

      const themes = readThemes(button);
      if (!themes.length) return;

      if (enableTransition) {
        root.classList.add("theme-anim");
        window.setTimeout(() => root.classList.remove("theme-anim"), 280);
      }

      const current = normalizeTheme(themes, root.dataset.theme);
      const next = current === themeDark ? themeLight : themeDark;
      applyTheme(next);
    });

    document.addEventListener("astro:page-load", () => {
      syncToggleUi(root.dataset.theme || root.dataset.defaultTheme || themeLight);
    });

    syncToggleUi(root.dataset.theme || root.dataset.defaultTheme || themeLight);
  })();
</script>

<style>
  .theme-toggle {
    border: 1px solid var(--line);
    color: var(--text);
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: color-mix(in oklab, var(--bg-elev) 86%, transparent 14%);
    cursor: pointer;
    display: inline-grid;
    place-items: center;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .theme-toggle:hover {
    border-color: color-mix(in oklab, var(--brand) 46%, var(--line) 54%);
    color: var(--brand);
    transform: translateY(-1px);
  }

  .theme-icon {
    font-size: 0.92rem;
    line-height: 1;
    font-weight: 700;
  }
</style>

