---
import siteConfig from "@/site.config";

const themes = siteConfig.theme.themes;
const storageKey = "flycode-theme";
const explicitKey = "flycode-theme-explicit";
const enableTransition = siteConfig.theme.transitions.theme;
---

<button class="theme-toggle" id="theme-toggle" aria-label="切换主题" data-themes={JSON.stringify(themes)}>
  <span class="theme-icon" aria-hidden="true">☼</span>
</button>

<script type="module" define:vars={{ storageKey, explicitKey, enableTransition }}>
  const button = document.getElementById("theme-toggle");
  const root = document.documentElement;

  const parsed = JSON.parse(button?.dataset.themes ?? "[]");
  const themes = Array.isArray(parsed)
    ? parsed.filter((item) => typeof item === "string" && item.trim())
    : [];
  const fallback = root.dataset.defaultTheme ?? themes[0] ?? "plume";
  const normalizeTheme = (value) => {
    const next = String(value ?? "").trim();
    if (themes.includes(next)) return next;
    return themes.includes(fallback) ? fallback : themes[0] ?? "plume";
  };

  const current = normalizeTheme(root.dataset.theme);
  if (current) {
    root.dataset.theme = current;
    localStorage.setItem(storageKey, current);
  }

  button?.addEventListener("click", () => {
    if (!themes.length) return;
    if (enableTransition) {
      root.classList.add("theme-anim");
      window.setTimeout(() => root.classList.remove("theme-anim"), 280);
    }
    const now = normalizeTheme(root.dataset.theme);
    const idx = themes.indexOf(now);
    const next = themes[(idx + 1) % themes.length];
    const safeNext = normalizeTheme(next);
    root.dataset.theme = safeNext;
    localStorage.setItem(storageKey, safeNext);
    localStorage.setItem(explicitKey, "1");
    window.dispatchEvent(new CustomEvent("site:theme-change", { detail: safeNext }));
  });
</script>

<style>
  .theme-toggle {
    border: 1px solid var(--line);
    color: var(--text);
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--bg-elev);
    cursor: pointer;
  }
  .theme-icon {
    font-size: 0.95rem;
  }
</style>
