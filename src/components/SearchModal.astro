---
import siteConfig from "@/site.config";

const enabled = siteConfig.search.provider !== "off";
const pagefindEnableInDev =
  (siteConfig.search as { pagefind?: { enableInDev?: boolean } }).pagefind?.enableInDev ?? false;
const pagefindEnabled = siteConfig.search.provider === "pagefind" && (!import.meta.env.DEV || pagefindEnableInDev);
---

{
  enabled && (
    <div
      id="search-root"
      class="search-root"
      data-native={siteConfig.search.ui.useNativeDialog ? "1" : "0"}
      data-shortcut={siteConfig.search.ui.openShortcut}
      data-provider={siteConfig.search.provider}
      data-runtime-fallback={(siteConfig.search as { runtimeFallback?: string }).runtimeFallback ?? "off"}
      data-index-path={siteConfig.search.minisearch.indexPath}
      data-pagefind-path={siteConfig.search.pagefind.bundlePath}
      data-pagefind-enabled={pagefindEnabled ? "1" : "0"}
      data-top-k={String(siteConfig.search.topK)}
      data-group-by-domain={siteConfig.search.ui.groupByDomain ? "1" : "0"}
    >
      <dialog id="search-modal" class="search-modal">
        <div class="search-panel surface" role="dialog" aria-modal="true" aria-label="站内搜索">
          <header class="search-head">
            <h2>站内搜索</h2>
            <p>输入关键词，支持标题/正文/标签匹配与高亮预览。</p>
          </header>

          <label class="search-input-wrap" for="search-input">
            <span class="search-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="16" height="16">
                <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-4.35-4.35m0 0a8 8 0 1 0-11.31-11.31a8 8 0 0 0 11.31 11.31Z" />
              </svg>
            </span>
            <span class="sr-only">站内搜索</span>
            <input id="search-input" type="search" placeholder="搜索文章、教程、收藏..." autocomplete="off" />
          </label>

          <ul id="search-results" class="search-results"></ul>

          <div class="search-footer">
            <span id="search-count" class="search-count">0 条结果</span>
            <span class="search-shortcut"><span class="kbd-key">↑</span><span class="kbd-key">↓</span> 选择</span>
            <span class="search-shortcut"><span class="kbd-key">ENTER</span> 打开</span>
            <span class="search-shortcut"><span class="kbd-key">ESC</span> 关闭</span>
          </div>
        </div>
      </dialog>

      <div id="search-fallback" class="search-fallback" hidden>
        <div class="search-panel surface" role="dialog" aria-modal="true" aria-label="站内搜索">
          <header class="search-head">
            <h2>站内搜索</h2>
            <p>输入关键词，支持标题/正文/标签匹配与高亮预览。</p>
          </header>

          <label class="search-input-wrap" for="search-input-fallback">
            <span class="search-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="16" height="16">
                <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-4.35-4.35m0 0a8 8 0 1 0-11.31-11.31a8 8 0 0 0 11.31 11.31Z" />
              </svg>
            </span>
            <span class="sr-only">站内搜索</span>
            <input id="search-input-fallback" type="search" placeholder="搜索文章、教程、收藏..." autocomplete="off" />
          </label>

          <ul id="search-results-fallback" class="search-results"></ul>

          <div class="search-footer">
            <span id="search-count-fallback" class="search-count">0 条结果</span>
            <span class="search-shortcut"><span class="kbd-key">↑</span><span class="kbd-key">↓</span> 选择</span>
            <span class="search-shortcut"><span class="kbd-key">ENTER</span> 打开</span>
            <span class="search-shortcut"><span class="kbd-key">ESC</span> 关闭</span>
          </div>
        </div>
      </div>
    </div>
  )
}

<script type="module" src="/scripts/search-modal.js"></script>

<style>
  .search-modal {
    width: min(860px, calc(100vw - 22px));
    border: 0;
    background: transparent;
    padding: 0;
  }
  .search-modal::backdrop {
    background: rgba(8, 10, 18, 0.55);
    backdrop-filter: blur(7px);
  }
  .search-fallback {
    position: fixed;
    inset: 0;
    z-index: 70;
    background: rgba(8, 10, 18, 0.55);
    backdrop-filter: blur(7px);
    padding: 6vh 12px 12px;
    display: none;
  }
  .search-fallback.open {
    display: block;
  }
  .search-panel {
    padding: 1rem 1rem 0.75rem;
    border-radius: 20px;
    box-shadow: 0 24px 56px -20px rgba(0, 0, 0, 0.45);
    border: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    background:
      radial-gradient(780px 220px at -10% -30%, color-mix(in oklab, var(--brand-soft) 66%, transparent 34%), transparent 72%),
      radial-gradient(540px 200px at 110% 0%, color-mix(in oklab, var(--accent) 20%, transparent 80%), transparent 74%),
      var(--bg-elev);
  }
  .search-head {
    display: grid;
    gap: 0.25rem;
    padding: 0.2rem 0.15rem 0;
  }
  .search-head h2 {
    margin: 0;
    font-size: 1.08rem;
    font-family: var(--font-sans);
    letter-spacing: 0.01em;
  }
  .search-head p {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-soft);
  }
  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.36rem 0.5rem 0.36rem 0.65rem;
    background: color-mix(in oklab, var(--bg) 90%, transparent 10%);
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }
  .search-input-wrap:focus-within {
    border-color: color-mix(in oklab, var(--brand) 58%, var(--line) 42%);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--brand-soft) 50%, transparent 50%);
  }
  .search-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-soft);
    transform: translateY(-1px);
  }
  .search-input-wrap input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text);
    padding: 0.46rem 0.55rem;
    font-size: 1rem;
    outline: none;
  }
  .search-input-wrap input::placeholder {
    color: color-mix(in oklab, var(--text-soft) 60%, transparent 40%);
  }
  .search-results {
    max-height: min(60vh, 520px);
    overflow: auto;
    list-style: none;
    margin: 0;
    padding: 0 0.05rem;
    display: grid;
    gap: 0.5rem;
  }
  .result-group-title {
    margin: 0.4rem 0 0.2rem;
    padding: 0.24rem 0.45rem;
    font-size: 0.76rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--text-soft);
    border-top: 1px dashed var(--line);
  }
  .result-item {
    border-radius: 12px;
    border: 1px solid color-mix(in oklab, var(--line) 82%, transparent 18%);
    background: color-mix(in oklab, var(--bg-elev) 96%, transparent 4%);
    transition: border-color 140ms ease, box-shadow 140ms ease, transform 140ms ease;
  }
  .result-item a {
    display: grid;
    gap: 0.34rem;
    padding: 0.76rem 0.86rem;
    text-decoration: none;
    color: inherit;
  }
  .result-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .result-rank {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.02rem 0.34rem;
    font-size: 0.68rem;
    color: var(--text-soft);
    background: color-mix(in oklab, var(--bg) 90%, transparent 10%);
  }
  .result-item .result-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: var(--text-soft);
    min-width: 0;
  }
  .result-item .result-domain {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.06rem 0.42rem;
    background: color-mix(in oklab, var(--bg) 92%, transparent 8%);
    white-space: nowrap;
  }
  .result-path {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .result-divider {
    height: 1px;
    background: color-mix(in oklab, var(--line) 85%, transparent 15%);
  }
  .result-item h4 {
    margin: 0;
    font-size: 0.97rem;
    font-weight: 600;
    color: var(--text);
  }
  .result-snippet {
    margin: 0.05rem 0 0;
    color: var(--text-soft);
    font-size: 0.82rem;
    line-height: 1.44;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .result-item :global(mark) {
    background: color-mix(in oklab, var(--brand) 24%, #ffd76c 24%);
    color: color-mix(in oklab, var(--text) 74%, var(--brand) 26%);
    border-radius: 3px;
    padding: 0 3px;
    font-weight: 600;
  }
  .result-item.active {
    transform: translateY(-1px);
    background: color-mix(in oklab, var(--brand-soft) 54%, transparent 46%);
    border-color: color-mix(in oklab, var(--brand) 30%, var(--line) 70%);
    box-shadow: 0 12px 22px -16px color-mix(in oklab, var(--brand) 20%, transparent 80%);
  }
  .result-item.active h4 {
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
  }
  .result-empty {
    list-style: none;
    color: var(--text-soft);
    padding: 2rem 0.8rem;
    text-align: center;
    font-size: 0.9rem;
  }
  .search-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.9rem;
    padding-top: 0.68rem;
    border-top: 1px solid var(--line);
    margin-top: 0.3rem;
    flex-wrap: wrap;
  }
  .search-count {
    margin-right: auto;
    font-size: 0.76rem;
    color: var(--text-soft);
  }
  .search-shortcut {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--text-soft);
  }
  .kbd-key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 19px;
    height: 19px;
    padding: 0 0.25rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    box-shadow: 0 1px 1px rgba(0, 0, 0, 0.05);
  }

  @media (max-width: 760px) {
    .search-panel {
      padding: 0.8rem 0.7rem 0.62rem;
      border-radius: 14px;
    }
    .search-results {
      max-height: 56vh;
    }
  }
</style>
