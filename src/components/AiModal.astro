---
import siteConfig from "@/site.config";

const aiUiConfig = {
  models: siteConfig.ai.models ?? [],
  defaultModel: siteConfig.ai.defaultModel ?? siteConfig.ai.openaiCompatible.model,
  promptTemplates: siteConfig.ai.promptTemplates ?? []
};
---

<dialog
  id="ai-modal"
  class="ai-modal"
  data-shortcut={siteConfig.ai.triggerShortcut}
  data-connection-mode={siteConfig.ai.connectionMode}
  data-default-base={siteConfig.ai.openaiCompatible.apiBaseUrl}
  data-default-model={siteConfig.ai.openaiCompatible.model}
>
  <section id="ai-shell" class="ai-shell" role="dialog" aria-modal="true" aria-label="AI 聊天面板">
    <aside class="ai-sidebar">
      <header class="ai-sidebar-head">
        <h3>对话</h3>
        <button id="ai-new-session" type="button">新建</button>
      </header>
      <ul id="ai-session-list" class="ai-session-list"></ul>
      <footer class="ai-sidebar-foot">
        <button id="ai-open-settings" type="button" class="settings-btn">设置</button>
      </footer>
    </aside>

    <main class="ai-main">
      <header class="ai-main-head">
        <div class="title-wrap">
          <h3 id="ai-active-title">新会话</h3>
          <small id="ai-active-role">默认助手</small>
        </div>
        <button id="ai-close" type="button" class="close-btn" aria-label="关闭">关闭</button>
      </header>

      <div id="ai-chat-stream" class="ai-chat-stream" aria-live="polite"></div>

      <form id="ai-chat-form" class="ai-composer">
        <div class="ai-composer-inner">
          <textarea id="ai-chat-input" rows="2" placeholder="发消息给 AI（Enter 发送，Shift+Enter 换行）"></textarea>
          <button id="ai-chat-send" type="submit" class="send-btn">发送</button>
        </div>
      </form>
    </main>

    <section id="ai-settings-panel" class="ai-settings-panel" hidden>
      <header class="settings-head">
        <h4>模型与角色设置</h4>
        <button id="ai-close-settings" type="button" class="ghost-btn">关闭</button>
      </header>

      <div class="setting-group">
        <label for="ai-provider-select">Provider 预设</label>
        <select id="ai-provider-select">
          <option value="openai">OpenAI</option>
          <option value="claude">Claude</option>
          <option value="gemini">Gemini</option>
          <option value="custom">Custom</option>
        </select>
      </div>

      <div class="setting-group">
        <label for="ai-base-input">API Base</label>
        <input id="ai-base-input" type="url" placeholder="https://api.openai.com/v1" />
      </div>

      <div class="setting-group">
        <label for="ai-model-input">Model</label>
        <input id="ai-model-input" type="text" placeholder="gpt-4o-mini" />
      </div>

      <div class="setting-group">
        <label for="ai-key-input">API Key（加密存储）</label>
        <input id="ai-key-input" type="password" placeholder="sk-..." />
      </div>

      <div class="setting-group">
        <label for="ai-master-pass">主密码（用于加密/解锁）</label>
        <input id="ai-master-pass" type="password" placeholder="至少 8 位" />
      </div>

      <div class="setting-actions">
        <button id="ai-unlock-key" type="button" class="ghost-btn">解锁密钥</button>
        <button id="ai-clear-key" type="button" class="ghost-btn danger">清除密钥</button>
        <button id="ai-save-settings" type="button" class="primary-btn">保存配置</button>
      </div>

      <div class="setting-divider"></div>

      <div class="setting-group">
        <label for="ai-role-select">角色</label>
        <select id="ai-role-select"></select>
      </div>

      <div class="setting-group">
        <label for="ai-role-name">角色名称</label>
        <input id="ai-role-name" type="text" placeholder="例如：前端评审官" />
      </div>

      <div class="setting-group">
        <label for="ai-role-prompt">系统提示词</label>
        <textarea id="ai-role-prompt" rows="5" placeholder="定义该角色的行为边界与输出风格"></textarea>
      </div>

      <div class="setting-actions">
        <button id="ai-new-role" type="button" class="ghost-btn">新角色</button>
        <button id="ai-save-role" type="button" class="primary-btn">保存角色</button>
        <button id="ai-delete-role" type="button" class="ghost-btn danger">删除角色</button>
      </div>

      <p id="ai-settings-status" class="settings-status" aria-live="polite"></p>
    </section>
  </section>
</dialog>

<script is:inline define:vars={{ aiUiConfig }}>
  window.__siteAiUiConfig = aiUiConfig;
</script>
<script is:inline src="/scripts/ai-modal.js"></script>

<style>
  .ai-modal {
    width: 100vw;
    max-width: 100vw;
    height: 100vh;
    max-height: 100vh;
    border: 0;
    background: transparent;
    padding: 0;
    margin: 0;
  }

  .ai-modal::backdrop {
    background: rgba(8, 11, 18, 0.72);
    backdrop-filter: blur(12px);
  }

  .ai-shell {
    width: min(1400px, calc(100vw - 24px));
    height: calc(100vh - 24px);
    margin: 12px auto;
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 286px minmax(0, 1fr);
    background: color-mix(in oklab, var(--bg) 94%, #0b1118 6%);
    box-shadow: 0 34px 70px rgba(0, 0, 0, 0.4);
    position: relative;
  }

  .ai-sidebar {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    gap: 0.72rem;
    min-height: 0;
    padding: 0.9rem 0.74rem 0.74rem;
    border-right: 1px solid var(--line);
    background:
      radial-gradient(circle at 16% 14%, color-mix(in oklab, var(--brand-soft) 50%, transparent 50%), transparent 52%),
      color-mix(in oklab, var(--bg-elev) 96%, var(--bg) 4%);
  }

  .ai-sidebar-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .ai-sidebar-head h3 {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 650;
    letter-spacing: 0.02em;
  }

  .ai-sidebar-head button,
  .settings-btn {
    border: 1px solid var(--line);
    border-radius: 9px;
    background: color-mix(in oklab, var(--bg) 90%, var(--bg-elev) 10%);
    color: var(--text);
    cursor: pointer;
    padding: 0.32rem 0.6rem;
    font-size: 0.75rem;
  }

  .settings-btn {
    width: 100%;
    text-align: center;
  }

  .ai-session-list {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow: auto;
    display: grid;
    align-content: start;
    gap: 0.4rem;
  }

  .session-card {
    width: 100%;
    border: 1px solid color-mix(in oklab, var(--line) 88%, transparent 12%);
    border-radius: 10px;
    background: color-mix(in oklab, var(--bg) 93%, transparent 7%);
    color: var(--text);
    cursor: pointer;
    padding: 0.56rem 0.62rem;
    display: grid;
    gap: 0.2rem;
  }

  .session-card:hover {
    border-color: color-mix(in oklab, var(--line) 68%, var(--brand) 32%);
    background: color-mix(in oklab, var(--bg) 94%, var(--brand-soft) 6%);
  }

  .session-card.active {
    border-color: color-mix(in oklab, var(--line) 58%, var(--brand) 42%);
    background: color-mix(in oklab, var(--brand-soft) 42%, var(--bg) 58%);
  }

  .session-card:focus-visible {
    outline: 2px solid color-mix(in oklab, var(--brand) 52%, transparent 48%);
    outline-offset: 2px;
  }

  .session-card .title {
    font-size: 0.82rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .session-card .meta {
    font-size: 0.7rem;
    color: var(--text-soft);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ai-main {
    min-height: 0;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    background:
      radial-gradient(circle at 68% 8%, color-mix(in oklab, var(--brand-soft) 32%, transparent 68%), transparent 62%),
      var(--bg);
  }

  .ai-main-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    border-bottom: 1px solid var(--line);
    padding: 0.84rem 1rem;
    background: color-mix(in oklab, var(--bg-elev) 95%, var(--bg) 5%);
  }

  .title-wrap h3 {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 630;
  }

  .title-wrap small {
    display: inline-block;
    margin-top: 0.2rem;
    color: var(--text-soft);
    font-size: 0.75rem;
  }

  .close-btn,
  .ghost-btn,
  .primary-btn {
    border-radius: 9px;
    cursor: pointer;
    padding: 0.3rem 0.62rem;
    font-size: 0.75rem;
  }

  .close-btn,
  .ghost-btn {
    border: 1px solid var(--line);
    background: var(--bg);
    color: var(--text-soft);
  }

  .primary-btn {
    border: 1px solid color-mix(in oklab, var(--brand) 72%, #000 28%);
    background: color-mix(in oklab, var(--brand) 84%, #000 16%);
    color: #fff;
  }

  .ghost-btn.danger {
    color: #ef4444;
  }

  .ai-chat-stream {
    min-height: 0;
    overflow: auto;
    padding: 1.1rem clamp(0.9rem, 4vw, 2.5rem);
    display: grid;
    align-content: start;
    gap: 0.86rem;
  }

  .message-row {
    width: min(920px, 100%);
    display: flex;
    align-items: flex-start;
    gap: 0.56rem;
  }

  .message-row.assistant {
    margin-right: auto;
  }

  .message-row.user {
    margin-left: auto;
    justify-content: flex-end;
  }

  .avatar {
    width: 30px;
    height: 30px;
    border-radius: 999px;
    flex: 0 0 30px;
    border: 1px solid color-mix(in oklab, var(--line) 80%, transparent 20%);
    background: color-mix(in oklab, var(--brand-soft) 62%, var(--bg) 38%);
    display: grid;
    place-items: center;
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
    font-size: 0.67rem;
    font-weight: 700;
  }

  .bubble {
    max-width: min(820px, calc(100vw - 140px));
    border-radius: 16px;
    padding: 0.72rem 0.85rem;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 96%, transparent 4%);
  }

  .message-row.user .bubble {
    border-color: color-mix(in oklab, var(--brand) 34%, var(--line) 66%);
    background: color-mix(in oklab, var(--brand-soft) 44%, var(--bg) 56%);
  }

  .bubble .role {
    display: block;
    margin-bottom: 0.3rem;
    font-size: 0.68rem;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .bubble .msg-content {
    line-height: 1.62;
    font-size: 0.92rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .ai-composer {
    border-top: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 96%, var(--bg) 4%);
    padding: 0.88rem clamp(0.8rem, 3vw, 1.3rem) 1.05rem;
  }

  .ai-composer-inner {
    width: min(900px, 100%);
    margin: 0 auto;
    border: 1px solid color-mix(in oklab, var(--line) 84%, transparent 16%);
    border-radius: 18px;
    padding: 0.62rem 0.7rem;
    background: color-mix(in oklab, var(--bg) 97%, var(--bg-elev) 3%);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 0.6rem;
  }

  .ai-composer-inner textarea {
    width: 100%;
    min-height: 62px;
    max-height: 220px;
    border: 0;
    outline: none;
    resize: none;
    background: transparent;
    color: var(--text);
    padding: 0.12rem 0.2rem;
    font-size: 0.96rem;
    line-height: 1.5;
  }

  .send-btn {
    height: 36px;
    min-width: 68px;
    border: 1px solid color-mix(in oklab, var(--brand) 74%, #000 26%);
    border-radius: 10px;
    background: color-mix(in oklab, var(--brand) 84%, #000 16%);
    color: #fff;
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0 0.75rem;
  }

  .send-btn:disabled {
    opacity: 0.58;
    cursor: not-allowed;
  }

  .ai-settings-panel {
    position: absolute;
    left: 300px;
    bottom: 12px;
    width: min(420px, calc(100vw - 40px));
    max-height: calc(100vh - 90px);
    overflow: auto;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: color-mix(in oklab, var(--bg) 96%, var(--bg-elev) 4%);
    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.32);
    z-index: 5;
    padding: 0.78rem;
    display: grid;
    align-content: start;
    gap: 0.62rem;
  }

  .settings-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.46rem;
    cursor: move;
    user-select: none;
  }

  .settings-head h4 {
    margin: 0;
    font-size: 0.88rem;
  }

  .setting-group {
    display: grid;
    gap: 0.28rem;
  }

  .setting-group label {
    font-size: 0.74rem;
    color: var(--text-soft);
  }

  .setting-group input,
  .setting-group select,
  .setting-group textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 9px;
    background: var(--bg-elev);
    color: var(--text);
    padding: 0.45rem 0.55rem;
    font-size: 0.8rem;
    outline: none;
  }

  .setting-group textarea {
    resize: vertical;
    min-height: 90px;
    line-height: 1.45;
  }

  .setting-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
  }

  .setting-divider {
    border-top: 1px dashed var(--line);
    margin-top: 0.1rem;
  }

  .settings-status {
    margin: 0;
    min-height: 1.3em;
    color: var(--text-soft);
    font-size: 0.74rem;
  }

  @media (max-width: 980px) {
    .ai-shell {
      grid-template-columns: 220px minmax(0, 1fr);
    }

    .ai-settings-panel {
      left: 230px;
      width: min(420px, calc(100vw - 250px));
    }
  }

  @media (max-width: 760px) {
    .ai-modal {
      width: 100vw;
      height: 100vh;
    }

    .ai-shell {
      width: 100vw;
      height: 100vh;
      margin: 0;
      border-radius: 0;
      border: 0;
      grid-template-columns: 1fr;
      grid-template-rows: auto minmax(0, 1fr);
    }

    .ai-sidebar {
      border-right: 0;
      border-bottom: 1px solid var(--line);
      max-height: 172px;
      padding: 0.7rem 0.62rem;
      gap: 0.5rem;
    }

    .ai-chat-stream {
      padding: 0.82rem;
    }

    .bubble {
      max-width: calc(100vw - 110px);
    }

    .ai-composer {
      padding: 0.72rem 0.72rem 0.9rem;
    }

    .ai-settings-panel {
      left: 10px;
      right: 10px;
      bottom: 10px;
      width: auto;
      max-height: calc(100vh - 28px);
    }
  }
</style>
