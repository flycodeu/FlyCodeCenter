---
import siteConfig from "@/site.config";

const enabled = siteConfig.watermark.enable;
const marks = ["tl", "tr", "bl", "br"] as const;
---

{
  enabled && (
    <div
      class="watermark"
      style={`--wm-opacity:${siteConfig.watermark.opacity};--wm-rotate:${siteConfig.watermark.rotate}deg;--wm-gap:${siteConfig.watermark.gap}px;--wm-font-size:${siteConfig.watermark.fontSize};`}
      data-center-readable={siteConfig.watermark.keepCenterReadable ? "1" : "0"}
      aria-hidden="true"
    >
      {marks.map((pos) => <span class={`mark mark-${pos}`}>{siteConfig.watermark.text}</span>)}
    </div>
  )
}

<style>
  .watermark {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    opacity: var(--wm-opacity);
  }

  .watermark::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      transparent 0 calc(var(--wm-gap) - 1px),
      color-mix(in oklab, var(--text-soft) 18%, transparent 82%) calc(var(--wm-gap) - 1px) var(--wm-gap)
    );
  }

  .watermark[data-center-readable="1"]::before {
    mask-image: radial-gradient(circle at center, transparent 0 36%, black 56% 100%);
  }

  .mark {
    position: absolute;
    transform: rotate(var(--wm-rotate));
    font-size: var(--wm-font-size);
    color: color-mix(in oklab, var(--text-soft) 55%, transparent 45%);
    letter-spacing: 0.26rem;
    font-weight: 700;
    user-select: none;
    white-space: nowrap;
  }

  .mark-tl {
    top: 9%;
    left: 3.2%;
  }

  .mark-tr {
    top: 9%;
    right: 3.2%;
  }

  .mark-bl {
    bottom: 9%;
    left: 3.2%;
  }

  .mark-br {
    bottom: 9%;
    right: 3.2%;
  }

  @media (max-width: 900px) {
    .mark {
      font-size: clamp(1.2rem, 4vw, 2rem);
      letter-spacing: 0.2rem;
    }
  }
</style>
