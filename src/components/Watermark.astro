---
import siteConfig from "@/site.config";

interface Props {
  scope?: "global" | "hero";
}

const { scope = "global" } = Astro.props;
const enabled = siteConfig.watermark.enable;
const marks = ["tl", "tr", "bl", "br"] as const;
---

{
  enabled && (
    <div
      class={`watermark watermark-${scope}`}
      style={`--wm-opacity:${siteConfig.watermark.opacity};--wm-rotate:${siteConfig.watermark.rotate}deg;--wm-gap:${siteConfig.watermark.gap}px;--wm-font-size:${siteConfig.watermark.fontSize};`}
      data-center-readable={siteConfig.watermark.keepCenterReadable ? "1" : "0"}
      aria-hidden="true"
    >
      {marks.map((pos) => <span class={`mark mark-${pos}`}>{siteConfig.watermark.text}</span>)}
    </div>
  )
}

<style>
  .watermark {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: var(--wm-opacity);
    overflow: hidden;
  }

  .watermark-global {
    position: fixed;
    z-index: 5;
  }

  .watermark-hero {
    border-radius: inherit;
  }

  .watermark[data-center-readable="1"] {
    mask-image: radial-gradient(circle at center, transparent 0 42%, black 70% 100%);
  }

  .mark {
    position: absolute;
    transform: rotate(var(--wm-rotate));
    font-size: var(--wm-font-size);
    color: color-mix(in oklab, var(--text-soft) 36%, transparent 64%);
    letter-spacing: 0.22rem;
    font-weight: 620;
    user-select: none;
    white-space: nowrap;
  }

  .mark-tl {
    top: 9%;
    left: 3.2%;
  }

  .mark-tr {
    top: 9%;
    right: 3.2%;
  }

  .mark-bl {
    bottom: 9%;
    left: 3.2%;
  }

  .mark-br {
    bottom: 9%;
    right: 3.2%;
  }

  @media (max-width: 900px) {
    .mark {
      font-size: clamp(1.2rem, 4vw, 2rem);
      letter-spacing: 0.2rem;
    }
  }
</style>
