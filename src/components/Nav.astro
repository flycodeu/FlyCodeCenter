---
import siteConfig from "@/site.config";

const pathname = Astro.url.pathname;
const interviewConfig = siteConfig.pages.interviewCenter;
const interviewInsertAfter = String(interviewConfig.navInsertAfter || "/about").trim();
const navEntries: Array<
  | { kind: "item"; item: (typeof siteConfig.theme.navbar)[number] }
  | { kind: "interview" }
> = [];
let interviewInserted = false;

for (const item of siteConfig.theme.navbar) {
  navEntries.push({ kind: "item", item });
  const matchesInsertTarget =
    item.link === interviewInsertAfter || item.text === interviewInsertAfter || item.link === "/about";

  if (interviewConfig.enable && !interviewInserted && matchesInsertTarget) {
    navEntries.push({ kind: "interview" });
    interviewInserted = true;
  }
}

if (interviewConfig.enable && !interviewInserted) {
  navEntries.push({ kind: "interview" });
}
---

<nav class="nav">
  {
    navEntries.map((entry) => {
      if (entry.kind === "interview") {
        const active = pathname === interviewConfig.route || pathname.startsWith(`${interviewConfig.route}/`);
        return (
          <a class={`nav-link ${active ? "active" : ""}`} href={interviewConfig.route}>
            {interviewConfig.navLabel}
          </a>
        );
      }

      const active = pathname === entry.item.link || pathname.startsWith(`${entry.item.link}/`);
      return (
        <a class={`nav-link ${active ? "active" : ""}`} href={entry.item.link}>
          {entry.item.text}
        </a>
      );
    })
  }
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    gap: 0.18rem;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.08rem;
  }

  .nav::-webkit-scrollbar {
    display: none;
  }

  :global(.nav-link) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0.38rem 0.76rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-soft);
    white-space: nowrap;
    font-size: 0.82rem;
    font-weight: 520;
    letter-spacing: 0.01em;
    transition: color 180ms ease, background-color 180ms ease, border-color 180ms ease;
    flex: 0 0 auto;
  }

  :global(.nav-link:hover) {
    color: var(--text);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--surface-2) 86%, transparent 14%), color-mix(in oklab, var(--brand-soft) 14%, transparent 86%));
    border-color: color-mix(in oklab, var(--line-strong) 72%, transparent 28%);
    transform: none;
    box-shadow: none;
  }

  :global(.nav-link.active) {
    color: var(--text);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--surface-1) 90%, transparent 10%), color-mix(in oklab, var(--brand-soft) 18%, transparent 82%));
    border-color: color-mix(in oklab, var(--brand) 24%, var(--line) 76%);
    box-shadow: inset 0 1px 0 color-mix(in oklab, white 8%, transparent 92%);
  }

  @media (max-width: 900px) {
    .nav {
      width: 100%;
    }

    :global(.nav-link) {
      min-height: 40px;
      padding: 0.46rem 0.82rem;
    }
  }
</style>
