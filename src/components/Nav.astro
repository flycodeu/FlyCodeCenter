---
import siteConfig from "@/site.config";

const pathname = Astro.url.pathname;
---

<nav class="nav">
  {
    siteConfig.theme.navbar.map((item) => {
      const active = pathname === item.link || pathname.startsWith(`${item.link}/`);
      return (
        <a class={`nav-link ${active ? "active" : ""}`} href={item.link}>
          {item.text}
        </a>
      );
    })
  }
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    gap: 0.28rem;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x proximity;
    padding-bottom: 0.08rem;
  }
  .nav::-webkit-scrollbar {
    display: none;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0.42rem 0.66rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--line) 70%, transparent 30%);
    background: color-mix(in oklab, var(--bg-elev) 76%, transparent 24%);
    color: var(--text-soft);
    white-space: nowrap;
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    transition: color 180ms ease, background 180ms ease, border-color 180ms ease, transform 180ms ease;
    flex: 0 0 auto;
    scroll-snap-align: start;
  }
  .nav-link:hover {
    color: var(--text);
    background: color-mix(in oklab, var(--brand-soft) 72%, transparent 28%);
    border-color: color-mix(in oklab, var(--brand) 32%, var(--line) 68%);
    transform: translateY(-1px);
  }
  .nav-link.active {
    color: var(--brand);
    background:
      linear-gradient(120deg, color-mix(in oklab, var(--brand) 22%, transparent 78%), transparent),
      color-mix(in oklab, var(--brand-soft) 82%, transparent 18%);
    border-color: color-mix(in oklab, var(--brand) 52%, var(--line) 48%);
    box-shadow: 0 12px 28px -22px color-mix(in oklab, var(--brand) 62%, transparent 38%);
  }
  @media (max-width: 900px) {
    .nav {
      width: 100%;
    }
    .nav-link {
      min-height: 40px;
      padding: 0.54rem 0.88rem;
      border-color: color-mix(in oklab, var(--line) 72%, transparent 28%);
      background: color-mix(in oklab, var(--bg-elev) 90%, transparent 10%);
    }
  }
</style>
