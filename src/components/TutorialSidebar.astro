---
interface TutorialSidebarItem {
  id: string;
  slug: string;
  title: string;
  order: number;
  url: string;
}

interface Props {
  seriesKey: string;
  seriesLabel: string;
  currentSlug: string;
  items: TutorialSidebarItem[];
  width?: number;
  collapsible?: boolean;
  defaultCollapsed?: boolean;
  showOrder?: boolean;
  showProgress?: boolean;
  mobileDrawer?: boolean;
}

const {
  seriesKey,
  seriesLabel,
  currentSlug,
  items,
  width = 320,
  collapsible = true,
  defaultCollapsed = false,
  showOrder = true,
  showProgress = true,
  mobileDrawer = true
} = Astro.props;
---

<div
  class={`tutorial-sidebar-wrap ${defaultCollapsed ? "is-collapsed" : ""}`}
  style={`--tutorial-sidebar-width-base:${width}px;`}
  data-tutorial-sidebar-root
  data-series-key={seriesKey}
  data-current-slug={currentSlug}
  data-show-progress={showProgress ? "1" : "0"}
>
  <aside class="surface tutorial-sidebar desktop-rail" aria-label={`${seriesLabel} 章节导航`}>
    <header class="tutorial-sidebar-head">
      <h3>{seriesLabel}</h3>
      {
        collapsible && (
          <button class="tutorial-sidebar-toggle" type="button" data-sidebar-toggle aria-label="折叠章节导航">
            收起
          </button>
        )
      }
    </header>

    <div class="tutorial-sidebar-scroll" data-sidebar-scroll>
      <ol class="tutorial-sidebar-list" data-sidebar-list>
        {
          items.map((item) => (
            <li data-tutorial-item data-slug={item.slug}>
              <a href={item.url} class={item.slug === currentSlug ? "is-active" : ""}>
                {showOrder && <span class="order">{item.order}</span>}
                <span class="title">{item.title}</span>
                {showProgress && <span class="progress-mark" aria-hidden="true" />}
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </aside>

  {
    mobileDrawer && (
      <>
        <button class="tutorial-sidebar-mobile-open" type="button" data-sidebar-mobile-open aria-label="打开章节目录">
          章节
        </button>
        <div class="tutorial-sidebar-mobile-overlay" data-sidebar-mobile-overlay hidden></div>
        <aside class="surface tutorial-sidebar mobile-drawer" data-sidebar-mobile-panel hidden aria-label={`${seriesLabel} 章节导航`}>
          <header class="tutorial-sidebar-head">
            <h3>{seriesLabel}</h3>
            <button class="tutorial-sidebar-mobile-close" type="button" data-sidebar-mobile-close aria-label="关闭章节目录">
              关闭
            </button>
          </header>
          <div class="tutorial-sidebar-scroll" data-sidebar-scroll>
            <ol class="tutorial-sidebar-list" data-sidebar-list>
              {
                items.map((item) => (
                  <li data-tutorial-item data-slug={item.slug}>
                    <a href={item.url} class={item.slug === currentSlug ? "is-active" : ""}>
                      {showOrder && <span class="order">{item.order}</span>}
                      <span class="title">{item.title}</span>
                      {showProgress && <span class="progress-mark" aria-hidden="true" />}
                    </a>
                  </li>
                ))
              }
            </ol>
          </div>
        </aside>
      </>
    )
  }
</div>

<script type="module">
  const PROGRESS_KEY = "fly-tutorial-progress-v1";

  const readProgress = () => {
    try {
      const raw = localStorage.getItem(PROGRESS_KEY);
      if (!raw) return {};
      const parsed = JSON.parse(raw);
      if (!parsed || typeof parsed !== "object") return {};
      return parsed;
    } catch {
      return {};
    }
  };

  const writeProgress = (value) => {
    localStorage.setItem(PROGRESS_KEY, JSON.stringify(value));
  };

  const initSidebar = () => {
    document.querySelectorAll("[data-tutorial-sidebar-root]").forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.bound === "1") return;
      root.dataset.bound = "1";

      const seriesKey = String(root.dataset.seriesKey || "").trim();
      const currentSlug = String(root.dataset.currentSlug || "").trim();
      const showProgress = root.dataset.showProgress === "1";
      const toggleBtn = root.querySelector("[data-sidebar-toggle]");
      const openBtn = root.querySelector("[data-sidebar-mobile-open]");
      const closeBtn = root.querySelector("[data-sidebar-mobile-close]");
      const mobilePanel = root.querySelector("[data-sidebar-mobile-panel]");
      const mobileOverlay = root.querySelector("[data-sidebar-mobile-overlay]");
      const readerShell = root.closest(".tutorial-reader");

      const closeDrawer = () => {
        if (!(mobilePanel instanceof HTMLElement) || !(mobileOverlay instanceof HTMLElement)) return;
        mobilePanel.classList.remove("open");
        mobileOverlay.classList.remove("open");
        document.body.classList.remove("tutorial-sidebar-drawer-open");
        window.setTimeout(() => {
          mobilePanel.hidden = true;
          mobileOverlay.hidden = true;
        }, 180);
      };

      const openDrawer = () => {
        if (!(mobilePanel instanceof HTMLElement) || !(mobileOverlay instanceof HTMLElement)) return;
        mobilePanel.hidden = false;
        mobileOverlay.hidden = false;
        document.body.classList.add("tutorial-sidebar-drawer-open");
        requestAnimationFrame(() => {
          mobilePanel.classList.add("open");
          mobileOverlay.classList.add("open");
        });
      };

      const syncCollapsedState = () => {
        const isCollapsed = root.classList.contains("is-collapsed");
        readerShell?.classList.toggle("tutorial-reader-sidebar-collapsed", isCollapsed);
        if (toggleBtn instanceof HTMLButtonElement) {
          toggleBtn.textContent = isCollapsed ? "展开" : "收起";
          toggleBtn.setAttribute("aria-label", isCollapsed ? "展开章节导航" : "折叠章节导航");
        }
      };

      syncCollapsedState();

      toggleBtn?.addEventListener("click", () => {
        root.classList.toggle("is-collapsed");
        syncCollapsedState();
      });
      openBtn?.addEventListener("click", openDrawer);
      closeBtn?.addEventListener("click", closeDrawer);
      mobileOverlay?.addEventListener("click", closeDrawer);
      window.addEventListener("resize", () => {
        if (window.innerWidth > 1024) closeDrawer();
      });

      root.querySelectorAll("[data-sidebar-scroll]").forEach((scrollNode) => {
        if (!(scrollNode instanceof HTMLElement)) return;
        if (scrollNode.clientHeight < 2) return;
        const activeLink = scrollNode.querySelector("a.is-active");
        if (!(activeLink instanceof HTMLElement)) return;

        const activeRect = activeLink.getBoundingClientRect();
        const scrollRect = scrollNode.getBoundingClientRect();
        const activeTop = activeRect.top - scrollRect.top + scrollNode.scrollTop;
        const activeBottom = activeTop + activeLink.offsetHeight;
        const viewTop = scrollNode.scrollTop;
        const viewBottom = viewTop + scrollNode.clientHeight;

        if (activeTop >= viewTop && activeBottom <= viewBottom) return;
        const targetTop = Math.max(0, activeTop - (scrollNode.clientHeight - activeLink.offsetHeight) / 2);
        scrollNode.scrollTo({ top: targetTop, behavior: "auto" });
      });

      if (!showProgress || !seriesKey || !currentSlug) return;
      const state = readProgress();
      const series = Array.isArray(state[seriesKey]) ? state[seriesKey] : [];
      if (!series.includes(currentSlug)) {
        state[seriesKey] = [...series, currentSlug];
        writeProgress(state);
      }

      const visited = new Set(Array.isArray(state[seriesKey]) ? state[seriesKey] : []);
      root.querySelectorAll("[data-tutorial-item]").forEach((node) => {
        if (!(node instanceof HTMLElement)) return;
        const slug = String(node.dataset.slug || "").trim();
        node.classList.toggle("is-read", Boolean(slug && visited.has(slug)));
      });
    });
  };

  initSidebar();
  if (!window.__flyTutorialSidebarBound) {
    window.__flyTutorialSidebarBound = true;
    document.addEventListener("astro:page-load", initSidebar);
  }
</script>

<style>
  .tutorial-sidebar-wrap {
    --tutorial-sidebar-width-effective: var(--tutorial-sidebar-width, clamp(272px, var(--tutorial-sidebar-width-base, 300px), 280px));
    --tutorial-sidebar-collapsed-width: 68px;
    width: var(--tutorial-sidebar-width-effective);
    flex: 0 0 var(--tutorial-sidebar-width-effective);
    min-width: 0;
    position: sticky;
    top: calc(var(--layout-header-height, 68px) + 0.75rem);
    height: calc(
      100vh - var(--layout-header-height, 68px) - var(--layout-footer-height, 54px) - 1.5rem -
        var(--floating-safe-bottom, 0px)
    );
    align-self: flex-start;
    display: flex;
  }

  .tutorial-sidebar {
    width: 100%;
    min-width: 0;
    min-height: 0;
    border-radius: 24px;
    border: 1px solid color-mix(in oklab, var(--line) 74%, var(--brand) 26%);
    background:
      linear-gradient(120deg, color-mix(in oklab, var(--brand-soft) 22%, transparent 78%) 0, transparent 36%),
      linear-gradient(180deg, color-mix(in oklab, var(--surface-1) 95%, transparent 5%), color-mix(in oklab, var(--surface-2) 92%, transparent 8%));
    box-shadow: 0 24px 48px -40px rgb(15 23 42 / 0.32);
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: 0.8rem;
    padding: 1rem 0.96rem;
  }

  .desktop-rail {
    height: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .tutorial-sidebar-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.58rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid color-mix(in oklab, var(--line) 64%, transparent 36%);
  }

  .tutorial-sidebar-head h3 {
    margin: 0;
    min-width: 0;
    font-family: var(--font-display);
    font-size: 1.02rem;
    line-height: 1.28;
    overflow-wrap: anywhere;
    color: var(--text);
  }

  .tutorial-sidebar-toggle,
  .tutorial-sidebar-mobile-close,
  .tutorial-sidebar-mobile-open {
    border: 1px solid color-mix(in oklab, var(--line) 74%, transparent 26%);
    border-radius: var(--radius-pill);
    background: color-mix(in oklab, var(--bg-elev) 88%, transparent 12%);
    color: var(--text-soft);
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.72rem;
    cursor: pointer;
  }

  .tutorial-sidebar-toggle:hover,
  .tutorial-sidebar-mobile-close:hover,
  .tutorial-sidebar-mobile-open:hover {
    color: var(--text);
    border-color: color-mix(in oklab, var(--brand) 36%, var(--line) 64%);
  }

  .tutorial-sidebar-scroll {
    min-width: 0;
    min-height: 0;
    max-height: 100%;
    overflow: auto;
    overscroll-behavior: contain;
    scrollbar-gutter: stable both-edges;
    padding-right: 0.12rem;
  }

  .tutorial-sidebar-scroll::-webkit-scrollbar {
    width: 7px;
    height: 7px;
  }

  .tutorial-sidebar-scroll::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: color-mix(in oklab, var(--line-strong) 60%, transparent 40%);
  }

  .tutorial-sidebar-list {
    margin: 0;
    padding: 0;
    list-style: none;
    width: 100%;
    min-width: 100%;
    display: grid;
    align-content: start;
    grid-auto-rows: min-content;
    gap: 0.4rem;
  }

  .tutorial-sidebar-list li {
    min-width: 0;
  }

  .tutorial-sidebar-list a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    min-width: 0;
    align-items: center;
    gap: 0.48rem;
    text-decoration: none;
    color: var(--text-soft);
    border: 1px solid color-mix(in oklab, var(--line) 76%, transparent 24%);
    border-left: 3px solid transparent;
    border-radius: 18px;
    padding: 0.64rem 0.66rem;
    background: color-mix(in oklab, var(--surface-1) 74%, transparent 26%);
    transition: border-color 0.16s ease, background-color 0.16s ease, color 0.16s ease, transform 0.16s ease;
  }

  .tutorial-sidebar-list a:hover {
    color: var(--text);
    transform: translateY(-1px);
    border-color: color-mix(in oklab, var(--brand) 26%, var(--line) 74%);
    background: color-mix(in oklab, var(--brand-soft) 34%, transparent 66%);
  }

  .tutorial-sidebar-list a.is-active {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 42%, var(--line) 58%);
    border-left-color: color-mix(in oklab, var(--brand) 92%, #fff 8%);
    background: color-mix(in oklab, var(--brand-soft) 56%, transparent 44%);
    box-shadow: inset 0 1px 0 color-mix(in oklab, white 12%, transparent 88%);
  }

  .tutorial-sidebar-list .order {
    min-width: 1.3rem;
    text-align: center;
    font-size: 0.72rem;
    font-family: var(--font-tech);
    color: var(--text-muted);
  }

  .tutorial-sidebar-list .title {
    min-width: 0;
    font-size: 0.84rem;
    line-height: 1.46;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .progress-mark {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: transparent;
  }

  [data-tutorial-item].is-read .progress-mark {
    border-color: color-mix(in oklab, #16a34a 56%, var(--line) 44%);
    background: color-mix(in oklab, #16a34a 72%, transparent 28%);
  }

  .tutorial-sidebar-wrap.is-collapsed .tutorial-sidebar-scroll,
  .tutorial-sidebar-wrap.is-collapsed .tutorial-sidebar-head h3 {
    display: none;
  }

  .tutorial-sidebar-wrap.is-collapsed {
    flex-basis: var(--tutorial-sidebar-collapsed-width);
    width: var(--tutorial-sidebar-collapsed-width);
  }

  .tutorial-sidebar-wrap.is-collapsed .tutorial-sidebar {
    justify-items: center;
    padding-inline: 0.45rem;
  }

  .tutorial-sidebar-wrap.is-collapsed .tutorial-sidebar-head {
    justify-content: center;
  }

  .tutorial-sidebar-wrap.is-collapsed .tutorial-sidebar-toggle {
    writing-mode: vertical-rl;
    padding: 0.56rem 0.3rem;
  }

  .tutorial-sidebar-mobile-open,
  .tutorial-sidebar-mobile-overlay,
  .mobile-drawer {
    display: none;
  }

  @media (max-width: 1024px) {
    .tutorial-sidebar-wrap {
      width: 0;
      flex-basis: 0;
      position: static;
      top: auto;
      height: auto;
    }

    .desktop-rail {
      display: none;
    }

    .tutorial-sidebar-mobile-open {
      display: inline-flex;
      position: fixed;
      left: 1rem;
      bottom: calc(5rem + env(safe-area-inset-bottom) + var(--floating-safe-bottom, 0px));
      z-index: 78;
      box-shadow: 0 8px 24px color-mix(in oklab, var(--text) 12%, transparent 88%);
    }

    .tutorial-sidebar-mobile-overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(8, 10, 18, 0.45);
      backdrop-filter: blur(2px);
      z-index: 90;
      opacity: 0;
      transition: opacity 180ms ease;
    }

    .tutorial-sidebar-mobile-overlay.open {
      opacity: 1;
    }

    .mobile-drawer {
      display: grid;
      position: fixed;
      top: 0;
      left: 0;
      width: min(86vw, 340px);
      height: 100vh;
      z-index: 91;
      transform: translateX(-100%);
      transition: transform 180ms ease;
      border-radius: 0 22px 22px 0;
      padding: 0.82rem;
    }

    .mobile-drawer.open {
      transform: translateX(0);
    }

    .mobile-drawer .tutorial-sidebar-scroll {
      max-height: none;
      overflow: auto;
    }

    :global(body.tutorial-sidebar-drawer-open) {
      overflow: hidden;
    }
  }
</style>
