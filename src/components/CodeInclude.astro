---
import fs from "node:fs/promises";
import path from "node:path";

interface Props {
  file: string;
  lang?: string;
}

const SUPPORTED_LANGS = new Set([
  "ts",
  "tsx",
  "jsx",
  "javascript",
  "c",
  "cpp",
  "csharp",
  "java",
  "kotlin",
  "groovy",
  "python",
  "go",
  "sql",
  "json",
  "json5",
  "jsonc",
  "yaml",
  "toml",
  "ini",
  "properties",
  "dotenv",
  "bash",
  "powershell",
  "http",
  "diff",
  "dockerfile",
  "nginx",
  "makefile",
  "html",
  "xml",
  "markdown",
  "mermaid",
  "txt",
  "plaintext",
  "log"
]);

const ALIASES: Record<string, string> = {
  js: "javascript",
  ts: "ts",
  sh: "bash",
  shell: "bash",
  zsh: "bash",
  ps1: "powershell",
  ps: "powershell",
  bat: "powershell",
  cmd: "powershell",
  yml: "yaml",
  md: "markdown",
  vue: "html",
  vue3: "html",
  plain: "txt",
  text: "txt"
};

const normalizeLang = (value: string) => {
  const token = String(value || "")
    .trim()
    .toLowerCase()
    .split(/\s+/)[0];
  if (!token) return "txt";
  const normalized = ALIASES[token] ?? token;
  return SUPPORTED_LANGS.has(normalized) ? normalized : "txt";
};

const { file, lang = "text" } = Astro.props;
const normalizedLang = normalizeLang(lang);
const absolute = path.resolve(process.cwd(), file);
let content = "";
try {
  content = await fs.readFile(absolute, "utf8");
} catch (error) {
  content = `// include failed: ${file}`;
}
---

<pre class="code-include"><code class={`language-${normalizedLang}`}>{content}</code></pre>

<style>
  .code-include {
    border-radius: 12px;
    border: 1px solid var(--line);
    padding: 0.8rem;
    overflow: auto;
  }
</style>
