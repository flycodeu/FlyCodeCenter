---
import siteConfig from "@/site.config";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
}

const { headings = [] } = Astro.props;
const list = headings.filter(
  (item) =>
    item.depth >= siteConfig.theme.toc.minDepth &&
    item.depth <= siteConfig.theme.toc.maxDepth
);
---

{
  siteConfig.theme.toc.enable && list.length > 0 && (
    <aside class="surface toc">
      <h3>此页内容</h3>
      <ol id="toc-list">
        {list.map((item) => (
          <li data-depth={item.depth}>
            <a href={`#${item.slug}`}>{item.text}</a>
          </li>
        ))}
      </ol>
    </aside>
  )
}

{
  siteConfig.theme.toc.enable && list.length > 0 && (
    <script type="module">
      const root = document.getElementById("toc-list");
      if (!root) {
        // no-op
      } else {
        const links = new Map();
        root.querySelectorAll("a").forEach((a) => {
          const id = a.getAttribute("href")?.replace(/^#/, "");
          if (!id) return;
          links.set(id, a);
        });

        const setActive = (id) => {
          links.forEach((anchor, key) => {
            anchor.classList.toggle("active", key === id);
          });
        };

        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((item) => item.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
            if (!visible.length) return;
            setActive(visible[0].target.id);
          },
          {
            rootMargin: "-20% 0px -65% 0px",
            threshold: [0.1, 0.35, 0.7]
          }
        );

        links.forEach((_, id) => {
          const heading = document.getElementById(id);
          if (heading) observer.observe(heading);
        });
      }
    </script>
  )
}

<style>
  .toc {
    padding: 1rem 0;
    position: sticky;
    top: 84px;
    background: transparent;
    border: none;
    box-shadow: none;
  }
  .toc h3 {
    margin: 0 0 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }
  .toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--line);
    margin-left: 1rem;
  }
  .toc li {
    margin: 0;
  }
  .toc li[data-depth="3"] a {
    padding-left: 1.5rem;
  }
  .toc a {
    display: block;
    padding: 0.25rem 0 0.25rem 1rem;
    color: var(--text-soft);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.5;
    position: relative;
    left: -1px;
    border-left: 1px solid transparent;
  }
  .toc a:hover {
    color: var(--text);
  }
  .toc a.active {
    color: var(--brand);
    border-left-color: var(--brand);
    font-weight: 500;
  }
</style>
