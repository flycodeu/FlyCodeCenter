---
import siteConfig from "@/site.config";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface TocItem extends Heading {
  level: number;
}

interface Props {
  headings?: Heading[];
}

const { headings = [] } = Astro.props;
const filtered = headings.filter(
  (item) => item.depth >= siteConfig.theme.toc.minDepth && item.depth <= siteConfig.theme.toc.maxDepth
);
const baseDepth = filtered.length > 0 ? Math.min(...filtered.map((item) => item.depth)) : siteConfig.theme.toc.minDepth;

const list: TocItem[] = filtered.map((item) => {
  const level = Math.max(1, item.depth - baseDepth + 1);
  return {
    ...item,
    level
  };
});
---

{
  siteConfig.theme.toc.enable && list.length > 0 && (
    <>
      <div class="toc-desktop-wrap" aria-label="文章目录">
        <nav class="surface toc toc-desktop" aria-label="文章目录">
          <h3>本文目录</h3>
          <ol class="toc-list toc-list-desktop">
            {list.map((item) => (
              <li style={`--toc-level:${item.level}`}>
                <a href={`#${item.slug}`}>
                  <span class="toc-text">{item.text}</span>
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </div>

      <button id="toc-mobile-toggle" class="toc-mobile-toggle" type="button" aria-label="打开目录">
        目录
      </button>
      <div id="toc-mobile-overlay" class="toc-mobile-overlay" hidden></div>
      <aside id="toc-mobile-panel" class="toc-mobile-panel" hidden aria-label="文章目录">
        <nav class="surface toc toc-mobile">
          <header class="toc-mobile-head">
            <h3>本文目录</h3>
            <button id="toc-mobile-close" class="toc-mobile-close" type="button" aria-label="关闭目录">
              关闭
            </button>
          </header>
          <ol class="toc-list toc-list-mobile">
            {list.map((item) => (
              <li style={`--toc-level:${item.level}`}>
                <a href={`#${item.slug}`}>
                  <span class="toc-text">{item.text}</span>
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>
    </>
  )
}

{
  siteConfig.theme.toc.enable && list.length > 0 && (
    <script type="module">
      const cleanupKey = "__flyTocCleanup";

      const initToc = () => {
        if (typeof window[cleanupKey] === "function") {
          window[cleanupKey]();
        }

        const anchors = [...document.querySelectorAll(".toc-list a")].filter((item) => item instanceof HTMLAnchorElement);
        if (!anchors.length) return;

        const sections = [];
        const bucket = new Map();

        anchors.forEach((anchor) => {
          const id = anchor.getAttribute("href")?.replace(/^#/, "");
          if (!id) return;
          if (!bucket.has(id)) bucket.set(id, []);
          bucket.get(id).push(anchor);
        });

        bucket.forEach((group, id) => {
          const heading = document.getElementById(id);
          if (!heading) return;
          sections.push({ id, heading, links: group });
        });

        sections.sort((a, b) => a.heading.offsetTop - b.heading.offsetTop);
        if (!sections.length) return;

        const toggleBtn = document.getElementById("toc-mobile-toggle");
        const closeBtn = document.getElementById("toc-mobile-close");
        const overlay = document.getElementById("toc-mobile-overlay");
        const panel = document.getElementById("toc-mobile-panel");
        const desktopList = document.querySelector(".toc-list-desktop");
        const body = document.body;

        const openMobileToc = () => {
          if (!(panel instanceof HTMLElement) || !(overlay instanceof HTMLElement)) return;
          panel.hidden = false;
          overlay.hidden = false;
          body.classList.add("toc-drawer-open");
          requestAnimationFrame(() => {
            panel.classList.add("open");
            overlay.classList.add("open");
          });
        };

        const closeMobileToc = () => {
          if (!(panel instanceof HTMLElement) || !(overlay instanceof HTMLElement)) return;
          panel.classList.remove("open");
          overlay.classList.remove("open");
          body.classList.remove("toc-drawer-open");
          window.setTimeout(() => {
            panel.hidden = true;
            overlay.hidden = true;
          }, 180);
        };

        const onDesktopResize = () => {
          if (window.innerWidth > 1024) closeMobileToc();
        };

        toggleBtn?.addEventListener("click", openMobileToc);
        closeBtn?.addEventListener("click", closeMobileToc);
        overlay?.addEventListener("click", closeMobileToc);
        window.addEventListener("resize", onDesktopResize);

        let activeId = "";
        const activate = (id) => {
          if (!id || id === activeId) return;
          activeId = id;

          sections.forEach((item) => {
            const isActive = item.id === id;
            item.links.forEach((link) => link.classList.toggle("active", isActive));
          });

          if (desktopList instanceof HTMLElement) {
            const active = desktopList.querySelector("a.active");
            if (active instanceof HTMLElement) {
              active.scrollIntoView({ block: "nearest" });
            }
          }
        };

        let ticking = false;
        const updateActive = () => {
          const edge = 140;
          let current = sections[0];
          for (const section of sections) {
            const top = section.heading.getBoundingClientRect().top;
            if (top - edge <= 0) {
              current = section;
            } else {
              break;
            }
          }
          activate(current?.id || sections[0]?.id || "");
          ticking = false;
        };

        const queueUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateActive);
        };

        window.addEventListener("scroll", queueUpdate, { passive: true });
        window.addEventListener("resize", queueUpdate);
        window.addEventListener("hashchange", queueUpdate);
        window.addEventListener("site:decrypted", queueUpdate);

        document.querySelectorAll(".toc-list-mobile a").forEach((anchor) => {
          anchor.addEventListener("click", closeMobileToc);
        });

        queueUpdate();

        window[cleanupKey] = () => {
          toggleBtn?.removeEventListener("click", openMobileToc);
          closeBtn?.removeEventListener("click", closeMobileToc);
          overlay?.removeEventListener("click", closeMobileToc);
          window.removeEventListener("resize", onDesktopResize);
          window.removeEventListener("scroll", queueUpdate);
          window.removeEventListener("resize", queueUpdate);
          window.removeEventListener("hashchange", queueUpdate);
          window.removeEventListener("site:decrypted", queueUpdate);
        };
      };

      initToc();

      if (!window.__flyTocPageLoadBound) {
        window.__flyTocPageLoadBound = true;
        document.addEventListener("astro:page-load", () => {
          initToc();
        });
      }
    </script>
  )
}

<style>
  .toc {
    padding: 0.88rem 0;
    background: color-mix(in oklab, var(--surface-1) 84%, transparent 16%);
    border: 1px solid var(--line);
    box-shadow: none;
    backdrop-filter: blur(8px);
    height: 100%;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-md);
  }

  .toc h3 {
    margin: 0 0 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 650;
    color: var(--text);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--line-soft);
    margin-left: 1rem;
    max-height: inherit;
  }

  .toc-list li {
    margin: 0;
  }

  .toc-list a {
    display: block;
    padding: 0.3rem 0.4rem 0.3rem calc(0.9rem + (var(--toc-level, 1) - 1) * 0.85rem);
    color: var(--text-muted);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease, border-left-color 0.2s ease;
    line-height: 1.45;
    position: relative;
    left: -1px;
    border-left: 2px solid transparent;
    border-radius: 0 8px 8px 0;
  }

  .toc-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .toc-list a:hover {
    color: var(--text);
  }

  .toc-list a.active {
    color: var(--brand);
    border-left-color: var(--brand);
    font-weight: 600;
    background: color-mix(in oklab, var(--brand-soft) 36%, transparent 64%);
    box-shadow: none;
  }
  .toc-desktop-wrap {
    display: none;
  }

  .toc-mobile-toggle {
    position: fixed;
    right: 1rem;
    bottom: calc(5rem + env(safe-area-inset-bottom) + var(--floating-safe-bottom, 0px));
    z-index: 78;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg-elev) 90%, transparent 10%);
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.4rem 0.72rem;
    box-shadow: 0 8px 24px color-mix(in oklab, var(--text) 12%, transparent 88%);
  }

  .toc-mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(8, 10, 18, 0.45);
    backdrop-filter: blur(2px);
    z-index: 90;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .toc-mobile-overlay.open {
    opacity: 1;
  }

  .toc-mobile-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: min(88vw, 360px);
    height: 100vh;
    z-index: 91;
    transform: translateX(100%);
    transition: transform 180ms ease;
    padding: 0.65rem 0.65rem 0.75rem;
  }

  .toc-mobile-panel.open {
    transform: translateX(0);
  }

  .toc-mobile {
    height: 100%;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
  }

  .toc-mobile .toc-list {
    overflow: auto;
    max-height: none;
    padding-bottom: 0.5rem;
  }

  .toc-mobile-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-right: 0.75rem;
  }

  .toc-mobile-close {
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg) 88%, transparent 12%);
    color: var(--text-soft);
    font-size: 0.78rem;
    padding: 0.2rem 0.56rem;
  }

  :global(body.toc-drawer-open) {
    overflow: hidden;
  }

  @media (min-width: 1025px) {
    .toc-mobile-toggle,
    .toc-mobile-overlay,
    .toc-mobile-panel {
      display: none;
    }

    .toc-desktop-wrap {
      display: block;
      height: 100%;
    }

    .toc-desktop {
      max-height: none;
      height: 100%;
      overflow: auto;
    }
  }
</style>
