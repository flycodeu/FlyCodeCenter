---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "@/utils/date";

interface Props {
  entry: CollectionEntry<"sites"> | CollectionEntry<"reading">;
}

const { entry } = Astro.props;
const isReading = entry.collection === "reading";
const sourceHost = (() => {
  try {
    return new URL(entry.data.url).hostname.replace(/^www\./, "");
  } catch {
    return "external";
  }
})();
---

<article class="surface resource-card fade-up">
  <header>
    <span class={`kind ${isReading ? "reading" : "site"}`}>{isReading ? "精选文章" : "网站资源"}</span>
    <time>{formatDate(entry.data.pubDate)}</time>
  </header>
  <h3>
    <a href={entry.data.url} target="_blank" rel="noreferrer">{entry.data.title}</a>
  </h3>
  <p>{entry.data.description}</p>
  <footer>
    <span>{sourceHost}</span>
    <span class="tag-wrap">{entry.data.tags.slice(0, 3).map((tag) => <span class="chip tag-chip">{tag}</span>)}</span>
  </footer>
</article>

<style>
  .resource-card {
    padding: 0.95rem;
    display: grid;
    gap: 0.55rem;
  }
  .resource-card header,
  .resource-card footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--text-soft);
    font-size: 0.84rem;
  }
  .resource-card h3 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.12rem;
  }
  .resource-card a:hover {
    color: var(--brand);
  }
  .resource-card p {
    margin: 0;
    color: var(--text-soft);
  }
  .kind {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.15rem 0.45rem;
  }
  .kind.site {
    color: var(--brand);
  }
  .kind.reading {
    color: var(--accent);
  }
  .tag-wrap {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.3rem;
  }
  .tag-chip {
    font-size: 0.72rem;
    padding: 0.14rem 0.48rem;
  }
</style>
