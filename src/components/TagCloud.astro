---
interface Item {
  name: string;
  count: number;
  href: string;
}

interface Props {
  title: string;
  items: Item[];
}

const { title, items } = Astro.props;
---

<section class="surface tag-cloud">
  <h3>{title}</h3>
  <div class="tags">
    {
      items.map((item) => (
        <a class="chip tag-badge cloud-chip" href={item.href}>
          {item.name}
          <span>{item.count}</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .tag-cloud {
    padding: 0.75rem;
  }
  .tag-cloud h3 {
    margin: 0 0 0.54rem;
    font-size: 0.9rem;
    color: var(--text-soft);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.48rem;
  }
  .tags .chip {
    transition: color 180ms ease, border-color 180ms ease;
  }
  .tags .chip:hover {
    color: color-mix(in oklab, var(--text) 74%, var(--brand) 26%);
    border-color: color-mix(in oklab, var(--line) 72%, var(--brand) 28%);
  }
  .cloud-chip {
    border-radius: var(--radius-pill);
    font-size: 0.79rem;
    max-width: 180px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tags .chip span {
    opacity: 0.84;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--surface-1) 78%, transparent 22%);
    border-radius: 999px;
    padding: 0 0.3rem;
  }
</style>
