---
import type { CollectionEntry } from "astro:content";
import siteConfig from "@/site.config";
import { formatDate } from "@/utils/date";
import { getBlogEntryUrl, getTutorialEntryUrl } from "@/utils/content";
import { resolveArticleMeta } from "@/utils/article-meta";
import { getTagColorVars } from "@/utils/tag-color";

type PostKind = "blog" | "tutorial";

interface Props {
  entry: CollectionEntry<"blog"> | CollectionEntry<"tutorial">;
  kind: PostKind;
  coverMode?: "left" | "right" | "none";
  coverHeight?: number;
  cardStyle?: "rounded" | "square" | "glass";
}

const { entry, kind, coverMode, coverHeight, cardStyle } = Astro.props;

const pageOverride = siteConfig.blog.pageCardOverrides[kind === "blog" ? "blog" : "tutorial"];
const rawDataCoverMode = (entry.data as { coverMode?: string }).coverMode;
const dataCoverMode =
  rawDataCoverMode === "left" || rawDataCoverMode === "right" || rawDataCoverMode === "none" ? rawDataCoverMode : undefined;
const mode = coverMode ?? dataCoverMode ?? pageOverride.coverMode ?? siteConfig.blog.listCard.defaultCoverMode;
const height = coverHeight ?? siteConfig.blog.listCard.coverHeight;
const styleVariant = cardStyle ?? siteConfig.blog.listCard.cardStyle;

const link = kind === "blog" ? getBlogEntryUrl(entry as CollectionEntry<"blog">) : getTutorialEntryUrl(entry as CollectionEntry<"tutorial">);
const meta = resolveArticleMeta(entry as CollectionEntry<"blog"> | CollectionEntry<"tutorial">);
const cover = meta.cover || "";
const hasCover = mode !== "none" && Boolean(cover);
const width = siteConfig.blog.listCard.coverWidth;
const ratio = siteConfig.blog.listCard.coverRatio;
const pinned = kind === "blog" && meta.pinned;
const summary = (meta.summary || meta.description || "").trim();
const dateText = formatDate(meta.createTime, "YYYY-MM-DD");
---

<article class={`surface post-card cover-${mode} style-${styleVariant} fade-up ${pinned ? "is-pinned" : ""}`} style={`--cover-width:${width}px;--cover-height:${height}px;--cover-ratio:${ratio};`}>
  <div class="meta">
    <header class="card-head">
      {pinned && <span class="pin">置顶</span>}
      <a class="title" href={link}>{meta.title}</a>
    </header>

    {summary && <p class="summary">{summary}</p>}

    <footer class="card-foot">
      <div class="meta-left">
        <div class="tags">
          {meta.tags.slice(0, 4).map((item) => <span class="tag-chip tag-badge" style={getTagColorVars(item)}>{item}</span>)}
        </div>
      </div>

      <time class="date" datetime={meta.createTime.toISOString()}>
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 2v4m8-4v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" />
        </svg>
        {dateText}
      </time>
    </footer>
  </div>

  {
    hasCover && (
      <a class="cover-wrap" href={link} aria-label={`查看 ${meta.title}`}>
        <img src={cover} alt={meta.title} loading="lazy" />
      </a>
    )
  }
</article>

<style>
  .post-card {
    position: relative;
    display: grid;
    gap: 1.15rem;
    padding: 1.05rem;
    align-items: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .post-card.cover-right {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .post-card.cover-left {
    grid-template-columns: auto minmax(0, 1fr);
  }

  .post-card.cover-left .meta {
    order: 2;
  }

  .post-card.cover-left .cover-wrap {
    order: 1;
  }

  .post-card.cover-none {
    grid-template-columns: 1fr;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--line) 70%, var(--brand) 30%);
    box-shadow: 0 12px 24px -18px rgba(15, 23, 42, 0.32);
  }

  .post-card.style-square {
    border-radius: 8px;
  }

  .post-card.style-glass {
    background: rgba(var(--bg-elev), 0.7);
    backdrop-filter: blur(9px);
  }

  .meta {
    min-height: var(--cover-height);
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 0.55rem;
    padding-left: 0;
  }

  .card-head {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.44rem;
    margin: 0;
  }

  .pin {
    display: inline-flex;
    align-items: center;
    border: 1px solid color-mix(in oklab, var(--line) 72%, var(--brand) 28%);
    color: color-mix(in oklab, var(--text) 65%, var(--brand) 35%);
    font-size: 0.74rem;
    line-height: 1;
    padding: 0.18rem 0.38rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--brand-soft) 54%, var(--bg-elev) 46%);
    font-weight: 500;
  }

  .title {
    color: var(--text);
    line-height: 1.45;
    letter-spacing: -0.01em;
    font-size: 1.12rem;
    font-family: "Source Han Sans SC", "Noto Sans SC", var(--font-sans);
    font-weight: 620;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .title:hover {
    color: color-mix(in oklab, var(--text) 68%, var(--brand) 32%);
  }

  .summary {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.52;
    font-size: 0.92rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    align-self: center;
  }

  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .meta-left {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .tags {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.42rem;
    min-width: 0;
  }

  .tag-chip {
    font-size: 0.78rem;
    padding: 0.18rem 0.64rem;
    max-width: min(220px, 56vw);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.35;
  }

  .date {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .cover-wrap {
    width: var(--cover-width);
    min-height: var(--cover-height);
    aspect-ratio: var(--cover-ratio);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--line) 92%, transparent 8%);
    background: var(--bg-elev);
  }

  .cover-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.36s ease;
  }

  .post-card:hover .cover-wrap img {
    transform: scale(1.03);
  }

  @media (max-width: 900px) {
    .title {
      font-size: 1.06rem;
    }
  }

  @media (max-width: 760px) {
    .post-card.cover-right,
    .post-card.cover-left {
      grid-template-columns: 1fr;
    }

    .post-card.cover-left .meta,
    .post-card.cover-left .cover-wrap {
      order: initial;
    }

    .cover-wrap {
      width: 100%;
    }

    .meta {
      min-height: auto;
      grid-template-rows: auto auto auto;
      padding-left: 0;
    }

    .card-foot {
      align-items: flex-start;
      justify-content: flex-start;
    }

    .date {
      font-size: 0.84rem;
    }

    .title {
      font-size: 1rem;
    }

    .pin {
      font-size: 0.7rem;
      padding: 0.16rem 0.34rem;
    }
  }
</style>
