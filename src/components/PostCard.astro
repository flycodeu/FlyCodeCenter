---
import type { CollectionEntry } from "astro:content";
import siteConfig from "@/site.config";
import { formatDate } from "@/utils/date";
import { getBlogEntryUrl, getTutorialEntryUrl } from "@/utils/content";
import { resolveArticleMeta } from "@/utils/article-meta";

type PostKind = "blog" | "tutorial";
type CoverMode = "left" | "right" | "top" | "none";

interface Props {
  entry: CollectionEntry<"blog"> | CollectionEntry<"tutorial">;
  kind: PostKind;
  coverMode?: CoverMode;
  coverHeight?: number;
  cardStyle?: "rounded" | "square" | "glass";
}

const { entry, kind, coverMode, coverHeight } = Astro.props;
const listCard = siteConfig.blog.listCard as {
  defaultCoverMode?: CoverMode;
  coverInlineSize?: number;
  coverTopMaxHeight?: number;
  coverAspectRatio?: string;
  mobileCollapseToTop?: boolean;
  coverWidth?: number;
  coverHeight?: number;
  coverRatio?: string;
  tagsMax?: number;
  titleLines?: number;
  outlineLines?: number;
};

function normalizeCoverMode(value: unknown): CoverMode | undefined {
  if (typeof value !== "string") return undefined;
  const normalized = value.trim().toLowerCase();
  if (normalized === "left" || normalized === "right" || normalized === "top" || normalized === "none") {
    return normalized;
  }
  return undefined;
}

const pageOverride = siteConfig.blog.pageCardOverrides[kind === "blog" ? "blog" : "tutorial"];
const entryData = entry.data as { coverMode?: string; coverPosition?: string };
const meta = resolveArticleMeta(entry as CollectionEntry<"blog"> | CollectionEntry<"tutorial">);
const dataCoverMode =
  normalizeCoverMode(entryData.coverMode) ?? normalizeCoverMode(entryData.coverPosition) ?? normalizeCoverMode(meta.coverMode);
const mode: CoverMode =
  normalizeCoverMode(coverMode) ??
  dataCoverMode ??
  normalizeCoverMode(pageOverride.coverMode) ??
  normalizeCoverMode(listCard.defaultCoverMode) ??
  "right";

const link =
  kind === "blog" ? getBlogEntryUrl(entry as CollectionEntry<"blog">) : getTutorialEntryUrl(entry as CollectionEntry<"tutorial">);
const outline = (meta.outline || "").trim();
const dateText = formatDate(meta.createTime, "YYYY-MM-DD");

const inlineSize = listCard.coverInlineSize ?? listCard.coverWidth ?? 224;
const topMaxHeight = coverHeight ?? listCard.coverTopMaxHeight ?? listCard.coverHeight ?? 150;
const ratio = listCard.coverAspectRatio ?? listCard.coverRatio ?? "16 / 9";
const hasCover = mode !== "none" && Boolean(meta.cover);
const resolvedMode: CoverMode = hasCover ? mode : "none";
const collapseMobileToTop = listCard.mobileCollapseToTop ?? true;

const tagsLimit = listCard.tagsMax ?? 3;
const shownTags = meta.tags.slice(0, tagsLimit);
const hiddenTags = Math.max(0, meta.tags.length - shownTags.length);
const titleLines = listCard.titleLines ?? 2;
const outlineLines = listCard.outlineLines ?? 2;
---

<article
  class={`surface post-card mode-${resolvedMode} ${collapseMobileToTop ? "collapse-mobile-top" : ""} ${meta.pinned ? "is-pinned" : ""}`}
  style={`--title-lines:${titleLines};--outline-lines:${outlineLines};--cover-inline-size:${inlineSize}px;--cover-top-max-height:${topMaxHeight}px;--cover-aspect-ratio:${ratio};`}
>
  <div class="meta content-wrap">
    <header class="card-head">
      {meta.pinned && <span class="pin">Pinned</span>}
      <a class="title" href={link}>{meta.title}</a>
    </header>

    {shownTags.length > 0 && (
      <div class="tags">
        {shownTags.map((item) => <span class="tag-badge tag-chip">{item}</span>)}
        {hiddenTags > 0 && <span class="tag-badge tag-chip">+{hiddenTags}</span>}
      </div>
    )}

    {outline && <p class="outline">{outline}</p>}

    <time class="date" datetime={meta.createTime.toISOString()}>{dateText}</time>
  </div>

  {
    hasCover && (
      <a class="cover-wrap" href={link} aria-label={meta.title}>
        <img src={meta.cover} alt={meta.title} loading="lazy" decoding="async" />
      </a>
    )
  }
</article>

<style>
  .post-card {
    min-height: 152px;
    border-radius: var(--radius-md);
    overflow: hidden;
    padding: 1rem;
    display: grid;
    gap: 0.9rem;
    align-content: start;
    align-items: stretch;
    border: 2px solid color-mix(in oklab, var(--line) 76%, var(--brand) 24%);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--surface-1) 92%, transparent 8%), color-mix(in oklab, var(--surface-2) 92%, transparent 8%)),
      repeating-linear-gradient(
        0deg,
        color-mix(in oklab, var(--brand) 6%, transparent 94%) 0,
        color-mix(in oklab, var(--brand) 6%, transparent 94%) 1px,
        transparent 1px,
        transparent 10px
      );
    content-visibility: auto;
    contain-intrinsic-size: 320px 220px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--brand) 58%, var(--line) 42%);
  }

  .post-card.mode-right {
    grid-template-columns: minmax(0, 1fr) minmax(158px, var(--cover-inline-size));
  }

  .post-card.mode-left {
    grid-template-columns: minmax(158px, var(--cover-inline-size)) minmax(0, 1fr);
  }

  .post-card.mode-left .cover-wrap {
    order: 1;
  }

  .post-card.mode-left .content-wrap {
    order: 2;
  }

  .post-card.mode-top {
    grid-template-columns: 1fr;
  }

  .post-card.mode-none {
    grid-template-columns: 1fr;
  }

  .post-card.mode-top .cover-wrap {
    order: 1;
  }

  .post-card.mode-top .content-wrap {
    order: 2;
  }

  .cover-wrap {
    width: 100%;
    height: auto;
    aspect-ratio: var(--cover-aspect-ratio);
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--line) 78%, var(--brand) 22%);
    display: block;
    background: color-mix(in oklab, var(--surface-2) 90%, transparent 10%);
    align-self: stretch;
  }

  .post-card.mode-top .cover-wrap {
    aspect-ratio: auto;
    height: var(--cover-top-max-height);
  }

  .cover-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.24s ease;
  }

  .post-card:hover .cover-wrap img {
    transform: scale(1.03);
  }

  .meta {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.55rem;
    min-height: 0;
  }

  .card-head {
    display: grid;
    gap: var(--space-1);
    margin: 0;
  }

  .pin {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.14rem 0.48rem;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in oklab, var(--brand) 34%, var(--line) 66%);
    color: var(--brand);
    font-size: 0.68rem;
    font-weight: 650;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .title {
    margin: 0;
    color: var(--text);
    line-height: 1.38;
    letter-spacing: -0.01em;
    font-size: 1rem;
    font-weight: 700;
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    display: -webkit-box;
    -webkit-line-clamp: var(--title-lines);
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.38rem;
    min-width: 0;
  }

  .tag-chip {
    font-size: 0.7rem;
    padding: 0.16rem 0.5rem;
    white-space: nowrap;
    max-width: 132px;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: var(--font-tech);
  }

  .outline {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.48;
    font-size: 0.84rem;
    display: -webkit-box;
    -webkit-line-clamp: var(--outline-lines);
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .date {
    align-self: end;
    color: var(--text-muted);
    font-size: 0.78rem;
    white-space: nowrap;
    font-family: var(--font-tech);
  }

  @media (max-width: 900px) {
    .post-card.collapse-mobile-top.mode-right,
    .post-card.collapse-mobile-top.mode-left {
      grid-template-columns: 1fr;
    }

    .post-card.collapse-mobile-top.mode-right .cover-wrap,
    .post-card.collapse-mobile-top.mode-left .cover-wrap {
      order: 1;
    }

    .post-card.collapse-mobile-top.mode-right .content-wrap,
    .post-card.collapse-mobile-top.mode-left .content-wrap {
      order: 2;
    }

    .post-card.collapse-mobile-top.mode-right .cover-wrap,
    .post-card.collapse-mobile-top.mode-left .cover-wrap {
      width: 100%;
      aspect-ratio: auto;
      height: var(--cover-top-max-height);
    }
  }

  @media (hover: none) {
    .post-card:hover {
      transform: none;
    }

    .post-card:hover .cover-wrap img {
      transform: none;
    }
  }
</style>
