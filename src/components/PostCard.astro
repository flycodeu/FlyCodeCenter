---
import type { CollectionEntry } from "astro:content";
import siteConfig from "@/site.config";
import { formatDate } from "@/utils/date";
import { getBlogEntryUrl, getTutorialEntryUrl } from "@/utils/content";
import { resolveArticleMeta } from "@/utils/article-meta";
import { getTagColorVars } from "@/utils/tag-color";

type PostKind = "blog" | "tutorial";

interface Props {
  entry: CollectionEntry<"blog"> | CollectionEntry<"tutorial">;
  kind: PostKind;
  coverMode?: "left" | "right" | "none";
  coverHeight?: number;
  cardStyle?: "rounded" | "square" | "glass";
}

const { entry, kind, coverMode, coverHeight, cardStyle } = Astro.props;

const pageOverride = siteConfig.blog.pageCardOverrides[kind === "blog" ? "blog" : "tutorial"];
const mode = coverMode ?? pageOverride.coverMode ?? siteConfig.blog.listCard.defaultCoverMode;
const height = coverHeight ?? siteConfig.blog.listCard.coverHeight;
const styleVariant = cardStyle ?? siteConfig.blog.listCard.cardStyle;

const link = kind === "blog" ? getBlogEntryUrl(entry as CollectionEntry<"blog">) : getTutorialEntryUrl(entry as CollectionEntry<"tutorial">);
const meta = resolveArticleMeta(entry as CollectionEntry<"blog"> | CollectionEntry<"tutorial">);
const cover = meta.cover || "";
const hasCover = mode !== "none" && Boolean(cover);
const width = siteConfig.blog.listCard.coverWidth;
const ratio = siteConfig.blog.listCard.coverRatio;
const pinned = kind === "blog" && meta.pinned;
const summary = (meta.summary || meta.description || "").trim();
const compactMetaClass = summary ? "meta" : "meta no-summary";
---

<article class={`surface post-card cover-${mode} style-${styleVariant} fade-up`} style={`--cover-width:${width}px;--cover-height:${height}px;--cover-ratio:${ratio};`}>
  <div class={compactMetaClass}>
    <div class="card-head">
      {pinned && <span class="pin">置顶</span>}
      <a class="title" href={link}>{entry.data.title}</a>
    </div>
    {summary && <p class="summary">{summary}</p>}
    <div class="card-foot">
      <span class="date">
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 2v4m8-4v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"/>
        </svg>
        {formatDate(meta.createTime)}
      </span>
      <div class="tags">
        {meta.tags.slice(0, 4).map((item) => <span class="tag-chip tag-badge" style={getTagColorVars(item)}>{item}</span>)}
      </div>
    </div>
  </div>

  {
    hasCover && (
      <a class="cover-wrap" href={link}>
        <img src={cover} alt={entry.data.title} loading="lazy" />
      </a>
    )
  }
</article>

<style>
  .post-card {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    align-items: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .post-card.cover-right {
    grid-template-columns: minmax(0, 1fr) auto;
  }
  .post-card.cover-left {
    grid-template-columns: auto minmax(0, 1fr);
  }
  .post-card.cover-left .meta {
    order: 2;
  }
  .post-card.cover-left .cover-wrap {
    order: 1;
  }
  .post-card.cover-none {
    grid-template-columns: 1fr;
  }
  .post-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--line) 76%, var(--brand) 24%);
    box-shadow: 0 10px 18px -14px rgba(15, 23, 42, 0.24);
  }
  .post-card.style-square {
    border-radius: 8px;
  }
  .post-card.style-glass {
    background: rgba(var(--bg-elev), 0.68);
    backdrop-filter: blur(8px);
  }
  .meta {
    min-height: var(--cover-height);
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 0.5rem;
    align-items: stretch;
  }
  .meta.no-summary {
    min-height: auto;
    grid-template-rows: auto auto;
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-self: start;
  }
  .pin {
    display: inline-flex;
    align-items: center;
    border: 1px solid color-mix(in oklab, var(--line) 68%, var(--brand) 32%);
    color: color-mix(in oklab, var(--text) 65%, var(--brand) 35%);
    font-size: 0.75rem;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    background: color-mix(in oklab, var(--brand-soft) 52%, var(--bg-elev) 48%);
    font-weight: 500;
  }
  .title {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
    letter-spacing: -0.01em;
  }
  .title:hover {
    color: color-mix(in oklab, var(--text) 68%, var(--brand) 32%);
  }
  .summary {
    margin: 0;
    color: var(--text-soft);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    align-self: center;
    line-height: 1.6;
    font-size: 0.9375rem;
  }
  .meta.no-summary .summary {
    display: none;
  }
  .card-foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    color: var(--text-soft);
    font-size: 0.875rem;
    align-items: center;
    align-self: end;
  }
  .date {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
  }
  .tags {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.375rem;
  }
  .tag-chip {
    font-size: 0.75rem;
    padding: 0.14rem 0.46rem;
    max-width: min(132px, 42vw);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cover-wrap {
    width: var(--cover-width);
    min-height: var(--cover-height);
    aspect-ratio: var(--cover-ratio);
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-elev);
  }
  .cover-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .post-card:hover .cover-wrap img {
    transform: scale(1.03);
  }
  @media (max-width: 760px) {
    .post-card.cover-right,
    .post-card.cover-left {
      grid-template-columns: 1fr;
    }
    .post-card.cover-left .meta,
    .post-card.cover-left .cover-wrap {
      order: initial;
    }
    .cover-wrap {
      width: 100%;
    }
    .meta {
      min-height: auto;
      grid-template-rows: auto auto auto;
    }
    .card-foot {
      justify-content: flex-start;
    }
  }
</style>
