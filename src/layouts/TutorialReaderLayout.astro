---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TOC from "@/components/TOC.astro";
import Comments from "@/components/Comments.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import EncryptGate from "@/components/EncryptGate.astro";
import TutorialSidebar from "@/components/TutorialSidebar.astro";
import { formatDate } from "@/utils/date";
import { toSeriesRouteKey } from "@/utils/tutorial-series";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface TutorialSidebarItem {
  id: string;
  slug: string;
  title: string;
  order: number;
  url: string;
}

interface Neighbor {
  title: string;
  url: string;
}

interface Props {
  title: string;
  summary?: string;
  description?: string;
  tags?: string[];
  articleUrl: string;
  seriesKey: string;
  seriesLabel: string;
  currentSlug: string;
  items: TutorialSidebarItem[];
  headings?: Heading[];
  pubDate: Date;
  updatedDate?: Date;
  wordCount?: number;
  readingMinutes?: number;
  prev?: Neighbor;
  next?: Neighbor;
  encrypted?: boolean;
  encryptedFile?: string;
  passwordHint?: string;
}

const {
  title,
  summary = "",
  description = summary || title,
  tags = [],
  articleUrl,
  seriesKey,
  seriesLabel,
  currentSlug,
  items,
  headings = [],
  pubDate,
  updatedDate,
  wordCount = 0,
  readingMinutes = 0,
  prev,
  next,
  encrypted = false,
  encryptedFile = "",
  passwordHint = ""
} = Astro.props;

const tutorialsConfig =
  (siteConfig.pages.tutorials as {
    reader?: {
      sidebar?: {
        enable?: boolean;
        position?: "left" | "right";
        width?: number;
        collapsible?: boolean;
        defaultCollapsed?: boolean;
        showOrder?: boolean;
        showProgress?: boolean;
        mobileDrawer?: boolean;
      };
      toc?: {
        enable?: boolean;
        position?: "left" | "right";
        width?: number;
      };
      content?: {
        maxWidth?: number;
        showPrevNext?: boolean;
        showSeriesBreadcrumb?: boolean;
      };
    };
  } | undefined) ?? {};

const reader = tutorialsConfig.reader ?? {};
const sidebar = reader.sidebar ?? {};
const toc = reader.toc ?? {};
const content = reader.content ?? {};
const layoutPreset = (siteConfig.theme as {
  layout?: { tutorialSidebarWidth?: number; tutorialTocWidth?: number; tutorialContentMaxWidth?: number };
}).layout;

const sidebarEnable = sidebar.enable ?? true;
const sidebarPosition = sidebar.position === "right" ? "right" : "left";
const sidebarWidth = Number(sidebar.width ?? layoutPreset?.tutorialSidebarWidth ?? 320);
const tocEnable = (toc.enable ?? true) && siteConfig.theme.toc.enable;
const tocPosition = toc.position === "left" ? "left" : "right";
const tocWidth = Number(toc.width ?? layoutPreset?.tutorialTocWidth ?? 280);
const contentMaxWidth = Number(content.maxWidth ?? layoutPreset?.tutorialContentMaxWidth ?? 780);
const showPrevNext = content.showPrevNext ?? true;
const showSeriesBreadcrumb = content.showSeriesBreadcrumb ?? true;
const seriesRouteKey = toSeriesRouteKey(seriesKey);
const readerClass = [
  "tutorial-reader",
  "reading-page",
  sidebarEnable ? `has-sidebar sidebar-${sidebarPosition}` : "no-sidebar",
  tocEnable ? `has-toc toc-${tocPosition}` : "no-toc"
]
  .filter(Boolean)
  .join(" ");

const deferUntilEvent = encrypted ? "site:decrypted" : undefined;
const articleRuntimeConfig = {
  isEncrypted: encrypted,
  enableMermaid: siteConfig.features.diagram.mermaid,
  enableDrawio: siteConfig.features.diagram.drawio,
  enableEcharts: siteConfig.features.diagram.echarts,
  mermaidSource: siteConfig.diagram.mermaid.source ?? "cdn",
  mermaidBundle: siteConfig.diagram.mermaid.bundleUrl,
  mermaidLocalBundle: siteConfig.diagram.mermaid.localBundle ?? "",
  mermaidTheme: siteConfig.diagram.mermaid.theme,
  drawioViewerBase: siteConfig.diagram.drawio.viewerBase,
  echartsSource: siteConfig.diagram.echarts.source ?? "cdn",
  echartsBundle: siteConfig.diagram.echarts.bundleUrl,
  echartsLocalBundle: siteConfig.diagram.echarts.localBundle ?? "",
  diagramFallbackToCdn: Boolean((siteConfig.diagram as { fallbackToCdn?: boolean }).fallbackToCdn ?? true),
  chartHeight: siteConfig.diagram.echarts.defaultHeight,
  enableEchartsThemeSync: Boolean((siteConfig.diagram as { echarts?: { themeSync?: boolean } }).echarts?.themeSync ?? false),
  enableCodeCopy: siteConfig.markdown.copy.code,
  enableMathCopy: siteConfig.markdown.copy.math,
  enableMermaidCopy: siteConfig.markdown.copy.mermaid,
  enableExtendedMarkdown: Boolean((siteConfig.markdown as { extended?: { enable?: boolean } }).extended?.enable ?? false),
  enableChartJs: Boolean((siteConfig.markdown as { extended?: { chartjs?: { enable?: boolean } } }).extended?.chartjs?.enable ?? false),
  chartJsBundle:
    (siteConfig.markdown as { extended?: { chartjs?: { bundleUrl?: string } } }).extended?.chartjs?.bundleUrl ??
    "https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js",
  enableChartJsThemeSync: Boolean(
    (siteConfig.markdown as { extended?: { chartjs?: { themeSync?: boolean } } }).extended?.chartjs?.themeSync ?? false
  ),
  enableCodeFold: Boolean((siteConfig.markdown as { extended?: { codeFold?: { enable?: boolean } } }).extended?.codeFold?.enable ?? false),
  codeFoldDefaultLines: Number((siteConfig.markdown as { extended?: { codeFold?: { defaultLines?: number } } }).extended?.codeFold?.defaultLines ?? 18),
  enableCodeGroup: Boolean((siteConfig.markdown as { extended?: { codeGroup?: { enable?: boolean } } }).extended?.codeGroup?.enable ?? false),
  enableDiffEnhance: Boolean((siteConfig.markdown as { extended?: { diffEnhance?: { enable?: boolean } } }).extended?.diffEnhance?.enable ?? false),
  enableAnchorCopy: false,
  enableDiagramDiagnostics: Boolean((siteConfig.article as { diagnostics?: { enable?: boolean } }).diagnostics?.enable ?? true),
  enableInlineIcon: Boolean((siteConfig.markdown as { extended?: { icon?: { enable?: boolean } } }).extended?.icon?.enable ?? false),
  iconifyBundle:
    (siteConfig.markdown as { extended?: { icon?: { bundleUrl?: string } } }).extended?.icon?.bundleUrl ??
    "https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js",
  codeHighlightProvider: String((siteConfig as { codeHighlight?: { provider?: string } }).codeHighlight?.provider ?? "prism"),
  enableCodeLineNumbers: Boolean((siteConfig as { codeHighlight?: { lineNumbers?: boolean } }).codeHighlight?.lineNumbers ?? true),
  codeWindowTitleMode: String((siteConfig as { codeHighlight?: { window?: { titleMode?: string } } }).codeHighlight?.window?.titleMode ?? "lang"),
  articleTitle: title,
  articleTags: tags,
  viewStatsEnabled: siteConfig.stats.enable,
  viewStatsEndpoint: siteConfig.stats.endpoint,
  antiCrawlEnabled: Boolean((siteConfig.article as { antiCrawl?: { enable?: boolean } }).antiCrawl?.enable ?? false),
  antiCrawlLockOnSuspicious: Boolean((siteConfig.article as { antiCrawl?: { lockOnSuspicious?: boolean } }).antiCrawl?.lockOnSuspicious ?? true),
  antiCrawlMaxCopyActions: Number((siteConfig.article as { antiCrawl?: { maxCopyActions?: number } }).antiCrawl?.maxCopyActions ?? 8),
  antiCrawlTimeWindowMs: Number((siteConfig.article as { antiCrawl?: { timeWindowMs?: number } }).antiCrawl?.timeWindowMs ?? 20000)
};
---

<BaseLayout title={title} description={description} canonicalPath={articleUrl}>
  <ReadingProgress />

  <div
    class={readerClass}
    style={`--tutorial-sidebar-width-base:${sidebarWidth}px;--tutorial-toc-width-base:${tocWidth}px;--tutorial-content-max-base:${contentMaxWidth}px;`}
  >
    {
      sidebarEnable && sidebarPosition === "left" && (
        <TutorialSidebar
          seriesKey={seriesKey}
          seriesLabel={seriesLabel}
          currentSlug={currentSlug}
          items={items}
          width={sidebarWidth}
          collapsible={sidebar.collapsible ?? true}
          defaultCollapsed={sidebar.defaultCollapsed ?? false}
          showOrder={sidebar.showOrder ?? true}
          showProgress={sidebar.showProgress ?? true}
          mobileDrawer={sidebar.mobileDrawer ?? true}
        />
      )
    }

    {tocEnable && tocPosition === "left" && <aside class="tutorial-toc-rail"><TOC headings={headings} /></aside>}

    <section class="tutorial-main-wrap">
      <section class="tutorial-main">
        <section class="surface tutorial-sheet reading-sheet">
          <div class="tutorial-sheet-head reading-head">
            {
              showSeriesBreadcrumb && (
                <nav class="tutorial-breadcrumb reading-breadcrumb" aria-label="面包屑">
                  <a href="/tutorials">教程</a>
                  <span>/</span>
                  <a href={`/tutorials/${encodeURIComponent(seriesRouteKey)}`}>{seriesLabel}</a>
                  <span>/</span>
                  <span>{title}</span>
                </nav>
              )
            }

            <header class="tutorial-head">
              <p class="reading-kicker">Series Tutorial</p>
              <h1 class="reading-title">{title}</h1>
              {summary && <p class="summary reading-summary">{summary}</p>}
              <div class="meta-strip reading-meta-strip">
                <div class="meta-row reading-meta-row">
                  <span class="chip">{wordCount} 字</span>
                  {siteConfig.readingTime.enable && <span class="chip">{readingMinutes} 分钟</span>}
                  {siteConfig.stats.enable && <span class="chip" id="post-view-count" data-view-slug={articleUrl}>阅读 --</span>}
                  <span class="chip date-chip">发布 {formatDate(pubDate, "YYYY-MM-DD")}</span>
                  {updatedDate && <span class="chip date-chip">更新 {formatDate(updatedDate, "YYYY-MM-DD")}</span>}
                </div>
                {
                  tags.length > 0 && (
                    <div class="tag-row-badge reading-tag-row">
                      {tags.map((tag) => <a class="tag-badge tag-link" href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>)}
                    </div>
                  )
                }
              </div>
            </header>
          </div>

          <div class="tutorial-sheet-body">
            <article class="prose article-body reading-body" data-article-encrypted={encrypted ? "1" : "0"}>
              {encrypted && siteConfig.encrypt.enable ? <EncryptGate encryptedFile={encryptedFile} passwordHint={passwordHint} /> : <slot />}
            </article>
          </div>
        </section>

        {
          showPrevNext && (prev || next) && (
            <section class="surface tutorial-card tutorial-nav-card reading-panel">
              <nav class="prev-next reading-switcher">
                {prev ? <a href={prev.url}>← {prev.title}</a> : <span />}
                {next ? <a href={next.url}>{next.title} →</a> : <span />}
              </nav>
            </section>
          )
        }

        <section class="surface tutorial-card tutorial-comment-card reading-panel">
          <Comments deferUntilEvent={deferUntilEvent} />
        </section>
      </section>
    </section>

    {
      sidebarEnable && sidebarPosition === "right" && (
        <TutorialSidebar
          seriesKey={seriesKey}
          seriesLabel={seriesLabel}
          currentSlug={currentSlug}
          items={items}
          width={sidebarWidth}
          collapsible={sidebar.collapsible ?? true}
          defaultCollapsed={sidebar.defaultCollapsed ?? false}
          showOrder={sidebar.showOrder ?? true}
          showProgress={sidebar.showProgress ?? true}
          mobileDrawer={sidebar.mobileDrawer ?? true}
        />
      )
    }

    {tocEnable && tocPosition === "right" && <aside class="tutorial-toc-rail"><TOC headings={headings} /></aside>}
  </div>

  <script id="article-runtime-config" type="application/json" set:html={JSON.stringify(articleRuntimeConfig)} />
  <script>
    import "@/scripts/article-runtime-entry.js";
  </script>
</BaseLayout>

<style is:global>
  @import "../styles/katex-local.css";
</style>

<style>
  :global(main.container) {
    width: min(var(--layout-tutorial-shell-max, 1560px), calc(100% - var(--space-5)));
  }

  .tutorial-reader {
    --tutorial-sidebar-width: var(--tutorial-sidebar-width-base, 300px);
    --tutorial-toc-width: var(--tutorial-toc-width-base, 260px);
    --tutorial-content-max: var(--tutorial-content-max-base, 900px);
    --tutorial-rail-gap: clamp(0.9rem, 1.4vw, 1.45rem);
    --tutorial-sheet-padding: clamp(1.4rem, 1.8vw, 2rem);
    --tutorial-sheet-gap: clamp(1rem, 1.5vw, 1.6rem);
    display: grid;
    gap: var(--tutorial-rail-gap);
    align-items: start;
    min-width: 0;
  }

  .tutorial-reader.has-sidebar.sidebar-left.has-toc.toc-right {
    grid-template-columns: minmax(220px, var(--tutorial-sidebar-width)) minmax(0, 1fr) minmax(200px, var(--tutorial-toc-width));
    grid-template-areas: "sidebar main toc";
  }

  .tutorial-reader.has-sidebar.sidebar-left.has-toc.toc-left {
    grid-template-columns: minmax(220px, var(--tutorial-sidebar-width)) minmax(200px, var(--tutorial-toc-width)) minmax(0, 1fr);
    grid-template-areas: "sidebar toc main";
  }

  .tutorial-reader.has-sidebar.sidebar-right.has-toc.toc-left {
    grid-template-columns: minmax(200px, var(--tutorial-toc-width)) minmax(0, 1fr) minmax(220px, var(--tutorial-sidebar-width));
    grid-template-areas: "toc main sidebar";
  }

  .tutorial-reader.has-sidebar.sidebar-right.has-toc.toc-right {
    grid-template-columns: minmax(0, 1fr) minmax(200px, var(--tutorial-toc-width)) minmax(220px, var(--tutorial-sidebar-width));
    grid-template-areas: "main toc sidebar";
  }

  .tutorial-reader.has-sidebar.sidebar-left.no-toc {
    grid-template-columns: minmax(220px, var(--tutorial-sidebar-width)) minmax(0, 1fr);
    grid-template-areas: "sidebar main";
  }

  .tutorial-reader.has-sidebar.sidebar-right.no-toc {
    grid-template-columns: minmax(0, 1fr) minmax(220px, var(--tutorial-sidebar-width));
    grid-template-areas: "main sidebar";
  }

  .tutorial-reader.no-sidebar.has-toc.toc-right {
    grid-template-columns: minmax(0, 1fr) minmax(200px, var(--tutorial-toc-width));
    grid-template-areas: "main toc";
  }

  .tutorial-reader.no-sidebar.has-toc.toc-left {
    grid-template-columns: minmax(200px, var(--tutorial-toc-width)) minmax(0, 1fr);
    grid-template-areas: "toc main";
  }

  .tutorial-reader.no-sidebar.no-toc {
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas: "main";
  }

  .tutorial-reader .tutorial-sidebar-wrap {
    grid-area: sidebar;
  }

  .tutorial-main-wrap {
    grid-area: main;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    display: grid;
    justify-items: center;
    align-items: start;
  }

  .tutorial-main {
    width: 100%;
    max-width: min(100%, var(--tutorial-content-max));
    min-width: 0;
    display: grid;
    gap: var(--tutorial-sheet-gap);
  }

  .tutorial-card {
    border: 1px solid color-mix(in oklab, var(--line) 82%, transparent 18%);
    border-radius: calc(var(--radius-md) * var(--layout-radius-scale, 1));
    background: color-mix(in oklab, var(--surface-1) 86%, transparent 14%);
    padding: 0.92rem 1.05rem;
  }

  .tutorial-sheet {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    padding: var(--tutorial-sheet-padding);
    border-radius: calc(var(--radius-lg) * var(--layout-radius-scale, 1));
    border: 1px solid color-mix(in oklab, var(--line) 72%, var(--brand) 28%);
    background:
      linear-gradient(90deg, color-mix(in oklab, var(--brand) 12%, transparent 88%) 0%, transparent 58%),
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--surface-1) 92%, transparent 8%),
        color-mix(in oklab, var(--surface-2) 94%, transparent 6%)
      );
    box-shadow: 0 18px 40px color-mix(in oklab, var(--bg) 78%, transparent 22%);
  }

  .tutorial-sheet-head {
    display: grid;
    gap: 0.9rem;
    padding-bottom: 1.1rem;
    border-bottom: 1px dashed color-mix(in oklab, var(--line) 70%, transparent 30%);
    margin-bottom: 1.2rem;
  }

  .tutorial-sheet-body {
    min-width: 0;
    max-width: 100%;
  }

  .tutorial-toc-rail {
    grid-area: toc;
    width: var(--tutorial-toc-width);
    position: sticky;
    top: calc(var(--layout-header-height, 68px) + 0.75rem);
    height: calc(
      100vh - var(--layout-header-height, 68px) - var(--layout-footer-height, 54px) - 1.5rem -
        var(--floating-safe-bottom, 0px)
    );
    min-width: 0;
    align-self: start;
    display: flex;
    flex-direction: column;
  }

  .tutorial-breadcrumb {
    margin-bottom: 0.35rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: color-mix(in oklab, var(--text-muted) 88%, var(--text) 12%);
  }

  .tutorial-breadcrumb a {
    color: var(--text-soft);
    text-decoration: none;
  }

  .tutorial-breadcrumb a:hover {
    color: var(--brand);
  }

  .tutorial-head {
    display: grid;
    gap: 0.75rem;
  }

  .tutorial-head h1 {
    margin: 0;
    line-height: 1.18;
    font-size: clamp(1.8rem, 2.6vw + 1rem, 2.7rem);
  }

  .summary {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.62;
    max-width: 52rem;
  }

  .meta-strip {
    border: 1px solid color-mix(in oklab, var(--line) 74%, var(--brand) 26%);
    border-radius: calc(var(--radius-md) * var(--layout-radius-scale, 1));
    background: color-mix(in oklab, var(--surface-1) 84%, transparent 16%);
    padding: 0.65rem 0.75rem;
    display: grid;
    gap: 0.5rem;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .tag-row-badge {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tag-link {
    text-decoration: none;
    transition: border-color 120ms ease, color 120ms ease;
    font-size: 0.75rem;
    padding: 0.2rem 0.58rem;
  }

  .tag-link:hover {
    border-color: color-mix(in oklab, var(--brand) 36%, var(--line) 64%);
    color: var(--brand);
  }

  .article-body {
    min-width: 0;
    max-width: 100%;
    overflow-wrap: break-word;
    font-size: clamp(1.02rem, 0.3vw + 0.98rem, 1.12rem);
    line-height: 1.78;
  }

  .article-body :global(pre),
  .article-body :global(.code-block-wrapper),
  .article-body :global(.code-block-wrapper pre),
  .article-body :global(.expressive-code),
  .article-body :global(.diagram-wrapper),
  .article-body :global(.md-tabs-nav),
  .article-body :global(.md-code-group-nav),
  .article-body :global(.md-chartjs),
  .article-body :global(.md-chartjs-host),
  .article-body :global(.md-demo-body) {
    max-width: 100%;
    overflow-x: auto;
  }

  .article-body :global(.md-tabs-nav),
  .article-body :global(.md-code-group-nav) {
    flex-wrap: nowrap;
  }

  .article-body :global(.md-tabs-tab),
  .article-body :global(.md-code-group-tab) {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .prev-next {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
  }

  .prev-next a {
    color: var(--brand);
    font-weight: 500;
    text-decoration: none;
    display: flex;
    align-items: center;
    padding: 0.55rem 0.7rem;
    border-radius: calc(var(--radius-md) * var(--layout-radius-scale, 1));
    border: 1px solid color-mix(in oklab, var(--line) 74%, transparent 26%);
    background: color-mix(in oklab, var(--surface-1) 88%, transparent 12%);
  }

  .prev-next a:hover {
    color: var(--text);
  }

  .prev-next a:last-child {
    justify-content: flex-end;
  }

  .tutorial-comment-card {
    padding: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  @media (max-width: 1280px) {
    .tutorial-reader {
      --tutorial-sidebar-width: min(var(--tutorial-sidebar-width-base, 300px), 280px);
      --tutorial-toc-width: min(var(--tutorial-toc-width-base, 260px), 240px);
      --tutorial-content-max: min(var(--tutorial-content-max-base, 900px), 860px);
    }
  }

  @media (max-width: 1100px) {
    .tutorial-reader {
      --tutorial-sidebar-width: min(var(--tutorial-sidebar-width-base, 300px), 260px);
      --tutorial-toc-width: min(var(--tutorial-toc-width-base, 260px), 220px);
      --tutorial-content-max: min(var(--tutorial-content-max-base, 900px), 820px);
    }
  }

  @media (max-width: 1024px) {
    .tutorial-reader {
      grid-template-columns: minmax(0, 1fr) !important;
      grid-template-areas: "main" !important;
    }

    .tutorial-reader .tutorial-sidebar-wrap,
    .tutorial-reader .tutorial-toc-rail {
      grid-area: auto;
    }

    .tutorial-main {
      width: 100%;
    }

    .tutorial-toc-rail {
      width: auto;
      height: auto;
      position: static;
    }
  }

  @media (max-width: 760px) {
    :global(main.container) {
      width: min(100%, calc(100% - var(--space-4)));
    }

    .tutorial-sheet {
      padding: 1.15rem;
    }

    .tutorial-card {
      padding: 0.85rem;
    }

    .tutorial-head h1 {
      font-size: clamp(1.36rem, 5vw, 1.88rem);
      line-height: 1.32;
    }

    .summary {
      font-size: 0.95rem;
      line-height: 1.55;
    }

    .meta-strip {
      padding: 0.55rem;
    }

    .prev-next {
      grid-template-columns: minmax(0, 1fr);
      gap: 0.7rem;
    }

    .prev-next a:last-child {
      justify-content: flex-start;
    }

    .article-body {
      font-size: 0.98rem;
      font-family: var(--font-regular-sans);
      letter-spacing: 0;
      line-height: 1.75;
      word-break: normal;
      overflow-wrap: break-word;
    }

    .tutorial-head h1,
    .summary,
    .meta-row,
    .tag-row-badge,
    .prev-next a {
      font-family: var(--font-regular-sans);
      letter-spacing: 0;
      text-transform: none;
    }

    .article-body :global(h1),
    .article-body :global(h2),
    .article-body :global(h3),
    .article-body :global(h4) {
      font-family: var(--font-regular-sans);
      letter-spacing: 0.01em;
      text-transform: none;
    }

    .article-body :global(pre),
    .article-body :global(.code-block-wrapper pre),
    .article-body :global(.diagram-wrapper),
    .article-body :global(.md-tabs-nav),
    .article-body :global(.md-code-group-nav),
    .article-body :global(.md-chartjs-host),
    .article-body :global(.md-demo-body) {
      max-width: 100%;
      overflow-x: auto;
    }

    .article-body :global(.md-tabs-nav),
    .article-body :global(.md-code-group-nav) {
      flex-wrap: nowrap;
    }

    .article-body :global(.md-tabs-tab),
    .article-body :global(.md-code-group-tab) {
      flex: 0 0 auto;
      white-space: nowrap;
    }

    .article-body :global(.md-demo-body) {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
