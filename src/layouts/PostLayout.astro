---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TOC from "@/components/TOC.astro";
import Comments from "@/components/Comments.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import Copyright from "@/components/Copyright.astro";
import EncryptGate from "@/components/EncryptGate.astro";
import { formatDate } from "@/utils/date";
import { absoluteUrl } from "@/utils/url";
import { buildArticleJsonLd } from "@/utils/seo";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Neighbor {
  title: string;
  url: string;
}

interface Props {
  title: string;
  summary?: string;
  description?: string;
  tags?: string[];
  pubDate: Date;
  updatedDate?: Date;
  headings?: Heading[];
  wordCount?: number;
  readingMinutes?: number;
  articleUrl: string;
  code?: string;
  githubEditUrl?: string;
  encrypted?: boolean;
  encryptedFile?: string;
  passwordHint?: string;
  prev?: Neighbor;
  next?: Neighbor;
  cover?: string;
  hideCover?: boolean;
}

const {
  title,
  summary = "",
  description = summary || title,
  tags = [],
  pubDate,
  updatedDate,
  headings = [],
  wordCount = 0,
  readingMinutes = 0,
  articleUrl,
  code = "",
  githubEditUrl,
  encrypted = false,
  encryptedFile = "",
  passwordHint = "",
  prev,
  next,
  cover,
  hideCover = false
} = Astro.props;

const deferUntilEvent = encrypted ? "site:decrypted" : undefined;
const spacing = siteConfig.article.ui.spacing;
const tocPosition = siteConfig.theme.toc.position === "left" ? "left" : "right";
const tocWidth = Number(siteConfig.theme.toc.width ?? 332);
const jsonLd = buildArticleJsonLd({
  title,
  description,
  url: absoluteUrl(articleUrl),
  datePublished: pubDate,
  dateModified: updatedDate,
  image: cover,
  tags
});
const articleRuntimeConfig = {
  isEncrypted: encrypted,
  enableMermaid: siteConfig.features.diagram.mermaid,
  enableDrawio: siteConfig.features.diagram.drawio,
  enableEcharts: siteConfig.features.diagram.echarts,
  mermaidSource: siteConfig.diagram.mermaid.source ?? "cdn",
  mermaidBundle: siteConfig.diagram.mermaid.bundleUrl,
  mermaidLocalBundle: siteConfig.diagram.mermaid.localBundle ?? "",
  mermaidTheme: siteConfig.diagram.mermaid.theme,
  drawioViewerBase: siteConfig.diagram.drawio.viewerBase,
  echartsSource: siteConfig.diagram.echarts.source ?? "cdn",
  echartsBundle: siteConfig.diagram.echarts.bundleUrl,
  echartsLocalBundle: siteConfig.diagram.echarts.localBundle ?? "",
  diagramFallbackToCdn: Boolean((siteConfig.diagram as { fallbackToCdn?: boolean }).fallbackToCdn ?? true),
  chartHeight: siteConfig.diagram.echarts.defaultHeight,
  enableEchartsThemeSync: Boolean(
    (siteConfig.diagram as { echarts?: { themeSync?: boolean } }).echarts?.themeSync ?? false
  ),
  enableCodeCopy: siteConfig.markdown.copy.code,
  enableMathCopy: siteConfig.markdown.copy.math,
  enableMermaidCopy: siteConfig.markdown.copy.mermaid,
  enableExtendedMarkdown: Boolean(
    (
      siteConfig.markdown as {
        extended?: { enable?: boolean };
      }
    ).extended?.enable ?? false
  ),
  enableChartJs: Boolean(
    (
      siteConfig.markdown as {
        extended?: { chartjs?: { enable?: boolean } };
      }
    ).extended?.chartjs?.enable ?? false
  ),
  chartJsBundle:
    (
      siteConfig.markdown as {
        extended?: { chartjs?: { bundleUrl?: string } };
      }
    ).extended?.chartjs?.bundleUrl ?? "https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js",
  enableChartJsThemeSync: Boolean(
    (
      siteConfig.markdown as {
        extended?: { chartjs?: { themeSync?: boolean } };
      }
    ).extended?.chartjs?.themeSync ?? false
  ),
  enableCodeFold: Boolean(
    (
      siteConfig.markdown as {
        extended?: { codeFold?: { enable?: boolean } };
      }
    ).extended?.codeFold?.enable ?? false
  ),
  codeFoldDefaultLines: Number(
    (
      siteConfig.markdown as {
        extended?: { codeFold?: { defaultLines?: number } };
      }
    ).extended?.codeFold?.defaultLines ?? 18
  ),
  enableCodeGroup: Boolean(
    (
      siteConfig.markdown as {
        extended?: { codeGroup?: { enable?: boolean } };
      }
    ).extended?.codeGroup?.enable ?? false
  ),
  enableDiffEnhance: Boolean(
    (
      siteConfig.markdown as {
        extended?: { diffEnhance?: { enable?: boolean } };
      }
    ).extended?.diffEnhance?.enable ?? false
  ),
  enableAnchorCopy: Boolean(
    (siteConfig.article as { anchorCopy?: { enable?: boolean } }).anchorCopy?.enable ?? false
  ),
  enableDiagramDiagnostics: Boolean(
    (siteConfig.article as { diagnostics?: { enable?: boolean } }).diagnostics?.enable ?? true
  ),
  enableInlineIcon: Boolean(
    (
      siteConfig.markdown as {
        extended?: { icon?: { enable?: boolean } };
      }
    ).extended?.icon?.enable ?? false
  ),
  iconifyBundle:
    (
      siteConfig.markdown as {
        extended?: { icon?: { bundleUrl?: string } };
      }
    ).extended?.icon?.bundleUrl ?? "https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js",
  codeHighlightProvider: String(
    (
      siteConfig as {
        codeHighlight?: { provider?: string };
      }
    ).codeHighlight?.provider ?? "prism"
  ),
  enableCodeLineNumbers: Boolean(
    (
      siteConfig as {
        codeHighlight?: { lineNumbers?: boolean };
      }
    ).codeHighlight?.lineNumbers ?? true
  ),
  codeWindowTitleMode: String(
    (
      siteConfig as {
        codeHighlight?: { window?: { titleMode?: string } };
      }
    ).codeHighlight?.window?.titleMode ?? "lang"
  ),
  articleTitle: title,
  articleTags: tags,
  viewStatsEnabled: siteConfig.stats.enable,
  viewStatsEndpoint: siteConfig.stats.endpoint,
  antiCrawlEnabled: Boolean((siteConfig.article as { antiCrawl?: { enable?: boolean } }).antiCrawl?.enable ?? false),
  antiCrawlLockOnSuspicious: Boolean(
    (siteConfig.article as { antiCrawl?: { lockOnSuspicious?: boolean } }).antiCrawl?.lockOnSuspicious ?? true
  ),
  antiCrawlMaxCopyActions: Number((siteConfig.article as { antiCrawl?: { maxCopyActions?: number } }).antiCrawl?.maxCopyActions ?? 8),
  antiCrawlTimeWindowMs: Number((siteConfig.article as { antiCrawl?: { timeWindowMs?: number } }).antiCrawl?.timeWindowMs ?? 20000)
};
---

<BaseLayout title={title} description={description} canonicalPath={articleUrl} image={cover}>
  <ReadingProgress />
  <div
    class={`grid-main post-layout post-layout-${tocPosition}`}
    style={`--toc-width:${tocWidth}px;--post-top-gap:${spacing.topBarBottom};--post-hero-gap:${spacing.heroBottom};--post-head-pt:${spacing.headPaddingTop};--post-head-pb:${spacing.headPaddingBottom};--post-head-gap:${spacing.headGap};--post-head-mb:${spacing.headBottom};--post-article-pb:${spacing.articleBottom};--post-summary-size:${spacing.summarySize};--post-p-margin:${spacing.paragraphMargin};--post-h2-top:${spacing.h2Top};--post-h2-bottom:${spacing.h2Bottom};--post-h3-top:${spacing.h3Top};--post-h3-bottom:${spacing.h3Bottom};`}
  >
    <section class="post-main">
      <section class="surface post-card-shell post-info-card">
        <div class="post-top-bar">
          <a href="javascript:history.back()" class="back-link">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            返回上一级
          </a>
        </div>

        {!hideCover && cover && (
          <div class="post-hero-image">
            <img src={cover} alt={title} loading="eager" fetchpriority="high" />
          </div>
        )}

        <header class="post-head">
          <h1>{title}</h1>
          {summary && <p class="summary">{summary}</p>}
          <div class="meta-strip">
            <div class="meta-row">
              <span class="chip">{wordCount} 字</span>
              {siteConfig.readingTime.enable && <span class="chip">{readingMinutes} 分钟</span>}
              {siteConfig.stats.enable && <span class="chip" id="post-view-count" data-view-slug={articleUrl}>阅读 --</span>}
              <span class="chip date-chip">发布 {formatDate(pubDate, "YYYY-MM-DD")}</span>
              {updatedDate && <span class="chip date-chip">更新 {formatDate(updatedDate, "YYYY-MM-DD")}</span>}
            </div>
          </div>
          {
            tags.length > 0 && (
              <div class="tag-row-badge">
                {tags.map((tag) => <a class="tag-badge tag-link" href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>)}
              </div>
            )
          }
        </header>
      </section>

      <section class="surface post-card-shell post-body-card">
        <article class="prose article-body" data-article-encrypted={encrypted ? "1" : "0"}>
          {
            encrypted && siteConfig.encrypt.enable ? (
              <EncryptGate encryptedFile={encryptedFile} passwordHint={passwordHint} />
            ) : (
              <slot />
            )
          }
        </article>
      </section>

      <section class="surface post-card-shell post-meta-card">
        <Copyright title={title} url={absoluteUrl(articleUrl)} editUrl={githubEditUrl} />

        {
          siteConfig.prevNext.enable && (prev || next) && (
            <nav class="prev-next">
              {prev ? <a href={prev.url}>← {prev.title}</a> : <span />}
              {next ? <a href={next.url}>{next.title} →</a> : <span />}
            </nav>
          )
        }
      </section>

      <section class="surface post-card-shell post-comment-card">
        <Comments deferUntilEvent={deferUntilEvent} />
      </section>
    </section>

    {!encrypted && <aside class="post-toc-rail"><TOC headings={headings} /></aside>}
  </div>

  <script id="article-runtime-config" type="application/json" set:html={JSON.stringify(articleRuntimeConfig)} />
  <script>
    import "@/scripts/article-runtime-entry.js";
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style is:global>
  @import "../styles/katex-local.css";
</style>

<style>
  :global(main.container) {
    width: min(var(--layout-post-shell-max, 1280px), calc(100% - var(--space-6)));
  }

  .post-layout {
    --post-main-width: var(--layout-post-main-width, 860px);
    --toc-width: var(--layout-post-toc-width, 332px);
    padding-bottom: 1.2rem;
    column-gap: var(--layout-post-gap, 1.7rem);
    row-gap: 1rem;
    align-items: start;
  }
  .post-layout.post-layout-right {
    grid-template-columns: minmax(0, 1fr) minmax(0, var(--post-main-width)) minmax(260px, var(--toc-width));
  }
  .post-layout.post-layout-left {
    grid-template-columns: minmax(260px, var(--toc-width)) minmax(0, var(--post-main-width)) minmax(0, 1fr);
  }
  .post-layout > section,
  .post-layout > aside {
    min-width: 0;
    align-self: start;
  }
  .post-layout > section.post-main {
    width: 100%;
    grid-column: 2;
  }
  .post-layout.post-layout-right > aside.post-toc-rail {
    grid-column: 3;
  }
  .post-layout.post-layout-left > aside.post-toc-rail {
    grid-column: 1;
  }
  .post-main {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }
  .post-main > * {
    width: 100%;
    max-width: none;
    margin: 0;
  }
  .post-card-shell {
    padding: 1.1rem 1.15rem;
    background: color-mix(in oklab, var(--surface-1) 90%, transparent 10%);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    box-shadow: var(--card-shadow);
  }
  .post-layout > aside.post-toc-rail {
    position: sticky;
    top: 84px;
    height: calc(100vh - 100px - var(--floating-safe-bottom, 0px));
  }
  .post-layout.post-layout-left > aside.post-toc-rail {
    order: -1;
  }
  @media (max-width: 1024px) {
    .post-layout,
    .post-layout.post-layout-right,
    .post-layout.post-layout-left {
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
    }
    .post-layout > section.post-main {
      grid-column: auto;
    }
    .post-layout > aside.post-toc-rail {
      position: static;
      height: auto;
      order: initial;
      grid-column: auto;
    }
    .post-card-shell {
      padding: 1rem;
    }
  }
  .post-top-bar {
    margin-bottom: var(--post-top-gap, 0.8rem);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--text-soft);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 0.5rem 0.75rem;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .back-link:hover {
    color: var(--brand);
    border-color: var(--brand);
  }
  .post-hero-image {
    margin-bottom: var(--post-hero-gap, 1.5rem);
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 10px;
  }
  .post-hero-image img {
    width: 100%;
    aspect-ratio: 16 / 8;
    object-fit: cover;
    display: block;
  }
  .post-head {
    padding: var(--post-head-pt, 0.35rem) 0 var(--post-head-pb, 0.2rem);
    display: grid;
    gap: var(--post-head-gap, 0.72rem);
  }
  .post-head h1 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(1.76rem, 2.4vw + 1rem, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.28;
    color: var(--text);
  }
  .summary {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.6;
    font-size: var(--post-summary-size, 1.125rem);
  }
  .meta-strip {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: color-mix(in oklab, var(--surface-1) 82%, transparent 18%);
    padding: 0.65rem;
  }
  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0;
    align-items: center;
  }
  .tag-row-badge {
    margin-top: 0.3rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-link {
    text-decoration: none;
    transition: border-color 120ms ease, color 120ms ease;
    font-size: 0.75rem;
    padding: 0.2rem 0.58rem;
  }
  .tag-link:hover {
    border-color: color-mix(in oklab, var(--brand) 36%, var(--line) 64%);
    color: var(--brand);
  }
  .date-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }
  .post-body-card {
    padding: 1.05rem 1.1rem;
    min-width: 0;
  }
  .article-body {
    padding: 0.08rem 0 calc(var(--post-article-pb, 1.2rem) + 0.2rem);
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    font-size: clamp(1rem, 0.2vw + 0.98rem, 1.08rem);
    min-width: 0;
    overflow-wrap: break-word;
  }
  .article-body :global(h2) {
    margin-top: var(--post-h2-top, 2.1rem);
    margin-bottom: var(--post-h2-bottom, 1rem);
  }
  .article-body :global(h3) {
    margin-top: var(--post-h3-top, 1.35rem);
    margin-bottom: var(--post-h3-bottom, 0.7rem);
  }
  .article-body :global(p) {
    margin: var(--post-p-margin, 0.92em) 0;
  }
  .article-body :global(img) {
    border-radius: 10px;
    border: 1px solid var(--line-soft);
  }
  .article-body :global(pre),
  .article-body :global(.diagram-wrapper),
  .article-body :global(.md-chartjs) {
    content-visibility: auto;
    contain-intrinsic-size: auto 320px;
  }
  .article-body :global(.md-inline-icon) {
    display: inline-flex;
    width: 1.1em;
    height: 1.1em;
    margin: 0 0.08em;
    vertical-align: -0.12em;
  }
  .article-body :global(.md-mark) {
    border-radius: 0.35rem;
    padding: 0.08em 0.42em;
    border: 1px solid transparent;
    color: inherit;
    font-weight: 600;
  }
  .article-body :global(.md-mark-tip) {
    background: color-mix(in oklab, #2f80ed 18%, transparent);
    border-color: color-mix(in oklab, #2f80ed 34%, transparent);
  }
  .article-body :global(.md-mark-warning) {
    background: color-mix(in oklab, #f59e0b 18%, transparent);
    border-color: color-mix(in oklab, #f59e0b 34%, transparent);
  }
  .article-body :global(.md-mark-danger) {
    background: color-mix(in oklab, #ef4444 17%, transparent);
    border-color: color-mix(in oklab, #ef4444 33%, transparent);
  }
  .article-body :global(.md-mark-important) {
    background: color-mix(in oklab, var(--brand) 20%, transparent);
    border-color: color-mix(in oklab, var(--brand) 36%, transparent);
  }
  .article-body :global(.md-steps) {
    list-style: none;
    margin: 1.1rem 0;
    padding: 0.2rem 0 0.2rem 0.2rem;
    counter-reset: md-steps;
    display: grid;
    gap: 0.9rem;
  }
  .article-body :global(.md-step-item) {
    counter-increment: md-steps;
    position: relative;
    border: 1px solid var(--line-soft);
    border-radius: 12px;
    padding: 0.75rem 0.8rem 0.75rem 3rem;
    background: color-mix(in oklab, var(--surface-1) 90%, transparent 10%);
  }
  .article-body :global(.md-step-item)::before {
    content: counter(md-steps);
    position: absolute;
    left: 0.8rem;
    top: 0.72rem;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 999px;
    display: inline-grid;
    place-items: center;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--brand);
    border: 1px solid color-mix(in oklab, var(--brand) 36%, transparent);
    background: color-mix(in oklab, var(--brand-soft) 72%, transparent);
  }
  .article-body :global(.md-tabs) {
    margin: 1.15rem 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: color-mix(in oklab, var(--surface-1) 92%, transparent 8%);
  }
  .article-body :global(.md-tabs-nav) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.48rem;
    border-bottom: 1px solid var(--line-soft);
    background: color-mix(in oklab, var(--surface-2) 80%, transparent 20%);
  }
  .article-body :global(.md-tabs-tab) {
    height: 30px;
    border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-soft);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0 0.7rem;
    cursor: pointer;
    transition: color 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }
  .article-body :global(.md-tabs-tab:hover) {
    color: var(--text);
    border-color: color-mix(in oklab, var(--brand) 32%, var(--line) 68%);
    background: color-mix(in oklab, var(--brand-soft) 60%, transparent 40%);
  }
  .article-body :global(.md-tabs-tab[data-active="1"]) {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 44%, var(--line) 56%);
    background: color-mix(in oklab, var(--brand-soft) 72%, transparent 28%);
  }
  .article-body :global(.md-tabs-panel) {
    padding: 0.9rem 0.95rem;
  }
  .article-body :global(.md-code-group) {
    margin: 1.15rem 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: color-mix(in oklab, var(--surface-1) 92%, transparent 8%);
  }
  .article-body :global(.md-code-group-nav) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.48rem;
    border-bottom: 1px solid var(--line-soft);
    background: color-mix(in oklab, var(--surface-2) 80%, transparent 20%);
  }
  .article-body :global(.md-code-group-tab) {
    height: 30px;
    border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text-soft);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0 0.7rem;
    cursor: pointer;
    transition: color 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }
  .article-body :global(.md-code-group-tab:hover) {
    color: var(--text);
    border-color: color-mix(in oklab, var(--brand) 32%, var(--line) 68%);
    background: color-mix(in oklab, var(--brand-soft) 60%, transparent 40%);
  }
  .article-body :global(.md-code-group-tab[data-active="1"]) {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 44%, var(--line) 56%);
    background: color-mix(in oklab, var(--brand-soft) 72%, transparent 28%);
  }
  .article-body :global(.md-code-group-panel) {
    padding: 0.45rem 0.75rem 0.75rem;
  }
  .article-body :global(.md-demo) {
    margin: 1.2rem 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: color-mix(in oklab, var(--surface-1) 92%, transparent 8%);
  }
  .article-body :global(.md-demo-head) {
    padding: 0.62rem 0.82rem;
    border-bottom: 1px solid var(--line-soft);
    font-size: 0.86rem;
    color: var(--text-soft);
    font-weight: 600;
    background: color-mix(in oklab, var(--surface-2) 82%, transparent 18%);
  }
  .article-body :global(.md-demo-body) {
    display: grid;
    gap: 0;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }
  .article-body :global(.md-demo[data-mode="stack"] .md-demo-body) {
    grid-template-columns: minmax(0, 1fr);
  }
  .article-body :global(.md-demo-source),
  .article-body :global(.md-demo-preview) {
    min-width: 0;
  }
  .article-body :global(.md-demo-source) {
    border-right: 1px solid var(--line-soft);
  }
  .article-body :global(.md-demo[data-mode="stack"] .md-demo-source) {
    border-right: none;
    border-bottom: 1px solid var(--line-soft);
  }
  .article-body :global(.md-demo-label) {
    padding: 0.48rem 0.72rem;
    font-size: 0.75rem;
    color: var(--text-soft);
    letter-spacing: 0.01em;
    border-bottom: 1px solid var(--line-soft);
    background: color-mix(in oklab, var(--surface-2) 78%, transparent 22%);
  }
  .article-body :global(.md-demo-note) {
    padding: 0.12rem 0.82rem 0.78rem;
    color: var(--text-soft);
    font-size: 0.88rem;
  }
