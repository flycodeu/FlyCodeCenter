---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TOC from "@/components/TOC.astro";
import Comments from "@/components/Comments.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import Copyright from "@/components/Copyright.astro";
import EncryptGate from "@/components/EncryptGate.astro";
import { formatDate } from "@/utils/date";
import { absoluteUrl } from "@/utils/url";
import { buildArticleJsonLd } from "@/utils/seo";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Neighbor {
  title: string;
  url: string;
}

interface Props {
  title: string;
  code?: string;
  summary?: string;
  description: string;
  tags: string[];
  pubDate: Date;
  updatedDate?: Date;
  headings?: Heading[];
  wordCount?: number;
  readingMinutes?: number;
  articleUrl: string;
  githubEditUrl?: string;
  encrypted?: boolean;
  encryptedFile?: string;
  passwordHint?: string;
  prev?: Neighbor;
  next?: Neighbor;
  cover?: string;
  hideCover?: boolean;
}

const {
  title,
  code = "",
  summary = "",
  description,
  tags,
  pubDate,
  updatedDate,
  headings = [],
  wordCount = 0,
  readingMinutes = 0,
  articleUrl,
  githubEditUrl,
  encrypted = false,
  encryptedFile = "",
  passwordHint = "",
  prev,
  next,
  cover,
  hideCover = false
} = Astro.props;

const deferUntilEvent = encrypted ? "site:decrypted" : undefined;
const jsonLd = buildArticleJsonLd({
  title,
  description,
  url: absoluteUrl(articleUrl),
  datePublished: pubDate,
  dateModified: updatedDate,
  image: cover,
  tags
});
---

<BaseLayout title={title} description={description} canonicalPath={articleUrl} image={cover}>
  <ReadingProgress />
  <div class="grid-main">
    <section>
      <div class="post-top-bar">
        <a href="javascript:history.back()" class="back-link">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          返回上一级
        </a>
      </div>
      
      {!hideCover && cover && (
        <div class="post-hero-image surface">
          <img src={cover} alt={title} loading="eager" fetchpriority="high" />
        </div>
      )}

      <header class="surface post-head">
        {code && <div class="code-row"><span class="chip code-chip">{code}</span></div>}
        <h1>{title}</h1>
        {summary && <p class="summary">{summary}</p>}
        <div class="meta-row">
          <span class="chip">{wordCount} 字</span>
          {siteConfig.readingTime.enable && <span class="chip">{readingMinutes} 分钟</span>}
          <span class="chip">发布 {formatDate(pubDate)}</span>
          {updatedDate && <span class="chip">更新 {formatDate(updatedDate)}</span>}
        </div>
        <div class="tag-row">
          {tags.map((tag) => <a class="chip tag-chip" href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>)}
        </div>
      </header>

      <article class="surface prose article-body" data-article-encrypted={encrypted ? "1" : "0"}>
        {
          encrypted && siteConfig.encrypt.enable ? (
            <EncryptGate encryptedFile={encryptedFile} passwordHint={passwordHint} />
          ) : (
            <slot />
          )
        }
      </article>

      <Copyright title={title} url={absoluteUrl(articleUrl)} editUrl={githubEditUrl} />

      {
        siteConfig.prevNext.enable && (prev || next) && (
          <nav class="surface prev-next">
            {prev ? <a href={prev.url}>← {prev.title}</a> : <span />}
            {next ? <a href={next.url}>{next.title} →</a> : <span />}
          </nav>
        )
      }

      <Comments deferUntilEvent={deferUntilEvent} />
    </section>

    {!encrypted && <aside><TOC headings={headings} /></aside>}
  </div>

  <script
    type="module"
    define:vars={{
      isEncrypted: encrypted,
      enableMermaid: siteConfig.features.diagram.mermaid,
      enableDrawio: siteConfig.features.diagram.drawio,
      enableEcharts: siteConfig.features.diagram.echarts,
      mermaidBundle: siteConfig.diagram.mermaid.bundleUrl,
      mermaidTheme: siteConfig.diagram.mermaid.theme,
      drawioViewerBase: siteConfig.diagram.drawio.viewerBase,
      echartsBundle: siteConfig.diagram.echarts.bundleUrl,
      chartHeight: siteConfig.diagram.echarts.defaultHeight
    }}
  >
    const root = document.documentElement;
    root.dataset.encryptedLocked = isEncrypted ? "1" : "0";

    if (isEncrypted) {
      window.addEventListener("site:decrypted", () => {
        root.dataset.encryptedLocked = "0";
      });
    }

    if (isEncrypted) {
      // encrypted article should not initialize rich diagram runtimes
    } else {
      const article = document.querySelector(".article-body");
      if (article) {
        const renderMermaid = async () => {
          const blocks = article.querySelectorAll("pre[data-language='mermaid'] code, pre code.language-mermaid");
          if (!blocks.length) return;

          const mod = await import(/* @vite-ignore */ mermaidBundle);
          const mermaid = mod.default ?? mod;
          mermaid.initialize({ startOnLoad: false, theme: mermaidTheme });

          let index = 0;
          for (const code of blocks) {
            const pre = code.closest("pre");
            if (!pre) continue;
            const raw = code.textContent || "";
            
            const wrapper = document.createElement("div");
            wrapper.className = "diagram-wrapper";
            
            const copyBtn = document.createElement("button");
            copyBtn.className = "diagram-copy-btn";
            copyBtn.title = "复制 Mermaid 源码";
            copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2m-8-4h8a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"/></svg>';
            copyBtn.onclick = () => {
              navigator.clipboard.writeText(raw);
              copyBtn.classList.add("copied");
              setTimeout(() => copyBtn.classList.remove("copied"), 2000);
            };
            wrapper.appendChild(copyBtn);

            const host = document.createElement("div");
            host.className = "diagram-host mermaid-host";
            wrapper.appendChild(host);
            pre.replaceWith(wrapper);

            const id = `mermaid-${index++}`;
            try {
              const result = await mermaid.render(id, raw);
              host.innerHTML = result.svg;
            } catch (error) {
              host.textContent = "Mermaid 渲染失败，请检查语法。";
              console.error(error);
            }
          }
        };

        const addMathCopy = () => {
          const displays = article.querySelectorAll(".katex-display");
          displays.forEach(display => {
            const annotation = display.querySelector("annotation[encoding='application/x-tex']");
            if (!annotation) return;
            const raw = annotation.textContent || "";
            
            display.classList.add("math-wrapper");
            const copyBtn = document.createElement("button");
            copyBtn.className = "math-copy-btn";
            copyBtn.title = "复制公式源码";
            copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2m-8-4h8a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"/></svg>';
            copyBtn.onclick = () => {
              navigator.clipboard.writeText(raw);
              copyBtn.classList.add("copied");
              setTimeout(() => copyBtn.classList.remove("copied"), 2000);
            };
            display.appendChild(copyBtn);
          });
        };

        const renderDrawio = async () => {
          const blocks = [...article.querySelectorAll("pre code")].filter((code) => {
            const raw = (code.textContent || "").trim();
            const lang = (code.getAttribute("data-language") || code.className || "").toLowerCase();
            if (lang.includes("drawio")) return true;
            return /^https?:\/\/\S+\.drawio(\?.*)?$/i.test(raw);
          });
          if (!blocks.length) return;

          for (const code of blocks) {
            const pre = code.closest("pre");
            if (!pre) continue;
            const src = (code.textContent || "").trim();
            const host = document.createElement("figure");
            host.className = "diagram-host drawio-host";

            if (!src) {
              host.textContent = "Draw.io 代码块需要填写文件 URL。";
              pre.replaceWith(host);
              continue;
            }

            const iframe = document.createElement("iframe");
            const encoded = btoa(unescape(encodeURIComponent(src)));
            iframe.src = `${drawioViewerBase}?lightbox=1&nav=1&edit=_blank#U${encoded}`;
            iframe.loading = "lazy";
            iframe.referrerPolicy = "no-referrer";
            iframe.title = "drawio diagram";
            iframe.style.width = "100%";
            iframe.style.height = "460px";
            iframe.style.border = "1px solid var(--line)";
            iframe.style.borderRadius = "12px";
            host.appendChild(iframe);

            const note = document.createElement("figcaption");
            note.innerHTML = `<a href="${src}" target="_blank" rel="noreferrer">打开原始 Draw.io 文件</a>`;
            host.appendChild(note);
            pre.replaceWith(host);
          }
        };

        const renderCharts = async () => {
          const blocks = [...article.querySelectorAll("pre code")].filter((code) => {
            const raw = (code.textContent || "").trim();
            const lang = (code.getAttribute("data-language") || code.className || "").toLowerCase();
            if (lang.includes("chart")) return true;
            if (!(lang.includes("json") || lang.includes("plain"))) return false;
            return raw.startsWith("{") && raw.includes("\"series\"");
          });
          if (!blocks.length) return;

          const mod = await import(/* @vite-ignore */ echartsBundle);
          const echarts = mod.default ?? mod;

          for (const code of blocks) {
            const pre = code.closest("pre");
            if (!pre) continue;
            const raw = (code.textContent || "{}").trim();
            const host = document.createElement("div");
            host.className = "diagram-host chart-host";
            host.style.height = `${chartHeight}px`;
            pre.replaceWith(host);

            try {
              const option = JSON.parse(raw);
              const chart = echarts.init(host);
              chart.setOption(option);
              const resize = () => chart.resize();
              window.addEventListener("resize", resize);
            } catch (error) {
              host.textContent = "图表配置 JSON 解析失败。";
              console.error(error);
            }
          }
        };

        const addMathCopy = () => {
          const displays = article.querySelectorAll(".katex-display");
          displays.forEach(display => {
            const annotation = display.querySelector("annotation[encoding='application/x-tex']");
            if (!annotation) return;
            const raw = annotation.textContent || "";
            
            display.classList.add("math-wrapper");
            const copyBtn = document.createElement("button");
            copyBtn.className = "math-copy-btn";
            copyBtn.title = "复制公式源码";
            copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2m-8-4h8a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"/></svg>';
            copyBtn.onclick = () => {
              navigator.clipboard.writeText(raw);
              copyBtn.classList.add("copied");
              setTimeout(() => copyBtn.classList.remove("copied"), 2000);
            };
            display.appendChild(copyBtn);
          });
        };

        const addImageCopy = () => {
          const images = article.querySelectorAll("img");
          images.forEach(img => {
            if (img.closest('.gallery-item')) return;
            const wrapper = document.createElement("div");
            wrapper.className = "img-wrapper";
            img.parentNode.insertBefore(wrapper, img);
            wrapper.appendChild(img);

            const copyBtn = document.createElement("button");
            copyBtn.className = "img-copy-btn";
            copyBtn.title = "复制图片链接";
            copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2m-8-4h8a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"/></svg>';
            copyBtn.onclick = () => {
              navigator.clipboard.writeText(img.src);
              copyBtn.classList.add("copied");
              setTimeout(() => copyBtn.classList.remove("copied"), 2000);
            };
            wrapper.appendChild(copyBtn);
          });
        };

        if (enableMermaid) renderMermaid().catch(console.error);
        if (enableDrawio) renderDrawio().catch(console.error);
        if (enableEcharts) renderCharts().catch(console.error);
        addMathCopy();
        addImageCopy();
        
        // Add Copy Button and Language label
        const preElements = article.querySelectorAll("pre.astro-code, pre:not([class*='mermaid']):not([class*='drawio']):not([class*='chart'])");
        preElements.forEach((pre) => {
          const lang = pre.getAttribute("data-language") || pre.className.match(/language-(\w+)/)?.[1] || "";
          if (["mermaid", "drawio", "chart"].some(l => lang.includes(l))) return;
          if (pre.closest('.code-block-wrapper')) return;
          
          const wrapper = document.createElement("div");
          wrapper.className = "code-block-wrapper";
          pre.parentNode.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const header = document.createElement("div");
          header.className = "code-block-header";
          
          const langSpan = document.createElement("span");
          langSpan.className = "code-block-lang";
          langSpan.textContent = lang;
          
          const copyBtn = document.createElement("button");
          copyBtn.className = "code-block-copy";
          copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2m-8-4h8a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"/></svg>';
          
          copyBtn.onclick = () => {
            navigator.clipboard.writeText(pre.textContent || "");
            copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 6 9 17l-5-5"/></svg>';
            copyBtn.classList.add("copied");
            setTimeout(() => {
              copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2m-8-4h8a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"/></svg>';
              copyBtn.classList.remove("copied");
            }, 2000);
          };

          header.appendChild(langSpan);
          header.appendChild(copyBtn);
          wrapper.insertBefore(header, pre);
        });
      }
    }
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style>
  .post-top-bar {
    margin-bottom: 1.5rem;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--text-soft);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 0.5rem 0.75rem;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .back-link:hover {
    color: var(--brand);
    border-color: var(--brand);
  }
  .post-head {
    padding: 2rem 0 1.5rem;
    margin-bottom: 2rem;
    display: grid;
    gap: 1rem;
    border-bottom: 1px solid var(--line);
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    border-left: none;
    border-right: none;
    border-top: none;
  }
  .code-row {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }
  .code-chip {
    font-size: 0.875rem;
    letter-spacing: 0.02em;
    color: var(--brand);
    background: var(--brand-soft);
    border: none;
  }
  .post-head h1 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--text);
  }
  .summary {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.6;
    font-size: 1.125rem;
  }
  .meta-row,
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
    align-items: center;
  }
  .tag-chip {
    color: var(--text);
    background: transparent;
    border: 1px solid var(--line);
  }
  .article-body {
    padding: 0 0 2rem 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }
  .prev-next {
    margin-top: 2rem;
    padding: 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-radius: 8px;
  }
  .prev-next a {
    color: var(--brand);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .prev-next a:hover {
    color: var(--text);
  }
  .prev-next a:last-child {
    text-align: right;
  }
  :global(.diagram-host) {
    margin: 2rem 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1rem;
    background: var(--bg-elev);
  }
  :global(.drawio-host figcaption) {
    color: var(--text-soft);
    font-size: 0.875rem;
    margin-top: 0.75rem;
    text-align: center;
  }
</style>
