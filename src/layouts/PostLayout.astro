---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TOC from "@/components/TOC.astro";
import Comments from "@/components/Comments.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import Copyright from "@/components/Copyright.astro";
import EncryptGate from "@/components/EncryptGate.astro";
import { formatDate } from "@/utils/date";
import { absoluteUrl } from "@/utils/url";
import { getTagColorVars } from "@/utils/tag-color";
import { buildArticleJsonLd } from "@/utils/seo";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Neighbor {
  title: string;
  url: string;
}

interface Props {
  title: string;
  summary?: string;
  description?: string;
  tags?: string[];
  pubDate: Date;
  updatedDate?: Date;
  headings?: Heading[];
  wordCount?: number;
  readingMinutes?: number;
  articleUrl: string;
  code?: string;
  githubEditUrl?: string;
  encrypted?: boolean;
  encryptedFile?: string;
  passwordHint?: string;
  prev?: Neighbor;
  next?: Neighbor;
  cover?: string;
  hideCover?: boolean;
}

const {
  title,
  summary = "",
  description = summary || title,
  tags = [],
  pubDate,
  updatedDate,
  headings = [],
  wordCount = 0,
  readingMinutes = 0,
  articleUrl,
  code = "",
  githubEditUrl,
  encrypted = false,
  encryptedFile = "",
  passwordHint = "",
  prev,
  next,
  cover,
  hideCover = false
} = Astro.props;

const deferUntilEvent = encrypted ? "site:decrypted" : undefined;
const spacing = siteConfig.article.ui.spacing;
const jsonLd = buildArticleJsonLd({
  title,
  description,
  url: absoluteUrl(articleUrl),
  datePublished: pubDate,
  dateModified: updatedDate,
  image: cover,
  tags
});
---

<BaseLayout title={title} description={description} canonicalPath={articleUrl} image={cover}>
  <ReadingProgress />
  <div
    class="grid-main post-layout"
    style={`--post-top-gap:${spacing.topBarBottom};--post-hero-gap:${spacing.heroBottom};--post-head-pt:${spacing.headPaddingTop};--post-head-pb:${spacing.headPaddingBottom};--post-head-gap:${spacing.headGap};--post-head-mb:${spacing.headBottom};--post-article-pb:${spacing.articleBottom};--post-summary-size:${spacing.summarySize};--post-p-margin:${spacing.paragraphMargin};--post-h2-top:${spacing.h2Top};--post-h2-bottom:${spacing.h2Bottom};--post-h3-top:${spacing.h3Top};--post-h3-bottom:${spacing.h3Bottom};`}
  >
    <section>
      <div class="post-top-bar">
        <a href="javascript:history.back()" class="back-link">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          返回上一级
        </a>
      </div>

      {!hideCover && cover && (
        <div class="post-hero-image">
          <img src={cover} alt={title} loading="eager" fetchpriority="high" />
        </div>
      )}

      <header class="post-head">
        <h1>{title}</h1>
        {summary && <p class="summary">{summary}</p>}
        <div class="meta-row">
          <span class="chip">{wordCount} 字</span>
          {siteConfig.readingTime.enable && <span class="chip">{readingMinutes} 分钟</span>}
          {siteConfig.stats.enable && <span class="chip" id="post-view-count" data-view-slug={articleUrl}>阅读 --</span>}
          <span class="chip date-chip">
            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 2v4m8-4v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"/></svg>
            创建于 {formatDate(pubDate, "YYYY/MM/DD HH:mm:ss")}
          </span>
          {updatedDate && <span class="chip date-chip"><svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 2v4m8-4v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"/></svg>更新于 {formatDate(updatedDate, "YYYY/MM/DD HH:mm:ss")}</span>}
        </div>
        {
          tags.length > 0 && (
            <div class="tag-row-badge">
              {tags.map((tag) => <a class="tag-badge tag-link" style={getTagColorVars(tag)} href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>)}
            </div>
          )
        }
      </header>

      <hr class="post-divider" />

      <article class="prose article-body" data-article-encrypted={encrypted ? "1" : "0"}>
        {
          encrypted && siteConfig.encrypt.enable ? (
            <EncryptGate encryptedFile={encryptedFile} passwordHint={passwordHint} />
          ) : (
            <slot />
          )
        }
      </article>

      <hr class="post-divider" />

      <Copyright title={title} url={absoluteUrl(articleUrl)} editUrl={githubEditUrl} />

      {
        siteConfig.prevNext.enable && (prev || next) && (
          <nav class="prev-next">
            {prev ? <a href={prev.url}>← {prev.title}</a> : <span />}
            {next ? <a href={next.url}>{next.title} →</a> : <span />}
          </nav>
        )
      }

      <Comments deferUntilEvent={deferUntilEvent} />
    </section>

    {!encrypted && <aside><TOC headings={headings} /></aside>}
  </div>

  <script
    type="module"
    define:vars={{
      isEncrypted: encrypted,
      enableMermaid: siteConfig.features.diagram.mermaid,
      enableDrawio: siteConfig.features.diagram.drawio,
      enableEcharts: siteConfig.features.diagram.echarts,
      mermaidBundle: siteConfig.diagram.mermaid.bundleUrl,
      mermaidTheme: siteConfig.diagram.mermaid.theme,
      drawioViewerBase: siteConfig.diagram.drawio.viewerBase,
      echartsBundle: siteConfig.diagram.echarts.bundleUrl,
      chartHeight: siteConfig.diagram.echarts.defaultHeight,
      enableCodeCopy: siteConfig.markdown.copy.code,
      enableMathCopy: siteConfig.markdown.copy.math,
      enableMermaidCopy: siteConfig.markdown.copy.mermaid,
      articleTitle: title,
      articleTags: tags,
      viewStatsEnabled: siteConfig.stats.enable,
      viewStatsEndpoint: siteConfig.stats.endpoint
    }}
  >
    const root = document.documentElement;
    root.dataset.encryptedLocked = isEncrypted ? "1" : "0";

    if (isEncrypted) {
      window.addEventListener("site:decrypted", () => {
        root.dataset.encryptedLocked = "0";
        initArticleEnhancements().catch(console.error);
      });
    }

    const copyIcon = '<svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2m-8-4h8a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"/></svg>';
    const successIcon = '<svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 6 9 17l-5-5"/></svg>';

    const copyWithFeedback = async (btn, text) => {
      try {
        await navigator.clipboard.writeText(text);
        btn.classList.add("copied");
        btn.innerHTML = successIcon;
        setTimeout(() => {
          btn.classList.remove("copied");
          btn.innerHTML = copyIcon;
        }, 1800);
      } catch (error) {
        console.error("copy failed", error);
      }
    };

    const createCopyBtn = (className, title, contentProvider) => {
      const btn = document.createElement("button");
      btn.className = className;
      btn.type = "button";
      btn.title = title;
      btn.innerHTML = copyIcon;
      btn.addEventListener("click", () => {
        copyWithFeedback(btn, contentProvider());
      });
      return btn;
    };

    const scheduleIdle = (task) => {
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(task, { timeout: 500 });
      } else {
        window.setTimeout(() => task({ timeRemaining: () => 8 }), 20);
      }
    };

    const getLanguage = (code) => {
      const pre = code.closest("pre");
      const raw =
        pre?.getAttribute("data-language") ||
        code.getAttribute("data-language") ||
        code.className ||
        "";
      const match = raw.match(/language-([a-z0-9-]+)/i);
      return (match?.[1] || raw).toLowerCase();
    };

    const isMermaidBlock = (code) => {
      const language = getLanguage(code);
      return language.includes("mermaid");
    };

    const isDrawioBlock = (code) => {
      const raw = (code.textContent || "").trim();
      const language = getLanguage(code);
      if (language.includes("drawio")) return true;
      return /^https?:\/\/\S+\.drawio(\?.*)?$/i.test(raw);
    };

    const isChartBlock = (code) => {
      const raw = (code.textContent || "").trim();
      const language = getLanguage(code);
      if (language.includes("chart")) return true;
      if (!(language.includes("json") || language.includes("plain"))) return false;
      return raw.startsWith("{") && raw.includes('"series"');
    };

    let mermaidRenderIndex = 0;
    let mermaidApiPromise = null;
    const getMermaidApi = async () => {
      if (!mermaidApiPromise) {
        mermaidApiPromise = import(/* @vite-ignore */ mermaidBundle).then((mod) => {
          const mermaid = mod.default ?? mod;
          mermaid.initialize({ startOnLoad: false, theme: mermaidTheme });
          return mermaid;
        });
      }
      return mermaidApiPromise;
    };

    let echartsApiPromise = null;
    const chartInstances = [];
    let chartResizeBound = false;
    const getEchartsApi = async () => {
      if (!echartsApiPromise) {
        echartsApiPromise = import(/* @vite-ignore */ echartsBundle).then((mod) => mod.default ?? mod);
      }
      return echartsApiPromise;
    };

    const bindChartResize = () => {
      if (chartResizeBound) return;
      chartResizeBound = true;
      window.addEventListener("resize", () => {
        chartInstances.forEach((chart) => {
          try {
            chart.resize();
          } catch {
            // no-op
          }
        });
      });
    };

    const renderMermaidBlock = async (code) => {
      const pre = code.closest("pre");
      if (!pre || pre.dataset.diagramEnhanced === "1") return;
      pre.dataset.diagramEnhanced = "1";
      const raw = (code.textContent || "").trim();

      const wrapper = document.createElement("div");
      wrapper.className = "diagram-wrapper";

      if (enableMermaidCopy) {
        wrapper.appendChild(createCopyBtn("diagram-copy-btn", "复制 Mermaid 源码", () => raw));
      }

      const host = document.createElement("div");
      host.className = "diagram-host mermaid-host";
      wrapper.appendChild(host);
      pre.replaceWith(wrapper);

      try {
        const mermaid = await getMermaidApi();
        const result = await mermaid.render(`mermaid-${mermaidRenderIndex++}`, raw);
        host.innerHTML = result.svg;
      } catch (error) {
        host.textContent = "Mermaid 渲染失败，请检查语法。";
        console.error(error);
      }
    };

    const addMathCopy = (article) => {
      if (!enableMathCopy) return;
      const displays = article.querySelectorAll(".katex-display");
      displays.forEach((display) => {
        if (display.querySelector(".math-copy-btn")) return;
        const annotation = display.querySelector("annotation[encoding='application/x-tex']");
        if (!annotation) return;
        const raw = annotation.textContent || "";
        display.classList.add("math-wrapper");
        display.appendChild(createCopyBtn("math-copy-btn", "复制公式源码", () => raw));
      });
    };

    const renderDrawioBlock = async (code) => {
      const pre = code.closest("pre");
      if (!pre || pre.dataset.diagramEnhanced === "1") return;
      pre.dataset.diagramEnhanced = "1";
      const src = (code.textContent || "").trim();
      const host = document.createElement("figure");
      host.className = "diagram-host drawio-host";

      if (!src) {
        host.textContent = "Draw.io 代码块需要填写文件 URL。";
        pre.replaceWith(host);
        return;
      }

      const iframe = document.createElement("iframe");
      const encoded = btoa(unescape(encodeURIComponent(src)));
      iframe.src = `${drawioViewerBase}?lightbox=1&nav=1&edit=_blank#U${encoded}`;
      iframe.loading = "lazy";
      iframe.referrerPolicy = "no-referrer";
      iframe.title = "drawio diagram";
      iframe.style.width = "100%";
      iframe.style.height = "460px";
      iframe.style.border = "1px solid var(--line)";
      iframe.style.borderRadius = "12px";
      host.appendChild(iframe);

      const note = document.createElement("figcaption");
      note.innerHTML = `<a href="${src}" target="_blank" rel="noreferrer">打开原始 Draw.io 文件</a>`;
      host.appendChild(note);
      pre.replaceWith(host);
    };

    const renderChartBlock = async (code) => {
      const pre = code.closest("pre");
      if (!pre || pre.dataset.diagramEnhanced === "1") return;
      pre.dataset.diagramEnhanced = "1";
      const raw = (code.textContent || "{}").trim();
      const host = document.createElement("div");
      host.className = "diagram-host chart-host";
      host.style.height = `${chartHeight}px`;
      pre.replaceWith(host);

      try {
        const echarts = await getEchartsApi();
        const option = JSON.parse(raw);
        const chart = echarts.init(host);
        chartInstances.push(chart);
        bindChartResize();
        chart.setOption(option);
      } catch (error) {
        host.textContent = "图表配置 JSON 解析失败。";
        console.error(error);
      }
    };

    const enhanceCodeBlock = (pre) => {
      if (pre.dataset.codeEnhanced === "1" || pre.closest(".code-block-wrapper")) return;
      const codeNode = pre.querySelector("code");
      const language = (
        pre.getAttribute("data-language") ||
        codeNode?.getAttribute("data-language") ||
        pre.className.match(/language-([a-z0-9-]+)/i)?.[1] ||
        "text"
      ).toLowerCase();
      if (["mermaid", "drawio", "chart"].some((name) => language.includes(name))) return;

      const wrapper = document.createElement("div");
      wrapper.className = "code-block-wrapper";
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const header = document.createElement("div");
      header.className = "code-block-header";

      const langSpan = document.createElement("span");
      langSpan.className = "code-block-lang";
      langSpan.textContent = language;
      header.appendChild(langSpan);

      if (enableCodeCopy) {
        const btn = createCopyBtn("code-block-copy", "复制代码", () => codeNode?.textContent || pre.textContent || "");
        header.appendChild(btn);
      }

      wrapper.insertBefore(header, pre);
      pre.dataset.codeEnhanced = "1";
    };

    const enhanceCodeBlocksInBatches = (article) => {
      const preElements = [...article.querySelectorAll("pre")].filter((pre) => pre instanceof HTMLElement);
      let index = 0;

      const step = (deadline) => {
        while (index < preElements.length) {
          const pre = preElements[index];
          const code = pre.querySelector("code");
          if (code && !isMermaidBlock(code) && !isDrawioBlock(code) && !isChartBlock(code)) {
            enhanceCodeBlock(pre);
          }
          index += 1;
          if (deadline && typeof deadline.timeRemaining === "function" && deadline.timeRemaining() < 4) {
            break;
          }
        }
        if (index < preElements.length) {
          scheduleIdle(step);
        }
      };

      scheduleIdle(step);
    };

    const observeAndRenderDiagrams = (article) => {
      const allCodeBlocks = [...article.querySelectorAll("pre code")];
      const targets = allCodeBlocks.filter((code) => {
        if (isMermaidBlock(code)) return Boolean(enableMermaid);
        if (isDrawioBlock(code)) return Boolean(enableDrawio);
        if (isChartBlock(code)) return Boolean(enableEcharts);
        return false;
      });

      if (!targets.length) return;

      const runForCode = (code) => {
        if (isMermaidBlock(code) && enableMermaid) {
          renderMermaidBlock(code).catch(console.error);
          return;
        }
        if (isDrawioBlock(code) && enableDrawio) {
          renderDrawioBlock(code).catch(console.error);
          return;
        }
        if (isChartBlock(code) && enableEcharts) {
          renderChartBlock(code).catch(console.error);
        }
      };

      if (!("IntersectionObserver" in window)) {
        targets.forEach((code) => scheduleIdle(() => runForCode(code)));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            observer.unobserve(entry.target);
            const code = entry.target;
            if (code instanceof HTMLElement) {
              scheduleIdle(() => runForCode(code));
            }
          });
        },
        { rootMargin: "220px 0px" }
      );

      targets.forEach((code) => observer.observe(code));
    };

    const initArticleEnhancements = async () => {
      if (root.dataset.encryptedLocked === "1") return;
      const article = document.querySelector(".article-body");
      if (!article) return;
      if (article.dataset.enhanced === "1") return;
      article.dataset.enhanced = "1";

      addMathCopy(article);
      observeAndRenderDiagrams(article);
      enhanceCodeBlocksInBatches(article);
    };

    const VIEW_CLIENT_KEY = "fly-view-client-id";
    const HISTORY_KEY = "fly-reading-history-v1";
    const STATE_KEY = "fly-reading-state-v1";

    const getClientId = () => {
      let id = localStorage.getItem(VIEW_CLIENT_KEY);
      if (!id) {
        id = `u-${Math.random().toString(36).slice(2, 10)}${Date.now().toString(36)}`;
        localStorage.setItem(VIEW_CLIENT_KEY, id);
      }
      return id;
    };

    const updateViewChip = (count) => {
      const chip = document.getElementById("post-view-count");
      if (!chip) return;
      chip.textContent = `阅读 ${Number(count || 0).toLocaleString("zh-CN")}`;
    };

    const syncViewStats = async () => {
      if (!viewStatsEnabled || !viewStatsEndpoint) return;
      const chip = document.getElementById("post-view-count");
      if (!(chip instanceof HTMLElement)) return;
      const slug = chip.dataset.viewSlug || location.pathname;
      if (!slug) return;

      const clientId = getClientId();

      try {
        const getResp = await fetch(`${viewStatsEndpoint}?slug=${encodeURIComponent(slug)}`, {
          headers: { "X-Client-Id": clientId }
        });
        if (getResp.ok) {
          const payload = await getResp.json();
          updateViewChip(payload?.count || 0);
        }
      } catch (error) {
        console.warn("view count get failed", error);
      }

      try {
        const postResp = await fetch(viewStatsEndpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-Client-Id": clientId
          },
          body: JSON.stringify({ slug })
        });
        if (postResp.ok) {
          const payload = await postResp.json();
          updateViewChip(payload?.count || 0);
        }
      } catch (error) {
        console.warn("view count post failed", error);
      }
    };

    const writeReadingHistory = (progress) => {
      const entry = {
        title: articleTitle,
        url: location.pathname,
        tags: articleTags,
        updatedAt: Date.now(),
        progress
      };

      const list = JSON.parse(localStorage.getItem(HISTORY_KEY) || "[]");
      const next = [entry, ...list.filter((item) => item.url !== entry.url)].slice(0, 20);
      localStorage.setItem(HISTORY_KEY, JSON.stringify(next));

      const state = JSON.parse(localStorage.getItem(STATE_KEY) || "{}");
      state[entry.url] = { progress, updatedAt: entry.updatedAt };
      localStorage.setItem(STATE_KEY, JSON.stringify(state));
    };

    const bindReadingState = () => {
      let timer = 0;
      const write = () => {
        const total = Math.max(document.body.scrollHeight - window.innerHeight, 1);
        const progress = Math.max(0, Math.min(100, Math.round((window.scrollY / total) * 100)));
        writeReadingHistory(progress);
      };

      window.addEventListener("scroll", () => {
        window.clearTimeout(timer);
        timer = window.setTimeout(write, 200);
      }, { passive: true });

      window.addEventListener("beforeunload", write);
      write();
    };

    initArticleEnhancements().catch(console.error);
    syncViewStats().catch(console.error);
    bindReadingState();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style>
  .post-top-bar {
    margin-bottom: var(--post-top-gap, 1.5rem);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--text-soft);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 0.5rem 0.75rem;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .back-link:hover {
    color: var(--brand);
    border-color: var(--brand);
  }
  .post-hero-image {
    margin-bottom: var(--post-hero-gap, 1.5rem);
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 10px;
  }
  .post-hero-image img {
    width: 100%;
    aspect-ratio: 16 / 8;
    object-fit: cover;
    display: block;
  }
  .post-head {
    padding: var(--post-head-pt, 1.4rem) 0 var(--post-head-pb, 0.9rem);
    margin-bottom: 0.3rem;
    display: grid;
    gap: var(--post-head-gap, 1rem);
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    border: none;
  }
  .post-head h1 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--text);
  }
  .summary {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.6;
    font-size: var(--post-summary-size, 1.125rem);
  }
  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
    align-items: center;
  }
  .tag-row-badge {
    margin-top: 0.45rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .tag-link {
    text-decoration: none;
    transition: transform 120ms ease, filter 120ms ease;
  }
  .tag-link:hover {
    transform: translateY(-1px);
    filter: saturate(1.06);
  }
  .date-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
  }
  .post-divider {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 0.8rem 0 1rem;
  }
  .article-body {
    padding: 0 0 var(--post-article-pb, 1.2rem) 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }
  .article-body :global(h2) {
    margin-top: var(--post-h2-top, 2.1rem);
    margin-bottom: var(--post-h2-bottom, 1rem);
  }
  .article-body :global(h3) {
    margin-top: var(--post-h3-top, 1.35rem);
    margin-bottom: var(--post-h3-bottom, 0.7rem);
  }
  .article-body :global(p) {
    margin: var(--post-p-margin, 0.92em) 0;
  }
  .prev-next {
    margin-top: 2rem;
    padding: 1rem 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid var(--line);
  }
  .prev-next a {
