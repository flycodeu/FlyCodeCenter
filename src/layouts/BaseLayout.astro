---
import siteConfig from "@/site.config";
import Header from "@/components/Header.astro";
import SearchModal from "@/components/SearchModal.astro";
import Watermark from "@/components/Watermark.astro";
import JarvisOrb from "@/components/JarvisOrb.astro";
import { makePageTitle, resolveCanonical } from "@/utils/seo";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  robots?: string;
  pagefindIgnore?: boolean;
}

const {
  title,
  description = siteConfig.site.description,
  image = siteConfig.seo.defaultOgImage,
  canonicalPath = Astro.url.pathname,
  robots = "",
  pagefindIgnore = false
} = Astro.props;
const pageTitle = makePageTitle(title);
const canonical = siteConfig.seo.canonical ? resolveCanonical(canonicalPath) : "";
const normalizePath = (value: string) => {
  const raw = String(value || "").trim() || "/";
  if (raw === "/") return "/";
  return raw.replace(/\/+$/, "") || "/";
};
const orbConfig = (siteConfig.jarvis?.floatingOrb as { excludeRoutes?: string[] } | undefined) ?? {};
const defaultOrbExcluded = siteConfig.jarvis?.route ?? "/jarvis";
const orbExcludeRoutes = (Array.isArray(orbConfig.excludeRoutes) && orbConfig.excludeRoutes.length
  ? orbConfig.excludeRoutes
  : [defaultOrbExcluded]
).map((value) => String(value || "").trim());
const currentPath = normalizePath(Astro.url.pathname);
const matchRoutePattern = (pattern: string, path: string) => {
  const normalizedPattern = normalizePath(pattern);
  if (!normalizedPattern) return false;
  if (!normalizedPattern.includes("*")) {
    return path === normalizedPattern || path.startsWith(`${normalizedPattern}/`);
  }
  const patternParts = normalizedPattern.split("/").filter(Boolean);
  const pathParts = normalizePath(path).split("/").filter(Boolean);
  if (patternParts.length !== pathParts.length) return false;
  return patternParts.every((part, index) => part === "*" || part === pathParts[index]);
};
const showJarvisOrb = !orbExcludeRoutes.some((route) => matchRoutePattern(route, currentPath));
const footerConfig = siteConfig.theme.footer as {
  message: string;
  copyright: string;
  showRuntime?: boolean;
  runtimeSince?: string;
};
const showRuntime = footerConfig.showRuntime ?? true;
const runtimeSince = String(footerConfig.runtimeSince || "2026-03-05T00:00:00+08:00");
const codeThemePanelColors = siteConfig.codeTheme.panelColors ?? {};
const typographyConfig = (siteConfig.theme as {
  typography?: { fontPresetDefault?: string; fontPresets?: Record<string, unknown> };
}).typography;
const fontPresetDefault = String(typographyConfig?.fontPresetDefault || "pixel").trim() || "pixel";
const fontPresetList = Object.keys(typographyConfig?.fontPresets ?? {}).filter((key) => key.trim());
const themePresetConfig = (siteConfig.theme as {
  preset?: {
    activePack?: string;
    activeLayout?: string;
    packs?: Record<string, { backgroundStyle?: string; surfaceStyle?: string; codeThemeMap?: Record<string, string> }>;
    layouts?: Record<
      string,
      {
        containerWidth?: number;
        mainGridGap?: number;
        mainSidebarWidth?: number;
        postShellWidth?: number;
        postMainWidth?: number;
        postTocWidth?: number;
        postGap?: number;
        tutorialShellWidth?: number;
        tutorialSidebarWidth?: number;
        tutorialTocWidth?: number;
        tutorialContentMaxWidth?: number;
        cardBorderWidth?: number;
        radiusScale?: number;
      }
    >;
  };
}).preset;
const activeThemePack = String(themePresetConfig?.activePack || "aurora").trim() || "aurora";
const activeLayoutPreset = String(themePresetConfig?.activeLayout || "balanced").trim() || "balanced";
const activePackMeta = themePresetConfig?.packs?.[activeThemePack];
const activeLayoutMeta = themePresetConfig?.layouts?.[activeLayoutPreset];
const themeBackgroundStyle = String(activePackMeta?.backgroundStyle || "aurora");
const themeSurfaceStyle = String(activePackMeta?.surfaceStyle || "grid");
const themeCodeMap = activePackMeta?.codeThemeMap ?? ((siteConfig.theme as { codeThemeMap?: Record<string, string> }).codeThemeMap ?? {});
const backgroundImageConfig = (siteConfig.theme as {
  backgroundImage?: {
    enable?: boolean;
    url?: string;
    fallbackUrl?: string;
    wallpapers?: Array<{ id?: string; name?: string; url?: string; thumbnail?: string }>;
    excludeRoutes?: string[];
    defaultWallpaperId?: string;
    initialWidth?: number;
    displayWidth?: number;
    opacity?: number;
    blur?: number;
    overlayOpacity?: number;
    saturate?: number;
    grayscale?: number;
  };
}).backgroundImage;
const backgroundImageFallbackUrl =
  String(backgroundImageConfig?.url || "").trim() || String(backgroundImageConfig?.fallbackUrl || "").trim();
const configuredWallpapers = Array.isArray(backgroundImageConfig?.wallpapers) ? backgroundImageConfig.wallpapers : [];
const normalizedWallpapers = configuredWallpapers
  .map((item, index) => {
    const url = String(item?.url || "").trim();
    if (!url) return null;
    const id = String(item?.id || `wallpaper-${index + 1}`).trim() || `wallpaper-${index + 1}`;
    return {
      id,
      name: String(item?.name || `壁纸 ${index + 1}`).trim() || `壁纸 ${index + 1}`,
      url,
      thumbnail: String(item?.thumbnail || url).trim() || url
    };
  })
  .filter((item): item is { id: string; name: string; url: string; thumbnail: string } => Boolean(item));
const defaultWallpaperId =
  String(backgroundImageConfig?.defaultWallpaperId || "").trim() || normalizedWallpapers[0]?.id || "";
const defaultWallpaper = normalizedWallpapers.find((item) => item.id === defaultWallpaperId) ?? normalizedWallpapers[0];
const backgroundExcludeRoutes = Array.isArray(backgroundImageConfig?.excludeRoutes)
  ? backgroundImageConfig.excludeRoutes.map((value) => String(value || "").trim()).filter(Boolean)
  : [];
const backgroundImageUrl = defaultWallpaper?.url || backgroundImageFallbackUrl;
const wallpaperPayload = JSON.stringify(normalizedWallpapers);
const backgroundImageInitialWidth = Math.max(320, Number(backgroundImageConfig?.initialWidth ?? 640));
const backgroundImageDisplayWidth = Math.max(backgroundImageInitialWidth, Number(backgroundImageConfig?.displayWidth ?? 1600));
const backgroundAllowedByRoute = !backgroundExcludeRoutes.some((route) => matchRoutePattern(route, currentPath));
const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));
const globalBackgroundEnable = Boolean(backgroundImageConfig?.enable && backgroundAllowedByRoute && backgroundImageUrl);
const globalBackgroundOpacity = clamp(Number(backgroundImageConfig?.opacity ?? 0.14), 0, 1);
const globalBackgroundBlur = clamp(Number(backgroundImageConfig?.blur ?? 14), 0, 40);
const globalBackgroundOverlayOpacity = clamp(Number(backgroundImageConfig?.overlayOpacity ?? 0.58), 0, 1);
const globalBackgroundSaturate = clamp(Number(backgroundImageConfig?.saturate ?? 102), 50, 180);
const globalBackgroundGrayscale = clamp(Number(backgroundImageConfig?.grayscale ?? 0), 0, 100);
const copyToastConfig = (siteConfig.ui as {
  copyToast?: {
    enable?: boolean;
    durationMs?: number;
    position?: "bottom-right" | "bottom-center";
  };
}).copyToast;
const copyToastEnable = copyToastConfig?.enable ?? true;
const copyToastDurationMs = Math.max(1000, Number(copyToastConfig?.durationMs ?? 1800));
const copyToastPosition = copyToastConfig?.position === "bottom-center" ? "bottom-center" : "bottom-right";
const perfTiering = (siteConfig.performance as {
  tiering?: {
    enable?: boolean;
    lowDeviceMemory?: number;
    lowConcurrency?: number;
    saveDataAsLow?: boolean;
  };
})?.tiering ?? {};
const globalBackgroundVars = [
  `--site-bg-opacity:${globalBackgroundOpacity}`,
  `--site-bg-blur:${globalBackgroundBlur}px`,
  `--site-bg-overlay-opacity:${globalBackgroundOverlayOpacity}`,
  `--site-bg-saturate:${globalBackgroundSaturate}%`,
  `--site-bg-grayscale:${globalBackgroundGrayscale}%`
].join(";");
const layoutCssVars = [
  `--layout-container-width:${Number(activeLayoutMeta?.containerWidth ?? 1160)}px`,
  `--layout-main-grid-gap:${Number(activeLayoutMeta?.mainGridGap ?? 32)}px`,
  `--layout-main-sidebar-width:${Number(activeLayoutMeta?.mainSidebarWidth ?? 300)}px`,
  `--layout-post-shell-max:${Number(activeLayoutMeta?.postShellWidth ?? 1280)}px`,
  `--layout-post-main-width:${Number(activeLayoutMeta?.postMainWidth ?? 860)}px`,
  `--layout-post-toc-width:${Number(activeLayoutMeta?.postTocWidth ?? 332)}px`,
  `--layout-post-gap:${Number(activeLayoutMeta?.postGap ?? 27)}px`,
  `--layout-tutorial-shell-max:${Number(activeLayoutMeta?.tutorialShellWidth ?? 1360)}px`,
  `--layout-tutorial-sidebar-width:${Number(activeLayoutMeta?.tutorialSidebarWidth ?? 320)}px`,
  `--layout-tutorial-toc-width:${Number(activeLayoutMeta?.tutorialTocWidth ?? 280)}px`,
  `--layout-tutorial-content-max:${Number(activeLayoutMeta?.tutorialContentMaxWidth ?? 780)}px`,
  `--layout-card-border-width:${Number(activeLayoutMeta?.cardBorderWidth ?? 2)}px`,
  `--layout-radius-scale:${Number(activeLayoutMeta?.radiusScale ?? 1)}`
].join(";");
const buildImageUrl = (input: string, width: number) => {
  const raw = String(input || "").trim();
  if (!raw) return raw;
  if (raw.startsWith("http://") || raw.startsWith("https://")) {
    try {
      const url = new URL(raw);
      url.searchParams.set("w", String(width));
      return url.toString();
    } catch {
      return raw;
    }
  }
  const [path, query = ""] = raw.split("?");
  const params = new URLSearchParams(query);
  params.set("w", String(width));
  const nextQuery = params.toString();
  return nextQuery ? `${path}?${nextQuery}` : path;
};
const buildImageSrcset = (input: string, sizes: number[]) => {
  const raw = String(input || "").trim();
  if (!raw) return "";
  return sizes.map((size) => `${buildImageUrl(raw, size)} ${size}w`).join(", ");
};
const backgroundImageInitialUrl = buildImageUrl(backgroundImageUrl, backgroundImageInitialWidth);
---

<!doctype html>
<html
  lang={siteConfig.site.lang}
  data-theme={siteConfig.theme.defaultTheme}
  data-default-theme={siteConfig.theme.defaultTheme}
  data-theme-list={JSON.stringify(siteConfig.theme.switchableThemes ?? siteConfig.theme.themes)}
  data-theme-pack={activeThemePack}
  data-perf="high"
  data-layout-preset={activeLayoutPreset}
  data-theme-bg-style={themeBackgroundStyle}
  data-theme-surface-style={themeSurfaceStyle}
  data-theme-code-map={JSON.stringify(themeCodeMap)}
  data-code-theme={siteConfig.codeTheme.defaultTheme}
  data-code-theme-list={JSON.stringify(siteConfig.codeTheme.themes)}
  data-code-highlight-provider={String((siteConfig as { codeHighlight?: { provider?: string } }).codeHighlight?.provider ?? "prism")}
  data-font-preset={fontPresetDefault}
  data-font-preset-list={JSON.stringify(fontPresetList.length ? fontPresetList : ["regular", "pixel"])}
  data-link-prefetch={siteConfig.shouldPrefetch ? "1" : "0"}
  style={layoutCssVars}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="icon" type="image/svg+xml" href={siteConfig.site.icon} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonical || Astro.url.toString()} />
    <meta name="twitter:card" content={siteConfig.seo.twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    {
      siteConfig.site.head.meta.map((meta) => (
        <meta name={meta.name} content={meta.content} />
      ))
    }
    {siteConfig.theme.transitions?.page && <ViewTransitions fallback="swap" />}
    <script
      is:inline
      define:vars={{
        codeThemeStorageKey: siteConfig.codeTheme.storageKey,
        codeThemePanelColorsJson: JSON.stringify(codeThemePanelColors),
        fontPresetDefault,
        fontPresetListJson: JSON.stringify(fontPresetList.length ? fontPresetList : ["regular", "pixel"]),
        perfTieringJson: JSON.stringify(perfTiering)
      }}
    >
      (() => {
        const root = document.documentElement;
        const parsePerfTiering = (input) => {
          try {
            const parsed = JSON.parse(input || "{}");
            return parsed && typeof parsed === "object" ? parsed : {};
          } catch {
            return {};
          }
        };
        const perfTiering = parsePerfTiering(perfTieringJson);
        const tieringEnabled = perfTiering.enable !== false;
        const lowDeviceMemory = Number(perfTiering.lowDeviceMemory ?? 4);
        const lowConcurrency = Number(perfTiering.lowConcurrency ?? 4);
        const saveDataAsLow = perfTiering.saveDataAsLow !== false;
        const detectPerfTier = () => {
          if (!tieringEnabled) return "high";
          const reducedMotion =
            typeof window.matchMedia === "function" &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
          const saveData = Boolean(connection && connection.saveData);
          const ua = navigator.userAgent || "";
          const isMobileUa = /Android|iPhone|iPad|iPod/i.test(ua);
          const isTouchSmall =
            typeof navigator.maxTouchPoints === "number" &&
            navigator.maxTouchPoints > 1 &&
            window.innerWidth < 768;
          const isMobile = isMobileUa || isTouchSmall;
          const deviceMemory = Number(navigator.deviceMemory || 0);
          const concurrency = Number(navigator.hardwareConcurrency || 0);
          const lowDevice =
            (deviceMemory && deviceMemory <= lowDeviceMemory) ||
            (concurrency && concurrency <= lowConcurrency);
          if (reducedMotion) return "low";
          if (isMobile) return "low";
          if (saveDataAsLow && saveData) return "low";
          if (lowDevice) return "low";
          return "high";
        };
        const perfTier = detectPerfTier();
        root.dataset.perf = perfTier;
        window.__flyPerfTier = perfTier;
        const key = "flycode-theme";
        const explicitKey = "flycode-theme-explicit";
        const codeThemeKey = codeThemeStorageKey;
        const codeThemeExplicitKey = `${codeThemeStorageKey}-explicit`;
        const codeThemePanelColors = (() => {
          try {
            const parsed = JSON.parse(codeThemePanelColorsJson || "{}");
            return parsed && typeof parsed === "object" ? parsed : {};
          } catch {
            return {};
          }
        })();
        const fallback = root.dataset.defaultTheme || "aurora-light";
        const parseFontPresetList = (input) => {
          try {
            const parsed = JSON.parse(input || "[]");
            if (!Array.isArray(parsed)) return [];
            return parsed.filter((item) => typeof item === "string" && item.trim());
          } catch {
            return [];
          }
        };
        const configuredFontPresetList = parseFontPresetList(fontPresetListJson);
        let fontPresetList = parseFontPresetList(root.dataset.fontPresetList || "[]");
        if (!fontPresetList.length) {
          fontPresetList = configuredFontPresetList;
        }
        if (!fontPresetList.length) {
          fontPresetList = ["regular", "pixel"];
        }
        const normalizeFontPreset = (input) => {
          const value = String(input || "").trim();
          if (fontPresetList.includes(value)) return value;
          if (fontPresetList.includes(fontPresetDefault)) return fontPresetDefault;
          return fontPresetList[0];
        };
        let themeList = [];
        try {
          const parsed = JSON.parse(root.dataset.themeList || "[]");
          if (Array.isArray(parsed)) {
            themeList = parsed.filter((item) => typeof item === "string" && item.trim());
          }
        } catch {}

        if (!themeList.length) themeList = [fallback];

        const hasExplicitTheme = () => localStorage.getItem(explicitKey) === "1";
        const readSavedTheme = () => (hasExplicitTheme() ? localStorage.getItem(key) : null);

        const normalizeTheme = (input) => {
          const value = String(input || "").trim();
          if (themeList.includes(value)) return value;
          return themeList.includes(fallback) ? fallback : themeList[0];
        };

        const saved = readSavedTheme();
        const next = normalizeTheme(saved || root.dataset.theme || fallback);
        const nextFontPreset = normalizeFontPreset(root.dataset.fontPreset || fontPresetDefault);
        let codeThemeList = [];
        try {
          const parsed = JSON.parse(root.dataset.codeThemeList || "[]");
          if (Array.isArray(parsed)) {
            codeThemeList = parsed.filter((item) => typeof item === "string" && item.trim());
          }
        } catch {}
        const codeFallback = root.dataset.codeTheme || "github-light";
        const themeCodeMap = (() => {
          try {
            const parsed = JSON.parse(root.dataset.themeCodeMap || "{}");
            return parsed && typeof parsed === "object" ? parsed : {};
          } catch {
            return {};
          }
        })();
        const normalizeCodeTheme = (input) => {
          const value = String(input || "").trim();
          if (codeThemeList.includes(value)) return value;
          if (codeThemeList.includes(codeFallback)) return codeFallback;
          return codeThemeList.length ? codeThemeList[0] : "github-light";
        };
        const mapCodeThemeFromSiteTheme = (theme) => {
          const key = String(theme || "").trim();
          if (key && typeof themeCodeMap[key] === "string" && String(themeCodeMap[key]).trim()) {
            return String(themeCodeMap[key]).trim();
          }
          const normalized = key.toLowerCase();
          if (normalized.includes("dark")) return "mac-dark";
          if (normalized.includes("light")) return "mac-light";
          return codeFallback;
        };
        const isExpressiveProvider =
          String(root.dataset.codeHighlightProvider || "")
            .trim()
            .toLowerCase() === "expressive";
        const resolveExpressiveTheme = (siteTheme) => {
          const normalized = String(siteTheme || "").trim().toLowerCase();
          return normalized.includes("dark") ? "github-dark" : "github-light";
        };
        const syncExpressiveCodeTheme = (targetDocument = document, siteThemeForSync = root.dataset.theme || fallback) => {
          if (!isExpressiveProvider) return;
          if (!(targetDocument instanceof Document)) return;
          const expressiveTheme = resolveExpressiveTheme(siteThemeForSync);
          targetDocument.querySelectorAll(".expressive-code").forEach((block) => {
            if (block instanceof HTMLElement) {
              block.dataset.theme = expressiveTheme;
            }
          });
        };
        const resolveCodeTheme = (themeForAuto) => {
          const mapped = mapCodeThemeFromSiteTheme(themeForAuto || root.dataset.theme || fallback);
          return normalizeCodeTheme(mapped);
        };
        const savedCodeTheme = localStorage.getItem(codeThemeKey);
        const nextCodeTheme = resolveCodeTheme(next);
        // Migrate historical manual code-theme lock so code blocks follow site theme consistently.
        if (localStorage.getItem(codeThemeExplicitKey) === "1") {
          localStorage.removeItem(codeThemeExplicitKey);
        }
        const applyCodeThemePanelColors = (theme, targetRoot = root) => {
          const palette =
            codeThemePanelColors?.[theme] ||
            codeThemePanelColors?.[codeFallback] ||
            codeThemePanelColors?.["github-light"];
          if (!palette || !targetRoot?.style) return;
          if (typeof palette.panel === "string" && palette.panel.trim()) {
            targetRoot.style.setProperty("--code-panel", palette.panel);
          }
          if (typeof palette.border === "string" && palette.border.trim()) {
            targetRoot.style.setProperty("--code-border", palette.border);
          }
          if (typeof palette.header === "string" && palette.header.trim()) {
            targetRoot.style.setProperty("--code-header", palette.header);
          }
        };
        const syncCodeThemeWithSiteTheme = (themeForAuto) => {
          const targetCodeTheme = resolveCodeTheme(themeForAuto);
          if (root.dataset.codeTheme !== targetCodeTheme) {
            root.dataset.codeTheme = targetCodeTheme;
          }
          applyCodeThemePanelColors(targetCodeTheme);
          localStorage.setItem(codeThemeKey, targetCodeTheme);
        };

        root.dataset.theme = next;
        root.dataset.fontPreset = nextFontPreset;
        root.dataset.fontPresetList = JSON.stringify(fontPresetList);
        root.dataset.codeTheme = nextCodeTheme;
        applyCodeThemePanelColors(nextCodeTheme);
        syncExpressiveCodeTheme(document, next);
        if (saved !== next || !saved) {
          localStorage.setItem(key, next);
        }
        if (savedCodeTheme !== nextCodeTheme || !savedCodeTheme) {
          localStorage.setItem(codeThemeKey, nextCodeTheme);
        }

        document.addEventListener("astro:before-swap", (event) => {
          const nextDocument = event?.detail?.newDocument;
          if (!(nextDocument instanceof Document)) return;
          const current = normalizeTheme(root.dataset.theme || readSavedTheme() || fallback);
          const nextRoot = nextDocument.documentElement;
          nextRoot.dataset.theme = current;
          nextRoot.dataset.perf = root.dataset.perf || "high";
          nextRoot.dataset.defaultTheme = root.dataset.defaultTheme || fallback;
          nextRoot.dataset.themeList = root.dataset.themeList || "[]";
          nextRoot.dataset.themePack = root.dataset.themePack || nextRoot.dataset.themePack || "aurora";
          nextRoot.dataset.layoutPreset = root.dataset.layoutPreset || nextRoot.dataset.layoutPreset || "balanced";
          nextRoot.dataset.themeBgStyle = root.dataset.themeBgStyle || nextRoot.dataset.themeBgStyle || "aurora";
          nextRoot.dataset.themeSurfaceStyle = root.dataset.themeSurfaceStyle || nextRoot.dataset.themeSurfaceStyle || "grid";
          nextRoot.dataset.themeCodeMap = root.dataset.themeCodeMap || nextRoot.dataset.themeCodeMap || "{}";
          nextRoot.dataset.fontPreset = normalizeFontPreset(root.dataset.fontPreset || fontPresetDefault);
          nextRoot.dataset.fontPresetList = root.dataset.fontPresetList || JSON.stringify(fontPresetList);
          const nextCodeTheme = resolveCodeTheme(current);
          nextRoot.dataset.codeTheme = nextCodeTheme;
          nextRoot.dataset.codeThemeList = root.dataset.codeThemeList || "[]";
          applyCodeThemePanelColors(nextCodeTheme, nextRoot);
          syncExpressiveCodeTheme(nextDocument, current);
          if (hasExplicitTheme()) {
            localStorage.setItem(key, current);
          }
        });

        document.addEventListener("astro:page-load", () => {
          const current = normalizeTheme(readSavedTheme() || root.dataset.theme || fallback);
          root.dataset.theme = current;
          root.dataset.fontPreset = normalizeFontPreset(root.dataset.fontPreset || fontPresetDefault);
          syncCodeThemeWithSiteTheme(current);
          syncExpressiveCodeTheme(document, current);
        });

        window.addEventListener("site:theme-change", (event) => {
          const nextTheme = normalizeTheme(event?.detail || root.dataset.theme || fallback);
          root.dataset.theme = nextTheme;
          if (!hasExplicitTheme()) {
            localStorage.setItem(key, nextTheme);
          }
          syncCodeThemeWithSiteTheme(nextTheme);
          syncExpressiveCodeTheme(document, nextTheme);
        });

        const observer = new MutationObserver(() => {
          syncCodeThemeWithSiteTheme(normalizeTheme(root.dataset.theme || fallback));
        });
        observer.observe(root, {
          attributes: true,
          attributeFilter: ["data-code-theme", "data-theme"]
        });

        root.dataset.encryptedLocked = "0";
      })();
    </script>
  </head>
  <body data-pagefind-ignore={pagefindIgnore ? "all" : undefined}>
    <div
      id="site-bg-image"
      class="site-bg-image"
      data-enabled={globalBackgroundEnable ? "1" : "0"}
      data-wallpapers={wallpaperPayload}
      data-default-wallpaper={defaultWallpaperId}
      data-wallpaper-storage-key="flycode-wallpaper-id"
      data-display-width={String(backgroundImageDisplayWidth)}
      style={globalBackgroundVars}
      aria-hidden="true"
    >
      {globalBackgroundEnable && (
        <img
          id="site-bg-image-el"
          src={backgroundImageInitialUrl}
          alt=""
          loading="lazy"
          decoding="async"
          fetchpriority="low"
        />
      )}
    </div>
    <div class="site-bg-overlay" data-enabled={globalBackgroundEnable ? "1" : "0"} style={globalBackgroundVars} aria-hidden="true"></div>
    <div class="aurora-bg" data-style={themeBackgroundStyle} aria-hidden="true">
      <span class="aurora-orb orb-a"></span>
      <span class="aurora-orb orb-b"></span>
      <span class="aurora-orb orb-c"></span>
    </div>
    {siteConfig.watermark.enable && siteConfig.watermark.scope === "global" && <Watermark scope="global" />}
    <Header />
    <main class="container" data-pagefind-ignore={pagefindIgnore ? "all" : undefined}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>{footerConfig.message}</p>
        <div class="footer-meta">
          {
            showRuntime && (
              <small class="footer-runtime" id="site-runtime" data-runtime-since={runtimeSince}>
                已运行 -- 天 --:--:--
              </small>
            )
          }
          <small>{footerConfig.copyright}</small>
        </div>
      </div>
    </footer>
    <SearchModal />
    {showJarvisOrb && <JarvisOrb />}
    {copyToastEnable && (
      <div
        id="global-copy-toast"
        class={`global-copy-toast ${copyToastPosition}`}
        role="status"
        aria-live="polite"
        aria-atomic="true"
        aria-hidden="true"
        data-duration-ms={String(copyToastDurationMs)}
      ></div>
    )}
    <script>
      import "@/scripts/base-layout-runtime.js";
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  :global(html) {
    --layout-header-height: 72px;
    --layout-footer-height: 56px;
  }

  :global(body) {
    min-height: 100dvh;
  }

  main {
    padding: calc(var(--layout-header-height) + 1.05rem) 0 calc(var(--layout-footer-height) + 0.95rem);
    position: relative;
    z-index: 2;
  }
  .site-footer {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    border-top: 1px solid color-mix(in oklab, var(--line) 84%, transparent 16%);
    z-index: 58;
    background: color-mix(in oklab, var(--bg-elev) 90%, transparent 10%);
    backdrop-filter: blur(12px);
  }
  .footer-inner {
    min-height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-soft);
    font-size: 0.8rem;
    font-family: var(--font-sans);
    line-height: 1.25;
  }
  .footer-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
  }
  .footer-runtime {
    font-variant-numeric: tabular-nums;
    opacity: 0.92;
  }
  .footer-inner p,
  .footer-inner small {
    margin: 0;
  }

  .site-bg-image,
  .site-bg-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .site-bg-image[data-enabled="0"],
  .site-bg-overlay[data-enabled="0"] {
    display: none;
  }

  .site-bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: var(--site-bg-opacity, 0.14);
    filter: blur(var(--site-bg-blur, 14px)) saturate(var(--site-bg-saturate, 102%))
      grayscale(var(--site-bg-grayscale, 0%));
    transform: scale(1.06);
    transform-origin: center;
    transition: opacity 220ms ease, transform 320ms ease;
  }

  .site-bg-image img.is-switching {
    opacity: 0.05;
    transform: scale(1.1);
  }

  .site-bg-overlay {
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--bg) 54%, transparent 46%),
        color-mix(in oklab, var(--bg) 86%, transparent 14%)
      ),
      radial-gradient(60% 60% at 50% 0%, color-mix(in oklab, var(--brand-soft) 10%, transparent 90%), transparent 74%);
    opacity: var(--site-bg-overlay-opacity, 0.42);
  }

  .aurora-bg {
    position: fixed;
    inset: -20vh -20vw;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
    filter: blur(44px);
  }

  .aurora-orb {
    position: absolute;
    border-radius: 999px;
    opacity: 0.16;
    animation: aurora-float 18s ease-in-out infinite;
  }

  .orb-a {
    width: 38vw;
    height: 38vw;
    min-width: 320px;
    min-height: 320px;
    left: 0;
    top: 8%;
    background: color-mix(in oklab, var(--brand) 52%, transparent 48%);
  }

  .orb-b {
    width: 30vw;
    height: 30vw;
    min-width: 260px;
    min-height: 260px;
    right: 6%;
    top: 3%;
    background: color-mix(in oklab, var(--accent) 48%, transparent 52%);
    animation-delay: -6s;
  }

  .orb-c {
    width: 26vw;
    height: 26vw;
    min-width: 220px;
    min-height: 220px;
    left: 28%;
    bottom: 10%;
    background: color-mix(in oklab, var(--brand) 40%, transparent 60%);
    animation-delay: -11s;
  }

  .aurora-bg[data-style="none"] {
    display: none;
  }

  .aurora-bg[data-style="mesh"] {
    filter: blur(56px) saturate(108%);
  }

  .aurora-bg[data-style="mesh"] .orb-a {
    width: 44vw;
    height: 40vw;
    left: -4%;
    top: -4%;
    background: color-mix(in oklab, var(--brand) 44%, transparent 56%);
  }

  .aurora-bg[data-style="mesh"] .orb-b {
    width: 36vw;
    height: 32vw;
    right: -4%;
    top: 8%;
    background: color-mix(in oklab, var(--accent) 40%, transparent 60%);
  }

  .aurora-bg[data-style="mesh"] .orb-c {
    width: 48vw;
    height: 34vw;
    left: 18%;
    bottom: -8%;
    background: color-mix(in oklab, var(--brand-soft) 42%, transparent 58%);
  }

  .aurora-bg[data-style="flare"] {
    filter: blur(62px) saturate(118%);
  }

  .aurora-bg[data-style="flare"] .orb-a {
    width: 42vw;
    height: 38vw;
    left: 6%;
    top: 12%;
    background: color-mix(in oklab, var(--brand) 50%, transparent 50%);
  }

  .aurora-bg[data-style="flare"] .orb-b {
    width: 34vw;
    height: 34vw;
    right: 4%;
    top: 0;
    background: color-mix(in oklab, var(--accent) 52%, transparent 48%);
  }

  .aurora-bg[data-style="flare"] .orb-c {
    width: 22vw;
    height: 22vw;
    left: 38%;
    bottom: 4%;
    background: color-mix(in oklab, var(--brand-soft) 34%, transparent 66%);
  }

  @keyframes aurora-float {
    0% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(2.5vw, -1.8vh, 0) scale(1.06);
    }
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  .global-copy-toast {
    position: fixed;
    bottom: calc(var(--layout-footer-height) + 16px);
    z-index: 120;
    max-width: min(60vw, 320px);
    padding: 0.52rem 0.78rem;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in oklab, var(--brand) 40%, var(--line) 60%);
    color: var(--text);
    background: color-mix(in oklab, var(--bg-elev) 90%, transparent 10%);
    box-shadow: 0 8px 20px color-mix(in oklab, var(--bg) 75%, transparent 25%);
    backdrop-filter: blur(8px);
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.01em;
    font-family: var(--font-tech);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease;
    pointer-events: none;
  }

  .global-copy-toast.bottom-right {
    right: 18px;
  }

  .global-copy-toast.bottom-center {
    left: 50%;
    transform: translateX(-50%) translateY(8px);
  }

  .global-copy-toast.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .global-copy-toast.bottom-center.is-visible {
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 900px) {
    .site-footer {
      backdrop-filter: none;
      background: color-mix(in oklab, var(--surface-2) 97%, var(--bg) 3%);
    }

    .site-bg-image,
    .site-bg-overlay,
    .aurora-bg {
      display: none !important;
    }
  }

  @media (max-width: 760px) {
    .global-copy-toast {
      left: 12px;
      right: 12px;
      bottom: calc(var(--layout-footer-height) + 10px);
      max-width: none;
    }
    .global-copy-toast.bottom-center,
    .global-copy-toast.bottom-right {
      left: 12px;
      right: 12px;
      transform: translateY(8px);
    }
    .global-copy-toast.bottom-center.is-visible,
    .global-copy-toast.bottom-right.is-visible {
      transform: translateY(0);
    }
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
      padding: 0.35rem 0;
    }
    .footer-meta {
      flex-wrap: wrap;
      gap: 0.3rem 0.9rem;
    }
  }
</style>
