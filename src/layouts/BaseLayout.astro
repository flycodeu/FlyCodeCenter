---
import siteConfig from "@/site.config";
import Header from "@/components/Header.astro";
import SearchModal from "@/components/SearchModal.astro";
import Watermark from "@/components/Watermark.astro";
import JarvisOrb from "@/components/JarvisOrb.astro";
import { makePageTitle, resolveCanonical } from "@/utils/seo";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
}

const {
  title,
  description = siteConfig.site.description,
  image = siteConfig.seo.defaultOgImage,
  canonicalPath = Astro.url.pathname
} = Astro.props;
const pageTitle = makePageTitle(title);
const canonical = siteConfig.seo.canonical ? resolveCanonical(canonicalPath) : "";
const showJarvisOrb = Astro.url.pathname !== (siteConfig.jarvis?.route ?? "/jarvis");
---

<!doctype html>
<html
  lang={siteConfig.site.lang}
  data-theme={siteConfig.theme.defaultTheme}
  data-default-theme={siteConfig.theme.defaultTheme}
  data-theme-list={JSON.stringify(siteConfig.theme.switchableThemes ?? siteConfig.theme.themes)}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={siteConfig.site.icon} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonical || Astro.url.toString()} />
    <meta name="twitter:card" content={siteConfig.seo.twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    {
      siteConfig.site.head.meta.map((meta) => (
        <meta name={meta.name} content={meta.content} />
      ))
    }
    {siteConfig.theme.transitions?.page && <ViewTransitions fallback="swap" />}
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const key = "flycode-theme";
        const explicitKey = "flycode-theme-explicit";
        const fallback = root.dataset.defaultTheme || "plume";
        let themeList = [];
        try {
          const parsed = JSON.parse(root.dataset.themeList || "[]");
          if (Array.isArray(parsed)) {
            themeList = parsed.filter((item) => typeof item === "string" && item.trim());
          }
        } catch {}

        if (!themeList.length) themeList = [fallback];

        const hasExplicitTheme = () => localStorage.getItem(explicitKey) === "1";
        const readSavedTheme = () => (hasExplicitTheme() ? localStorage.getItem(key) : null);

        const normalizeTheme = (input) => {
          const value = String(input || "").trim();
          if (themeList.includes(value)) return value;
          return themeList.includes(fallback) ? fallback : themeList[0];
        };

        const saved = readSavedTheme();
        const next = normalizeTheme(saved || root.dataset.theme || fallback);

        root.dataset.theme = next;
        if (saved !== next || !saved) {
          localStorage.setItem(key, next);
        }

        document.addEventListener("astro:before-swap", (event) => {
          const nextDocument = event?.detail?.newDocument;
          if (!(nextDocument instanceof Document)) return;
          const current = normalizeTheme(root.dataset.theme || readSavedTheme() || fallback);
          const nextRoot = nextDocument.documentElement;
          nextRoot.dataset.theme = current;
          nextRoot.dataset.defaultTheme = root.dataset.defaultTheme || fallback;
          nextRoot.dataset.themeList = root.dataset.themeList || "[]";
          if (hasExplicitTheme()) {
            localStorage.setItem(key, current);
          }
        });

        document.addEventListener("astro:page-load", () => {
          const current = normalizeTheme(readSavedTheme() || root.dataset.theme || fallback);
          root.dataset.theme = current;
        });

        root.dataset.encryptedLocked = "0";
      })();
    </script>
  </head>
  <body>
    <div class="aurora-bg" aria-hidden="true">
      <span class="aurora-orb orb-a"></span>
      <span class="aurora-orb orb-b"></span>
      <span class="aurora-orb orb-c"></span>
    </div>
    {siteConfig.watermark.enable && <Watermark />}
    <Header />
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>{siteConfig.theme.footer.message}</p>
        <small>{siteConfig.theme.footer.copyright}</small>
      </div>
    </footer>
    <SearchModal />
    {showJarvisOrb && <JarvisOrb />}
    <script is:inline>
      const initFloatingSafeArea = () => {
        const root = document.documentElement;
        const update = () => {
          const footer = document.querySelector(".site-footer");
          if (!(footer instanceof HTMLElement)) {
            root.style.setProperty("--floating-safe-bottom", "0px");
            return;
          }
          const rect = footer.getBoundingClientRect();
          const overlap = Math.max(0, window.innerHeight - rect.top + 12);
          const safe = Math.min(overlap, rect.height + 24);
          root.style.setProperty("--floating-safe-bottom", `${safe}px`);
        };

        let ticking = false;
        const requestUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(() => {
            update();
            ticking = false;
          });
        };

        if (!window.__flyFloatingSafeBound) {
          window.__flyFloatingSafeBound = true;
          window.addEventListener("scroll", requestUpdate, { passive: true });
          window.addEventListener("resize", requestUpdate);
        }
        requestUpdate();
      };

      const initGlobalCodeCopy = () => {
        const icon =
          '<svg viewBox="0 0 24 24" width="14" height="14"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2m-8-4h8a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"/></svg>';
        const success =
          '<svg viewBox="0 0 24 24" width="14" height="14"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 6 9 17l-5-5"/></svg>';

        const copy = async (button, text) => {
          try {
            await navigator.clipboard.writeText(text);
            button.innerHTML = success;
            button.classList.add("copied");
            window.setTimeout(() => {
              button.innerHTML = icon;
              button.classList.remove("copied");
            }, 1400);
          } catch (error) {
            console.error("global pre copy failed", error);
          }
        };

        document.querySelectorAll("main pre").forEach((pre) => {
          if (!(pre instanceof HTMLElement)) return;
          if (pre.closest(".article-body")) return;
          if (pre.querySelector(".global-pre-copy")) return;

          const code = pre.querySelector("code");
          const text = (code?.textContent || pre.textContent || "").trim();
          if (!text) return;

          pre.classList.add("has-global-copy");
          const button = document.createElement("button");
          button.type = "button";
          button.className = "global-pre-copy";
          button.title = "复制代码";
          button.ariaLabel = "复制代码";
          button.innerHTML = icon;
          button.addEventListener("click", () => copy(button, text));
          pre.appendChild(button);
        });
      };

      document.addEventListener("astro:page-load", () => {
        document.body.classList.remove("has-overlay");
        for (const dialog of document.querySelectorAll("dialog[open]")) {
          if (dialog instanceof HTMLDialogElement) {
            try {
              dialog.close();
            } catch {}
          }
        }
        initGlobalCodeCopy();
        initFloatingSafeArea();
      });
      initGlobalCodeCopy();
      initFloatingSafeArea();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  main {
    padding: 1rem 0 1.3rem;
    position: relative;
    z-index: 1;
  }
  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: 1.1rem;
    position: relative;
    z-index: 1;
    background: color-mix(in oklab, var(--bg-elev) 84%, transparent 16%);
    backdrop-filter: blur(10px);
  }
  .footer-inner {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-soft);
    font-size: 0.88rem;
  }
  .footer-inner p,
  .footer-inner small {
    margin: 0;
  }

  .aurora-bg {
    position: fixed;
    inset: -20vh -20vw;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    filter: blur(54px);
  }

  .aurora-orb {
    position: absolute;
    border-radius: 999px;
    opacity: 0.34;
    animation: aurora-float 16s ease-in-out infinite;
  }

  .orb-a {
    width: 38vw;
    height: 38vw;
    min-width: 320px;
    min-height: 320px;
    left: 0;
    top: 8%;
    background: color-mix(in oklab, var(--brand) 68%, transparent 32%);
  }

  .orb-b {
    width: 30vw;
    height: 30vw;
    min-width: 260px;
    min-height: 260px;
    right: 6%;
    top: 3%;
    background: color-mix(in oklab, var(--accent) 60%, transparent 40%);
    animation-delay: -6s;
  }

  .orb-c {
    width: 26vw;
    height: 26vw;
    min-width: 220px;
    min-height: 220px;
    left: 28%;
    bottom: 10%;
    background: color-mix(in oklab, #0ea5e9 62%, transparent 38%);
    animation-delay: -11s;
  }

  @keyframes aurora-float {
    0% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(2.5vw, -1.8vh, 0) scale(1.06);
    }
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
  }
  @media (max-width: 760px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 0.65rem 0;
    }
  }
</style>
