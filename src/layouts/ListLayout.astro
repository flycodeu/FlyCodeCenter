---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SidebarProfile from "@/components/SidebarProfile.astro";
import StatsCard from "@/components/StatsCard.astro";
import TagCloud from "@/components/TagCloud.astro";

interface TaxItem {
  name: string;
  count: number;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  stats?: Array<{ title: string; value: string | number; href?: string }>;
  tags?: TaxItem[];
  hideSidebar?: boolean;
}

const { title, description, stats = [], tags = [], hideSidebar = false } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class={`grid-main ${hideSidebar ? "no-side" : ""}`}>
    <section class="list-main">
      <header class="surface page-hero fade-up">
        <h1>{title}</h1>
        {description && <p>{description}</p>}
      </header>
      <slot />
    </section>

    {
      !hideSidebar && (
        <aside class="list-side">
          <SidebarProfile />
          <div class="stats-grid">
            {stats.map((item) => <StatsCard title={item.title} value={item.value} href={item.href} />)}
          </div>
        </aside>
      )
    }
  </div>
</BaseLayout>

<style>
  .list-main {
    display: grid;
    gap: 1.25rem;
  }
  .page-hero {
    padding: 1.5rem 2rem;
    position: relative;
    overflow: hidden;
    background: var(--bg-elev);
    border-radius: 12px;
  }
  .page-hero::after {
    content: "";
    position: absolute;
    width: 200px;
    height: 200px;
    right: -60px;
    top: -80px;
    border-radius: 999px;
    background: radial-gradient(circle at center, var(--brand-soft), transparent 70%);
    opacity: 0.5;
  }
  .page-hero h1 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .page-hero p {
    margin: 0.5rem 0 0;
    color: var(--text-soft);
    max-width: 68ch;
    font-size: 1.0625rem;
    line-height: 1.6;
  }
  .list-side {
    display: grid;
    gap: 1.25rem;
    align-content: start;
    position: sticky;
    top: 84px;
    height: fit-content;
  }
  .stats-grid {
    display: grid;
    gap: 0.75rem;
  }
  .no-side {
    grid-template-columns: minmax(0, 1fr);
  }
  @media (max-width: 1024px) {
    .list-side {
      position: static;
      top: auto;
    }
  }
</style>
