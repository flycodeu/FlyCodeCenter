---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SidebarProfile from "@/components/SidebarProfile.astro";
import StatsCard from "@/components/StatsCard.astro";
import TagCloud from "@/components/TagCloud.astro";

interface TaxItem {
  name: string;
  count: number;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  stats: Array<{ title: string; value: string | number; href?: string }>;
  tags: TaxItem[];
  hideSidebar?: boolean;
}

const { title, description, stats, tags, hideSidebar = false } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class={`grid-main ${hideSidebar ? "no-side" : ""}`}>
    <section class="list-main">
      <header class="surface page-hero fade-up">
        <h1>{title}</h1>
        {description && <p>{description}</p>}
      </header>
      <slot />
    </section>

    {
      !hideSidebar && (
        <aside class="list-side">
          <SidebarProfile />
          <div class="stats-grid">
            {stats.map((item) => <StatsCard title={item.title} value={item.value} href={item.href} />)}
          </div>
          <TagCloud title="热门标签" items={tags.slice(0, 24)} />
        </aside>
      )
    }
  </div>
</BaseLayout>

<style>
  .list-main {
    display: grid;
    gap: 0.56rem;
  }
  .page-hero {
    padding: 0.72rem;
    position: relative;
    overflow: hidden;
  }
  .page-hero::after {
    content: "";
    position: absolute;
    width: 170px;
    height: 170px;
    right: -50px;
    top: -62px;
    border-radius: 999px;
    background: radial-gradient(circle at center, color-mix(in oklab, var(--brand) 18%, transparent 82%), transparent 72%);
  }
  .page-hero h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 0.9vw + 1.25rem, 1.95rem);
  }
  .page-hero p {
    margin: 0.35rem 0 0;
    color: var(--text-soft);
    max-width: 68ch;
  }
  .list-side {
    display: grid;
    gap: 0.66rem;
    align-content: start;
    position: sticky;
    top: 74px;
    height: fit-content;
  }
  .stats-grid {
    display: grid;
    gap: 0.48rem;
  }
  .no-side {
    grid-template-columns: minmax(0, 1fr);
  }
  @media (max-width: 980px) {
    .list-side {
      position: static;
      top: auto;
    }
  }
</style>
