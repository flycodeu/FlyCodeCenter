---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SidebarProfile from "@/components/SidebarProfile.astro";
import StatsCard from "@/components/StatsCard.astro";
import TagCloud from "@/components/TagCloud.astro";

interface TaxItem {
  name: string;
  count: number;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  stats?: Array<{ title: string; value: string | number; href?: string }>;
  tags?: TaxItem[];
  hideSidebar?: boolean;
}

const { title, description, stats = [], tags = [], hideSidebar = false } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class={`grid-main ${hideSidebar ? "no-side" : ""}`}>
    <section class="list-main">
      <slot />
    </section>

    {
      !hideSidebar && (
        <aside class="list-side">
          <SidebarProfile />
          <div class="stats-grid">
            {stats.map((item) => <StatsCard title={item.title} value={item.value} href={item.href} />)}
          </div>
          {tags.length > 0 && <TagCloud title="热门标签" items={tags.slice(0, 20)} />}
        </aside>
      )
    }
  </div>
</BaseLayout>

<style>
  .list-main {
    display: grid;
    gap: 0.72rem;
  }
  .list-side {
    display: grid;
    gap: 1.25rem;
    align-content: start;
    position: sticky;
    top: 84px;
    height: fit-content;
  }
  .stats-grid {
    display: grid;
    gap: 0.75rem;
  }
  .no-side {
    grid-template-columns: minmax(0, 1fr);
  }
  @media (max-width: 1024px) {
    .list-side {
      position: static;
      top: auto;
    }
  }
</style>
