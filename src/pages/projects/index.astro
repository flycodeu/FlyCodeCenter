---
import siteConfig from "@/site.config";
import ListLayout from "@/layouts/ListLayout.astro";
import { fetchAllContentEntries, fetchProjectEntries, makeTagItems } from "@/utils/query";
import { formatDate } from "@/utils/date";
import { getProjectEntryUrl } from "@/utils/content";
import { resolveArticleMeta } from "@/utils/article-meta";

const [entries, allEntries] = await Promise.all([fetchProjectEntries(), fetchAllContentEntries()]);
const tags = makeTagItems(allEntries);
const metaCache = new Map<string, ReturnType<typeof resolveArticleMeta>>();
const getMeta = (entry: (typeof entries)[number]) => {
  const cache = metaCache.get(entry.id);
  if (cache) return cache;
  const meta = resolveArticleMeta(entry);
  metaCache.set(entry.id, meta);
  return meta;
};
---

<ListLayout
  title={siteConfig.pages.projects.title}
  description="项目实践记录与可复用方案沉淀。"
  stats={[
    { title: "项目总数", value: entries.length },
    { title: "文章归档", value: "打开", href: "/archives" },
    { title: "标签索引", value: "打开", href: "/tags" }
  ]}
  tags={tags}
>
  <section class="project-grid">
    {
      entries.map((entry) => {
        const meta = getMeta(entry);
        return (
          <article class="surface project-card">
            <header>
              <a href={getProjectEntryUrl(entry)} class="title-link">{meta.title}</a>
              {meta.featured && <span class="chip featured">重点</span>}
            </header>
            <p>{meta.description || meta.summary || "暂无描述"}</p>

            <div class="meta-row">
              <span>发布时间：{formatDate(meta.createTime)}</span>
              <span>标签：{meta.tags.slice(0, 2).join(" / ") || "未设置"}</span>
            </div>

            <div class="meta-row links">
              {meta.repoUrl && (
                <a class="chip" href={meta.repoUrl} target="_blank" rel="noreferrer">仓库</a>
              )}
              {meta.docUrl && (
                <a class="chip" href={meta.docUrl} target="_blank" rel="noreferrer">文档</a>
              )}
              {meta.demoUrl && (
                <a class="chip" href={meta.demoUrl} target="_blank" rel="noreferrer">演示</a>
              )}
            </div>
          </article>
        );
      })
    }
  </section>
</ListLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.72rem;
  }
  .project-card {
    padding: 0.76rem;
    display: grid;
    gap: 0.55rem;
  }
  .project-card header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .title-link {
    font-family: var(--font-serif);
    font-size: 1.06rem;
    font-weight: 700;
  }
  .title-link:hover {
    color: var(--brand);
  }
  .featured {
    color: var(--brand);
  }
  .project-card p {
    margin: 0;
    color: var(--text-soft);
  }
  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.52rem;
    color: var(--text-soft);
    font-size: 0.84rem;
  }
  .links .chip {
    color: var(--text);
  }
</style>
