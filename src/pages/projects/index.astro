---
import ListLayout from "@/layouts/ListLayout.astro";
import { fetchAllContentEntries, fetchProjectEntries, makeTagItems } from "@/utils/query";
import { formatDate } from "@/utils/date";
import { getProjectEntryUrl } from "@/utils/content";
import { resolveArticleMeta } from "@/utils/article-meta";
import { getRenderedPageByCode } from "@/utils/page-content";

const [pageConfig, entries, allEntries] = await Promise.all([
  getRenderedPageByCode("projects-page"),
  fetchProjectEntries(),
  fetchAllContentEntries()
]);

if (!pageConfig) {
  throw new Error("Page config not found: projects-page");
}

const projectConfig = pageConfig.entry.data.projects;
if (!projectConfig) {
  throw new Error("Project page config not found: projects-page.projects");
}

const tags = makeTagItems(allEntries);
const metaCache = new Map<string, ReturnType<typeof resolveArticleMeta>>();
const getMeta = (entry: (typeof entries)[number]) => {
  const cache = metaCache.get(entry.id);
  if (cache) return cache;
  const meta = resolveArticleMeta(entry);
  metaCache.set(entry.id, meta);
  return meta;
};

type StageKey = "completed" | "in-progress" | "planned";
const stageOrder = projectConfig.sectionOrder as StageKey[];
const sections = projectConfig.sections;
const labels = projectConfig.labels;
const stats = projectConfig.stats;
const highlights = projectConfig.highlights;
const coverFallback = projectConfig.coverFallback;

const sortByPriority = (a: (typeof entries)[number], b: (typeof entries)[number]) => {
  const metaA = getMeta(a);
  const metaB = getMeta(b);
  if (metaA.priority !== metaB.priority) return metaB.priority - metaA.priority;
  const featuredDelta = Number(metaB.featured) - Number(metaA.featured);
  if (featuredDelta !== 0) return featuredDelta;
  if (metaA.weight !== metaB.weight) return metaB.weight - metaA.weight;
  return metaB.createTime.getTime() - metaA.createTime.getTime();
};

const stageGroups = stageOrder.map((stage) => ({
  stage,
  section: sections[stage],
  entries: entries.filter((entry) => getMeta(entry).projectStage === stage).sort(sortByPriority)
}));

const completedCount = stageGroups.find((group) => group.stage === "completed")?.entries.length ?? 0;
const plannedCount = stageGroups.find((group) => group.stage === "planned")?.entries.length ?? 0;

const topPriorityEntry = [...entries].sort(sortByPriority)[0];
const topPriorityMeta = topPriorityEntry ? getMeta(topPriorityEntry) : undefined;

const resolveCardCover = (meta: ReturnType<typeof resolveArticleMeta>) => {
  return meta.cover || coverFallback[meta.projectStage] || "";
};

const projectsContent = pageConfig.Content;
---

<ListLayout
  title={pageConfig.entry.data.title}
  description={pageConfig.entry.data.description}
  stats={[
    { title: stats.total, value: entries.length },
    { title: stats.completed, value: completedCount },
    { title: stats.planned, value: plannedCount }
  ]}
  tags={tags}
>
  <section class="surface command-panel">
    <div class="panel-head">
      <div>
        <h2>{highlights.title}</h2>
        {highlights.subtitle && <p>{highlights.subtitle}</p>}
      </div>
      {topPriorityMeta && <span class="chip alert-chip">{highlights.topPriorityLabel}</span>}
    </div>

    {topPriorityMeta && topPriorityEntry && (
      <article class="top-priority surface">
        <img
          class="priority-cover"
          src={resolveCardCover(topPriorityMeta)}
          alt={topPriorityMeta.title}
          loading="lazy"
          decoding="async"
        />
        <div class="priority-body">
          <div class="priority-title-row">
            <h3>{topPriorityMeta.title}</h3>
            <span class="chip priority-chip">{labels.priorityPrefix}{topPriorityMeta.priority}</span>
          </div>
          <p>{topPriorityMeta.description || topPriorityMeta.summary || labels.noDescription}</p>
          <div class="priority-meta">
            <span class="chip">{sections[topPriorityMeta.projectStage].title}</span>
            <span class="chip">{labels.publishDate} {formatDate(topPriorityMeta.createTime)}</span>
          </div>
          <div class="priority-actions">
            <a class="chip" href={getProjectEntryUrl(topPriorityEntry)}>{labels.detail}</a>
            {topPriorityMeta.repoUrl && (
              <a class="chip" href={topPriorityMeta.repoUrl} target="_blank" rel="noreferrer">{labels.repo}</a>
            )}
          </div>
        </div>
      </article>
    )}
  </section>

  <section class="prose config-note"><projectsContent /></section>

  <section class="project-sections">
    {
      stageGroups.map((group) => (
        <section class={`surface stage-section stage-${group.stage}`}>
          <header class="stage-head">
            <div>
              <h2>{group.section.title}</h2>
              {group.section.description && <p>{group.section.description}</p>}
            </div>
            <span class="chip count-chip">
              {group.entries.length} {labels.sectionCountSuffix}
            </span>
          </header>

          {group.entries.length === 0 ? (
            <p class="empty">{labels.empty}</p>
          ) : (
            <div class="project-grid">
              {group.entries.map((entry) => {
                const meta = getMeta(entry);
                return (
                  <article class="surface project-card">
                    <img class="cover" src={resolveCardCover(meta)} alt={meta.title} loading="lazy" decoding="async" />

                    <header>
                      <a href={getProjectEntryUrl(entry)} class="title-link">{meta.title}</a>
                      <div class="chips">
                        <span class="chip stage-chip">{group.section.title}</span>
                        <span class="chip priority-tag">
                          {labels.priorityPrefix}
                          {meta.priority}
                        </span>
                        {meta.featured && <span class="chip featured">{labels.featured}</span>}
                      </div>
                    </header>

                    <p>{meta.description || meta.summary || labels.noDescription}</p>

                    <div class="meta-row">
                      <span>{labels.publishDate}：{formatDate(meta.createTime)}</span>
                      <span>{labels.tags}：{meta.tags.slice(0, 3).join(" / ") || labels.unsetTags}</span>
                    </div>

                    <div class="meta-row links">
                      {meta.repoUrl && (
                        <a class="chip" href={meta.repoUrl} target="_blank" rel="noreferrer">{labels.repo}</a>
                      )}
                      {meta.docUrl && (
                        <a class="chip" href={meta.docUrl} target="_blank" rel="noreferrer">{labels.doc}</a>
                      )}
                      {meta.demoUrl && (
                        <a class="chip" href={meta.demoUrl} target="_blank" rel="noreferrer">{labels.demo}</a>
                      )}
                    </div>
                  </article>
                );
              })}
            </div>
          )}
        </section>
      ))
    }
  </section>
</ListLayout>

<style>
  .command-panel {
    padding: 0.85rem;
    display: grid;
    gap: 0.7rem;
    background:
      radial-gradient(90% 120% at 8% -20%, color-mix(in oklab, var(--brand) 14%, transparent), transparent 74%),
      radial-gradient(90% 100% at 100% 0%, color-mix(in oklab, var(--brand-soft) 24%, transparent), transparent 76%),
      linear-gradient(180deg, color-mix(in oklab, var(--surface-1) 94%, transparent 6%), color-mix(in oklab, var(--surface-2) 96%, transparent 4%));
  }

  .panel-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .panel-head h2,
  .panel-head p,
  .stage-head h2,
  .project-card h3 {
    margin: 0;
  }

  .panel-head p {
    color: var(--text-soft);
    margin-top: 0.24rem;
  }

  .alert-chip {
    border-color: color-mix(in oklab, #ef4444 55%, var(--line) 45%);
    color: color-mix(in oklab, #ef4444 68%, var(--text) 32%);
  }

  .top-priority {
    padding: 0.7rem;
    display: grid;
    grid-template-columns: minmax(230px, 320px) minmax(0, 1fr);
    gap: 0.72rem;
  }

  .priority-cover {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--line);
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .priority-body {
    display: grid;
    gap: 0.48rem;
  }

  .priority-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.6rem;
  }

  .priority-title-row h3 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.14rem;
  }

  .priority-body p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.6;
  }

  .priority-meta,
  .priority-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
  }

  .priority-chip,
  .priority-tag {
    font-family: "JetBrains Mono", monospace;
  }

  .config-note {
    margin: 0.8rem 0;
  }

  .project-sections {
    display: grid;
    gap: 0.86rem;
  }

  .stage-section {
    padding: 0.72rem;
    display: grid;
    gap: 0.66rem;
  }

  .stage-completed {
    border-color: color-mix(in oklab, #14b8a6 36%, var(--line) 64%);
  }

  .stage-in-progress {
    border-color: color-mix(in oklab, #f59e0b 40%, var(--line) 60%);
  }

  .stage-planned {
    border-color: color-mix(in oklab, #6366f1 42%, var(--line) 58%);
  }

  .stage-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .stage-head h2 {
    font-family: var(--font-serif);
    font-size: 1.08rem;
  }

  .stage-head p {
    margin: 0.24rem 0 0;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .count-chip {
    font-family: "JetBrains Mono", monospace;
  }

  .empty {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.72rem;
  }

  .project-card {
    padding: 0.7rem;
    display: grid;
    gap: 0.52rem;
  }

  .cover {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--line);
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .project-card header {
    display: grid;
    gap: 0.44rem;
  }

  .title-link {
    font-family: var(--font-serif);
    font-size: 1.06rem;
    font-weight: 700;
  }

  .title-link:hover {
    color: var(--brand);
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.36rem;
  }

  .project-card p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.6;
  }

  .featured {
    color: var(--brand);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-soft);
    font-size: 0.83rem;
  }

  .links .chip {
    color: var(--text);
  }

  @media (max-width: 900px) {
    .top-priority {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
