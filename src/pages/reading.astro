---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchReadingEntries } from "@/utils/query";
import { formatDate } from "@/utils/date";
import { getTagColorVars } from "@/utils/tag-color";

const entries = await fetchReadingEntries();

const tagMap = new Map<string, number>();
for (const entry of entries) {
  for (const tag of entry.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const tags = [...tagMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count }));

const getHost = (url?: string) => {
  if (!url) return "";
  try {
    return new URL(url).host.replace(/^www\./, "");
  } catch {
    return "";
  }
};
---

<BaseLayout title={siteConfig.pages.reading.title} description="按标签筛选和收藏高质量文章。">
  <section class="reading-shell">
    <section class="reading-hero surface">
      <div>
        <h1>{siteConfig.pages.reading.title}</h1>
        <p>按标签筛选并快速访问值得反复阅读的外部文章。</p>
      </div>
      <span class="total-pill">共 {entries.length} 篇</span>
    </section>

    <section class="reading-filter" id="reading-filter">
      <button type="button" class="tag-chip active" data-tag="all" style="--tag-hue:216">
        <span>全部</span>
        <small>{entries.length}</small>
      </button>
      {
        tags.map((tag) => (
          <button type="button" class="tag-chip" data-tag={tag.name} style={getTagColorVars(tag.name)}>
            <span>{tag.name}</span>
            <small>{tag.count}</small>
          </button>
        ))
      }
    </section>

    <section class="reading-grid" id="reading-grid">
      {
        entries.map((entry) => (
          <article class="reading-card surface" data-item data-tags={entry.data.tags.map((tag) => tag.toLowerCase().trim()).join("||")}>
            <header class="card-head">
              <div class="title-wrap">
                <h3>{entry.data.title}</h3>
                <div class="meta-row">
                  <span>{entry.data.source || "推荐"}</span>
                  {entry.data.url && (
                    <>
                      <span class="dot" aria-hidden="true"></span>
                      <span class="host">{getHost(entry.data.url)}</span>
                    </>
                  )}
                  <span class="dot" aria-hidden="true"></span>
                  <span class="date-chip">
                    <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
                      <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 2v4m8-4v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"/>
                    </svg>
                    {formatDate(entry.data.pubDate)}
                  </span>
                </div>
              </div>
              {entry.data.rating > 0 && <span class="score-pill">{entry.data.rating.toFixed(1)}</span>}
            </header>

            <p class="summary">{entry.data.description || "暂无摘要"}</p>

            <div class="tag-row">
              {entry.data.tags.map((tag) => <span class="meta-tag tag-badge" style={getTagColorVars(tag)}>{tag}</span>)}
            </div>

            {
              entry.data.url ? (
                <a class="read-btn" href={entry.data.url} target="_blank" rel="noreferrer">阅读全文</a>
              ) : (
                <span class="read-btn disabled">暂无链接</span>
              )
            }
          </article>
        ))
      }
    </section>
  </section>
</BaseLayout>

<script is:inline>
  const initReadingFilter = () => {
    const filter = document.getElementById('reading-filter');
    const grid = document.getElementById('reading-grid');
    if (!filter || !grid) return;

    if (window.__flyReadingFilterCleanup) {
      window.__flyReadingFilterCleanup();
    }

    const controller = new AbortController();
    const { signal } = controller;

    const buttons = Array.from(filter.querySelectorAll('.tag-chip'));
    const items = Array.from(grid.querySelectorAll('[data-item]'));
    const normalize = (value) => String(value || '').trim().toLowerCase();

    const applyFilter = (rawTag, syncQuery = true) => {
      const activeTag = normalize(rawTag || 'all');

      buttons.forEach((button) => {
        button.classList.toggle('active', normalize(button.dataset.tag) === activeTag);
      });

      items.forEach((item) => {
        const tagsText = item.getAttribute('data-tags') || '';
        const set = tagsText ? tagsText.split('||').map(normalize) : [];
        const visible = activeTag === 'all' || set.includes(activeTag);
        item.toggleAttribute('hidden', !visible);
      });

      if (syncQuery) {
        const url = new URL(window.location.href);
        if (activeTag === 'all') {
          url.searchParams.delete('tag');
        } else {
          const activeButton = buttons.find((button) => normalize(button.dataset.tag) === activeTag);
          if (activeButton?.dataset.tag) {
            url.searchParams.set('tag', activeButton.dataset.tag);
          }
        }
        window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
      }
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        applyFilter(button.dataset.tag || 'all');
      }, { signal });
    });

    const queryTag = new URLSearchParams(window.location.search).get('tag');
    if (queryTag) {
      const match = buttons.find((button) => normalize(button.dataset.tag) === normalize(queryTag));
      applyFilter(match?.dataset.tag || 'all', false);
    } else {
      applyFilter('all', false);
    }

    window.__flyReadingFilterCleanup = () => {
      controller.abort();
    };
  };

  document.addEventListener('astro:page-load', initReadingFilter);
  initReadingFilter();
</script>

<style>
  .reading-shell {
    display: grid;
    gap: 0.84rem;
  }

  .reading-hero {
    padding: 0.92rem 0.98rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.9rem;
  }

  .reading-hero h1 {
    margin: 0;
    font-size: clamp(1.25rem, 1vw + 1rem, 1.56rem);
  }

  .reading-hero p {
    margin: 0.22rem 0 0;
    color: var(--text-soft);
    font-size: 0.86rem;
  }

  .total-pill {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.16rem 0.48rem;
    font-size: 0.72rem;
    color: var(--text-soft);
    background: color-mix(in oklab, var(--bg) 92%, transparent 8%);
    white-space: nowrap;
  }

  .reading-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    position: sticky;
    top: 74px;
    z-index: 8;
    padding: 0.62rem;
    border: 1px solid var(--line);
    border-radius: 11px;
    background: color-mix(in oklab, var(--bg-elev) 95%, transparent 5%);
    backdrop-filter: blur(10px);
  }

  .tag-chip {
    --tag-border: color-mix(in oklab, var(--line) 86%, transparent 14%);
    --tag-bg: color-mix(in oklab, var(--bg-elev) 92%, transparent 8%);
    --tag-text: var(--text-soft);

    border: 1px solid var(--tag-border);
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 999px;
    padding: 0.24rem 0.56rem;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    cursor: pointer;
    max-width: min(220px, 48vw);
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .tag-chip small {
    border: 1px solid color-mix(in oklab, var(--tag-border) 82%, transparent 18%);
    border-radius: 999px;
    padding: 0.02rem 0.3rem;
    font-size: 0.68rem;
    background: color-mix(in oklab, var(--bg) 90%, transparent 10%);
  }

  .tag-chip.active {
    border-color: color-mix(in oklab, var(--tag-border) 74%, var(--brand) 26%);
    box-shadow: 0 8px 16px -14px color-mix(in oklab, var(--brand) 22%, transparent 78%);
  }

  .reading-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.68rem;
  }

  .reading-card {
    border-radius: 12px;
    padding: 0.72rem;
    display: grid;
    gap: 0.5rem;
    min-height: 220px;
    transition: border-color 170ms ease, box-shadow 170ms ease, transform 170ms ease;
  }

  .reading-card:hover {
    border-color: color-mix(in oklab, var(--line) 68%, var(--brand) 32%);
    box-shadow: 0 12px 20px -16px color-mix(in oklab, var(--brand) 16%, transparent 84%);
    transform: translateY(-1px);
  }

  .card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .title-wrap {
    min-width: 0;
  }

  .reading-card h3 {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.38;
  }

  .meta-row {
    margin-top: 0.16rem;
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    color: var(--text-soft);
    font-size: 0.72rem;
    flex-wrap: wrap;
  }

  .host {
    max-width: 160px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--line);
  }

  .date-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }

  .score-pill {
    border: 1px solid color-mix(in oklab, var(--brand) 24%, var(--line) 76%);
    border-radius: 999px;
    padding: 0.04rem 0.34rem;
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
    font-size: 0.7rem;
    white-space: nowrap;
    background: color-mix(in oklab, var(--brand-soft) 42%, var(--bg-elev) 58%);
  }

  .summary {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.82rem;
    line-height: 1.46;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.26rem;
  }

  .meta-tag {
    font-size: 0.68rem;
    padding: 0.03rem 0.34rem;
    border-radius: 7px;
  }

  .read-btn {
    margin-top: auto;
    border: 1px solid color-mix(in oklab, var(--brand) 30%, var(--line) 70%);
    border-radius: 8px;
    background: color-mix(in oklab, var(--brand-soft) 40%, var(--bg-elev) 60%);
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
    text-align: center;
    padding: 0.34rem 0.54rem;
    font-size: 0.76rem;
    transition: background-color 140ms ease, color 140ms ease;
  }

  .read-btn:hover {
    background: color-mix(in oklab, var(--brand-soft) 54%, var(--bg-elev) 46%);
    color: color-mix(in oklab, var(--text) 62%, var(--brand) 38%);
  }

  .read-btn.disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  @media (max-width: 900px) {
    .reading-filter {
      position: static;
      top: auto;
    }
  }

  @media (max-width: 700px) {
    .reading-hero {
      align-items: flex-start;
      flex-direction: column;
    }

    .reading-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
