---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchReadingEntries } from "@/utils/query";
import { formatDate } from "@/utils/date";
import { getTagColorVars } from "@/utils/tag-color";

const entries = await fetchReadingEntries();

const tagMap = new Map<string, number>();
for (const entry of entries) {
  for (const tag of entry.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const tags = [...tagMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count }));
---

<BaseLayout title={siteConfig.pages.reading.title} description="°´±ęÇ©Î¬»¤ÓĹĐă˛©żÍÓëÎÄŐÂÁ´˝ÓˇŁ">
  <section class="reading-shell">
    <section class="reading-head surface">
      <div>
        <h1>{siteConfig.pages.reading.title}</h1>
        <p>°´±ęÇ©É¸Ńˇ˛˘żěËŮ·ĂÎĘ¸ßÖĘÁżÍâ˛żÎÄŐÂˇŁ</p>
      </div>
      <span class="total-count">ą˛ {entries.length} ĆŞ</span>
    </section>

    <section class="reading-filter" id="reading-filter">
      <button type="button" class="tag-btn active" data-tag="all" style="--tag-hue:216">
        <span class="label">Č«˛ż</span>
        <span class="count">{entries.length}</span>
      </button>
      {
        tags.map((tag) => (
          <button type="button" class="tag-btn" data-tag={tag.name} style={getTagColorVars(tag.name)}>
            <span class="label">{tag.name}</span>
            <span class="count">{tag.count}</span>
          </button>
        ))
      }
    </section>

    <section class="reading-grid" id="reading-grid">
      {
        entries.map((entry) => (
          <article class="reading-card surface" data-item data-tags={entry.data.tags.map((tag) => tag.toLowerCase().trim()).join("||")}>
            <header>
              <div class="title-wrap">
                <h3>{entry.data.title}</h3>
                <div class="meta-row">
                  <span>{entry.data.source || "ÓĹĐăÎÄŐÂ"}</span>
                  <span class="dot" aria-hidden="true"></span>
                  <span class="date-chip">
                    <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
                      <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 2v4m8-4v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"/>
                    </svg>
                    {formatDate(entry.data.pubDate)}
                  </span>
                </div>
              </div>
              {entry.data.rating > 0 && <span class="score">{entry.data.rating.toFixed(1)}</span>}
            </header>

            <p>{entry.data.description || "ÔÝÎŢŐŞŇŞ"}</p>

            <div class="tag-row">
              {entry.data.tags.map((tag) => <span class="meta-tag tag-badge" style={getTagColorVars(tag)}>{tag}</span>)}
            </div>

            {
              entry.data.url ? (
                <a class="visit-link" href={entry.data.url} target="_blank" rel="noreferrer">ÔÄ¶ÁČ«ÎÄ</a>
              ) : (
                <span class="visit-link disabled">ÔÝÎŢÁ´˝Ó</span>
              )
            }
          </article>
        ))
      }
    </section>
  </section>
</BaseLayout>

<script is:inline>
  const initReadingFilter = () => {
    const filter = document.getElementById('reading-filter');
    const grid = document.getElementById('reading-grid');
    if (!filter || !grid) return;

    if (window.__flyReadingFilterCleanup) {
      window.__flyReadingFilterCleanup();
    }

    const controller = new AbortController();
    const { signal } = controller;

    const buttons = Array.from(filter.querySelectorAll('.tag-btn'));
    const items = Array.from(grid.querySelectorAll('[data-item]'));
    const normalize = (value) => String(value || '').trim().toLowerCase();

    const applyFilter = (rawTag, syncQuery = true) => {
      const activeTag = normalize(rawTag || 'all');

      buttons.forEach((button) => {
        button.classList.toggle('active', normalize(button.dataset.tag) === activeTag);
      });

      items.forEach((item) => {
        const tagsText = item.getAttribute('data-tags') || '';
        const set = tagsText ? tagsText.split('||').map(normalize) : [];
        const visible = activeTag === 'all' || set.includes(activeTag);
        item.toggleAttribute('hidden', !visible);
      });

      if (syncQuery) {
        const url = new URL(window.location.href);
        if (activeTag === 'all') {
          url.searchParams.delete('tag');
        } else {
          const activeButton = buttons.find((button) => normalize(button.dataset.tag) === activeTag);
          if (activeButton?.dataset.tag) {
            url.searchParams.set('tag', activeButton.dataset.tag);
          }
        }
        window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
      }
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        applyFilter(button.dataset.tag || 'all');
      }, { signal });
    });

    const queryTag = new URLSearchParams(window.location.search).get('tag');
    if (queryTag) {
      const match = buttons.find((button) => normalize(button.dataset.tag) === normalize(queryTag));
      applyFilter(match?.dataset.tag || 'all', false);
    } else {
      applyFilter('all', false);
    }

    window.__flyReadingFilterCleanup = () => {
      controller.abort();
    };
  };

  document.addEventListener('astro:page-load', initReadingFilter);
  initReadingFilter();
</script>

<style>
  .reading-shell {
    display: grid;
    gap: 0.8rem;
  }

  .reading-head {
    padding: 0.86rem 0.94rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .reading-head h1 {
    margin: 0;
    font-size: clamp(1.25rem, 1vw + 1rem, 1.5rem);
  }

  .reading-head p {
    margin: 0.2rem 0 0;
    color: var(--text-soft);
    font-size: 0.84rem;
  }

  .total-count {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.14rem 0.42rem;
    font-size: 0.73rem;
    color: var(--text-soft);
    background: color-mix(in oklab, var(--bg) 90%, transparent 10%);
    white-space: nowrap;
  }

  .reading-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    position: sticky;
    top: 74px;
    z-index: 5;
    padding: 0.6rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: color-mix(in oklab, var(--bg-elev) 94%, transparent 6%);
    backdrop-filter: blur(10px);
  }

  .tag-btn {
    --tag-border: color-mix(in oklab, var(--line) 84%, transparent 16%);
    --tag-bg: color-mix(in oklab, var(--bg-elev) 90%, transparent 10%);
    --tag-text: var(--text-soft);
    --tag-count-bg: color-mix(in oklab, var(--bg) 88%, transparent 12%);

    border: 1px solid var(--tag-border);
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 999px;
    padding: 0.24rem 0.56rem;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    cursor: pointer;
    max-width: min(220px, 48vw);
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
  }

  .tag-btn .label {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tag-btn .count {
    border: 1px solid color-mix(in oklab, var(--tag-border) 80%, transparent 20%);
    border-radius: 999px;
    padding: 0.02rem 0.3rem;
    font-size: 0.68rem;
    background: var(--tag-count-bg);
    color: inherit;
  }

  .tag-btn:hover {
    transform: translateY(-1px);
  }

  .tag-btn.active {
    border-color: color-mix(in oklab, var(--tag-border) 78%, var(--brand) 22%);
    box-shadow: 0 8px 16px -14px color-mix(in oklab, var(--brand) 22%, transparent 78%);
  }

  .reading-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 0.62rem;
  }

  .reading-card {
    border-radius: 10px;
    padding: 0.66rem;
    display: grid;
    gap: 0.44rem;
    min-height: 206px;
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
  }

  .reading-card:hover {
    border-color: color-mix(in oklab, var(--line) 68%, var(--brand) 32%);
    box-shadow: 0 12px 20px -16px color-mix(in oklab, var(--brand) 16%, transparent 84%);
    transform: translateY(-1px);
  }

  .reading-card header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.45rem;
  }

  .title-wrap {
    min-width: 0;
  }

  .reading-card h3 {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.36;
  }

  .meta-row {
    margin-top: 0.16rem;
    display: inline-flex;
    align-items: center;
    gap: 0.36rem;
    color: var(--text-soft);
    font-size: 0.72rem;
    flex-wrap: wrap;
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--line);
  }

  .date-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }

  .score {
    border: 1px solid color-mix(in oklab, var(--brand) 24%, var(--line) 76%);
    border-radius: 6px;
    padding: 0.02rem 0.35rem;
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
    font-size: 0.7rem;
    white-space: nowrap;
    background: color-mix(in oklab, var(--brand-soft) 42%, var(--bg-elev) 58%);
  }

  .reading-card p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.24rem;
  }

  .meta-tag {
    font-size: 0.68rem;
    padding: 0.02rem 0.34rem;
    border-radius: 7px;
  }

  .visit-link {
    margin-top: auto;
    border: 1px solid color-mix(in oklab, var(--brand) 30%, var(--line) 70%);
    border-radius: 7px;
    background: color-mix(in oklab, var(--brand-soft) 40%, var(--bg-elev) 60%);
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
    text-align: center;
    padding: 0.32rem 0.54rem;
    font-size: 0.76rem;
    transition: background-color 140ms ease, color 140ms ease;
  }

  .visit-link:hover {
    background: color-mix(in oklab, var(--brand-soft) 54%, var(--bg-elev) 46%);
    color: color-mix(in oklab, var(--text) 62%, var(--brand) 38%);
  }

  .visit-link.disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  @media (max-width: 900px) {
    .reading-filter {
      position: static;
      top: auto;
    }
  }

  @media (max-width: 700px) {
    .reading-head {
      align-items: flex-start;
      flex-direction: column;
    }
    .reading-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
