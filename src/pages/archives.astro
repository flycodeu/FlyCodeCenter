---
import siteConfig from "@/site.config";
import ListLayout from "@/layouts/ListLayout.astro";
import ArchiveTimelineCard from "@/components/ArchiveTimelineCard.astro";
import { fetchAllContentEntries, fetchAllEntries, makeTagItems } from "@/utils/query";
import { buildArchiveTimeline } from "@/utils/archive";
import { resolveAntiCrawlRuntimeConfig, type AntiCrawlConfigInput } from "@/utils/anti-crawl";

const entries = await fetchAllEntries();
const allContent = await fetchAllContentEntries();
const tags = makeTagItems(allContent);
const years = buildArchiveTimeline(entries);

const archivePageConfig = siteConfig.pages.archives as {
  showCover?: boolean;
  timeline?: { layoutMode?: "both" | "left" | "right" };
  antiCrawl?: AntiCrawlConfigInput;
};

const showCover = archivePageConfig.showCover ?? true;
const timelineLayout = archivePageConfig.timeline?.layoutMode ?? "both";
const antiCrawlConfig = archivePageConfig.antiCrawl ?? {};
const antiCrawlRuntime = resolveAntiCrawlRuntimeConfig(antiCrawlConfig, { legacyMaxActionsDefault: 10 });
const archiveCoverMode = showCover ? undefined : "none";

const timelineItems = years.flatMap((yearBucket) =>
  yearBucket.months.flatMap((monthBucket) =>
    monthBucket.days.flatMap((dayBucket) =>
      dayBucket.entries.map((entry, entryIdx) => ({
        entry,
        dateLabel: `${dayBucket.year}-${dayBucket.month}-${dayBucket.day}`,
        showDate: entryIdx === 0,
        dayKey: dayBucket.key
      }))
    )
  )
);

const stats = [
  { title: "总文章数", value: entries.length, href: "/archives" },
  { title: "日期节点", value: years.reduce((sum, year) => sum + year.months.reduce((m, month) => m + month.days.length, 0), 0) },
  { title: "博客数量", value: entries.filter((entry) => entry.collection === "blog").length, href: "/blog" },
  { title: "教程数量", value: entries.filter((entry) => entry.collection === "tutorial").length, href: "/tutorials" }
];
---

<ListLayout title="归档" description="博客与教程统一归档，按日期倒序时间轴展示。" stats={stats} tags={tags}>
  <section class="archive-timeline" id="archive-timeline">
    <span class="timeline-line" aria-hidden="true"></span>
    {
      timelineItems.map((item, idx) => {
        const side = timelineLayout === "left" ? "left" : timelineLayout === "right" ? "right" : idx % 2 === 0 ? "left" : "right";
        return (
          <article class={`timeline-item side-${side}`} data-day={item.dayKey}>
            <div class="timeline-column timeline-col-left">
              {side === "left" && (
                <>
                  {item.showDate && <span class="timeline-date-inline">{item.dateLabel}</span>}
                  <ArchiveTimelineCard entry={item.entry} kind={item.entry.collection === "blog" ? "blog" : "tutorial"} coverMode={archiveCoverMode} />
                </>
              )}
            </div>
            <div class="timeline-axis">
              {item.showDate && <span class="timeline-date">{item.dateLabel}</span>}
              <span class="timeline-dot" aria-hidden="true"></span>
            </div>
            <div class="timeline-column timeline-col-right">
              {side === "right" && (
                <>
                  {item.showDate && <span class="timeline-date-inline">{item.dateLabel}</span>}
                  <ArchiveTimelineCard entry={item.entry} kind={item.entry.collection === "blog" ? "blog" : "tutorial"} coverMode={archiveCoverMode} />
                </>
              )}
            </div>
          </article>
        );
      })
    }
    <section class="archive-lock" id="archive-lock" hidden>
      <h2>访问已受限</h2>
      <p>检测到异常访问行为，归档内容已临时受限。</p>
      <p class="archive-lock-reason" id="archive-lock-reason">原因: suspicious</p>
    </section>
  </section>
</ListLayout>

<script id="archive-anti-crawl-config" type="application/json" set:html={JSON.stringify(antiCrawlRuntime)} />
<script>
  import "@/scripts/archive-anti-crawl-runtime.js";
</script>

<style>
  .archive-timeline {
    position: relative;
    display: grid;
    gap: var(--space-3);
    padding: 0.2rem 0;
  }

  .timeline-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    transform: translateX(-50%);
    background: color-mix(in oklab, var(--line) 75%, transparent 25%);
    pointer-events: none;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 92px minmax(0, 1fr);
    align-items: start;
    gap: var(--space-3);
    position: relative;
    z-index: 1;
  }

  .timeline-column {
    min-width: 0;
  }

  .timeline-axis {
    display: grid;
    justify-items: center;
    align-content: start;
    gap: 0.32rem;
    padding-top: 0.34rem;
  }

  .timeline-date {
    font-size: 0.76rem;
    color: var(--text-muted);
    background: color-mix(in oklab, var(--surface-1) 94%, transparent 6%);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    padding: 0.12rem 0.48rem;
    white-space: nowrap;
  }

  .timeline-date-inline {
    display: none;
    align-items: center;
    justify-content: flex-start;
    align-self: flex-start;
    width: fit-content;
    margin: 0 0 0.45rem;
    padding: 0.16rem 0.56rem;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in oklab, var(--line) 75%, transparent 25%);
    background: color-mix(in oklab, var(--surface-1) 92%, transparent 8%);
    color: var(--text-muted);
    font-size: 0.76rem;
    line-height: 1.2;
    white-space: nowrap;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid color-mix(in oklab, var(--brand) 52%, var(--line) 48%);
    background: color-mix(in oklab, var(--surface-1) 96%, transparent 4%);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--brand-soft) 55%, transparent 45%);
  }

  .timeline-col-left {
    grid-column: 1;
  }

  .timeline-col-right {
    grid-column: 3;
  }

  .side-left .timeline-col-right,
  .side-right .timeline-col-left {
    opacity: 0;
    pointer-events: none;
    min-height: 1px;
  }

  .archive-lock {
    border: 1px solid color-mix(in oklab, var(--brand) 35%, var(--line) 65%);
    border-radius: 12px;
    background: color-mix(in oklab, var(--surface-1) 92%, var(--brand-soft) 8%);
    padding: 1rem;
    display: grid;
    gap: 0.5rem;
    z-index: 2;
  }

  .archive-lock h2 {
    margin: 0;
    font-size: 1.08rem;
  }

  .archive-lock p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .archive-lock-reason {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .archive-timeline.is-locked .timeline-item {
    opacity: 0.25;
    pointer-events: none;
    filter: blur(1px);
  }

  @media (max-width: 980px) {
    .timeline-line {
      left: 10px;
      width: 1px;
      transform: none;
    }

    .timeline-item {
      grid-template-columns: 18px minmax(0, 1fr);
      gap: 0.5rem;
    }

    .timeline-axis {
      grid-column: 1;
      justify-items: start;
      padding-top: 0.4rem;
    }

    .timeline-date {
      display: none;
    }

    .timeline-col-left,
    .timeline-col-right {
      grid-column: 2;
      opacity: 1;
      pointer-events: auto;
    }

    .side-left .timeline-col-right,
    .side-right .timeline-col-left {
      display: none;
    }

    .timeline-date-inline {
      display: inline-flex;
    }

    .timeline-dot {
      width: 7px;
      height: 7px;
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--brand-soft) 55%, transparent 45%);
    }
  }
</style>
