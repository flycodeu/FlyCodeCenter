---
import ListLayout from "@/layouts/ListLayout.astro";
import { fetchAllContentEntries, fetchAllEntries, makeTagItems } from "@/utils/query";
import { buildArchiveBuckets, getBlogEntryUrl, getTutorialEntryUrl } from "@/utils/content";
import { formatDate } from "@/utils/date";
import { resolveArticleMeta } from "@/utils/article-meta";

const entries = await fetchAllEntries();
const allContent = await fetchAllContentEntries();
const tags = makeTagItems(allContent);
const map = buildArchiveBuckets(entries);
const months = [...map.keys()].sort((a, b) => (a > b ? -1 : 1));

const stats = [
  { title: "总文章数", value: entries.length, href: "/archives" },
  { title: "标签总数", value: tags.length, href: "/tags" }
];
---

<ListLayout title="归档" description="时光的足迹，按月份记录的全部文章。" stats={stats} tags={tags}>
  <section class="surface timeline-wrap">
    {
      months.map((month) => {
        const [y, m] = month.split("-");
        return (
          <div class="timeline-month">
            <h2 class="month-title">
              <span class="year">{y}</span>年<span class="month">{m}</span>月
              <span class="count">{map.get(month)?.length || 0} 篇</span>
            </h2>
            <div class="timeline-list">
              {(map.get(month) ?? []).map((entry) => {
                const url = entry.collection === "blog" ? getBlogEntryUrl(entry) : getTutorialEntryUrl(entry);
                const meta = resolveArticleMeta(entry);
                return (
                  <a class="timeline-item" href={url}>
                    <div class="date">{formatDate(meta.createTime, "MM-DD")}</div>
                    <div class="title">{meta.title}</div>
                  </a>
                );
              })}
            </div>
          </div>
        );
      })
    }
  </section>
</ListLayout>

<style>
  .timeline-wrap {
    padding: 2rem;
    border-radius: 12px;
  }
  .timeline-month {
    position: relative;
    padding-left: 2rem;
    border-left: 2px solid var(--line);
    margin-bottom: 2rem;
  }
  .timeline-month:last-child {
    margin-bottom: 0;
  }
  .timeline-month::before {
    content: "";
    position: absolute;
    left: -7px;
    top: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg-elev);
    border: 3px solid var(--brand);
  }
  .month-title {
    margin: 0 0 1rem 0;
    font-family: var(--font-sans);
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
  }
  .month-title .year {
    font-size: 1.5rem;
    font-weight: 700;
  }
  .month-title .month {
    font-weight: 600;
  }
  .month-title .count {
    font-size: 0.875rem;
    color: var(--brand);
    background: var(--brand-soft);
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    font-weight: 500;
    margin-left: 0.5rem;
  }
  .timeline-list {
    display: grid;
    gap: 1rem;
  }
  .timeline-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    transition: all 0.2s ease;
    text-decoration: none;
    color: var(--text);
  }
  .timeline-item:hover {
    border-color: var(--brand);
    transform: translateX(4px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }
  .timeline-item .date {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.875rem;
    color: var(--text-soft);
    white-space: nowrap;
  }
  .timeline-item .title {
    font-weight: 500;
    font-size: 1.0625rem;
    line-height: 1.4;
  }
  @media (max-width: 768px) {
    .timeline-wrap {
      padding: 1.5rem 1rem;
    }
    .timeline-month {
      padding-left: 1.25rem;
    }
    .timeline-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>

