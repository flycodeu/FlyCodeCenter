---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="标签中心" description="标签中心已迁移到 /tags。">
  <section class="surface redirect-card">
    <h1>标签中心已迁移</h1>
    <p>新的入口为 <a href="/tags">/tags</a>，该页面将自动跳转。</p>
  </section>

  <meta http-equiv="refresh" content="0; url=/tags" />
</BaseLayout>

<style>
  .redirect-card {
    margin: 2rem 0;
    padding: 1.5rem;
    border-radius: 12px;
  }
  .redirect-card h1 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }
  .redirect-card p {
    margin: 0;
    color: var(--text-soft);
  }
</style>
