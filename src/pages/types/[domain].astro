---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchAllEntries } from "@/utils/query";
import { resolveArticleMeta } from "@/utils/article-meta";

export async function getStaticPaths() {
  const entries = await fetchAllEntries();
  const tags = new Set<string>();
  for (const entry of entries) {
    for (const tag of resolveArticleMeta(entry).tags) tags.add(tag);
  }
  return [...tags].map((tag) => ({
    params: { domain: tag }
  }));
}

const domain = Astro.params.domain ?? "";
const target = `/tags/${encodeURIComponent(domain)}`;
---

<BaseLayout title="标签详情" description="标签详情页已迁移到 /tags/:tag。">
  <section class="surface redirect-card">
    <h1>标签详情已迁移</h1>
    <p>新的地址为 <a href={target}>{`/tags/${domain}`}</a>，该页面将自动跳转。</p>
  </section>

  <meta http-equiv="refresh" content={`0; url=${target}`} />
</BaseLayout>

<style>
  .redirect-card {
    margin: 2rem 0;
    padding: 1.5rem;
    border-radius: 12px;
  }
  .redirect-card h1 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }
  .redirect-card p {
    margin: 0;
    color: var(--text-soft);
  }
</style>
