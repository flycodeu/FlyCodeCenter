---
import siteConfig from "@/site.config";
import ListLayout from "@/layouts/ListLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { fetchAllEntries, makeTagItems } from "@/utils/query";

export async function getStaticPaths() {
  const entries = await fetchAllEntries();
  const tags = new Set<string>();
  for (const entry of entries) {
    for (const tag of entry.data.tags) tags.add(tag);
  }
  return [...tags].map((tag) => ({
    params: { domain: encodeURIComponent(tag) },
    props: { tag }
  }));
}

const { tag } = Astro.props as { tag: string };
const allEntries = await fetchAllEntries();
const matched = allEntries.filter((entry) => entry.data.tags.includes(tag));
const tags = makeTagItems(allEntries);
const mode = siteConfig.blog.pagination.mode;
const pageSize = siteConfig.blog.pagination.pageSize;
const tagCoverMode = siteConfig.blog.pageCardOverrides.tags.coverMode;
---

<ListLayout
  title={`标签：${tag}`}
  description="该标签下的全部文章。"
  stats={[
    { title: "命中结果", value: matched.length },
    { title: "返回标签统计", value: "打开", href: "/types" },
    { title: "全部标签", value: tags.length, href: "/tags" }
  ]}
  tags={tags}
>
  {
    matched.length > 0 ? (
      <>
        <div class="list" id="type-post-list">
          {
            matched.map((entry, idx) => (
              <div data-page-item hidden={mode === "loadMore" && idx >= pageSize ? true : undefined}>
                <PostCard
                  entry={entry}
                  kind={entry.collection === "blog" ? "blog" : "tutorial"}
                  coverMode={tagCoverMode}
                />
              </div>
            ))
          }
        </div>

        {mode === "loadMore" && <Pagination mode="loadMore" targetSelector="#type-post-list" batchSize={pageSize} />}
      </>
    ) : (
      <div class="surface empty">该标签暂无文章。</div>
    )
  }
</ListLayout>

<style>
  .list {
    display: grid;
    gap: 0.8rem;
  }
  .empty {
    padding: 0.9rem;
    color: var(--text-soft);
  }
</style>