---
import BaseLayout from "@/layouts/BaseLayout.astro";
import siteConfig from "@/site.config";

const defaultModels = siteConfig.jarvis?.defaultModels ?? [];
const personaPresets = siteConfig.jarvis?.personaPresets ?? [];
const interactionConfig = siteConfig.jarvis?.interaction ?? { eventNamespace: "jarvis" };
---

<BaseLayout title="JARVIS 控制台" description="会话、模型、角色与流式 Markdown 回复控制台">
  <section class="jarvis-shell">
    <aside class="jarvis-history surface" aria-label="聊天历史">
      <header class="history-head">
        <h2>会话</h2>
        <button id="jarvis-session-new" type="button" class="neo-btn">新建</button>
      </header>
      <div id="jarvis-session-list" class="history-list" role="listbox" aria-label="会话列表"></div>
      <button id="jarvis-settings-open" class="history-settings-btn" type="button" aria-label="打开设置">设置</button>
    </aside>

    <section class="jarvis-chat surface" aria-label="聊天窗口">
      <header class="chat-head">
        <div class="chat-title-wrap">
          <p class="chat-kicker">PIXEL FUTURE CORE</p>
          <h1>Jarvis</h1>
        </div>
        <div class="chat-state-wrap">
          <select id="jarvis-active-role" class="chat-role-select" aria-label="当前角色"></select>
          <div id="jarvis-active-chip" class="chat-active-chip">未激活模型</div>
        </div>
      </header>
      <div id="jarvis-stream" class="chat-stream" aria-live="polite"></div>
      <form id="jarvis-form" class="chat-form">
        <textarea id="jarvis-input" rows="2" placeholder="输入消息，Enter 发送，Shift+Enter 换行"></textarea>
        <button id="jarvis-send" class="neo-btn primary" type="submit">发送</button>
      </form>
      <p id="jarvis-chat-status" class="chat-status" aria-live="polite"></p>
    </section>
  </section>

  <div id="jarvis-settings-modal" class="jarvis-modal" hidden>
    <div id="jarvis-settings-backdrop" class="jarvis-modal-backdrop"></div>
    <section class="jarvis-modal-panel surface" role="dialog" aria-modal="true" aria-label="Jarvis 设置中心">
      <aside class="settings-menu" aria-label="设置菜单">
        <button type="button" data-tab="models" class="is-active">模型配置</button>
        <button type="button" data-tab="roles">角色配置</button>
        <button type="button" data-tab="selector">模型选择</button>
      </aside>

      <div class="settings-content">
        <header class="settings-head">
          <h3 id="jarvis-settings-title">模型配置</h3>
          <button id="jarvis-settings-close" class="neo-btn" type="button">关闭</button>
        </header>

        <section id="jarvis-panel-models" class="settings-pane">
          <label>当前草稿模型<select id="jarvis-model-draft-select"></select></label>
          <label>
            Provider
            <select id="jarvis-model-provider">
              <option value="openai-compatible">OpenAI Compatible</option>
              <option value="custom">Custom</option>
            </select>
          </label>
          <label>显示名称<input id="jarvis-model-name" type="text" placeholder="例如 GPT-4o mini" /></label>
          <label>模型 ID<input id="jarvis-model-id" type="text" placeholder="例如 gpt-4o-mini / deepseek-chat" /></label>
          <label>API Base<input id="jarvis-model-base" type="url" placeholder="https://api.openai.com/v1" /></label>
          <label>
            API Key（仅输入新值才会更新）
            <input id="jarvis-model-key" type="password" placeholder="sk-..." autocomplete="new-password" />
          </label>
          <label>Temperature<input id="jarvis-model-temp" type="number" min="0" max="2" step="0.1" value="0.7" /></label>

          <div class="settings-actions">
            <button id="jarvis-model-new" type="button" class="neo-btn">新建</button>
            <button id="jarvis-model-save" type="button" class="neo-btn primary">保存</button>
            <button id="jarvis-model-delete" type="button" class="neo-btn danger">删除</button>
          </div>
          <div class="settings-actions">
            <button id="jarvis-vault-reset" type="button" class="neo-btn danger">重置密钥保险库</button>
          </div>
        </section>

        <section id="jarvis-panel-roles" class="settings-pane" hidden>
          <label>当前草稿角色<select id="jarvis-role-draft-select"></select></label>
          <label>角色名<input id="jarvis-role-name" type="text" placeholder="例如 全栈助手" /></label>
          <label>前置系统提示词<textarea id="jarvis-role-system" rows="4" placeholder="你是一名专业 AI 助手..."></textarea></label>
          <label>角色补充设定<textarea id="jarvis-role-persona" rows="3" placeholder="回答风格、输出规范、语气等"></textarea></label>
          <label>开场白<textarea id="jarvis-role-greeting" rows="2" placeholder="角色已激活，准备对话。"></textarea></label>

          <div class="settings-actions">
            <button id="jarvis-role-new" type="button" class="neo-btn">新建</button>
            <button id="jarvis-role-save" type="button" class="neo-btn primary">保存</button>
            <button id="jarvis-role-delete" type="button" class="neo-btn danger">删除</button>
          </div>
          <div class="settings-actions">
            <button id="jarvis-role-activate" type="button" class="neo-btn primary">设为当前角色</button>
          </div>
        </section>

        <section id="jarvis-panel-selector" class="settings-pane" hidden>
          <div id="jarvis-model-selector-list" class="selector-list"></div>
          <div class="settings-actions">
            <button id="jarvis-model-activate" type="button" class="neo-btn primary">启用选中模型</button>
          </div>
        </section>

        <p id="jarvis-settings-status" class="settings-status" aria-live="polite"></p>
      </div>
    </section>
  </div>

  <div id="jarvis-save-confirm" class="jarvis-confirm" hidden>
    <div class="jarvis-confirm-mask"></div>
    <section class="jarvis-confirm-card surface" role="dialog" aria-modal="true" aria-label="确认保存模型">
      <h4>确认保存模型</h4>
      <p id="jarvis-confirm-note">将把模型信息写入浏览器本地存储。</p>
      <label id="jarvis-confirm-password-wrap" hidden>
        首次保存密钥，请设置加密密码
        <input id="jarvis-confirm-password" type="password" minlength="6" placeholder="至少 6 位" autocomplete="new-password" />
      </label>
      <div class="settings-actions">
        <button id="jarvis-confirm-cancel" type="button" class="neo-btn">取消</button>
        <button id="jarvis-confirm-ok" type="button" class="neo-btn primary">确认保存</button>
      </div>
    </section>
  </div>

  <script
    id="jarvis-page-config"
    type="application/json"
    set:html={JSON.stringify({ defaultModels, personaPresets, interactionConfig })}
  />

  <script>
    import "../scripts/jarvis-page-entry";
  </script>
</BaseLayout>

<style is:global>
  @import "../styles/jarvis.css";
</style>
