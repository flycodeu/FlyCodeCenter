---
import siteConfig from "@/site.config";
import ListLayout from "@/layouts/ListLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { fetchAllEntries, fetchBlogEntries, makeTagItems } from "@/utils/query";
import { paginatePageMode } from "@/utils/pagination";

export async function getStaticPaths() {
  if (siteConfig.blog.pagination.mode !== "page") return [];

  const entries = await fetchBlogEntries();
  const pageSize = siteConfig.blog.pagination.pageSize;
  const total = Math.max(1, Math.ceil(entries.length / pageSize));
  const paths = [];

  for (let page = 2; page <= total; page += 1) {
    const pageData = paginatePageMode(entries, page, pageSize);
    paths.push({
      params: { page: String(page) },
      props: {
        page,
        pageEntries: pageData.items,
        total
      }
    });
  }
  return paths;
}

const { page, pageEntries, total } = Astro.props;
const allEntries = await fetchAllEntries();
const tags = makeTagItems(allEntries);
---

<ListLayout
  title={`博客 - 第 ${page} 页`}
  description="工程化实践、性能优化与 Astro 插件化架构。"
  stats={[
    { title: "博客文章", value: allEntries.filter((item) => item.collection === "blog").length },
    { title: "标签总数", value: tags.length, href: "/tags" }
  ]}
  tags={tags}
>
  <div class="list">
    {pageEntries.map((entry: any) => <PostCard entry={entry} kind="blog" />)}
  </div>
  <Pagination currentPage={page} lastPage={total} basePath="/blog" mode="page" />
</ListLayout>

<style>
  .list {
    display: grid;
    gap: var(--space-4);
  }
</style>
