---
import siteConfig from "@/site.config";
import {
  buildInterviewSpaceBuckets,
  fetchInterviewEntries,
  fetchInterviewSpaceEntries,
  fromInterviewSpaceRouteKey,
  getInterviewEntryUrl,
  isInterviewReadmeEntry,
  resolveInterviewSlug,
  toInterviewSpaceRouteKey
} from "@/utils/interview";

interface RouteProps {
  space: string;
  slug: string;
  currentEntryId: string;
}

export async function getStaticPaths() {
  if (!siteConfig.pages.interviewCenter.enable) return [];
  const interviews = await fetchInterviewEntries();
  const spaceMap = buildInterviewSpaceBuckets(interviews);
  const paths: Array<{ params: { space: string; slug: string }; props: RouteProps }> = [];

  for (const bucket of spaceMap.values()) {
    for (const entry of bucket.entries) {
      if (isInterviewReadmeEntry(entry)) continue;
      paths.push({
        params: {
          space: toInterviewSpaceRouteKey(bucket.key),
          slug: resolveInterviewSlug(entry)
        },
        props: {
          space: bucket.key,
          slug: resolveInterviewSlug(entry),
          currentEntryId: entry.id
        }
      });
    }
  }

  return paths;
}

const { space, slug, currentEntryId } = Astro.props as RouteProps;
const spaceKey = fromInterviewSpaceRouteKey(space);
const entries = await fetchInterviewSpaceEntries(spaceKey);
if (!entries.length) {
  throw new Error(`Interview space not found: ${spaceKey}`);
}

const currentEntry = entries.find((entry) => entry.id === currentEntryId);
if (!currentEntry) {
  throw new Error(`Interview entry not found: ${spaceKey}/${slug}`);
}

return Astro.redirect(getInterviewEntryUrl(currentEntry), 301);
---
