---
import { render } from "astro:content";
import siteConfig from "@/site.config";
import InterviewReaderLayout from "@/layouts/InterviewReaderLayout.astro";
import {
  buildInterviewSpaceBuckets,
  fetchInterviewEntries,
  fetchInterviewSpaceEntries,
  fromInterviewSpaceRouteKey,
  isInterviewReadmeEntry,
  resolveInterviewMeta,
  resolveInterviewSlug,
  toInterviewSpaceRouteKey
} from "@/utils/interview";

interface RouteProps {
  space: string;
  currentEntryId: string;
}

export async function getStaticPaths() {
  if (!siteConfig.pages.interviewCenter.enable) return [];
  const interviews = await fetchInterviewEntries();
  const spaceMap = buildInterviewSpaceBuckets(interviews);
  const paths: Array<{ params: { space: string }; props: RouteProps }> = [];

  for (const bucket of spaceMap.values()) {
    const questions = bucket.entries.filter((entry) => !isInterviewReadmeEntry(entry));
    const first = questions[0] ?? bucket.readmeEntry ?? bucket.entries[0];
    if (!first) continue;
    paths.push({
      params: {
        space: toInterviewSpaceRouteKey(bucket.key)
      },
      props: {
        space: bucket.key,
        currentEntryId: first.id
      }
    });
  }

  return paths;
}

const { space, currentEntryId } = Astro.props as RouteProps;
const spaceKey = fromInterviewSpaceRouteKey(space);
const entries = await fetchInterviewSpaceEntries(spaceKey);
if (!entries.length) {
  throw new Error(`Interview space not found: ${spaceKey}`);
}

const spaceBucket = buildInterviewSpaceBuckets(entries).get(spaceKey);
const questionEntries = entries.filter((entry) => !isInterviewReadmeEntry(entry));
const currentEntry = questionEntries.find((entry) => entry.id === currentEntryId) ?? spaceBucket?.readmeEntry ?? entries[0];
const currentMeta = resolveInterviewMeta(currentEntry);
const rendered = await render(currentEntry);
const Content = rendered.Content;
const headings = rendered.headings;
const routeSpaceKey = toInterviewSpaceRouteKey(spaceKey);
const baseRoute = `${siteConfig.pages.interviewCenter.route}/${encodeURIComponent(routeSpaceKey)}`;
const items = questionEntries.map((entry) => {
  const meta = resolveInterviewMeta(entry);
  const slug = resolveInterviewSlug(entry);
  return {
    id: entry.id,
    slug,
    title: meta.title,
    difficulty: meta.difficulty,
    order: meta.order,
    url: `${baseRoute}/${encodeURIComponent(slug)}`
  };
});
const currentSlug = resolveInterviewSlug(currentEntry);
const currentIndex = items.findIndex((item) => item.id === currentEntry.id);
const prev = currentIndex > 0 ? { title: items[currentIndex - 1].title, url: items[currentIndex - 1].url } : undefined;
const next = currentIndex >= 0 && currentIndex < items.length - 1 ? { title: items[currentIndex + 1].title, url: items[currentIndex + 1].url } : undefined;
const articleUrl = baseRoute;
---

<InterviewReaderLayout
  title={currentMeta.title}
  summary={currentMeta.summary}
  description={currentMeta.description}
  type={currentMeta.type}
  difficulty={currentMeta.difficulty}
  articleUrl={articleUrl}
  spaceKey={spaceKey}
  spaceLabel={spaceBucket?.label ?? spaceKey}
  currentSlug={currentSlug}
  items={items}
  headings={headings}
  prev={prev}
  next={next}
>
  <Content />
</InterviewReaderLayout>
