---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchSitesEntries } from "@/utils/query";
import { getTagColorVars } from "@/utils/tag-color";

const sourceEntries = await fetchSitesEntries();

const entries = await Promise.all(
  sourceEntries.map(async (entry) => {
    const cards = [...(entry.data.cards ?? [])].sort((a, b) => {
      if (Number(b.pinned) !== Number(a.pinned)) return Number(b.pinned) - Number(a.pinned);
      if ((a.order ?? 999) !== (b.order ?? 999)) return (a.order ?? 999) - (b.order ?? 999);
      return a.title.localeCompare(b.title, "zh-CN");
    });

    return {
      entry,
      category: (entry.data.category || entry.data.title || "未分类").trim(),
      cards
    };
  })
);

const groups = [...entries].sort((a, b) => (a.entry.data.order ?? 999) - (b.entry.data.order ?? 999));
const defaultCategory = siteConfig.pages.sites.filter.defaultCategory;
const showFilter = siteConfig.pages.sites.filter.enable;
const resolvedDefaultCategory = groups[0]?.category ?? "";
const defaultSiteIcon = "/icons/site-default.svg";

const getHost = (url: string) => {
  try {
    return new URL(url).host.replace(/^www\./, "");
  } catch {
    return "";
  }
};

const resolveIcon = (url: string, icon: string, iconFetch?: boolean) => {
  if (icon?.trim()) return icon.trim();
  if (iconFetch === false) return "";
  const host = getHost(url);
  if (!host) return "";
  return `https://www.google.com/s2/favicons?domain=${encodeURIComponent(host)}&sz=64`;
};
---

<BaseLayout title={siteConfig.pages.sites.title} description={siteConfig.pages.sites.description}>
  <section class={`vault-shell ${showFilter ? "" : "no-nav"}`}>
    {
      showFilter && (
        <aside class="vault-nav surface" id="vault-nav">
          {
            groups.map((group) => (
              <button
                type="button"
                class={`nav-item${group.category === resolvedDefaultCategory ? " active" : ""}`}
                data-filter={group.category}
                style={getTagColorVars(group.category)}
              >
                <span class="nav-label">{group.category}</span>
                <span class="nav-count">{group.cards.length}</span>
              </button>
            ))
          }
        </aside>
      )
    }

    <section class="vault-content">
      <section class="vault-groups" id="vault-groups" data-default={resolvedDefaultCategory}>
        {
          groups.map((group) => (
            <section
              class={`vault-group surface${group.category === resolvedDefaultCategory ? " is-active" : ""}`}
              data-group={group.category}
              aria-hidden={group.category === resolvedDefaultCategory ? "false" : "true"}
            >
              <h2 class="sr-only">{group.entry.data.title}</h2>
              <div class="group-summary">
                <p class="group-desc">{group.entry.data.description || "按该主题组织的网站收藏清单。"}</p>
                <span class="group-count">{group.cards.length} 个站点</span>
              </div>

              <div class="group-grid">
                {
                  group.cards.map((card) => {
                    return (
                    <article class="site-card">
                      <header class="site-card-head">
                        <img
                          src={defaultSiteIcon}
                          data-icon-src={resolveIcon(card.url, card.icon, card.iconFetch)}
                          data-icon-key={getHost(card.url)}
                          alt=""
                          loading="lazy"
                          decoding="async"
                        />
                        <div class="site-title-wrap">
                          <h3 title={card.title}>{card.title}</h3>
                        </div>
                      </header>

                      <p class="site-desc">{card.desc || "暂无描述"}</p>

                      <div class="site-tags-line" aria-label="标签">
                        {card.tags.slice(0, 3).map((tag) => <span class="tag-badge meta-tag" style={getTagColorVars(tag)}>{tag}</span>)}
                      </div>

                      <footer class="site-foot">
                        <a class="visit-btn" href={card.url} target="_blank" rel="noreferrer">在线访问</a>
                      </footer>
                    </article>
                    );
                  })
                }
              </div>
            </section>
          ))
        }
      </section>
    </section>
  </section>
</BaseLayout>

<script is:inline>
  const initVaultFilter = () => {
    const root = document.getElementById('vault-groups');
    const filter = document.getElementById('vault-nav');
    if (!root || !filter) return;

    if (window.__flySitesFilterCleanup) {
      window.__flySitesFilterCleanup();
    }

    const controller = new AbortController();
    const { signal } = controller;

    const buttons = Array.from(filter.querySelectorAll('.nav-item'));
    const groups = Array.from(root.querySelectorAll('.vault-group'));
    const normalize = (value) => String(value || '').trim().toLowerCase();

    const setFilter = (value, syncQuery = true) => {
      const normalized = normalize(value || '');
      if (!normalized) return;

      buttons.forEach((btn) => {
        btn.classList.toggle('active', normalize(btn.dataset.filter) === normalized);
      });

      let hasVisible = false;
      groups.forEach((group) => {
        const category = normalize(group.getAttribute('data-group'));
        const visible = normalized === category;
        if (visible) hasVisible = true;
        group.classList.toggle('is-active', visible);
        group.setAttribute('aria-hidden', String(!visible));
      });

      if (!hasVisible) {
        const fallback = buttons[0]?.dataset.filter || '';
        if (fallback && fallback !== value) {
          setFilter(fallback, syncQuery);
        }
        return;
      }

      if (syncQuery && hasVisible) {
        const url = new URL(window.location.href);
        const activeBtn = buttons.find((btn) => normalize(btn.dataset.filter) === normalized);
        if (activeBtn?.dataset.filter) {
          url.searchParams.set('category', activeBtn.dataset.filter);
        }
        window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
      }
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', (event) => {
        event.preventDefault();
        setFilter(btn.dataset.filter || '');
      }, { signal });
    });

    const queryCategory = new URLSearchParams(window.location.search).get('category');
    const pickDefault = () => {
      const defaultFilter = root.getAttribute('data-default') || '';
      const hit = buttons.find((btn) => normalize(btn.dataset.filter) === normalize(defaultFilter));
      return hit?.dataset.filter || buttons[0]?.dataset.filter || '';
    };

    if (queryCategory) {
      const hit = buttons.find((btn) => normalize(btn.dataset.filter) === normalize(queryCategory));
      setFilter(hit?.dataset.filter || pickDefault(), false);
    } else {
      setFilter(pickDefault(), false);
    }

    window.__flySitesFilterCleanup = () => {
      controller.abort();
    };
  };

  document.addEventListener('astro:page-load', initVaultFilter);
  initVaultFilter();
  const initSiteIconCache = () => {
    const storageKey = "fly-sites-icon-fail";
    let failed = {};
    try {
      failed = JSON.parse(localStorage.getItem(storageKey) || "{}") || {};
    } catch {
      failed = {};
    }

    const save = () => {
      try {
        localStorage.setItem(storageKey, JSON.stringify(failed));
      } catch {}
    };

    document.querySelectorAll("img[data-icon-src]").forEach((img) => {
      if (!(img instanceof HTMLImageElement)) return;
      const iconSrc = (img.dataset.iconSrc || "").trim();
      const key = (img.dataset.iconKey || "").trim();
      if (!iconSrc || !key) return;
      if (failed[key]) return;

      img.addEventListener(
        "error",
        () => {
          failed[key] = 1;
          img.src = `${defaultSiteIcon}`;
          save();
        },
        { once: true }
      );

      img.src = iconSrc;
    });
  };

  document.addEventListener('astro:page-load', initSiteIconCache);
  initSiteIconCache();
</script>

<style>
  :global(main.container) {
    width: min(1480px, calc(100% - var(--space-6)));
  }

  .vault-shell {
    display: grid;
    grid-template-columns: minmax(180px, 240px) minmax(0, 1fr);
    gap: 1.2rem;
    align-items: start;
  }

  .vault-shell.no-nav {
    grid-template-columns: minmax(0, 1fr);
  }

  .vault-nav {
    position: sticky;
    top: 78px;
    display: grid;
    gap: 0.5rem;
    padding: 0.75rem;
    border-radius: 14px;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg-elev) 95%, transparent 5%);
    backdrop-filter: blur(10px);
    max-height: calc(100vh - 120px);
    overflow: auto;
  }

  .nav-item {
    --nav-border: color-mix(in oklab, var(--line) 86%, transparent 14%);
    --nav-bg: color-mix(in oklab, var(--bg-elev) 92%, transparent 8%);
    --nav-text: var(--text-soft);

    width: 100%;
    border: 1px solid var(--tag-border, var(--nav-border));
    background: var(--tag-bg, var(--nav-bg));
    color: var(--tag-text, var(--nav-text));
    border-radius: 12px;
    padding: 0.42rem 0.6rem;
    font-size: 0.82rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    cursor: pointer;
    text-align: left;
    transition: border-color 150ms ease, box-shadow 150ms ease, color 150ms ease;
  }

  .nav-item.active {
    border-color: color-mix(in oklab, var(--brand) 35%, var(--nav-border) 65%);
    color: var(--brand);
    box-shadow: 0 10px 20px -16px color-mix(in oklab, var(--brand) 26%, transparent 74%);
  }

  .nav-label {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-count {
    border: 1px solid color-mix(in oklab, var(--line) 80%, transparent 20%);
    border-radius: 999px;
    padding: 0.02rem 0.38rem;
    font-size: 0.68rem;
    background: var(--tag-count-bg, color-mix(in oklab, var(--bg) 90%, transparent 10%));
    white-space: nowrap;
  }

  .vault-content {
    min-width: 0;
  }

  .vault-groups {
    display: grid;
    gap: 1.1rem;
  }

  .vault-group {
    padding: 0.9rem;
    display: none;
    gap: 0.95rem;
  }

  .vault-group.is-active {
    display: grid;
  }

  .group-summary {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.9rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.6rem;
  }

  .group-desc {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.88rem;
    line-height: 1.5;
    flex: 1;
  }

  .group-count {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.08rem 0.38rem;
    font-size: 0.71rem;
    color: var(--text-soft);
    background: color-mix(in oklab, var(--bg) 92%, transparent 8%);
    white-space: nowrap;
  }

  .group-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .site-card {
    border: 1px solid color-mix(in oklab, var(--line) 86%, var(--brand) 14%);
    border-radius: 11px;
    background: color-mix(in oklab, var(--bg-elev) 96%, transparent 4%);
    padding: 0.74rem;
    display: flex;
    flex-direction: column;
    gap: 0.56rem;
    min-height: 188px;
    transition: border-color 170ms ease, box-shadow 170ms ease, transform 170ms ease;
  }

  .site-card:hover {
    border-color: color-mix(in oklab, var(--line) 68%, var(--brand) 32%);
    box-shadow: 0 12px 22px -16px color-mix(in oklab, var(--brand) 18%, transparent 82%);
    transform: translateY(-1px);
  }

  .site-card-head {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .site-card-head img {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    border: 1px solid var(--line);
    background: var(--bg);
    padding: 2px;
    object-fit: contain;
    flex: 0 0 auto;
  }

  .site-title-wrap {
    min-width: 0;
    display: grid;
    gap: 0.24rem;
  }

  .site-title-wrap h3 {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.32;
    min-height: calc(1.32em * 2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }


  .site-desc {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.76rem;
    line-height: 1.38;
    min-height: calc(1.38em * 2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .site-tags-line {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    min-height: 1.1rem;
    overflow: hidden;
    white-space: nowrap;
  }

  .site-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.7rem;
  }

  .meta-tag {
    font-size: 0.64rem;
    padding: 0.03rem 0.34rem;
    border-radius: 6px;
    flex: 0 0 auto;
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .visit-btn {
    border: 1px solid color-mix(in oklab, var(--brand) 30%, var(--line) 70%);
    border-radius: 7px;
    background: color-mix(in oklab, var(--brand-soft) 40%, var(--bg-elev) 60%);
    color: color-mix(in oklab, var(--text) 68%, var(--brand) 32%);
    text-align: center;
    padding: 0.24rem 0.5rem;
    font-size: 0.7rem;
    white-space: nowrap;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .visit-btn:hover {
    background: color-mix(in oklab, var(--brand-soft) 54%, var(--bg-elev) 46%);
    color: color-mix(in oklab, var(--text) 62%, var(--brand) 38%);
  }

  @media (max-width: 1500px) {
    .group-grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  @media (max-width: 1280px) {
    .group-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 1100px) {
    .group-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .vault-shell {
      grid-template-columns: 1fr;
    }

    .vault-nav {
      position: static;
      max-height: none;
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      gap: 0.6rem;
      padding: 0.6rem;
    }

    .nav-item {
      flex: 0 0 auto;
      white-space: nowrap;
    }

    .group-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .group-summary {
      flex-direction: column;
      align-items: flex-start;
    }

    .group-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
