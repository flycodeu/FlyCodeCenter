---
import siteConfig from "@/site.config";
import ListLayout from "@/layouts/ListLayout.astro";
import { fetchAllContentEntries, fetchSitesEntries, makeTagItems } from "@/utils/query";

const [entries, allEntries] = await Promise.all([fetchSitesEntries(), fetchAllContentEntries()]);
const tags = makeTagItems(allEntries);

const tagCounter = new Map<string, number>();
for (const entry of entries) {
  for (const tag of entry.data.tags) {
    tagCounter.set(tag, (tagCounter.get(tag) ?? 0) + 1);
  }
}

const siteTags = [...tagCounter.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count }));

const grid = siteConfig.pages.sites.grid;
---

<ListLayout
  title={siteConfig.pages.sites.title}
  description="整合 AI 网站资源与工具服务，支持按标签快速筛选。"
  stats={[
    { title: "资源数量", value: entries.length },
    { title: "站点标签", value: siteTags.length },
    { title: "标签索引", value: "打开", href: "/tags" },
    { title: "优秀文章", value: "打开", href: "/reading" }
  ]}
  tags={tags}
>
  <section class="surface filter-panel" id="site-filter-root" data-default="all">
    <button class="filter-chip active" type="button" data-site-filter="all">
      全部 <span>{entries.length}</span>
    </button>
    {
      siteTags.map((item) => (
        <button class="filter-chip" type="button" data-site-filter={item.name}>
          {item.name} <span>{item.count}</span>
        </button>
      ))
    }
  </section>

  <section
    class="site-grid"
    style={`--site-cols-md:${grid.columns.md};--site-cols-lg:${grid.columns.lg};--site-cols-xl:${grid.columns.xl};--site-gap:${grid.gap}px;`}
  >
    {
      entries.map((entry) => {
        const tagsText = entry.data.tags.join("||");
        return (
          <article class="surface site-card" data-site-card data-tags={tagsText}>
            <header>
              <a href={entry.data.url} target="_blank" rel="noreferrer" class="title-link">
                {entry.data.title}
              </a>
              <span class={`status ${entry.data.status}`}>{entry.data.status}</span>
            </header>

            <p>{entry.data.description}</p>

            <div class="meta-row">
              <strong>地址</strong>
              <a href={entry.data.url} target="_blank" rel="noreferrer" class="site-url">
                {entry.data.url.replace(/^https?:\/\//, "")}
              </a>
            </div>

            <div class="meta-row">
              <strong>标签</strong>
              <div class="chip-wrap">
                {entry.data.tags.map((item) => <span class="chip">{item}</span>)}
              </div>
            </div>
          </article>
        );
      })
    }
  </section>

  <script>
    import "../scripts/sites-filter";
  </script>
</ListLayout>

<style>
  .filter-panel {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0.66rem;
    margin-bottom: 0.65rem;
  }
  .filter-chip {
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--bg-elev);
    color: var(--text-soft);
    padding: 0.32rem 0.62rem;
    cursor: pointer;
    font-size: 0.82rem;
  }
  .filter-chip span {
    opacity: 0.7;
  }
  .filter-chip.active {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 46%, var(--line) 54%);
    background: color-mix(in oklab, var(--brand-soft) 54%, var(--bg-elev) 46%);
  }
  .site-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--site-gap);
  }
  .site-card {
    padding: 0.76rem;
    display: grid;
    gap: 0.56rem;
    transition: transform 180ms ease, border-color 180ms ease;
  }
  .site-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--brand) 35%, var(--line) 65%);
  }
  .site-card[hidden] {
    display: none;
  }
  .site-card header {
    display: flex;
    justify-content: space-between;
    gap: 0.65rem;
    align-items: center;
  }
  .title-link {
    font-family: var(--font-serif);
    font-size: 1.02rem;
    font-weight: 700;
  }
  .title-link:hover,
  .site-url:hover {
    color: var(--brand);
  }
  .status {
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 0.74rem;
    padding: 0.12rem 0.46rem;
    text-transform: uppercase;
    color: var(--text-soft);
  }
  .status.active {
    color: var(--brand);
  }
  .status.beta {
    color: var(--accent);
  }
  .meta-row {
    display: grid;
    gap: 0.32rem;
  }
  .meta-row strong {
    font-size: 0.8rem;
    color: var(--text-soft);
  }
  .site-url {
    color: var(--text);
    font-size: 0.88rem;
    overflow-wrap: anywhere;
  }
  .chip-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.34rem;
  }
  .chip-wrap .chip {
    font-size: 0.74rem;
  }

  @media (min-width: 760px) {
    .site-grid {
      grid-template-columns: repeat(var(--site-cols-md), minmax(0, 1fr));
    }
  }
  @media (min-width: 1120px) {
    .site-grid {
      grid-template-columns: repeat(var(--site-cols-lg), minmax(0, 1fr));
    }
  }
  @media (min-width: 1520px) {
    .site-grid {
      grid-template-columns: repeat(var(--site-cols-xl), minmax(0, 1fr));
    }
  }
</style>
