---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchSitesEntries } from "@/utils/query";
import { getTagColorVars } from "@/utils/tag-color";
import { render } from "astro:content";

const sourceEntries = await fetchSitesEntries();

const entries = await Promise.all(
  sourceEntries.map(async (entry) => {
    const { Content } = await render(entry);
    const cards = [...(entry.data.cards ?? [])].sort((a, b) => {
      if (Number(b.pinned) !== Number(a.pinned)) return Number(b.pinned) - Number(a.pinned);
      if ((a.order ?? 999) !== (b.order ?? 999)) return (a.order ?? 999) - (b.order ?? 999);
      return a.title.localeCompare(b.title, "zh-CN");
    });

    return {
      entry,
      Content,
      category: (entry.data.category || entry.data.title || "未分类").trim(),
      cards
    };
  })
);

const groups = [...entries].sort((a, b) => (a.entry.data.order ?? 999) - (b.entry.data.order ?? 999));
const defaultCategory = siteConfig.pages.sites.filter.defaultCategory;
const showFilter = siteConfig.pages.sites.filter.enable;
const totalItems = groups.reduce((sum, group) => sum + group.cards.length, 0);

const resolveIcon = (url: string, icon: string) => {
  if (icon?.trim()) return icon.trim();
  return `https://www.google.com/s2/favicons?domain_url=${encodeURIComponent(url)}&sz=64`;
};

const getHost = (url: string) => {
  try {
    return new URL(url).host.replace(/^www\./, "");
  } catch {
    return "";
  }
};
---

<BaseLayout title={siteConfig.pages.sites.title} description={siteConfig.pages.sites.description}>
  <section class="vault-hero surface">
    <div class="hero-copy">
      <h1>{siteConfig.pages.sites.title}</h1>
      <p>{siteConfig.pages.sites.description}</p>
    </div>
    <div class="hero-stats">
      <span class="stat-pill">{groups.length} 个分类</span>
      <span class="stat-pill">{totalItems} 个站点</span>
    </div>
  </section>

  {
    showFilter && (
      <section class="vault-filter" id="vault-filter">
        <button type="button" class="filter-chip active" data-filter="all" style="--tag-hue:216">
          <span>全部</span>
          <small>{totalItems}</small>
        </button>
        {
          groups.map((group) => (
            <button
              type="button"
              class="filter-chip"
              data-filter={group.category}
              style={getTagColorVars(group.category)}
            >
              <span>{group.category}</span>
              <small>{group.cards.length}</small>
            </button>
          ))
        }
      </section>
    )
  }

  <section class="vault-groups" id="vault-groups" data-default={defaultCategory}>
    {
      groups.map((group) => (
        <section class="vault-group surface" data-group={group.category}>
          <header class="group-head">
            <div>
              <h2>{group.entry.data.title}</h2>
              <p>{group.entry.data.description || "按该主题组织的网站收藏清单。"}</p>
            </div>
            <span class="group-count">{group.cards.length} 个站点</span>
          </header>

          <div class="group-intro prose">
            <group.Content />
          </div>

          <div class="group-grid">
            {
              group.cards.map((card) => (
                <article class="site-card">
                  <header class="site-card-head">
                    <img src={resolveIcon(card.url, card.icon)} alt="" loading="lazy" decoding="async" />
                    <div class="site-title-wrap">
                      <h3 title={card.title}>{card.title}</h3>
                      {card.badge && <span class="site-badge">{card.badge}</span>}
                    </div>
                  </header>

                  <p class="site-desc">{card.desc || "暂无描述"}</p>

                  <div class="site-meta">
                    {card.category && <span class="tag-badge meta-tag" style={getTagColorVars(card.category)}>{card.category}</span>}
                    {card.tags.slice(0, 3).map((tag) => <span class="tag-badge meta-tag" style={getTagColorVars(tag)}>{tag}</span>)}
                  </div>

                  <footer class="site-foot">
                    <span class="site-host">{getHost(card.url)}</span>
                    <a class="visit-btn" href={card.url} target="_blank" rel="noreferrer">访问站点</a>
                  </footer>
                </article>
              ))
            }
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>

<script is:inline>
  const initVaultFilter = () => {
    const root = document.getElementById('vault-groups');
    const filter = document.getElementById('vault-filter');
    if (!root || !filter) return;

    if (window.__flySitesFilterCleanup) {
      window.__flySitesFilterCleanup();
    }

    const controller = new AbortController();
    const { signal } = controller;

    const buttons = Array.from(filter.querySelectorAll('.filter-chip'));
    const groups = Array.from(root.querySelectorAll('.vault-group'));
    const normalize = (value) => String(value || '').trim().toLowerCase();

    const setFilter = (value, syncQuery = true) => {
      const normalized = normalize(value || 'all');

      buttons.forEach((btn) => {
        btn.classList.toggle('active', normalize(btn.dataset.filter) === normalized);
      });

      groups.forEach((group) => {
        const category = normalize(group.getAttribute('data-group'));
        const visible = normalized === 'all' || normalized === category;
        group.toggleAttribute('hidden', !visible);
      });

      if (syncQuery) {
        const url = new URL(window.location.href);
        if (normalized === 'all') {
          url.searchParams.delete('category');
        } else {
          const activeBtn = buttons.find((btn) => normalize(btn.dataset.filter) === normalized);
          if (activeBtn?.dataset.filter) {
            url.searchParams.set('category', activeBtn.dataset.filter);
          }
        }
        window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
      }
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        setFilter(btn.dataset.filter || 'all');
      }, { signal });
    });

    const queryCategory = new URLSearchParams(window.location.search).get('category');
    if (queryCategory) {
      const hit = buttons.find((btn) => normalize(btn.dataset.filter) === normalize(queryCategory));
      setFilter(hit?.dataset.filter || 'all', false);
    } else {
      const defaultFilter = root.getAttribute('data-default') || 'all';
      const hit = buttons.find((btn) => normalize(btn.dataset.filter) === normalize(defaultFilter));
      setFilter(hit?.dataset.filter || 'all', false);
    }

    window.__flySitesFilterCleanup = () => {
      controller.abort();
    };
  };

  document.addEventListener('astro:page-load', initVaultFilter);
  initVaultFilter();
</script>

<style>
  .vault-hero {
    margin-bottom: 0.9rem;
    padding: 1rem 1.05rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-copy h1 {
    margin: 0;
    font-size: clamp(1.35rem, 1vw + 1rem, 1.72rem);
    letter-spacing: -0.01em;
  }

  .hero-copy p {
    margin: 0.22rem 0 0;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .stat-pill {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.18rem 0.52rem;
    font-size: 0.73rem;
    color: var(--text-soft);
    background: color-mix(in oklab, var(--bg) 92%, transparent 8%);
    white-space: nowrap;
  }

  .vault-filter {
    position: sticky;
    top: 74px;
    z-index: 8;
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin-bottom: 0.82rem;
    padding: 0.62rem;
    border: 1px solid var(--line);
    border-radius: 11px;
    background: color-mix(in oklab, var(--bg-elev) 95%, transparent 5%);
    backdrop-filter: blur(10px);
  }

  .filter-chip {
    --tag-border: color-mix(in oklab, var(--line) 86%, transparent 14%);
    --tag-bg: color-mix(in oklab, var(--bg-elev) 92%, transparent 8%);
    --tag-text: var(--text-soft);

    border: 1px solid var(--tag-border);
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 999px;
    padding: 0.24rem 0.56rem;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    cursor: pointer;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .filter-chip small {
    border: 1px solid color-mix(in oklab, var(--tag-border) 82%, transparent 18%);
    border-radius: 999px;
    padding: 0.02rem 0.3rem;
    font-size: 0.68rem;
    background: color-mix(in oklab, var(--bg) 90%, transparent 10%);
  }

  .filter-chip.active {
    border-color: color-mix(in oklab, var(--tag-border) 74%, var(--brand) 26%);
    box-shadow: 0 8px 16px -14px color-mix(in oklab, var(--brand) 22%, transparent 78%);
  }

  .vault-groups {
    display: grid;
    gap: 0.9rem;
  }

  .vault-group {
    padding: 0.85rem;
    display: grid;
    gap: 0.78rem;
  }

  .group-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.52rem;
  }

  .group-head h2 {
    margin: 0;
    font-size: 1.05rem;
  }

  .group-head p {
    margin: 0.2rem 0 0;
    color: var(--text-soft);
    font-size: 0.82rem;
  }

  .group-count {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.08rem 0.38rem;
    font-size: 0.71rem;
    color: var(--text-soft);
    background: color-mix(in oklab, var(--bg) 92%, transparent 8%);
    white-space: nowrap;
  }

  .group-intro {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.82rem;
  }

  .group-intro p {
    margin: 0.3rem 0;
  }

  .group-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.68rem;
  }

  .site-card {
    border: 1px solid color-mix(in oklab, var(--line) 88%, var(--brand) 12%);
    border-radius: 12px;
    background: color-mix(in oklab, var(--bg-elev) 96%, transparent 4%);
    padding: 0.72rem;
    display: grid;
    gap: 0.5rem;
    min-height: 204px;
    transition: border-color 170ms ease, box-shadow 170ms ease, transform 170ms ease;
  }

  .site-card:hover {
    border-color: color-mix(in oklab, var(--line) 68%, var(--brand) 32%);
    box-shadow: 0 12px 22px -16px color-mix(in oklab, var(--brand) 18%, transparent 82%);
    transform: translateY(-1px);
  }

  .site-card-head {
    display: flex;
    align-items: center;
    gap: 0.56rem;
  }

  .site-card-head img {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: var(--bg);
    padding: 2px;
    object-fit: contain;
    flex: 0 0 auto;
  }

  .site-title-wrap {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .site-title-wrap h3 {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.36;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .site-badge {
    border: 1px solid color-mix(in oklab, var(--brand) 26%, var(--line) 74%);
    border-radius: 999px;
    padding: 0.03rem 0.35rem;
    font-size: 0.65rem;
    color: color-mix(in oklab, var(--text) 72%, var(--brand) 28%);
    background: color-mix(in oklab, var(--brand-soft) 42%, var(--bg-elev) 58%);
  }

  .site-desc {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .site-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.28rem;
    align-content: start;
  }

  .meta-tag {
    font-size: 0.68rem;
    padding: 0.03rem 0.35rem;
    border-radius: 7px;
  }

  .site-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.52rem;
  }

  .site-host {
    font-size: 0.72rem;
    color: var(--text-soft);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .visit-btn {
    border: 1px solid color-mix(in oklab, var(--brand) 30%, var(--line) 70%);
    border-radius: 8px;
    background: color-mix(in oklab, var(--brand-soft) 40%, var(--bg-elev) 60%);
    color: color-mix(in oklab, var(--text) 68%, var(--brand) 32%);
    text-align: center;
    padding: 0.3rem 0.58rem;
    font-size: 0.76rem;
    white-space: nowrap;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .visit-btn:hover {
    background: color-mix(in oklab, var(--brand-soft) 54%, var(--bg-elev) 46%);
    color: color-mix(in oklab, var(--text) 62%, var(--brand) 38%);
  }

  @media (max-width: 900px) {
    .vault-filter {
      position: static;
      top: auto;
    }
  }

  @media (max-width: 700px) {
    .vault-hero {
      align-items: flex-start;
      flex-direction: column;
    }

    .group-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
