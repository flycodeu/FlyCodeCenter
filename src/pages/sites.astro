---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchSitesEntries } from "@/utils/query";
import { render } from "astro:content";

const entries = await fetchSitesEntries();
---

<BaseLayout title={siteConfig.pages.sites.title} description="整合优质网站资源与工具服务">
  <div class="sites-header surface fade-up">
    <h1>优质网站导航</h1>
    <p>发现、整理并分享日常使用的高效工具与学习资源</p>
  </div>

  <div class="sites-container">
    {entries.map(async (entry) => {
      const { Content } = await render(entry);
      return (
        <section class="site-group surface fade-up">
          <h2 class="group-title">
            <span class="icon">#</span> {entry.data.title}
          </h2>
          <div class="site-content custom-list-cards prose">
            <Content />
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>

<style is:global>
  .sites-header {
    padding: 3rem 2rem;
    text-align: center;
    border-radius: 16px;
    margin-bottom: 2rem;
    background: linear-gradient(135deg, var(--bg-elev), var(--brand-soft));
  }
  .sites-header h1 {
    margin: 0 0 1rem 0;
    font-size: 2.5rem;
    font-family: var(--font-sans);
    color: var(--text);
  }
  .sites-header p {
    margin: 0;
    font-size: 1.125rem;
    color: var(--text-soft);
  }
  .sites-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .site-group {
    padding: 1.5rem;
    border-radius: 12px;
  }
  .group-title {
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-family: var(--font-sans);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.75rem;
  }
  .group-title .icon {
    color: var(--brand);
    opacity: 0.5;
  }
  
  /* Convert Markdown lists to Cards */
  .custom-list-cards ul {
    list-style: none !important;
    padding: 0 !important;
    margin: 1.5rem 0 0 0 !important;
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)) !important;
    gap: 1.25rem !important;
  }
  .custom-list-cards li {
    margin: 0 !important;
    padding: 1.25rem !important;
    background: var(--bg) !important;
    border: 1px solid var(--line) !important;
    border-radius: 12px !important;
    transition: all 0.2s ease !important;
    display: flex !important;
    flex-direction: column;
    gap: 0.5rem;
  }
  .custom-list-cards li::before {
    display: none !important;
  }
  .custom-list-cards li:hover {
    border-color: var(--brand) !important;
    transform: translateY(-4px) !important;
    box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.1) !important;
  }
  .custom-list-cards li a {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text) !important;
    text-decoration: none !important;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: none !important;
  }
  .custom-list-cards li a::before {
    content: "";
    display: inline-block;
    width: 20px;
    height: 20px;
    background-color: var(--brand);
    mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71m-5.4 6.1a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>') no-repeat center / contain;
    -webkit-mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71m-5.4 6.1a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>') no-repeat center / contain;
  }
  .custom-list-cards li a:hover {
    color: var(--brand) !important;
  }
  .custom-list-cards li p {
    margin: 0 !important;
    font-size: 0.9rem;
    color: var(--text-soft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
