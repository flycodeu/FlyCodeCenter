---
import { getCollection } from "astro:content";
import siteConfig from "@/site.config";
import ListLayout from "@/layouts/ListLayout.astro";

const entries = await getCollection("gallery", (entry) => !entry.data.draft);

const photos = entries
  .flatMap((entry) => entry.data.photos)
  .sort((a, b) => {
    if (Number(b.featured) !== Number(a.featured)) return Number(b.featured) - Number(a.featured);
    return (a.order ?? 999) - (b.order ?? 999);
  });

const pageSize = siteConfig.gallery.pageSize;
const lazyBatchSize = siteConfig.gallery.lazyBatchSize;
---

<ListLayout title="摄影" description="紧凑展示与丝滑交互，按需加载更多图片。" tags={[]} hideSidebar>
  <section class="photo-grid" id="photo-grid" oncontextmenu="return false;" data-batch={lazyBatchSize}>
    {
      photos.map((photo, index) => {
        const visible = index < pageSize;
        return (
          <figure class="photo-item surface fade-up" data-photo-item hidden={!visible ? true : undefined} style={`--object-position:${photo.position || "center"};`}>
            <a href={photo.src} target="_blank" rel="noreferrer" class="image-link" draggable="false">
              <img
                src={visible ? photo.src : undefined}
                data-src={!visible ? photo.src : undefined}
                alt={photo.title}
                loading="lazy"
                decoding="async"
                referrerpolicy="no-referrer"
                class="protected-img"
                draggable="false"
              />
            </a>
            <figcaption>
              <h3>{photo.title}</h3>
              <p>{photo.desc}</p>
              {photo.location && <span>{photo.location}</span>}
            </figcaption>
          </figure>
        );
      })
    }
  </section>

  <div class="load-wrap">
    <button id="load-more-photos" type="button" class="load-btn">加载更多</button>
  </div>
</ListLayout>

<script is:inline>
  const initGallery = () => {
    const grid = document.getElementById('photo-grid');
    const loadBtn = document.getElementById('load-more-photos');
    if (!grid || !loadBtn) return;

    if (window.__flyGalleryCleanup) {
      window.__flyGalleryCleanup();
    }

    const controller = new AbortController();
    const { signal } = controller;
    const batchSize = Number(grid.getAttribute('data-batch') || '8');

    const bindMotionEffects = (items) => {
      items.forEach((item) => {
        if (!(item instanceof HTMLElement)) return;
        if (item.dataset.motionBound === '1') return;
        item.dataset.motionBound = '1';

        let frame = 0;
        let targetX = 0;
        let targetY = 0;
        let currentX = 0;
        let currentY = 0;
        let active = false;

        const render = () => {
          currentX += (targetX - currentX) * 0.14;
          currentY += (targetY - currentY) * 0.14;
          item.style.setProperty('--tilt-x', `${currentY.toFixed(2)}deg`);
          item.style.setProperty('--tilt-y', `${currentX.toFixed(2)}deg`);
          item.style.setProperty('--zoom', active ? '1.06' : '1');
          if (Math.abs(targetX - currentX) > 0.05 || Math.abs(targetY - currentY) > 0.05 || active) {
            frame = window.requestAnimationFrame(render);
          } else {
            frame = 0;
          }
        };

        const start = () => {
          if (frame) return;
          frame = window.requestAnimationFrame(render);
        };

        item.addEventListener('pointerenter', () => {
          active = true;
          start();
        }, { signal });

        item.addEventListener('pointermove', (event) => {
          const rect = item.getBoundingClientRect();
          const px = (event.clientX - rect.left) / rect.width - 0.5;
          const py = (event.clientY - rect.top) / rect.height - 0.5;
          targetX = px * 8;
          targetY = -py * 8;
          start();
        }, { signal });

        item.addEventListener('pointerleave', () => {
          active = false;
          targetX = 0;
          targetY = 0;
          start();
        }, { signal });
      });
    };

    const revealNextBatch = () => {
      const hiddenItems = Array.from(grid.querySelectorAll('[data-photo-item][hidden]')).slice(0, batchSize);
      hiddenItems.forEach((item) => {
        item.removeAttribute('hidden');
        const img = item.querySelector('img[data-src]');
        if (img && img instanceof HTMLImageElement) {
          const src = img.getAttribute('data-src');
          if (src) {
            img.src = src;
            img.removeAttribute('data-src');
          }
        }
      });
      bindMotionEffects(hiddenItems);

      if (grid.querySelectorAll('[data-photo-item][hidden]').length === 0) {
        loadBtn.setAttribute('hidden', 'true');
      }
    };

    loadBtn.addEventListener('click', revealNextBatch, { signal });

    document.addEventListener('dragstart', (e) => {
      const target = e.target;
      if (target instanceof HTMLElement && target.classList.contains('protected-img')) {
        e.preventDefault();
      }
    }, { signal });

    document.addEventListener('copy', (e) => {
      const target = document.activeElement;
      if (target && target.closest && target.closest('.photo-grid')) {
        e.preventDefault();
      }
    }, { signal });

    bindMotionEffects(Array.from(grid.querySelectorAll('[data-photo-item]:not([hidden])')));

    if (grid.querySelectorAll('[data-photo-item][hidden]').length === 0) {
      loadBtn.setAttribute('hidden', 'true');
    }

    window.__flyGalleryCleanup = () => {
      controller.abort();
    };
  };

  document.addEventListener('astro:page-load', initGallery);
  initGallery();
</script>

<style>
  .photo-grid {
    columns: 4 220px;
    column-gap: 0.62rem;
  }

  .photo-item {
    break-inside: avoid;
    margin: 0 0 0.62rem;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-elev);
    transform: perspective(900px) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg)) scale(var(--zoom, 1));
    transform-style: preserve-3d;
    will-change: transform;
    transition: transform 180ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }

  .photo-item:hover {
    border-color: color-mix(in oklab, var(--brand) 48%, var(--line) 52%);
    box-shadow: 0 18px 32px color-mix(in oklab, var(--brand) 14%, transparent 86%);
  }

  .image-link {
    display: block;
    min-height: 180px;
    overflow: hidden;
    background: color-mix(in oklab, var(--bg) 88%, var(--line) 12%);
  }

  .image-link img {
    width: 100%;
    display: block;
    object-fit: cover;
    object-position: var(--object-position, center);
    transition: transform 320ms ease;
    user-select: none;
    -webkit-user-drag: none;
  }

  .photo-item:hover img {
    transform: scale(1.05);
  }

  figcaption {
    padding: 0.52rem 0.62rem 0.62rem;
    display: grid;
    gap: 0.16rem;
  }

  figcaption h3 {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.38;
  }

  figcaption p {
    margin: 0;
    font-size: 0.76rem;
    color: var(--text-soft);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  figcaption span {
    width: fit-content;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.05rem 0.38rem;
    font-size: 0.69rem;
    color: var(--text-soft);
  }

  .load-wrap {
    margin-top: 0.85rem;
    display: flex;
    justify-content: center;
  }

  .load-btn {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.4rem 0.95rem;
    background: var(--bg-elev);
    color: var(--text);
    cursor: pointer;
    font-size: 0.86rem;
  }

  .load-btn:hover {
    border-color: color-mix(in oklab, var(--brand) 45%, var(--line) 55%);
    color: var(--brand);
  }

  @media (max-width: 900px) {
    .photo-grid {
      columns: 2 170px;
    }
  }

  @media (max-width: 640px) {
    .photo-grid {
      columns: 1;
    }
  }
</style>