---
import ListLayout from "@/layouts/ListLayout.astro";
import { fetchAllEntries, makeTagItems } from "@/utils/query";

const entries = await fetchAllEntries();
const tags = makeTagItems(entries);
---

<ListLayout
  title="标签"
  description="浏览所有文章标签，快速定位你的兴趣点。"
  stats={[
    { title: "标签数量", value: tags.length },
    { title: "文章总数", value: entries.length, href: "/archives" }
  ]}
  tags={tags}
>
  <section class="tag-badge-container surface">
    {
      tags.map((item) => (
        <a class="tag-badge" href={item.href}>
          <span class="name">{item.name}</span>
          <span class="count">{item.count}</span>
        </a>
      ))
    }
  </section>
</ListLayout>

<style>
  .tag-badge-container {
    padding: 2rem;
    border-radius: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .tag-badge {
    display: inline-flex;
    align-items: stretch;
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid var(--line);
    transition: all 0.2s ease;
    background: var(--bg-elev);
  }
  .tag-badge:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px -2px color-mix(in oklab, var(--brand) 20%, transparent 80%);
  }
  .tag-badge .name {
    padding: 0.5rem 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
  }
  .tag-badge:hover .name {
    color: var(--brand);
    background: var(--brand-soft);
  }
  .tag-badge .count {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: monospace;
    background: var(--line);
    color: var(--text-soft);
    border-left: 1px solid var(--line);
  }
  .tag-badge:hover .count {
    background: var(--brand);
    color: #fff;
    border-color: var(--brand);
  }
</style>
