---
import siteConfig from "@/site.config";
import ListLayout from "@/layouts/ListLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { fetchAllEntries, makeTagItems } from "@/utils/query";
import { resolveArticleMeta } from "@/utils/article-meta";
import { buildTagGraphItems } from "@/utils/tag-graph";

const entries = await fetchAllEntries();
const tags = makeTagItems(entries);
const totalTagRefs = tags.reduce((sum, item) => sum + item.count, 0);
const topTags = tags.slice(0, siteConfig.taxonomy.showTopN);
const tagCoverMode = siteConfig.blog.pageCardOverrides.tags.coverMode;

const graphConfig = siteConfig.taxonomy.tagGraph;
const graphItems = buildTagGraphItems(topTags, {
  minFontSize: graphConfig.minFontSize,
  maxFontSize: graphConfig.maxFontSize,
  minWeight: graphConfig.minWeight,
  maxWeight: graphConfig.maxWeight,
  alphaMin: graphConfig.alphaMin,
  alphaMax: graphConfig.alphaMax
});

const tagsPageConfig = (siteConfig.pages as {
  tags?: {
    list?: { mode?: "page" | "infinite"; pageSize?: number };
    antiCrawl?: { enable?: boolean; lockOnSuspicious?: boolean; maxActions?: number; timeWindowMs?: number };
  };
}).tags ?? { list: { mode: "page", pageSize: 10 }, antiCrawl: { enable: true, lockOnSuspicious: true, maxActions: 10, timeWindowMs: 20000 } };

const listMode = tagsPageConfig.list?.mode ?? "page";
const pageSize = tagsPageConfig.list?.pageSize ?? 10;
---

<ListLayout
  title="标签中心"
  description="按热度图谱筛选标签，支持分页与无限滚动两种浏览模式。"
  stats={[
    { title: "标签总数", value: tags.length },
    { title: "文章总数", value: entries.length, href: "/archives" },
    { title: "标签引用", value: totalTagRefs }
  ]}
  tags={tags}
>
  <section class="tag-filter" id="tag-filter-root">
    <header class="tag-filter-head">
      <h2>标签</h2>
      <p id="tag-filter-status">全部标签 {entries.length} 篇文章</p>
    </header>

    <div class={`tag-graph layout-${graphConfig.layout}`} role="listbox" aria-label="标签筛选">
      <button type="button" class="tag-node is-all active" data-tag="all" style="--node-size:1.06rem;--node-weight:680;--node-hue:214;--node-alpha:0.99;--node-accent:98%;">
        <span>全部 {entries.length}</span>
      </button>
      {
        graphItems.map((item) => (
          <button type="button" class="tag-node" data-tag={item.name} title={item.name} style={item.style}>
            <span>{item.name} {item.count}</span>
          </button>
        ))
      }
    </div>
  </section>

  <section class="tag-result-section" id="tag-result-section">
    <div class="result-list" id="tag-result-list" data-list-mode={listMode} data-page-size={String(pageSize)}>
      {
        entries.map((entry, idx) => (
          <div
            data-entry-item
            data-entry-index={String(idx)}
            data-tags={resolveArticleMeta(entry).tags.map((tag) => tag.trim().toLowerCase()).join("||")}
          >
            <PostCard entry={entry} kind={entry.collection === "blog" ? "blog" : "tutorial"} coverMode={tagCoverMode} />
          </div>
        ))
      }
    </div>
    <nav class="surface pager-shell tag-pager" id="tag-result-pager" hidden></nav>
    <div id="tag-result-sentinel" aria-hidden="true"></div>
  </section>
</ListLayout>

<script is:inline>
  const initTagFilter = () => {
    const root = document.getElementById("tag-filter-root");
    const list = document.getElementById("tag-result-list");
    const status = document.getElementById("tag-filter-status");
    const pager = document.getElementById("tag-result-pager");
    const sentinel = document.getElementById("tag-result-sentinel");
    if (!(root instanceof HTMLElement) || !(list instanceof HTMLElement) || !(status instanceof HTMLElement) || !(sentinel instanceof HTMLElement)) return;

    if (window.__flyTagFilterCleanup) {
      window.__flyTagFilterCleanup();
    }

    const controller = new AbortController();
    const { signal } = controller;
    const buttons = Array.from(root.querySelectorAll(".tag-node"));
    const items = Array.from(list.querySelectorAll("[data-entry-item]"));
    const normalize = (value) => String(value || "").trim().toLowerCase();
    const listMode = list.dataset.listMode === "infinite" ? "infinite" : "page";
    const pageSize = Math.max(1, Number.parseInt(list.dataset.pageSize || "10", 10));

    let currentTag = "all";
    let filteredItems = [];
    let currentPage = 1;
    let observer = null;

    const revealNextBatch = () => {
      let revealed = 0;
      for (const item of filteredItems) {
        if (!item.hasAttribute("hidden")) continue;
        item.removeAttribute("hidden");
        revealed += 1;
        if (revealed >= pageSize) break;
      }
      const hasHidden = filteredItems.some((item) => item.hasAttribute("hidden"));
      sentinel.hidden = !hasHidden;
      return hasHidden;
    };

    const updateStatus = () => {
      const activeButton = buttons.find((button) => normalize(button.getAttribute("data-tag")) === currentTag);
      const label = currentTag === "all" ? "全部标签" : activeButton?.getAttribute("data-tag") || currentTag;
      status.textContent = `${label} ${filteredItems.length} 篇文章`;
    };

    const renderPager = () => {
      if (!(pager instanceof HTMLElement)) return;
      if (listMode !== "page") {
        pager.hidden = true;
        return;
      }
      const totalPages = Math.max(1, Math.ceil(filteredItems.length / pageSize));
      if (totalPages <= 1) {
        pager.hidden = true;
        return;
      }
      const pageButtons = Array.from({ length: totalPages }, (_, idx) => idx + 1)
        .map((pageNo) => `<button type="button" class="pager-btn pager-btn-num ${pageNo === currentPage ? "is-active" : ""}" data-page="${pageNo}">${pageNo}</button>`)
        .join("");
      pager.innerHTML = `
        <button type="button" class="pager-btn" data-page="${currentPage - 1}" ${currentPage <= 1 ? "disabled" : ""}>上一页</button>
        <div class="pager-pages">${pageButtons}</div>
        <button type="button" class="pager-btn" data-page="${currentPage + 1}" ${currentPage >= totalPages ? "disabled" : ""}>下一页</button>
      `;
      pager.hidden = false;
    };

    const setVisibilityPage = () => {
      const start = (currentPage - 1) * pageSize;
      const end = start + pageSize;
      filteredItems.forEach((item, idx) => item.toggleAttribute("hidden", idx < start || idx >= end));
      renderPager();
      sentinel.hidden = true;
    };

    const setVisibilityInfinite = () => {
      filteredItems.forEach((item, idx) => item.toggleAttribute("hidden", idx >= pageSize));
      const hasMore = filteredItems.length > pageSize;
      if (observer) observer.disconnect();
      sentinel.hidden = !hasMore;
      if (!hasMore) return;

      observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const hasMoreNext = revealNextBatch();
            if (!hasMoreNext && observer) observer.disconnect();
          }
        },
        { rootMargin: "220px 0px 320px 0px", threshold: 0.01 }
      );
      observer.observe(sentinel);
    };

    const applyFilter = (rawTag, syncQuery = true) => {
      currentTag = normalize(rawTag) === "all" ? "all" : normalize(rawTag);
      buttons.forEach((button) => {
        const isActive = normalize(button.getAttribute("data-tag")) === currentTag;
        button.classList.toggle("active", isActive);
      });

      filteredItems = [];
      for (const item of items) {
        const tagsText = item.getAttribute("data-tags") || "";
        const tagSet = tagsText ? tagsText.split("||").map(normalize) : [];
        const visible = currentTag === "all" || tagSet.includes(currentTag);
        item.toggleAttribute("hidden", !visible);
        if (visible) filteredItems.push(item);
      }

      currentPage = 1;
      if (listMode === "page") {
        setVisibilityPage();
      } else {
        if (pager instanceof HTMLElement) pager.hidden = true;
        setVisibilityInfinite();
      }
      updateStatus();

      if (syncQuery) {
        const url = new URL(window.location.href);
        if (currentTag === "all") url.searchParams.delete("tag");
        else url.searchParams.set("tag", currentTag);
        window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
      }
    };

    buttons.forEach((button) => {
      button.addEventListener(
        "click",
        () => {
          applyFilter(button.getAttribute("data-tag") || "all");
        },
        { signal }
      );
    });

    if (pager instanceof HTMLElement) {
      pager.addEventListener(
        "click",
        (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const btn = target.closest("button[data-page]");
          if (!(btn instanceof HTMLButtonElement) || btn.disabled) return;
          const next = Number.parseInt(btn.dataset.page || "1", 10);
          if (!Number.isFinite(next)) return;
          currentPage = next;
          setVisibilityPage();
        },
        { signal }
      );
    }

    const queryTag = new URLSearchParams(window.location.search).get("tag");
    if (queryTag) {
      const target = buttons.find((button) => normalize(button.getAttribute("data-tag")) === normalize(queryTag));
      applyFilter(target?.getAttribute("data-tag") || "all", false);
    } else {
      applyFilter("all", false);
    }

    window.__flyTagFilterCleanup = () => {
      controller.abort();
      if (observer) observer.disconnect();
    };
  };

  document.addEventListener("astro:page-load", initTagFilter);
  initTagFilter();
</script>

<style>
  .tag-filter {
    padding: 0.2rem 0 0.8rem;
    display: grid;
    gap: 0.78rem;
  }

  .tag-filter-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .tag-filter-head h2 {
    margin: 0;
    font-size: 1.03rem;
    font-family: var(--font-sans);
  }

  .tag-filter-head p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.86rem;
  }

  .tag-graph {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.48rem 0.76rem;
  }

  .tag-node {
    border: 0;
    background: transparent;
    padding: 0.08rem 0.12rem;
    cursor: pointer;
    line-height: 1.35;
    letter-spacing: 0.01em;
    font-size: var(--node-size, 0.96rem);
    font-weight: var(--node-weight, 500);
    opacity: var(--node-alpha, 0.88);
    color: color-mix(
      in oklab,
      hsl(var(--node-hue, 212) 84% 56%) var(--node-accent, 56%),
      var(--text-soft) calc(100% - var(--node-accent, 56%))
    );
    transition: color 160ms ease, opacity 160ms ease, transform 160ms ease;
    text-align: left;
  }

  .tag-node:hover {
    opacity: 1;
    transform: translateY(-1px);
    color: color-mix(in oklab, hsl(var(--node-hue, 212) 88% 52%) 84%, var(--text) 16%);
  }

  .tag-node span {
    display: inline;
    border-bottom: 1px solid transparent;
  }

  .tag-node.active {
    opacity: 1;
    color: color-mix(in oklab, var(--brand) 72%, var(--text) 28%);
  }

  .tag-node.active span {
    border-bottom-color: color-mix(in oklab, var(--brand) 74%, transparent 26%);
  }

  .tag-node.is-all {
    letter-spacing: 0.02em;
  }

  .tag-result-section {
    margin-top: 0.26rem;
    display: grid;
    gap: 0.9rem;
  }

  .result-list {
    display: grid;
    gap: var(--space-4);
  }

  .tag-pager {
    margin-top: 0.1rem;
  }

  #tag-result-sentinel {
    width: 100%;
    height: 2px;
  }

  @media (max-width: 760px) {
    .tag-graph {
      gap: 0.4rem 0.56rem;
    }
  }
</style>
