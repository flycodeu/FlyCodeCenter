---
import ListLayout from "@/layouts/ListLayout.astro";
import siteConfig from "@/site.config";
import { fetchAllEntries, fetchTutorialEntries, makeTagItems } from "@/utils/query";
import { resolveArticleMeta } from "@/utils/article-meta";
import { formatDate } from "@/utils/date";

interface TutorialsPageConfig {
  title?: string;
  description?: string;
  seriesLabels?: Record<string, string>;
  overview?: {
    columns?: { xl?: number; lg?: number; md?: number };
    gap?: number;
    cardStyle?: "cover-top" | "cover-left" | "compact";
    coverAspectRatio?: string;
    showEntryCount?: boolean;
    showLastUpdated?: boolean;
    showCategory?: boolean;
    showDescription?: boolean;
  };
  seriesMeta?: Record<
    string,
    {
      label?: string;
      description?: string;
      category?: string;
      cover?: string;
      icon?: string;
      order?: number;
    }
  >;
}

type TutorialEntry = Awaited<ReturnType<typeof fetchTutorialEntries>>[number];

const [tutorials, allEntries] = await Promise.all([fetchTutorialEntries(), fetchAllEntries()]);
const tags = makeTagItems(allEntries);
const pageConfig = (siteConfig.pages.tutorials as TutorialsPageConfig | undefined) ?? {};
const overview = pageConfig.overview ?? {};
const seriesMeta = pageConfig.seriesMeta ?? {};
const seriesLabels = pageConfig.seriesLabels ?? {};

const columns = {
  xl: Number(overview.columns?.xl ?? 3),
  lg: Number(overview.columns?.lg ?? 2),
  md: Number(overview.columns?.md ?? 1)
};
const gap = Number(overview.gap ?? 16);
const cardStyle = overview.cardStyle ?? "cover-top";
const coverAspectRatio = overview.coverAspectRatio ?? "16 / 9";
const showEntryCount = overview.showEntryCount ?? true;
const showLastUpdated = overview.showLastUpdated ?? true;
const showCategory = overview.showCategory ?? true;
const showDescription = overview.showDescription ?? true;

const prettifySeriesKey = (key: string) => {
  const raw = String(key || "").trim();
  if (!raw) return "未分类教程";
  const normalized = raw.replace(/[-_]+/g, " ").trim();
  if (/^[a-z0-9 ]+$/i.test(normalized)) {
    return normalized.replace(/\b[a-z]/g, (char) => char.toUpperCase());
  }
  return normalized;
};

const getSeriesLabel = (key: string) => {
  const metaLabel = String(seriesMeta[key]?.label || "").trim();
  if (metaLabel) return metaLabel;
  const oldLabel = String(seriesLabels[key] || "").trim();
  if (oldLabel) return oldLabel;
  return prettifySeriesKey(key);
};

type SeriesBucket = {
  key: string;
  label: string;
  description: string;
  category: string;
  cover: string;
  icon: string;
  order: number;
  entries: TutorialEntry[];
  latestAt: number;
};

const seriesMap = new Map<string, SeriesBucket>();
for (const entry of tutorials) {
  const meta = resolveArticleMeta(entry);
  const key = String(meta.series || "uncategorized").trim().toLowerCase() || "uncategorized";
  const seriesConfig = seriesMeta[key] ?? {};
  const bucket =
    seriesMap.get(key) ??
    {
      key,
      label: getSeriesLabel(key),
      description: String(seriesConfig.description || "").trim(),
      category: String(seriesConfig.category || "").trim(),
      cover: String(seriesConfig.cover || "").trim(),
      icon: String(seriesConfig.icon || "").trim(),
      order: Number(seriesConfig.order ?? Number.MAX_SAFE_INTEGER),
      entries: [],
      latestAt: 0
    };

  bucket.entries.push(entry);
  bucket.latestAt = Math.max(bucket.latestAt, meta.createTime.getTime());
  if (!bucket.cover) bucket.cover = String(meta.cover || "").trim();
  seriesMap.set(key, bucket);
}

const seriesList = [...seriesMap.values()]
  .map((bucket) => ({
    ...bucket,
    entries: [...bucket.entries].sort((a, b) => {
      const metaA = resolveArticleMeta(a);
      const metaB = resolveArticleMeta(b);
      if (metaA.order !== metaB.order) return metaA.order - metaB.order;
      return metaA.createTime.getTime() - metaB.createTime.getTime();
    })
  }))
  .sort((a, b) => {
    if (a.order !== b.order) return a.order - b.order;
    if (b.latestAt !== a.latestAt) return b.latestAt - a.latestAt;
    return b.entries.length - a.entries.length;
  });
---

<ListLayout
  title={pageConfig.title ?? "教程总览"}
  description={pageConfig.description ?? "系统化学习各技术栈的完整教程系列。"}
  stats={[
    { title: "教程总数", value: tutorials.length },
    { title: "系列数量", value: seriesList.length },
    { title: "归档页", value: "打开", href: "/archives" }
  ]}
  tags={tags}
>
  <div
    class={`series-grid style-${cardStyle}`}
    style={`--series-grid-gap:${gap}px;--series-col-xl:${columns.xl};--series-col-lg:${columns.lg};--series-col-md:${columns.md};--series-cover-ratio:${coverAspectRatio};`}
  >
    {
      seriesList.map((bucket) => {
        const href = `/tutorials/${encodeURIComponent(bucket.key)}`;
        return (
          <article class="surface series-card">
            {bucket.cover && (
              <a class="series-cover" href={href} aria-label={bucket.label}>
                <img src={bucket.cover} alt={bucket.label} loading="lazy" decoding="async" />
              </a>
            )}

            <div class="series-body">
              <header class="series-head">
                <h2>
                  <a href={href}>{bucket.label}</a>
                </h2>
                {showCategory && bucket.category && <span class="category-chip">{bucket.category}</span>}
              </header>

              {showDescription && bucket.description && <p class="series-description">{bucket.description}</p>}

              <div class="series-meta">
                {showEntryCount && <span>{bucket.entries.length} 篇</span>}
                {showLastUpdated && <span>更新于 {formatDate(new Date(bucket.latestAt), "YYYY-MM-DD")}</span>}
              </div>

              <footer class="series-foot">
                <a href={href}>开始学习</a>
              </footer>
            </div>
          </article>
        );
      })
    }
  </div>
</ListLayout>

<style>
  .series-grid {
    display: grid;
    grid-template-columns: repeat(var(--series-col-xl), minmax(0, 1fr));
    gap: var(--series-grid-gap);
  }

  .series-card {
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
    overflow: hidden;
    background: color-mix(in oklab, var(--surface-1) 90%, transparent 10%);
    display: grid;
  }

  .series-grid.style-cover-top .series-card,
  .series-grid.style-compact .series-card {
    grid-template-columns: 1fr;
  }

  .series-grid.style-cover-left .series-card {
    grid-template-columns: minmax(160px, 42%) minmax(0, 1fr);
  }

  .series-cover {
    display: block;
    background: color-mix(in oklab, var(--surface-2) 86%, transparent 14%);
  }

  .series-grid.style-cover-top .series-cover,
  .series-grid.style-compact .series-cover {
    aspect-ratio: var(--series-cover-ratio);
    border-bottom: 1px solid var(--line);
  }

  .series-grid.style-cover-left .series-cover {
    height: 100%;
    min-height: 164px;
    border-right: 1px solid var(--line);
  }

  .series-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 200ms ease;
  }

  .series-card:hover .series-cover img {
    transform: scale(1.03);
  }

  .series-body {
    padding: 0.9rem;
    display: grid;
    gap: 0.62rem;
    align-content: start;
  }

  .series-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.52rem;
  }

  .series-head h2 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
  }

  .series-head h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .series-head h2 a:hover {
    color: var(--brand);
  }

  .category-chip {
    flex: 0 0 auto;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in oklab, var(--brand) 36%, var(--line) 64%);
    color: var(--brand);
    background: color-mix(in oklab, var(--brand-soft) 84%, transparent 16%);
    font-size: 0.72rem;
    font-weight: 640;
    line-height: 1;
    padding: 0.26rem 0.5rem;
  }

  .series-description {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.86rem;
    line-height: 1.52;
  }

  .series-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem 0.78rem;
    font-size: 0.77rem;
    color: var(--text-muted);
  }

  .series-foot a {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    border: 1px solid var(--line);
    padding: 0.36rem 0.68rem;
    font-size: 0.8rem;
    color: var(--text-soft);
    text-decoration: none;
    background: color-mix(in oklab, var(--surface-1) 88%, transparent 12%);
  }

  .series-foot a:hover {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 42%, var(--line) 58%);
  }

  @media (max-width: 1200px) {
    .series-grid {
      grid-template-columns: repeat(var(--series-col-lg), minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .series-grid {
      grid-template-columns: repeat(var(--series-col-md), minmax(0, 1fr));
    }

    .series-grid.style-cover-left .series-card {
      grid-template-columns: 1fr;
    }

    .series-grid.style-cover-left .series-cover {
      border-right: 0;
      border-bottom: 1px solid var(--line);
      aspect-ratio: var(--series-cover-ratio);
      min-height: 0;
    }
  }
</style>
