---
import ListLayout from "@/layouts/ListLayout.astro";
import siteConfig from "@/site.config";
import { fetchAllEntries, fetchTutorialEntries, makeTagItems } from "@/utils/query";
import { resolveArticleMeta } from "@/utils/article-meta";
import { getTutorialEntryUrl } from "@/utils/content";
import { formatDate } from "@/utils/date";

const [tutorials, allEntries] = await Promise.all([fetchTutorialEntries(), fetchAllEntries()]);
const tags = makeTagItems(allEntries);
const metaCache = new Map<string, ReturnType<typeof resolveArticleMeta>>();
const getMeta = (entry: (typeof tutorials)[number]) => {
  const cache = metaCache.get(entry.id);
  if (cache) return cache;
  const meta = resolveArticleMeta(entry);
  metaCache.set(entry.id, meta);
  return meta;
};

const seriesLabels = (siteConfig.pages.tutorials as { seriesLabels?: Record<string, string> } | undefined)?.seriesLabels ?? {};
const prettifySeriesKey = (key: string) => {
  const raw = String(key || "").trim();
  if (!raw) return "未分类教程";
  const mapped = seriesLabels[raw];
  if (mapped && mapped.trim()) return mapped.trim();
  const normalized = raw.replace(/[-_]+/g, " ").trim();
  if (/^[a-z0-9 ]+$/i.test(normalized)) {
    return normalized.replace(/\b[a-z]/g, (char) => char.toUpperCase());
  }
  return normalized;
};

type SeriesBucket = {
  key: string;
  label: string;
  entries: (typeof tutorials)[number][];
  latestAt: number;
};

const seriesMap = new Map<string, SeriesBucket>();
for (const entry of tutorials) {
  const meta = getMeta(entry);
  const key = (meta.series || "uncategorized").trim().toLowerCase();
  const bucket = seriesMap.get(key) ?? {
    key,
    label: prettifySeriesKey(key),
    entries: [],
    latestAt: 0
  };
  bucket.entries.push(entry);
  bucket.latestAt = Math.max(bucket.latestAt, meta.createTime.getTime());
  seriesMap.set(key, bucket);
}

const seriesList = [...seriesMap.values()].sort((a, b) => {
  if (b.latestAt !== a.latestAt) return b.latestAt - a.latestAt;
  return b.entries.length - a.entries.length;
});
---

<ListLayout
  title="教程总览"
  description="先按教程系列浏览，再进入每个系列查看完整章节。"
  stats={[
    { title: "教程总数", value: tutorials.length },
    { title: "系列数量", value: seriesList.length },
    { title: "归档时间轴", value: "打开", href: "/archives" }
  ]}
  tags={tags}
>
  <div class="series-grid">
    {
      seriesList.map((bucket) => {
        const leadMeta = getMeta(bucket.entries[0]);
        return (
          <article class="surface series-card">
            <header class="series-head">
              <div class="head-main">
                <h2>
                  <a href={`/tutorials/${encodeURIComponent(bucket.key)}`}>{bucket.label}</a>
                </h2>
                <p>{formatDate(new Date(bucket.latestAt), "YYYY-MM-DD")} 更新</p>
              </div>
              <span class="series-count">{bucket.entries.length} 篇</span>
            </header>

            {leadMeta.cover && (
              <a class="series-cover" href={`/tutorials/${encodeURIComponent(bucket.key)}`} aria-label={bucket.label}>
                <img src={leadMeta.cover} alt={bucket.label} loading="lazy" decoding="async" />
              </a>
            )}

            <ul class="series-preview">
              {bucket.entries.slice(0, 3).map((entry) => <li><a href={getTutorialEntryUrl(entry)}>{getMeta(entry).title}</a></li>)}
            </ul>
            <footer class="series-foot">
              <a href={`/tutorials/${encodeURIComponent(bucket.key)}`}>查看系列文章</a>
            </footer>
          </article>
        );
      })
    }
  </div>
</ListLayout>

<style>
  .series-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .series-card {
    padding: 0.92rem;
    display: grid;
    gap: 0.78rem;
  }

  .series-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .head-main h2 {
    margin: 0;
    font-size: 1.12rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .head-main p {
    margin: 0.38rem 0 0;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .series-count {
    flex: 0 0 auto;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in oklab, var(--brand) 36%, var(--line) 64%);
    color: var(--brand);
    background: color-mix(in oklab, var(--brand-soft) 84%, transparent 16%);
    font-size: 0.74rem;
    font-weight: 640;
    line-height: 1;
    padding: 0.32rem 0.56rem;
  }

  .series-preview {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.52rem;
  }

  .series-cover {
    display: block;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--surface-2) 86%, transparent 14%);
  }

  .series-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 180ms ease;
  }

  .series-card:hover .series-cover img {
    transform: scale(1.02);
  }

  .series-preview a {
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .series-preview a:hover {
    color: var(--text);
  }

  .series-foot {
    padding-top: 0.15rem;
  }

  .series-foot a {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    border: 1px solid var(--line);
    padding: 0.4rem 0.74rem;
    font-size: 0.82rem;
    color: var(--text-soft);
    background: color-mix(in oklab, var(--surface-1) 88%, transparent 12%);
  }

  .series-foot a:hover {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 42%, var(--line) 58%);
  }

  @media (max-width: 1024px) {
    .series-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
