---
import ListLayout from "@/layouts/ListLayout.astro";
import siteConfig from "@/site.config";
import { fetchAllEntries, fetchTutorialEntries, makeTagItems } from "@/utils/query";
import { buildTutorialSeriesBuckets } from "@/utils/tutorial-series";
import { formatDate } from "@/utils/date";

interface TutorialsPageConfig {
  title?: string;
  description?: string;
  overview?: {
    columns?: { xl?: number; lg?: number; md?: number };
    gap?: number;
    cardStyle?: "cover-top" | "cover-left" | "compact";
    coverAspectRatio?: string;
    showEntryCount?: boolean;
    showLastUpdated?: boolean;
    showCategory?: boolean;
    showDescription?: boolean;
  };
}

const [tutorials, allEntries] = await Promise.all([fetchTutorialEntries(), fetchAllEntries()]);
const tags = makeTagItems(allEntries);
const pageConfig = (siteConfig.pages.tutorials as TutorialsPageConfig | undefined) ?? {};
const overview = pageConfig.overview ?? {};

const columns = {
  xl: Number(overview.columns?.xl ?? 3),
  lg: Number(overview.columns?.lg ?? 2),
  md: Number(overview.columns?.md ?? 1)
};
const gap = Number(overview.gap ?? 16);
const cardStyle = overview.cardStyle ?? "cover-top";
const coverAspectRatio = overview.coverAspectRatio ?? "16 / 9";
const showEntryCount = overview.showEntryCount ?? true;
const showLastUpdated = overview.showLastUpdated ?? true;
const showCategory = overview.showCategory ?? true;
const showDescription = overview.showDescription ?? true;

const seriesMap = buildTutorialSeriesBuckets(tutorials);

const seriesList = [...seriesMap.values()]
  .sort((a, b) => {
    if (a.order !== b.order) return a.order - b.order;
    if (b.latestAt !== a.latestAt) return b.latestAt - a.latestAt;
    return b.entries.length - a.entries.length;
  });
---

<ListLayout
  title={pageConfig.title ?? "教程总览"}
  description={pageConfig.description ?? "系统化学习各技术栈的完整教程系列。"}
  stats={[
    { title: "教程总数", value: tutorials.length },
    { title: "系列数量", value: seriesList.length }
  ]}
  tags={tags}
>
  <div
    class={`series-grid style-${cardStyle}`}
    style={`--series-grid-gap:${gap}px;--series-col-xl:${columns.xl};--series-col-lg:${columns.lg};--series-col-md:${columns.md};--series-cover-ratio:${coverAspectRatio};`}
  >
    {
      seriesList.map((bucket) => {
        const href = `/tutorials/${encodeURIComponent(bucket.key)}`;
        const metaParts = [];
        if (showEntryCount) metaParts.push(`${bucket.entries.length} 篇`);
        if (showLastUpdated) metaParts.push(`更新于 ${formatDate(new Date(bucket.latestAt), "YYYY-MM-DD")}`);
        const metaText = metaParts.join(" · ");
        return (
          <article class="surface series-card">
            {bucket.cover && (
              <a class="series-cover" href={href} aria-label={bucket.label}>
                <img src={bucket.cover} alt={bucket.label} loading="lazy" decoding="async" />
              </a>
            )}

            <div class="series-body">
              <header class="series-head">
                <h2>
                  <a href={href}>{bucket.label}</a>
                </h2>
                {showCategory && bucket.category && <span class="category-chip">{bucket.category}</span>}
              </header>

              {showDescription && (
                <p class={`series-description${bucket.description ? "" : " is-empty"}`}>
                  {bucket.description ?? ""}
                </p>
              )}

              <footer class="series-foot">
                {metaText && <span class="series-meta">{metaText}</span>}
                <a href={href}>开始学习</a>
              </footer>
            </div>
          </article>
        );
      })
    }
  </div>
</ListLayout>

<style>
  :global(main.container) {
    width: min(1360px, calc(100% - var(--space-6)));
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(var(--series-col-xl), minmax(0, 1fr));
    gap: var(--series-grid-gap);
  }

  .series-card {
    --series-title-lines: 2;
    --series-desc-lines: 3;
    border-radius: calc(var(--radius-lg) * var(--layout-radius-scale, 1));
    border: 1px solid color-mix(in oklab, var(--line) 72%, var(--brand) 28%);
    overflow: hidden;
    contain: layout paint;
    isolation: isolate;
    background: color-mix(in oklab, var(--surface-1) 92%, transparent 8%);
    display: grid;
    gap: clamp(0.9rem, 1.2vw, 1.3rem);
    padding: clamp(1rem, 1.6vw, 1.5rem);
    box-shadow: 0 16px 34px color-mix(in oklab, var(--bg) 78%, transparent 22%);
  }

  .series-card > * {
    min-width: 0;
  }

  .series-grid.style-cover-top .series-card,
  .series-grid.style-compact .series-card {
    grid-template-columns: 1fr;
  }

  .series-grid.style-cover-left .series-card {
    grid-template-columns: minmax(160px, 42%) minmax(0, 1fr);
  }

  .series-cover {
    display: block;
    background: color-mix(in oklab, var(--surface-2) 86%, transparent 14%);
    overflow: hidden;
    border-radius: calc(var(--radius-md) * var(--layout-radius-scale, 1));
  }

  .series-grid.style-cover-top .series-cover,
  .series-grid.style-compact .series-cover {
    aspect-ratio: var(--series-cover-ratio);
    border-bottom: 0;
  }

  .series-grid.style-cover-left .series-cover {
    height: 100%;
    min-height: 164px;
    border-right: 0;
  }

  .series-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 200ms ease;
  }

  .series-card:hover .series-cover img {
    transform: scale(1.03);
  }

  .series-body {
    padding: 0;
    display: grid;
    gap: 0.85rem;
    align-content: start;
    min-width: 0;
  }

  .series-head {
    display: grid;
    gap: 0.55rem;
    min-width: 0;
  }

  .series-head h2 {
    margin: 0;
    font-size: 1.12rem;
    line-height: 1.42;
    min-height: calc(1.42em * var(--series-title-lines));
    min-width: 0;
  }

  .series-head h2 a {
    color: var(--text);
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .series-head h2 a:hover {
    color: var(--brand);
  }

  .category-chip {
    min-width: 0;
    max-width: min(60%, 220px);
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in oklab, var(--brand) 36%, var(--line) 64%);
    color: var(--brand);
    background: color-mix(in oklab, var(--brand-soft) 84%, transparent 16%);
    font-size: 0.74rem;
    font-weight: 640;
    line-height: 1;
    padding: 0.28rem 0.6rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    justify-self: flex-start;
  }

  .series-description {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.6;
    min-height: calc(1.6em * var(--series-desc-lines));
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .series-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .series-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .series-foot a {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    border: 1px solid var(--line);
    padding: 0.46rem 0.88rem;
    font-size: 0.82rem;
    color: var(--text-soft);
    text-decoration: none;
    background: color-mix(in oklab, var(--surface-1) 88%, transparent 12%);
  }

  .series-foot a:hover {
    color: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 42%, var(--line) 58%);
  }

  @media (max-width: 1200px) {
    .series-grid {
      grid-template-columns: repeat(var(--series-col-lg), minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .series-grid {
      grid-template-columns: repeat(var(--series-col-md), minmax(0, 1fr));
    }

    .series-grid.style-cover-left .series-card {
      grid-template-columns: 1fr;
    }

    .series-grid.style-cover-left .series-cover {
      border-right: 0;
      border-bottom: 0;
      aspect-ratio: var(--series-cover-ratio);
      min-height: 0;
    }

    .series-card {
      padding: 1rem;
      gap: 0.9rem;
    }

  }
</style>
