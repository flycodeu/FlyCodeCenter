---
import ListLayout from "@/layouts/ListLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { fetchAllEntries, fetchTutorialEntries, makeTagItems } from "@/utils/query";
import { resolveArticleMeta } from "@/utils/article-meta";

const [tutorials, allEntries] = await Promise.all([fetchTutorialEntries(), fetchAllEntries()]);
const tags = makeTagItems(allEntries);
const metaCache = new Map<string, ReturnType<typeof resolveArticleMeta>>();
const getMeta = (entry: (typeof tutorials)[number]) => {
  const cache = metaCache.get(entry.id);
  if (cache) return cache;
  const meta = resolveArticleMeta(entry);
  metaCache.set(entry.id, meta);
  return meta;
};
const seriesCount = new Set(tutorials.map((item) => getMeta(item).series || "其他教程")).size;
---

<ListLayout
  title="教程总览"
  description="按发布时间浏览全部教程，统一卡片布局展示关键信息。"
  stats={[
    { title: "教程总数", value: tutorials.length },
    { title: "系列数量", value: seriesCount },
    { title: "标签分布", value: tags.length, href: "/tags" }
  ]}
  tags={tags}
>
  <div class="tutorial-list">
    {
      tutorials.map((entry) => {
        const meta = getMeta(entry);
        return (
          <section class="tutorial-card-wrap">
            <div class="chips">
              <span class="chip series">{meta.series || "其他教程"}</span>
              {meta.order > 0 && <span class="chip order">第 {meta.order} 章</span>}
            </div>
            <PostCard entry={entry} kind="tutorial" />
          </section>
        );
      })
    }
  </div>
</ListLayout>

<style>
  .tutorial-list {
    display: grid;
    gap: 0.8rem;
  }

  .tutorial-card-wrap {
    display: grid;
    gap: 0.42rem;
  }

  .chips {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    flex-wrap: wrap;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid var(--line);
    font-size: 0.74rem;
    color: var(--text-soft);
    background: color-mix(in oklab, var(--bg-elev) 95%, var(--bg) 5%);
    padding: 0.15rem 0.48rem;
    line-height: 1.1;
  }

  .chip.series {
    color: color-mix(in oklab, var(--text) 70%, #0ea5e9 30%);
  }

  .chip.order {
    color: color-mix(in oklab, var(--text) 70%, var(--brand) 30%);
  }
</style>
