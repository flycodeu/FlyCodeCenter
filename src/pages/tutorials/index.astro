---
import ListLayout from "@/layouts/ListLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { fetchAllEntries, fetchTutorialEntries, makeTagItems } from "@/utils/query";
import { getTutorialEntryUrl } from "@/utils/content";

const [tutorials, allEntries] = await Promise.all([fetchTutorialEntries(), fetchAllEntries()]);
const tags = makeTagItems(allEntries);

const seriesMap = new Map<string, typeof tutorials>();
for (const item of tutorials) {
  const series = item.data.series || "其他教程";
  if (!seriesMap.has(series)) seriesMap.set(series, []);
  seriesMap.get(series)!.push(item);
}

const seriesGroups = [...seriesMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<ListLayout
  title="教程总览"
  description="系统化、成体系的知识学习路径。"
  stats={[
    { title: "教程总数", value: tutorials.length },
    { title: "系列数量", value: seriesGroups.length },
    { title: "标签分布", value: tags.length, href: "/types" }
  ]}
  tags={tags}
>
  <div class="tutorial-container">
    {seriesGroups.map(([name, items]) => (
      <section class="tutorial-series surface">
        <div class="series-header">
          <h2>
            <span class="icon">📚</span> {name}
            <span class="count">{items.length} 篇</span>
          </h2>
        </div>
        <div class="series-list">
          {items.map((entry, idx) => (
            <a href={getTutorialEntryUrl(entry)} class="tutorial-item">
              <span class="idx">{String(idx + 1).padStart(2, "0")}</span>
              <div class="info">
                <h3>{entry.data.title}</h3>
                {entry.data.description && <p>{entry.data.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</ListLayout>

<style>
  .tutorial-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .tutorial-series {
    padding: 1.5rem;
    border-radius: 12px;
  }
  .series-header {
    border-bottom: 1px solid var(--line);
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }
  .series-header h2 {
    margin: 0;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
  }
  .series-header .count {
    font-size: 0.875rem;
    background: var(--brand-soft);
    color: var(--brand);
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    margin-left: 0.5rem;
    font-weight: 500;
  }
  .series-list {
    display: grid;
    gap: 0.5rem;
  }
  .tutorial-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .tutorial-item:hover {
    background: var(--bg-elev);
    transform: translateX(4px);
  }
  .idx {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--line);
    transition: color 0.2s ease;
  }
  .tutorial-item:hover .idx {
    color: var(--brand);
  }
  .info h3 {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.4;
  }
  .info p {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    color: var(--text-soft);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
