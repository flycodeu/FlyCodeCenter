---
import ListLayout from "@/layouts/ListLayout.astro";
import siteConfig from "@/site.config";
import PostCard from "@/components/PostCard.astro";
import { fetchAllEntries, fetchTutorialEntries, fetchTutorialSeries, makeTagItems } from "@/utils/query";
import { resolveArticleMeta } from "@/utils/article-meta";

export async function getStaticPaths() {
  const tutorials = await fetchTutorialEntries();
  const series = [...new Set(tutorials.map((item) => resolveArticleMeta(item).series.trim().toLowerCase()))];
  return series.map((key) => ({
    params: { series: key },
    props: { series: key }
  }));
}

const { series } = Astro.props;
const [entries, allEntries] = await Promise.all([fetchTutorialSeries(series), fetchAllEntries()]);
const tags = makeTagItems(allEntries);
const seriesLabels = (siteConfig.pages.tutorials as { seriesLabels?: Record<string, string> } | undefined)?.seriesLabels ?? {};
const seriesKey = String(series || "").trim().toLowerCase();
const displaySeries = seriesLabels[seriesKey] ?? (String(series || "").replace(/[-_]+/g, " ").trim() || "未分类教程");
---

<ListLayout
  title={`教程系列：${displaySeries}`}
  description="按章节顺序浏览该系列教程。"
  stats={[
    { title: "章节数量", value: entries.length },
    { title: "教程总览", value: "打开", href: "/tutorials" },
    { title: "归档页", value: "打开", href: "/archives" }
  ]}
  tags={tags}
>
  <div class="list">
    {
      entries.map((entry) => (
        <div class="order-wrap">
          <span class="chip">第 {resolveArticleMeta(entry).order} 章</span>
          <PostCard entry={entry} kind="tutorial" />
        </div>
      ))
    }
  </div>
</ListLayout>

<style>
  .list {
    display: grid;
    gap: var(--space-4);
  }
  .order-wrap {
    display: grid;
    gap: var(--space-2);
  }
</style>
