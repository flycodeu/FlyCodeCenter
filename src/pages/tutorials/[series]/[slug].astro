---
import { render } from "astro:content";
import siteConfig from "@/site.config";
import TutorialReaderLayout from "@/layouts/TutorialReaderLayout.astro";
import {
  fetchTutorialEntries,
  fetchTutorialSeriesEntries,
  normalizeSeriesKey,
  resolveTutorialSlug
} from "@/utils/query";
import { buildTutorialSeriesBuckets, toSeriesRouteKey } from "@/utils/tutorial-series";
import { resolveArticleMeta } from "@/utils/article-meta";
import { summarizeReading } from "@/utils/reading-time";

interface RouteProps {
  series: string;
  slug: string;
  currentEntryId: string;
}

export async function getStaticPaths() {
  const tutorials = await fetchTutorialEntries();
  const seriesMap = buildTutorialSeriesBuckets(tutorials);
  const paths: Array<{ params: { series: string; slug: string }; props: RouteProps }> = [];
  const routeKeySet = new Set<string>();

  for (const bucket of seriesMap.values()) {
    for (const entry of bucket.entries) {
      const slug = resolveTutorialSlug(entry);
      if (slug === "index") continue;

      const routeSeriesKey = toSeriesRouteKey(bucket.key);
      const routeKey = `${routeSeriesKey}::${slug}`;
      if (routeKeySet.has(routeKey)) {
        throw new Error(`Duplicate tutorial route detected: /tutorials/${routeSeriesKey}/${slug}`);
      }
      routeKeySet.add(routeKey);
      paths.push({
        params: {
          series: routeSeriesKey,
          slug
        },
        props: {
          series: bucket.key,
          slug,
          currentEntryId: entry.id
        }
      });
    }
  }

  return paths;
}

const { series, slug, currentEntryId } = Astro.props as RouteProps;
const seriesKey = normalizeSeriesKey(series);
const entries = await fetchTutorialSeriesEntries(seriesKey);
if (!entries.length) {
  throw new Error(`Tutorial series not found: ${seriesKey}`);
}

const seriesBucket = buildTutorialSeriesBuckets(entries).get(seriesKey);
const currentEntry = entries.find((entry) => entry.id === currentEntryId);
if (!currentEntry) {
  throw new Error(`Tutorial entry not found: ${seriesKey}/${slug}`);
}

const currentMeta = resolveArticleMeta(currentEntry);
const currentSlug = resolveTutorialSlug(currentEntry);
if (currentSlug === "index") {
  throw new Error(`Tutorial entry not found: ${seriesKey}/${slug}`);
}

const rendered = await render(currentEntry);
const Content = rendered.Content;
const headings = rendered.headings;
const reading = summarizeReading(currentEntry.body);

const seriesRouteKey = toSeriesRouteKey(seriesKey);
const seriesBase = `/tutorials/${encodeURIComponent(seriesRouteKey)}`;
const navItems = entries.map((entry) => {
  const meta = resolveArticleMeta(entry);
  const entrySlug = resolveTutorialSlug(entry);
  const displayOrder = entrySlug === "index" ? 0 : meta.order;
  return {
    id: entry.id,
    slug: entrySlug,
    title: meta.title,
    order: displayOrder,
    url: entrySlug === "index" ? seriesBase : `${seriesBase}/${encodeURIComponent(entrySlug)}`
  };
});

const currentIndex = navItems.findIndex((item) => item.id === currentEntry.id);
const prev = currentIndex > 0 ? { title: navItems[currentIndex - 1].title, url: navItems[currentIndex - 1].url } : undefined;
const next =
  currentIndex >= 0 && currentIndex < navItems.length - 1
    ? { title: navItems[currentIndex + 1].title, url: navItems[currentIndex + 1].url }
    : undefined;

const seriesLabel = seriesBucket?.label ?? seriesKey.replace(/[-_]+/g, " ").replace(/\b[a-z]/g, (char) => char.toUpperCase());

const articleUrl = `${seriesBase}/${encodeURIComponent(currentSlug)}`;
---

<TutorialReaderLayout
  title={currentMeta.title}
  summary={currentMeta.summary}
  description={currentMeta.description || currentMeta.title}
  tags={currentMeta.tags}
  articleUrl={articleUrl}
  seriesKey={seriesKey}
  seriesLabel={seriesLabel}
  currentSlug={currentSlug}
  items={navItems}
  headings={headings}
  pubDate={currentMeta.createTime}
  updatedDate={currentMeta.updatedTime}
  wordCount={reading.wordCount}
  readingMinutes={reading.minutes}
  prev={prev}
  next={next}
  encrypted={currentMeta.encrypted && siteConfig.encrypt.enable}
  encryptedFile={currentMeta.encryptedFile}
  passwordHint={currentMeta.passwordHint}
>
  <Content />
</TutorialReaderLayout>
