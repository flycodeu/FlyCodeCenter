---
import { getTutorialEntryUrl } from "@/utils/content";
import {
  fetchTutorialEntries,
  fetchTutorialSeriesEntries,
  normalizeSeriesKey,
  resolveTutorialSlug
} from "@/utils/query";
import { buildTutorialSeriesBuckets, toSeriesRouteKey } from "@/utils/tutorial-series";

interface RouteProps {
  series: string;
  slug: string;
  currentEntryId: string;
}

export async function getStaticPaths() {
  const tutorials = await fetchTutorialEntries();
  const seriesMap = buildTutorialSeriesBuckets(tutorials);
  const paths: Array<{ params: { series: string; slug: string }; props: RouteProps }> = [];
  const routeKeySet = new Set<string>();

  for (const bucket of seriesMap.values()) {
    for (const entry of bucket.entries) {
      const slug = resolveTutorialSlug(entry);
      if (slug === "index") continue;

      const routeSeriesKey = toSeriesRouteKey(bucket.key);
      const routeKey = `${routeSeriesKey}::${slug}`;
      if (routeKeySet.has(routeKey)) {
        throw new Error(`Duplicate tutorial route detected: /tutorials/${routeSeriesKey}/${slug}`);
      }
      routeKeySet.add(routeKey);
      paths.push({
        params: {
          series: routeSeriesKey,
          slug
        },
        props: {
          series: bucket.key,
          slug,
          currentEntryId: entry.id
        }
      });
    }
  }

  return paths;
}

const { series, slug, currentEntryId } = Astro.props as RouteProps;
const seriesKey = normalizeSeriesKey(series);
const entries = await fetchTutorialSeriesEntries(seriesKey);
if (!entries.length) {
  throw new Error(`Tutorial series not found: ${seriesKey}`);
}

const currentEntry = entries.find((entry) => entry.id === currentEntryId);
if (!currentEntry) {
  throw new Error(`Tutorial entry not found: ${seriesKey}/${slug}`);
}

return Astro.redirect(getTutorialEntryUrl(currentEntry), 301);
---
