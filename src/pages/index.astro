---
import BaseLayout from "@/layouts/BaseLayout.astro";
import siteConfig from "@/site.config";
import PostCard from "@/components/PostCard.astro";
import { fetchBlogEntries, fetchTutorialEntries } from "@/utils/query";
import { getTutorialEntryUrl } from "@/utils/content";
import { resolveArticleMeta } from "@/utils/article-meta";

const [blogs, tutorials] = await Promise.all([fetchBlogEntries(), fetchTutorialEntries()]);
const latestBlogs = blogs.slice(0, 6);
const latestTutorials = tutorials.slice(0, 4);

const hero = siteConfig.home.hero;
---

<BaseLayout>
  <div class="home-content">
    {
      hero.enable && (
        <section class="hero surface fade-up">
          {hero.image?.enable && (
            <div class="hero-bg">
              <img src={hero.image.src} alt={hero.image.alt} loading="lazy" />
              <div class="hero-overlay" />
            </div>
          )}
          <div class="hero-content">
            <h1>{hero.title}</h1>
            {hero.tagline && <p class="tagline">{hero.tagline}</p>}
            <p class="description">{hero.description}</p>
            {hero.actions && hero.actions.length > 0 && (
              <div class="hero-actions">
                {hero.actions.map((action) => (
                  <a href={action.link} class={`btn ${action.type}`}>{action.text}</a>
                ))}
              </div>
            )}
          </div>
        </section>
      )
    }

    <div class="home-shell">
      <section class="home-main">
        <div class="stream-head">
          <h2 class="section-title">最新文章</h2>
          <a href="/blog">全部文章 →</a>
        </div>
        <div class="blog-stream">
          {latestBlogs.map((entry) => <PostCard entry={entry} kind="blog" />)}
        </div>
      </section>

      <section class="home-secondary surface">
        <div class="secondary-head">
          <h3>教程更新</h3>
          <a href="/tutorials">全部 →</a>
        </div>
        <ul>
          {
            latestTutorials.map((entry) => (
              <li>
                <a href={getTutorialEntryUrl(entry)}>{resolveArticleMeta(entry).title}</a>
                <small>{resolveArticleMeta(entry).series}</small>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .home-content {
    width: min(900px, 100%);
    margin: 0 auto;
  }

  .hero {
    position: relative;
    padding: 5.2rem 2rem 4.7rem;
    width: 100%;
    margin: 0 auto 1.35rem;
    text-align: center;
    border-radius: 20px;
    overflow: hidden;
    background:
      radial-gradient(120% 180% at 0% 0%, color-mix(in oklab, var(--brand-soft) 56%, transparent 44%), transparent 62%),
      color-mix(in oklab, var(--bg-elev) 84%, transparent 16%);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 46vh;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, color-mix(in oklab, var(--bg-elev) 80%, transparent), var(--bg-elev));
    backdrop-filter: blur(2px);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero-content h1 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(2.2rem, 3.6vw + 0.9rem, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--text), color-mix(in oklab, var(--brand) 70%, #ffffff 30%));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1.1;
  }
  .tagline {
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 600;
    color: var(--text);
    margin: 1rem 0 0;
  }
  .description {
    margin: 1rem 0 0;
    color: var(--text-soft);
    font-size: 1.125rem;
    line-height: 1.6;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-actions {
    margin-top: 1.8rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
  .btn {
    border-radius: 999px;
    padding: 0.75rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.2s ease;
    text-decoration: none;
  }
  .btn.primary {
    color: #031421;
    background: linear-gradient(135deg, color-mix(in oklab, var(--brand) 92%, #ffffff 8%), color-mix(in oklab, var(--accent) 54%, var(--brand) 46%));
    border: 1px solid color-mix(in oklab, var(--brand) 62%, #ffffff 38%);
    box-shadow: 0 8px 20px -10px color-mix(in oklab, var(--brand) 58%, transparent 42%);
  }
  .btn.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px 0 color-mix(in oklab, var(--brand) 60%, transparent 40%);
  }
  .btn.secondary {
    color: var(--text);
    background: color-mix(in oklab, var(--bg-elev) 84%, transparent 16%);
    border: 1px solid var(--line);
  }
  .btn.secondary:hover {
    border-color: var(--brand);
    color: var(--brand);
    background: var(--brand-soft);
  }

  .home-shell {
    width: 100%;
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }
  .home-main {
    display: grid;
    gap: 1rem;
  }
  .stream-head,
  .secondary-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.75rem;
  }
  .stream-head h2,
  .secondary-head h3 {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--text);
  }
  .stream-head a,
  .secondary-head a {
    font-size: 0.875rem;
    color: var(--brand);
    font-weight: 500;
    text-decoration: none;
  }
  .stream-head a:hover,
  .secondary-head a:hover {
    text-decoration: underline;
  }
  .blog-stream {
    display: grid;
    gap: 1.25rem;
  }

  .home-secondary {
    padding: 1.5rem;
    border-radius: 12px;
  }
  .home-secondary ul {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .home-secondary li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--line);
  }
  .home-secondary li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .home-secondary li a {
    font-weight: 500;
    color: var(--text);
    transition: color 0.2s ease;
    line-height: 1.4;
  }
  .home-secondary li a:hover {
    color: var(--brand);
  }
  .home-secondary small {
    color: var(--brand);
    font-size: 0.75rem;
    background: var(--brand-soft);
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    width: fit-content;
  }
</style>
