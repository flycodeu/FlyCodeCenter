---
import BaseLayout from "@/layouts/BaseLayout.astro";
import siteConfig from "@/site.config";
import PostCard from "@/components/PostCard.astro";
import SidebarProfile from "@/components/SidebarProfile.astro";
import StatsCard from "@/components/StatsCard.astro";
import Watermark from "@/components/Watermark.astro";
import {
  fetchAllEntries,
  fetchBlogEntries,
  fetchHomeFeedEntries,
  fetchTutorialEntries,
  makeTagItems
} from "@/utils/query";
import { getBlogEntryUrl } from "@/utils/content";
import { resolveArticleMeta } from "@/utils/article-meta";
import { formatDate } from "@/utils/date";

const [blogs, tutorials, allEntries, homeFeedEntries] = await Promise.all([
  fetchBlogEntries(),
  fetchTutorialEntries(),
  fetchAllEntries(),
  fetchHomeFeedEntries()
]);
const hero = siteConfig.home.hero;
const heroImageConfig = (hero.image ?? {}) as { enable?: boolean; src?: string; fallbackSrc?: string; alt?: string };
const heroImageSrc =
  String(heroImageConfig.src || "").trim() ||
  String(heroImageConfig.fallbackSrc || "").trim() ||
  "https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=2400&q=80";
const heroImageAlt = String(heroImageConfig.alt || "Hero Image").trim() || "Hero Image";
const featuredConfig = siteConfig.home.featured;
const tagCount = makeTagItems(allEntries).length;
const homeFeedConfig = (siteConfig.home as { feed?: { mode?: "page" | "infinite"; pageSize?: number; mixCollections?: readonly ("blog" | "tutorial")[] } }).feed ?? {};
const feedMode = homeFeedConfig.mode ?? "page";
const pageSize = homeFeedConfig.pageSize ?? 10;
const feedCollections = new Set(homeFeedConfig.mixCollections ?? ["blog", "tutorial"]);

const pinnedBlogs = blogs.filter((entry) => resolveArticleMeta(entry).pinned);
const featuredEntry =
  featuredConfig.enable
    ? pinnedBlogs[0] ?? (featuredConfig.fallbackToLatest ? blogs[0] : undefined)
    : undefined;
const featuredMeta = featuredEntry ? resolveArticleMeta(featuredEntry) : undefined;
const featuredLink = featuredEntry ? getBlogEntryUrl(featuredEntry) : "#";
const recentEntries = homeFeedEntries.filter((entry) => {
  if (!feedCollections.has(entry.collection)) return false;
  if (!featuredEntry) return true;
  return !(entry.collection === "blog" && entry.id === featuredEntry.id);
});

type CoverMode = "left" | "right" | "top" | "none";

function normalizeCoverMode(value: unknown): CoverMode | undefined {
  if (typeof value !== "string") return undefined;
  const mode = value.trim().toLowerCase();
  if (mode === "left" || mode === "right" || mode === "top" || mode === "none") return mode;
  return undefined;
}

const featuredDefaultMode = normalizeCoverMode(siteConfig.blog.listCard.defaultCoverMode) ?? "right";
const featuredEntryData = featuredEntry?.data as { coverMode?: string; coverPosition?: string } | undefined;
const featuredMode =
  normalizeCoverMode(featuredEntryData?.coverMode) ??
  normalizeCoverMode(featuredEntryData?.coverPosition) ??
  normalizeCoverMode(featuredMeta?.coverMode) ??
  featuredDefaultMode;
const hasFeaturedCover = Boolean(featuredMeta?.cover) && featuredMode !== "none";
---

<BaseLayout>
  <div class="home-page">
    {
      hero.enable && (
        <section class="hero surface fade-up">
          {siteConfig.watermark.enable && siteConfig.watermark.scope === "hero" && <Watermark scope="hero" />}
          {heroImageConfig.enable && heroImageSrc && (
            <div class="hero-bg">
              <img src={heroImageSrc} alt={heroImageAlt} loading="lazy" />
            </div>
          )}
          <div class="hero-content">
            <h1>{hero.title}</h1>
            {hero.tagline && <p class="tagline">{hero.tagline}</p>}
            <p class="description">{hero.description}</p>
            <div class="hero-metrics" aria-label="site-overview">
              <span class="chip">{blogs.length} 篇博客</span>
              <span class="chip">{tutorials.length} 篇教程</span>
              <span class="chip">{tagCount} 个标签</span>
            </div>
            {hero.actions?.length ? (
              <div class="hero-actions">
                {hero.actions.slice(0, 3).map((action) => (
                  <a href={action.link} class={`btn ${action.type}`}>{action.text}</a>
                ))}
              </div>
            ) : null}
          </div>
        </section>
      )
    }

    <div class="home-shell">
      <section class="home-main">
        {
          featuredMeta && (
            <article class={`surface featured-card mode-${hasFeaturedCover ? featuredMode : "none"} fade-up`}>
              <div class="featured-meta">
                <p class="featured-label">Featured</p>
                <a class="featured-title" href={featuredLink}>{featuredMeta.title}</a>
                <p class="featured-summary">{(featuredMeta.summary || featuredMeta.description || "").trim()}</p>
                <footer class="featured-foot">
                  <div class="featured-tags">
                    {featuredMeta.tags.slice(0, 3).map((tag) => <span class="tag-badge">{tag}</span>)}
                  </div>
                  <time class="featured-date" datetime={featuredMeta.createTime.toISOString()}>
                    {formatDate(featuredMeta.createTime, "YYYY-MM-DD")}
                  </time>
                </footer>
              </div>
              {hasFeaturedCover && (
                <a class="featured-cover" href={featuredLink} aria-label={featuredMeta.title}>
                  {
                    featuredMeta.cover ? (
                      <img src={featuredMeta.cover} alt={featuredMeta.title} loading="lazy" decoding="async" />
                    ) : (
                      <div class="cover-fallback"></div>
                    )
                  }
                </a>
              )}
            </article>
          )
        }

        <div class="stream-head">
          <h2 class="section-title">Latest Posts</h2>
          <a href="/archives">全部内容</a>
        </div>
        <div class="recent-grid" id="home-feed-list">
          {
            recentEntries.map((entry, idx) => (
              <div data-page-item hidden={idx >= pageSize ? true : undefined}>
                <PostCard entry={entry} kind={entry.collection === "blog" ? "blog" : "tutorial"} />
              </div>
            ))
          }
        </div>
        <nav class="surface pager-shell home-pager" id="home-feed-pager" hidden></nav>
        <div id="home-feed-sentinel" aria-hidden="true"></div>
      </section>

      <aside class="home-side">
        <SidebarProfile />
        <div class="stats-grid">
          <StatsCard title="博客文章" value={blogs.length} href="/blog" />
          <StatsCard title="教程数量" value={tutorials.length} href="/tutorials" />
          <StatsCard title="标签总数" value={tagCount} href="/tags" />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ batchSize: pageSize, feedMode }}>
  const initHomeFeed = () => {
    const list = document.getElementById("home-feed-list");
    const pager = document.getElementById("home-feed-pager");
    const sentinel = document.getElementById("home-feed-sentinel");
    if (!(list instanceof HTMLElement) || !(sentinel instanceof HTMLElement)) return;

    if (window.__flyHomeFeedCleanup) window.__flyHomeFeedCleanup();

    const items = Array.from(list.querySelectorAll("[data-page-item]"));
    if (items.length <= batchSize) {
      sentinel.hidden = true;
      if (pager instanceof HTMLElement) pager.hidden = true;
      return;
    }

    if (feedMode === "page") {
      let currentPage = 1;
      const totalPages = Math.max(1, Math.ceil(items.length / batchSize));

      const setPage = (page, syncQuery = true) => {
        currentPage = Math.max(1, Math.min(totalPages, page));
        const start = (currentPage - 1) * batchSize;
        const end = start + batchSize;
        items.forEach((item, idx) => item.toggleAttribute("hidden", idx < start || idx >= end));

        if (pager instanceof HTMLElement) {
          if (totalPages <= 1) {
            pager.hidden = true;
          } else {
            const pages = Array.from({ length: totalPages }, (_, idx) => idx + 1)
              .map((pageNo) => {
                const active = pageNo === currentPage ? "is-active" : "";
                return `<button type="button" class="pager-btn pager-btn-num ${active}" data-page="${pageNo}">${pageNo}</button>`;
              })
              .join("");
            pager.innerHTML = `
              <button type="button" class="pager-btn" data-page="${currentPage - 1}" ${currentPage <= 1 ? "disabled" : ""}>上一页</button>
              <div class="pager-pages">${pages}</div>
              <button type="button" class="pager-btn" data-page="${currentPage + 1}" ${currentPage >= totalPages ? "disabled" : ""}>下一页</button>
            `;
            pager.hidden = false;
          }
        }

        if (syncQuery) {
          const url = new URL(window.location.href);
          if (currentPage <= 1) {
            url.searchParams.delete("page");
          } else {
            url.searchParams.set("page", String(currentPage));
          }
          window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
        }
      };

      const queryPage = Number.parseInt(new URLSearchParams(window.location.search).get("page") || "1", 10);
      setPage(Number.isFinite(queryPage) ? queryPage : 1, false);
      sentinel.hidden = true;

      const onPagerClick = (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest("button[data-page]");
        if (!(button instanceof HTMLButtonElement) || button.disabled) return;
        const next = Number.parseInt(button.dataset.page || "1", 10);
        if (!Number.isFinite(next)) return;
        setPage(next);
      };

      if (pager instanceof HTMLElement) {
        pager.addEventListener("click", onPagerClick);
      }

      window.__flyHomeFeedCleanup = () => {
        if (pager instanceof HTMLElement) {
          pager.removeEventListener("click", onPagerClick);
        }
      };
      return;
    }

    const revealNext = () => {
      let revealed = 0;
      for (const item of items) {
        if (!item.hasAttribute("hidden")) continue;
        item.removeAttribute("hidden");
        revealed += 1;
        if (revealed >= batchSize) break;
      }
      const hasHidden = items.some((item) => item.hasAttribute("hidden"));
      sentinel.hidden = !hasHidden;
      return hasHidden;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const hasMore = revealNext();
          if (!hasMore) observer.disconnect();
        }
      },
      { rootMargin: "260px 0px 360px 0px", threshold: 0.01 }
    );

    if (pager instanceof HTMLElement) pager.hidden = true;
    observer.observe(sentinel);
    sentinel.hidden = false;
    window.__flyHomeFeedCleanup = () => observer.disconnect();
  };

  document.addEventListener("astro:page-load", initHomeFeed);
  initHomeFeed();
</script>

<style>
  .home-page {
    display: grid;
    gap: var(--space-6);
  }

  .hero {
    position: relative;
    overflow: hidden;
    min-height: clamp(280px, 40vh, 420px);
    border-radius: var(--radius-lg);
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-5);
    background:
      radial-gradient(72% 90% at 50% 10%, color-mix(in oklab, var(--brand-soft) 58%, transparent 42%), transparent 72%),
      color-mix(in oklab, var(--surface-1) 84%, transparent 16%);
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.16;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 820px;
    display: grid;
    gap: var(--space-2);
    justify-items: center;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2rem, 2.4vw + 1.4rem, 2.75rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .tagline {
    margin: 0;
    color: var(--text);
    font-size: 1.1rem;
    font-weight: 600;
  }

  .description {
    margin: 0;
    color: var(--text-soft);
    max-width: 62ch;
    line-height: 1.75;
    font-size: 1.01rem;
  }

  .hero-metrics {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-1);
  }

  .hero-metrics .chip {
    font-size: 0.75rem;
    padding: 0.18rem 0.56rem;
  }

  .hero-actions {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }

  .btn {
    border-radius: var(--radius-pill);
    padding: 0.62rem 1.1rem;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid var(--line);
    transition: border-color 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  .btn.primary {
    color: color-mix(in oklab, var(--bg) 86%, #ffffff 14%);
    border-color: color-mix(in oklab, var(--brand) 54%, var(--line) 46%);
    background: linear-gradient(
      140deg,
      color-mix(in oklab, var(--brand) 88%, white 12%),
      color-mix(in oklab, var(--accent) 46%, var(--brand) 54%)
    );
  }

  .btn.secondary {
    background: color-mix(in oklab, var(--surface-1) 86%, transparent 14%);
    color: var(--text);
  }

  .btn:hover {
    border-color: color-mix(in oklab, var(--brand) 58%, var(--line) 42%);
    color: var(--brand);
  }

  .home-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: var(--space-5);
    align-items: start;
  }

  .home-main {
    display: grid;
    gap: var(--space-4);
  }

  .featured-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 42%);
    gap: var(--space-4);
    padding: var(--space-3);
    align-items: stretch;
  }

  .featured-card.mode-left {
    grid-template-columns: minmax(240px, 42%) minmax(0, 1fr);
  }

  .featured-card.mode-top {
    grid-template-columns: 1fr;
  }

  .featured-card.mode-none {
    grid-template-columns: 1fr;
  }

  .featured-cover {
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--line);
    display: block;
    background: color-mix(in oklab, var(--brand-soft) 56%, var(--surface-2) 44%);
    height: 100%;
  }

  .featured-card.mode-right .featured-cover {
    order: 2;
  }

  .featured-card.mode-left .featured-cover {
    order: 1;
  }

  .featured-card.mode-left .featured-meta {
    order: 2;
  }

  .featured-card.mode-top .featured-cover {
    aspect-ratio: auto;
    height: clamp(180px, 28vw, 248px);
  }

  .featured-card.mode-top .featured-meta {
    order: 2;
  }

  .featured-cover img,
  .cover-fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cover-fallback {
    background:
      radial-gradient(68% 90% at 20% 12%, color-mix(in oklab, var(--brand) 26%, transparent 74%), transparent 68%),
      radial-gradient(70% 90% at 80% 0%, color-mix(in oklab, var(--accent) 22%, transparent 78%), transparent 65%),
      color-mix(in oklab, var(--surface-2) 88%, transparent 12%);
  }

  .featured-meta {
    display: grid;
    align-content: center;
    gap: var(--space-2);
    min-width: 0;
  }

  .featured-label {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand);
    font-weight: 650;
  }

  .featured-title {
    margin: 0;
    font-size: clamp(1.2rem, 0.72vw + 0.98rem, 1.56rem);
    line-height: 1.26;
    letter-spacing: -0.01em;
    font-weight: 700;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-summary {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .featured-tags {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex-wrap: wrap;
  }

  .featured-tags .tag-badge {
    font-size: 0.72rem;
    padding: 0.2rem 0.56rem;
  }

  .featured-date {
    color: var(--text-muted);
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .stream-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--line);
  }

  .stream-head a {
    color: var(--brand);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .recent-grid {
    display: grid;
    gap: var(--space-4);
  }

  .home-pager {
    margin-top: 0.15rem;
  }

  #home-feed-sentinel {
    width: 100%;
    height: 2px;
  }

  .home-side {
    display: grid;
    gap: var(--space-4);
    position: sticky;
    top: 84px;
  }

  .side-panel {
    padding: var(--space-3);
    border-radius: var(--radius-md);
    display: grid;
    gap: var(--space-3);
  }

  .side-panel header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .side-panel h3 {
    margin: 0;
    font-size: 0.94rem;
  }

  .side-panel a {
    font-size: 0.82rem;
    color: var(--brand);
  }

  .side-panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-2);
  }

  .side-panel li a {
    color: var(--text-soft);
    line-height: 1.5;
    font-size: 0.88rem;
  }

  .side-panel li a:hover {
    color: var(--text);
  }

  .stats-grid {
    display: grid;
    gap: var(--space-2);
  }

  @media (max-width: 1120px) {
    .featured-card.mode-right,
    .featured-card.mode-left {
      grid-template-columns: 1fr;
    }

    .featured-card .featured-cover {
      order: 1;
      aspect-ratio: auto;
      height: clamp(180px, 30vw, 230px);
    }

    .featured-card .featured-meta {
      order: 2;
    }
  }

  @media (max-width: 1024px) {
    .home-shell {
      grid-template-columns: 1fr;
    }

    .home-side {
      position: static;
      top: auto;
    }
  }

  @media (max-width: 760px) {
    .hero {
      min-height: clamp(260px, 36vh, 340px);
      padding: var(--space-5) var(--space-3);
    }
  }
</style>

