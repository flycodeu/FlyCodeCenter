---
import BaseLayout from "@/layouts/BaseLayout.astro";
import siteConfig from "@/site.config";
import PostCard from "@/components/PostCard.astro";
import { fetchBlogEntries, fetchTutorialEntries } from "@/utils/query";
import { getTutorialEntryUrl } from "@/utils/content";

const [blogs, tutorials] = await Promise.all([fetchBlogEntries(), fetchTutorialEntries()]);
const latestBlogs = blogs.slice(0, 6);
const latestTutorials = tutorials.slice(0, 4);
const heroImage = siteConfig.home.heroImage;
const heroHeight = typeof heroImage.height === "number" ? `${heroImage.height}px` : heroImage.height;
---

<BaseLayout>
  {
    heroImage.enable && (
      <section
        class="hero-image surface fade-up"
        style={`--hero-height:${heroHeight};--hero-overlay:${heroImage.overlayOpacity};--hero-position:${heroImage.objectPosition};`}
      >
        <img src={heroImage.src} alt="首页大图" loading="lazy" />
      </section>
    )
  }

  <section class="hero surface fade-up">
    <div class="hero-main">
      <h1>飞云的编程宝典</h1>
      <p>面向实战的文章与教程，围绕工程效率、性能优化与架构设计持续更新。</p>
      <div class="hero-actions">
        <a href="/blog" class="primary">浏览博客</a>
        <a href="/tutorials">查看教程</a>
        <a href="/tags">标签索引</a>
      </div>
    </div>
  </section>

  <section class="home-main">
    <div class="stream-head">
      <h2 class="section-title">最新文章</h2>
      <a href="/blog">全部文章</a>
    </div>
    <div class="blog-stream">
      {latestBlogs.map((entry) => <PostCard entry={entry} kind="blog" />)}
    </div>
  </section>

  <section class="home-secondary surface">
    <div class="secondary-head">
      <h3>教程更新</h3>
      <a href="/tutorials">全部教程</a>
    </div>
    <ul>
      {
        latestTutorials.map((entry) => (
          <li>
            <a href={getTutorialEntryUrl(entry)}>{entry.data.title}</a>
            <small>{entry.data.series}</small>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .hero-image {
    margin-bottom: 0.64rem;
    position: relative;
    overflow: hidden;
    min-height: var(--hero-height);
    max-height: var(--hero-height);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-position);
    display: block;
  }
  .hero-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(14, 18, 28, calc(var(--hero-overlay) * 0.8)), rgba(14, 18, 28, var(--hero-overlay)));
    pointer-events: none;
  }
  .hero {
    padding: clamp(0.74rem, 0.9vw + 0.7rem, 1.08rem);
    margin-bottom: 0.64rem;
  }
  .hero-main h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 1.4vw + 1.1rem, 2.5rem);
  }
  .hero-main p {
    margin: 0.44rem 0 0;
    color: var(--text-soft);
    max-width: 60ch;
  }
  .hero-actions {
    margin-top: 0.56rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .hero-actions a {
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 0.42rem 0.72rem;
    font-size: 0.88rem;
    background: var(--bg-elev);
  }
  .hero-actions .primary {
    color: #fff;
    background: var(--brand);
    border-color: color-mix(in oklab, var(--brand) 72%, var(--line) 28%);
  }
  .home-main {
    display: grid;
    gap: 0.42rem;
  }
  .stream-head,
  .secondary-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .stream-head a,
  .secondary-head a {
    font-size: 0.86rem;
    color: var(--brand);
  }
  .blog-stream {
    display: grid;
    gap: 0.6rem;
  }
  .home-secondary {
    margin-top: 0.62rem;
    padding: 0.64rem;
  }
  .home-secondary h3 {
    margin: 0;
  }
  .home-secondary ul {
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }
  .home-secondary li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .home-secondary small {
    color: var(--text-soft);
    font-size: 0.82rem;
  }
</style>
