---
import { fetchBlogEntries, fetchProjectEntries } from "@/utils/query";
import { getBlogEntryUrl, getProjectEntryUrl } from "@/utils/content";
import { resolveArticleMeta } from "@/utils/article-meta";
import { stripSlashes } from "@/utils/url";

interface RouteProps {
  targetUrl: string;
}

export async function getStaticPaths() {
  const [blogEntries, projectEntries] = await Promise.all([fetchBlogEntries(), fetchProjectEntries()]);
  const legacyPrefix = "article";
  const paths: Array<{ params: { prefix: string; code: string }; props: RouteProps }> = [];
  const routeKeySet = new Set<string>();

  for (const entry of blogEntries) {
    const code = resolveArticleMeta(entry).code;
    const routeKey = `${legacyPrefix}/${code}`;
    if (routeKeySet.has(routeKey)) {
      throw new Error(`Duplicate legacy article route detected: /${routeKey}`);
    }
    routeKeySet.add(routeKey);
    paths.push({
      params: { prefix: legacyPrefix, code },
      props: { targetUrl: getBlogEntryUrl(entry) }
    });
  }

  for (const entry of projectEntries) {
    const code = resolveArticleMeta(entry).code;
    const routeKey = `${legacyPrefix}/${code}`;
    if (routeKeySet.has(routeKey)) {
      throw new Error(`Duplicate legacy article route detected: /${routeKey}`);
    }
    routeKeySet.add(routeKey);
    paths.push({
      params: { prefix: legacyPrefix, code },
      props: { targetUrl: getProjectEntryUrl(entry) }
    });
  }

  return paths;
}

const { prefix } = Astro.params;
const { targetUrl } = Astro.props as RouteProps;

if (stripSlashes(prefix || "") !== "article") {
  throw new Error(`Unsupported legacy article prefix: ${prefix}`);
}

return Astro.redirect(targetUrl, 301);
---
