---
import siteConfig from "@/site.config";
import { getEntry, render, type CollectionEntry } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import { fetchBlogEntries, fetchProjectEntries, fetchTutorialEntries } from "@/utils/query";
import { getBlogEntryUrl, getProjectEntryUrl, getTutorialEntryUrl } from "@/utils/content";
import { summarizeReading } from "@/utils/reading-time";
import { resolveArticleMeta } from "@/utils/article-meta";
import { stripSlashes } from "@/utils/url";

interface Neighbor {
  title: string;
  url: string;
}

interface RouteProps {
  collection: "blog" | "tutorial" | "projects";
  entryId: string;
  prev?: Neighbor;
  next?: Neighbor;
}

export async function getStaticPaths() {
  const [blogEntries, tutorialEntries, projectEntries] = await Promise.all([
    fetchBlogEntries(),
    fetchTutorialEntries(),
    fetchProjectEntries()
  ]);

  const prefix = stripSlashes(siteConfig.articlePrefix || "/article");
  const codeMap = new Map<string, string>();
  const slugMap = new Map<string, string>();
  const permalinkMap = new Map<string, string>();
  const parsePermalinkSlug = (permalink: string, identity: string) => {
    const normalized = stripSlashes(permalink);
    const parts = normalized.split("/").filter(Boolean);
    if (parts.length !== 2 || parts[0] !== prefix) {
      throw new Error(
        `Invalid permalink "${permalink}" for "${identity}". Expected format: /${prefix}/{slug}/`
      );
    }
    return parts[1];
  };
  const ensureUniqueCode = (code: string, identity: string) => {
    const existing = codeMap.get(code);
    if (!existing) {
      codeMap.set(code, identity);
      return;
    }
    throw new Error(`Duplicate article code "${code}" for "${identity}" and "${existing}"`);
  };
  const ensureUniqueSlug = (slug: string, identity: string) => {
    const existing = slugMap.get(slug);
    if (!existing) {
      slugMap.set(slug, identity);
      return;
    }
    throw new Error(`Duplicate article slug "${slug}" for "${identity}" and "${existing}"`);
  };
  const ensureUniquePermalink = (permalink: string, identity: string) => {
    const existing = permalinkMap.get(permalink);
    if (!existing) {
      permalinkMap.set(permalink, identity);
      return;
    }
    throw new Error(`Duplicate article permalink "${permalink}" for "${identity}" and "${existing}"`);
  };
  const paths: Array<{ params: { prefix: string; code: string }; props: RouteProps }> = [];

  for (const [index, entry] of blogEntries.entries()) {
    const meta = resolveArticleMeta(entry);
    const slug = parsePermalinkSlug(meta.permalink, `blog:${entry.id}`);
    ensureUniqueCode(meta.code, `blog:${entry.id}`);
    ensureUniqueSlug(slug, `blog:${entry.id}`);
    ensureUniquePermalink(meta.permalink, `blog:${entry.id}`);
    const prev = blogEntries[index - 1];
    const next = blogEntries[index + 1];
    paths.push({
      params: { prefix, code: slug },
      props: {
        collection: "blog",
        entryId: entry.id,
        prev: prev ? { title: prev.data.title, url: getBlogEntryUrl(prev) } : undefined,
        next: next ? { title: next.data.title, url: getBlogEntryUrl(next) } : undefined
      }
    });
  }

  const tutorialSeries = new Map<string, CollectionEntry<"tutorial">[]>();
  const tutorialMeta = new Map<string, ReturnType<typeof resolveArticleMeta>>();
  const getTutorialMeta = (entry: CollectionEntry<"tutorial">) => {
    const cache = tutorialMeta.get(entry.id);
    if (cache) return cache;
    const meta = resolveArticleMeta(entry);
    tutorialMeta.set(entry.id, meta);
    return meta;
  };

  for (const entry of tutorialEntries) {
    const list = tutorialSeries.get(getTutorialMeta(entry).series) ?? [];
    list.push(entry);
    tutorialSeries.set(getTutorialMeta(entry).series, list);
  }

  for (const seriesEntries of tutorialSeries.values()) {
    const sorted = [...seriesEntries].sort((a, b) => {
      const metaA = getTutorialMeta(a);
      const metaB = getTutorialMeta(b);
      if (metaA.order === metaB.order) return metaA.createTime.getTime() - metaB.createTime.getTime();
      return metaA.order - metaB.order;
    });
    for (const [index, entry] of sorted.entries()) {
      const meta = getTutorialMeta(entry);
      const slug = parsePermalinkSlug(meta.permalink, `tutorial:${entry.id}`);
      ensureUniqueCode(meta.code, `tutorial:${entry.id}`);
      ensureUniqueSlug(slug, `tutorial:${entry.id}`);
      ensureUniquePermalink(meta.permalink, `tutorial:${entry.id}`);
      const prev = sorted[index - 1];
      const next = sorted[index + 1];
      paths.push({
        params: { prefix, code: slug },
        props: {
          collection: "tutorial",
          entryId: entry.id,
          prev: prev ? { title: prev.data.title, url: getTutorialEntryUrl(prev) } : undefined,
          next: next ? { title: next.data.title, url: getTutorialEntryUrl(next) } : undefined
        }
      });
    }
  }

  for (const [index, entry] of projectEntries.entries()) {
    const meta = resolveArticleMeta(entry);
    const slug = parsePermalinkSlug(meta.permalink, `projects:${entry.id}`);
    ensureUniqueCode(meta.code, `projects:${entry.id}`);
    ensureUniqueSlug(slug, `projects:${entry.id}`);
    ensureUniquePermalink(meta.permalink, `projects:${entry.id}`);
    const prev = projectEntries[index - 1];
    const next = projectEntries[index + 1];
    paths.push({
      params: { prefix, code: slug },
      props: {
        collection: "projects",
        entryId: entry.id,
        prev: prev ? { title: prev.data.title, url: getProjectEntryUrl(prev) } : undefined,
        next: next ? { title: next.data.title, url: getProjectEntryUrl(next) } : undefined
      }
    });
  }

  return paths;
}

const { collection, entryId, prev, next } = Astro.props as RouteProps;
let entry: CollectionEntry<"blog"> | CollectionEntry<"tutorial"> | CollectionEntry<"projects"> | undefined;
if (collection === "blog") {
  entry = await getEntry("blog", entryId);
} else if (collection === "tutorial") {
  entry = await getEntry("tutorial", entryId);
} else {
  entry = await getEntry("projects", entryId);
}

if (!entry) {
  throw new Error(`Entry not found: ${collection}:${entryId}`);
}

const entryMeta = resolveArticleMeta(
  entry as CollectionEntry<"blog"> | CollectionEntry<"tutorial"> | CollectionEntry<"projects">
);
const encrypted = entryMeta.encrypted && siteConfig.encrypt.enable;
let Content: any = null;
let headings: any[] = [];
if (!encrypted) {
  const rendered = await render(entry);
  Content = rendered.Content;
  headings = rendered.headings;
}

const reading = summarizeReading(entry.body);
const articleUrl =
  collection === "blog"
    ? getBlogEntryUrl(entry as CollectionEntry<"blog">)
    : collection === "tutorial"
      ? getTutorialEntryUrl(entry as CollectionEntry<"tutorial">)
      : getProjectEntryUrl(entry as CollectionEntry<"projects">);
const summary = entryMeta.summary;
const description = entryMeta.description || entry.data.title;
const tags = entryMeta.tags;
const createTime = entryMeta.createTime;
const updatedTime = entryMeta.updatedTime;
const hideCover = !entryMeta.showCover;
const githubEditUrl = `${siteConfig.theme.social.github.replace(/\/$/, '')}/blob/main/src/content/${collection}/${entry.id}`;
---

<PostLayout
  title={entry.data.title}
  summary={summary}
  description={description}
  tags={tags}
  pubDate={createTime}
  updatedDate={updatedTime}
  headings={headings}
  wordCount={reading.wordCount}
  readingMinutes={reading.minutes}
  articleUrl={articleUrl}
  code={entryMeta.code}
  githubEditUrl={githubEditUrl}
  encrypted={encrypted}
  encryptedFile={entryMeta.encryptedFile}
  passwordHint={entryMeta.passwordHint}
  prev={prev}
  next={next}
  cover={entryMeta.cover}
  hideCover={hideCover}
>
  {Content && <Content />}
</PostLayout>
